{% extends 'base.html.twig' %}

{% block title %}Faculty Dashboard | SET-SEF Evaluation{% endblock %}

{% block body %}
{# ── Welcome Banner ── #}
<div class="welcome-banner">
    <div class="banner-main d-flex align-items-center gap-3">
        <div class="user-avatar">
            {% if app.user.profilePicture %}
                <img src="{{ asset('images/profiles/' ~ app.user.profilePicture) }}" alt="Profile" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
            {% else %}
                {{ app.user.firstName|first }}{{ app.user.lastName|first }}
            {% endif %}
        </div>
        <div>
            <h2 class="mb-0">Welcome, {{ app.user.firstName }}!</h2>
            <p>SET-SEF Evaluation Management System — Faculty Panel</p>
        </div>
    </div>
    <div class="banner-bottom">
        {% set cay = current_academic_year() %}
        {% if cay %}
        <span><i class="bi bi-mortarboard-fill me-1"></i>{{ cay.label }}</span>
        {% endif %}
        <span><i class="bi bi-calendar3 me-1"></i>{{ 'now'|date('l, F d, Y') }}</span>
        <span><i class="bi bi-book me-1"></i>{{ subjects|length }} assigned subject(s)</span>
        <span><i class="bi bi-clipboard-check me-1"></i>{{ openEvaluations|length }} active evaluation(s)</span>
    </div>
</div>

{# ═══════ STAT CARDS ═══════ #}
{% set avgRating = 0 %}
{% set totalEvaluators = 0 %}
{% for r in evalResults %}
    {% set avgRating = avgRating + r.average %}
    {% set totalEvaluators = totalEvaluators + r.evaluators %}
{% endfor %}
{% if evalResults|length > 0 %}
    {% set avgRating = (avgRating / evalResults|length) %}
{% endif %}

<div class="analytics-grid mb-4">
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:#EFF6FF;color:#2563EB">
            <i class="bi bi-book-fill"></i>
        </div>
        <div class="analytics-stat-body">
            <span class="analytics-stat-value">{{ subjects|length }}</span>
            <span class="analytics-stat-label">Subject Load</span>
        </div>
    </div>
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:#F0FDF4;color:#16A34A">
            <i class="bi bi-clipboard-check-fill"></i>
        </div>
        <div class="analytics-stat-body">
            <span class="analytics-stat-value">{{ evalResults|length }}</span>
            <span class="analytics-stat-label">Evaluation Results</span>
        </div>
    </div>
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:#FFF7ED;color:#EA580C">
            <i class="bi bi-calendar-event-fill"></i>
        </div>
        <div class="analytics-stat-body">
            <span class="analytics-stat-value">{{ openEvaluations|length }}</span>
            <span class="analytics-stat-label">Active Evaluations</span>
        </div>
    </div>
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:#FDF4FF;color:#A855F7">
            <i class="bi bi-star-fill"></i>
        </div>
        <div class="analytics-stat-body">
            <span class="analytics-stat-value">—</span>
            <span class="analytics-stat-label">Average Rating</span>
        </div>
    </div>
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:#ECFDF5;color:#059669">
            <i class="bi bi-people-fill"></i>
        </div>
        <div class="analytics-stat-body">
            <span class="analytics-stat-value">{{ totalEvaluators }}</span>
            <span class="analytics-stat-label">Total Evaluators</span>
        </div>
    </div>
    <div class="analytics-stat-card">
        <div class="analytics-stat-icon" style="background:#EEF2FF;color:#4F46E5">
            <i class="bi bi-building"></i>
        </div>
        <div class="analytics-stat-body">
            <span class="analytics-stat-value" style="font-size:1rem">{{ app.user.department ? app.user.department.departmentName : '—' }}</span>
            <span class="analytics-stat-label">Department</span>
        </div>
    </div>
</div>

{# ═══════ QUICK ACTIONS ═══════ #}
<div class="fd-actions-grid mb-4">
    <a href="{{ path('faculty_subjects') }}" class="fd-action-card">
        <div class="fd-action-icon" style="background:#EFF6FF;color:#2563EB"><i class="bi bi-book"></i></div>
        <div class="fd-action-text">
            <span class="fd-action-title">Subject Load</span>
            <span class="fd-action-desc">Browse & select subjects</span>
        </div>
        <i class="bi bi-chevron-right fd-action-arrow"></i>
    </a>
    <a href="{{ path('faculty_schedule') }}" class="fd-action-card">
        <div class="fd-action-icon" style="background:#F0FDF4;color:#16A34A"><i class="bi bi-calendar-week"></i></div>
        <div class="fd-action-text">
            <span class="fd-action-title">Class Schedule</span>
            <span class="fd-action-desc">View weekly timetable</span>
        </div>
        <i class="bi bi-chevron-right fd-action-arrow"></i>
    </a>
    <a href="{{ path('faculty_eval_results') }}" class="fd-action-card">
        <div class="fd-action-icon" style="background:#FDF4FF;color:#A855F7"><i class="bi bi-clipboard-data"></i></div>
        <div class="fd-action-text">
            <span class="fd-action-title">Evaluation Results</span>
            <span class="fd-action-desc">View student ratings</span>
        </div>
        <i class="bi bi-chevron-right fd-action-arrow"></i>
    </a>
    <a href="{{ path('faculty_eval_summary') }}" class="fd-action-card">
        <div class="fd-action-icon" style="background:#FFF7ED;color:#EA580C"><i class="bi bi-file-earmark-bar-graph"></i></div>
        <div class="fd-action-text">
            <span class="fd-action-title">Summary Report</span>
            <span class="fd-action-desc">Overall statistics</span>
        </div>
        <i class="bi bi-chevron-right fd-action-arrow"></i>
    </a>
    <a href="{{ path('faculty_eval_analytics') }}" class="fd-action-card">
        <div class="fd-action-icon" style="background:#ECFDF5;color:#059669"><i class="bi bi-graph-up-arrow"></i></div>
        <div class="fd-action-text">
            <span class="fd-action-title">Graphical Analytics</span>
            <span class="fd-action-desc">Charts & visual data</span>
        </div>
        <i class="bi bi-chevron-right fd-action-arrow"></i>
    </a>
    <a href="{{ path('faculty_eval_download') }}" class="fd-action-card">
        <div class="fd-action-icon" style="background:#FEF2F2;color:#DC2626"><i class="bi bi-download"></i></div>
        <div class="fd-action-text">
            <span class="fd-action-title">Download Reports</span>
            <span class="fd-action-desc">Export evaluation data</span>
        </div>
        <i class="bi bi-chevron-right fd-action-arrow"></i>
    </a>
</div>

{# ═══════ ASSIGNED SUBJECTS TABLE ═══════ #}
<div class="fd-section-header">
    <div class="fd-section-title">
        <i class="bi bi-book-fill"></i>
        <span>My Subject Load</span>
    </div>
    <span class="fd-section-badge">{{ subjects|length }} subject{{ subjects|length != 1 ? 's' : '' }}</span>
</div>

{% if subjects|length > 0 %}
<div class="fd-search-bar">
    <div class="fd-search-inner">
        <i class="bi bi-search fd-search-ico"></i>
        <input type="text" id="fdSubjectSearch" class="fd-search-input" placeholder="Search subjects..." oninput="fdFilterSubjects()">
    </div>
</div>

<div class="fd-table-wrap">
    <table class="fd-table" id="fdSubjectTable">
        <thead>
            <tr>
                <th style="width:40px">#</th>
                <th><span class="fd-sort-label" onclick="fdSortSubjects('code')">Code <i class="bi bi-arrow-down-up fd-sort-icon" data-col="code"></i></span></th>
                <th><span class="fd-sort-label" onclick="fdSortSubjects('name')">Subject Name <i class="bi bi-arrow-down-up fd-sort-icon" data-col="name"></i></span></th>
                <th><span class="fd-sort-label" onclick="fdSortSubjects('sem')">Semester <i class="bi bi-arrow-down-up fd-sort-icon" data-col="sem"></i></span></th>
                <th><span class="fd-sort-label" onclick="fdSortSubjects('year')">Year Level <i class="bi bi-arrow-down-up fd-sort-icon" data-col="year"></i></span></th>
                <th class="text-center"><span class="fd-sort-label" onclick="fdSortSubjects('units')">Units <i class="bi bi-arrow-down-up fd-sort-icon" data-col="units"></i></span></th>
                <th class="text-center" style="width:70px">Actions</th>
            </tr>
        </thead>
        <tbody id="fdSubjectBody">
            {% for subject in subjects %}
            <tr class="fd-row"
                data-search="{{ subject.subjectCode|lower }} {{ subject.subjectName|lower }} {{ subject.semester|default('')|lower }} {{ subject.yearLevel|default('')|lower }}"
                data-sort-code="{{ subject.subjectCode|lower }}"
                data-sort-name="{{ subject.subjectName|lower }}"
                data-sort-sem="{{ subject.semester|default('')|lower }}"
                data-sort-year="{{ subject.yearLevel|default('')|lower }}"
                data-sort-units="{{ subject.units|default(0) }}">
                <td class="fd-td-num">{{ loop.index }}</td>
                <td class="fd-td-code">{{ subject.subjectCode }}</td>
                <td class="fd-td-name">{{ subject.subjectName }}</td>
                <td><span class="fd-sem-badge">{{ subject.semester|default('—') }}</span></td>
                <td class="fd-td-meta">{{ subject.yearLevel|default('—') }}</td>
                <td class="text-center fd-td-meta">{{ subject.units|default('—') }}</td>
                <td class="text-center">
                    <a href="{{ path('faculty_subject_detail', {id: subject.id}) }}" class="fd-view-btn" title="View Details">
                        <i class="bi bi-eye-fill"></i>
                    </a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<div class="fd-table-wrap">
    <div class="text-center text-muted py-5">
        <i class="bi bi-book fs-1 d-block mb-2 opacity-25"></i>
        No subjects assigned yet.
    </div>
</div>
{% endif %}


{# ─── Inline Styles ─── #}
<style>
/* ── Quick Actions Grid ── */
.fd-actions-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;}
.fd-action-card{display:flex;align-items:center;gap:.85rem;padding:.9rem 1rem;background:#fff;border:1px solid #e8ecf1;border-radius:12px;text-decoration:none;transition:all .2s ease;box-shadow:0 1px 3px rgba(0,0,0,.03);}
.fd-action-card:hover{border-color:#c7d2fe;box-shadow:0 4px 15px rgba(37,99,235,.08);transform:translateY(-2px);}
.fd-action-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.15rem;flex-shrink:0;}
.fd-action-text{display:flex;flex-direction:column;min-width:0;flex:1;}
.fd-action-title{font-weight:600;font-size:.82rem;color:#1e293b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.fd-action-desc{font-size:.7rem;color:#94a3b8;margin-top:1px;}
.fd-action-arrow{color:#cbd5e1;font-size:.75rem;margin-left:auto;transition:color .15s;}
.fd-action-card:hover .fd-action-arrow{color:#2563EB;}

/* ── Section Header ── */
.fd-section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;}
.fd-section-title{display:flex;align-items:center;gap:.5rem;font-size:.95rem;font-weight:700;color:#1e293b;}
.fd-section-title i{color:#2563EB;font-size:1rem;}
.fd-section-badge{font-size:.72rem;font-weight:600;color:#2563EB;background:#EFF6FF;padding:3px 10px;border-radius:6px;}

/* ── Search ── */
.fd-search-bar{display:flex;justify-content:flex-end;margin-bottom:.75rem;}
.fd-search-inner{position:relative;width:280px;}
.fd-search-ico{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.82rem;}
.fd-search-input{width:100%;padding:7px 12px 7px 32px;border:1px solid #e2e8f0;border-radius:8px;font-size:.82rem;color:#1e293b;background:#fff;transition:border-color .2s,box-shadow .2s;outline:none;}
.fd-search-input:focus{border-color:#2563EB;box-shadow:0 0 0 3px rgba(37,99,235,.1);}
.fd-search-input::placeholder{color:#94a3b8;}

/* ── Table ── */
.fd-table-wrap{background:#fff;border:1px solid #e8ecf1;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.03);margin-bottom:1.5rem;}
.fd-table{width:100%;border-collapse:collapse;font-size:.82rem;}
.fd-table thead{background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-bottom:2px solid #e2e8f0;}
.fd-table thead th{padding:10px 14px;font-size:.7rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.6px;white-space:nowrap;border:none;cursor:default;user-select:none;}
.fd-sort-label{cursor:pointer;display:inline-flex;align-items:center;gap:4px;transition:color .15s;}
.fd-sort-label:hover{color:#1a56db;}
.fd-sort-icon{font-size:.62rem;opacity:.35;transition:opacity .15s;}
.fd-sort-label:hover .fd-sort-icon{opacity:.7;}
.fd-table tbody tr{border-bottom:1px solid #f1f5f9;transition:background .12s ease;}
.fd-table tbody tr:last-child{border-bottom:none;}
.fd-table tbody tr:hover{background:#f8faff;}
.fd-table tbody td{padding:10px 14px;vertical-align:middle;}
.fd-td-num{color:#94a3b8;font-size:.72rem;font-weight:600;text-align:center;}
.fd-td-code{font-weight:700;color:#2563EB;font-size:.78rem;white-space:nowrap;}
.fd-td-name{font-weight:600;color:#1e293b;}
.fd-td-meta{color:#64748b;}
.fd-sem-badge{display:inline-block;padding:2px 10px;border-radius:6px;font-size:.72rem;font-weight:600;background:#EFF6FF;color:#2563EB;}
.fd-view-btn{display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:8px;background:#EFF6FF;color:#2563EB;transition:all .15s;border:none;text-decoration:none;font-size:.8rem;}
.fd-view-btn:hover{background:#2563EB;color:#fff;}

/* ── Rating ── */
.fd-rating-value{font-weight:700;font-size:.9rem;color:#1e293b;}
.fd-rating-of{font-size:.72rem;color:#94a3b8;}
.fd-rating-bar{width:80px;height:6px;background:#e2e8f0;border-radius:4px;overflow:hidden;}
.fd-rating-fill{height:100%;border-radius:4px;transition:width .3s;}
.fd-rating-fill.fill-green{background:#16A34A;}
.fd-rating-fill.fill-blue{background:#2563EB;}
.fd-rating-fill.fill-yellow{background:#EAB308;}
.fd-rating-fill.fill-red{background:#DC2626;}

/* ── Evaluator Badge ── */
.fd-evaluator-badge{display:inline-block;min-width:28px;padding:2px 10px;border-radius:6px;font-size:.75rem;font-weight:600;background:#F0FDF4;color:#16A34A;text-align:center;}

/* ── Performance Tags ── */
.fd-perf-tag{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:6px;font-size:.7rem;font-weight:600;white-space:nowrap;}
.fd-perf-tag.perf-green{background:#F0FDF4;color:#16A34A;}
.fd-perf-tag.perf-blue{background:#EFF6FF;color:#2563EB;}
.fd-perf-tag.perf-yellow{background:#FFFBEB;color:#CA8A04;}
.fd-perf-tag.perf-orange{background:#FFF7ED;color:#EA580C;}
.fd-perf-tag.perf-red{background:#FEF2F2;color:#DC2626;}

/* ── Responsive ── */
@media(max-width:992px){
    .fd-actions-grid{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:576px){
    .fd-actions-grid{grid-template-columns:1fr;}
    .fd-search-inner{width:100%;}
    .fd-search-bar{justify-content:stretch;}
    .fd-table{font-size:.75rem;}
    .fd-table thead th{padding:8px 10px;font-size:.62rem;}
    .fd-table tbody td{padding:8px 10px;}
}

/* ── Animations ── */
.fd-table-wrap,.fd-search-bar,.fd-actions-grid,.fd-section-header{animation:fdFadeIn .25s ease;}
@keyframes fdFadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
</style>

{# ─── Sort & Search Script ─── #}
<script>
function fdFilterSubjects(){
    const q=(document.getElementById('fdSubjectSearch').value||'').toLowerCase();
    let idx=0;
    document.querySelectorAll('#fdSubjectBody .fd-row').forEach(r=>{
        const show=r.dataset.search.includes(q);
        r.style.display=show?'':'none';
        if(show){idx++;r.querySelector('.fd-td-num').textContent=idx;}
    });
}
function fdSortSubjects(col){
    const tb=document.getElementById('fdSubjectBody');
    if(!tb)return;
    const rows=Array.from(tb.querySelectorAll('.fd-row'));
    const key='sort-'+col;
    const dir=tb.dataset.sortDir===col?'desc':'asc';
    tb.dataset.sortDir=dir==='asc'?col:'';
    const isNum=col==='units';
    rows.sort((a,b)=>{
        let va=a.dataset[key]||'',vb=b.dataset[key]||'';
        if(isNum)return dir==='asc'?Number(va)-Number(vb):Number(vb)-Number(va);
        return dir==='asc'?va.localeCompare(vb):vb.localeCompare(va);
    });
    rows.forEach((r,i)=>{tb.appendChild(r);r.querySelector('.fd-td-num').textContent=i+1;});
    document.querySelectorAll('.fd-sort-icon').forEach(i=>{
        i.className='bi bi-arrow-down-up fd-sort-icon';i.style.opacity='.35';
    });
    const icon=document.querySelector('.fd-sort-icon[data-col="'+col+'"]');
    if(icon){icon.className='bi '+(dir==='asc'?'bi-arrow-up':'bi-arrow-down')+' fd-sort-icon';icon.style.opacity='.85';}
}
</script>
{% endblock %}
