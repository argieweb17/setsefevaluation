                </div>
            </form>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════
   SCOPED STYLES
   ═══════════════════════════════════════ #}

{# ═══════════════════════════════════════
   FILTER / SEARCH SCRIPT
   ═══════════════════════════════════════ #}
<script>
document.addEventListener('DOMContentLoaded', function(){
    const searchInput = document.getElementById('qqSearch');
    const catFilter = document.getElementById('qqCatFilter');
    const statusFilter = document.getElementById('qqStatusFilter');
    const resultCount = document.getElementById('qqResultCount');

    function applyFilters(){
        const query = searchInput.value.trim().toLowerCase();
        const cat = catFilter.value;
        const status = statusFilter.value;
        let visible = 0;

        document.querySelectorAll('.qq-section').forEach(function(section){
            const sectionCat = section.dataset.category || '';
            if(cat && sectionCat && sectionCat !== cat){ section.style.display = 'none'; return; }
            section.style.display = '';

            let sectionVisible = 0;
            section.querySelectorAll('.qq-row').forEach(function(row){
                const text = row.dataset.question || '';
                const rowStatus = row.dataset.status || '';
                let show = true;
                if(query && text.indexOf(query) === -1) show = false;
                if(status && rowStatus !== status) show = false;
                row.style.display = show ? '' : 'none';
                if(show){ visible++; sectionVisible++; }
            });
            if(sectionVisible === 0 && !cat) section.style.display = 'none';
        });

        resultCount.textContent = visible + ' question' + (visible !== 1 ? 's' : '');
    }

    searchInput.addEventListener('input', applyFilters);
    catFilter.addEventListener('change', applyFilters);
    statusFilter.addEventListener('change', applyFilters);
});
</script>
{% endblock %}
