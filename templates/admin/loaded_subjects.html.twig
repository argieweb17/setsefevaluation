{# ═══════════════════════════════════════
   JAVASCRIPT
   ═══════════════════════════════════════ #}
<script>
/* ── Toggle previous load sections ── */
function togglePrevLoad(id) {
    var body = document.getElementById(id);
    var chevron = document.getElementById('prevChevron' + id);
    if (!body) return;
    if (body.style.display === 'none') {
        body.style.display = '';
        if (chevron) chevron.classList.add('open');
    } else {
        body.style.display = 'none';
        if (chevron) chevron.classList.remove('open');
    }
}

/* ── Client-side search + semester filter ── */
var lsActiveSem = 'all';

function lsApplyAyFilter(ayId) {
    var url = new URL(window.location.href);
    if (ayId) {
        url.searchParams.set('ay', ayId);
    } else {
        url.searchParams.delete('ay');
    }
    window.location.href = url.toString();
}

function lsSemFilter(btn) {
    document.querySelectorAll('.ls-sem-pill').forEach(function(p) { p.classList.remove('active'); });
    btn.classList.add('active');
    lsActiveSem = btn.getAttribute('data-sem');
    lsFilter();
}

function lsFilter() {
    var q = document.getElementById('lsSearchInput').value.toLowerCase();
    var rows = document.querySelectorAll('#lsTableBody .ls-row');
    var count = 0;
    rows.forEach(function(r) {
        var matchSearch = (r.getAttribute('data-search') || '').indexOf(q) !== -1;
        var matchSem = lsActiveSem === 'all' || (r.getAttribute('data-semester') || '') === lsActiveSem;
        var show = matchSearch && matchSem;
        r.style.display = show ? '' : 'none';
        if (show) count++;
    });
    document.getElementById('lsNoResults').style.display = count === 0 ? '' : 'none';
}

function lsFilterPreviousLoads() {
    var filter = document.getElementById('lsPreviousAyFilter');
    var selectedAy = filter ? filter.value : 'all';
    var cards = document.querySelectorAll('.ls-prev-load-item');
    var visibleCount = 0;

    cards.forEach(function(card) {
        var cardAy = card.getAttribute('data-ay-id') || '';
        var isVisible = selectedAy === 'all' || cardAy === selectedAy;
        card.style.display = isVisible ? '' : 'none';
        if (isVisible) visibleCount++;
    });

    var empty = document.getElementById('lsPrevAyNoResults');
    if (empty) {
        empty.style.display = visibleCount === 0 ? '' : 'none';
    }
}

var lsSortState = {};
function lsSort(col) {
    var tbody = document.getElementById('lsTableBody');
    var rows = Array.from(tbody.querySelectorAll('.ls-row'));
    var asc = lsSortState[col] !== 'asc';
    lsSortState = {};
    lsSortState[col] = asc ? 'asc' : 'desc';

    document.querySelectorAll('.ls-sort-icon').forEach(function(ic) {
        ic.className = 'bi bi-arrow-down-up ls-sort-icon';
        ic.style.opacity = '.35';
    });
    var activeIcon = document.querySelector('.ls-sort-icon[data-col="' + col + '"]');
    if (activeIcon) {
        activeIcon.className = 'bi ls-sort-icon ' + (asc ? 'bi-arrow-up' : 'bi-arrow-down');
        activeIcon.style.opacity = '1';
    }

    rows.sort(function(a, b) {
        var va = a.getAttribute('data-sort-' + col) || '';
        var vb = b.getAttribute('data-sort-' + col) || '';
        if (col === 'units') {
            va = parseFloat(va) || 0;
            vb = parseFloat(vb) || 0;
            return asc ? va - vb : vb - va;
        }
        return asc ? va.localeCompare(vb) : vb.localeCompare(va);
    });
    rows.forEach(function(r) { tbody.appendChild(r); });
}

function lsViewDetail(btn) {
    var row = btn.closest('.ls-row');
    if (!row) return;
    document.getElementById('lsViewAvatar').textContent = row.getAttribute('data-view-code').slice(0,2).toUpperCase();
    document.getElementById('lsViewCode').textContent = row.getAttribute('data-view-code');
    document.getElementById('lsViewName').textContent = row.getAttribute('data-view-name');
    document.getElementById('lsViewUnits').textContent = row.getAttribute('data-view-units');
    document.getElementById('lsViewSection').textContent = row.getAttribute('data-view-section');
    document.getElementById('lsViewYearLevel').textContent = row.getAttribute('data-view-yearlevel');
    document.getElementById('lsViewSemester').textContent = row.getAttribute('data-view-semester');
    document.getElementById('lsViewDept').textContent = row.getAttribute('data-view-department');
    document.getElementById('lsViewSchedule').textContent = row.getAttribute('data-view-schedule');
    new bootstrap.Modal(document.getElementById('lsViewModal')).show();
}

document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.ls-row').forEach(function(r, i) {
        r.style.animationDelay = (i * 0.03) + 's';
    });

    var previousAyFilter = document.getElementById('lsPreviousAyFilter');
    if (previousAyFilter) {
        previousAyFilter.addEventListener('change', lsFilterPreviousLoads);
        lsFilterPreviousLoads();
    }
});

function showUnloadBlockedModal(message, subjects) {
    var msgEl = document.getElementById('lsUnloadBlockedMessage');
    var listEl = document.getElementById('lsUnloadBlockedList');
    if (msgEl) {
        msgEl.textContent = message || 'Cannot unload this subject because evaluation is currently active.';
    }
    if (listEl) {
        listEl.innerHTML = '';
        if (Array.isArray(subjects) && subjects.length > 0) {
            listEl.style.display = '';
            subjects.forEach(function(label) {
                var li = document.createElement('li');
                li.textContent = label;
                listEl.appendChild(li);
            });
        } else {
            listEl.style.display = 'none';
        }
    }

    var modalEl = document.getElementById('lsUnloadBlockedModal');
    if (!modalEl) return;
    var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    modal.show();
}

document.addEventListener('submit', function(event) {
    var form = event.target;
    if (!(form instanceof HTMLFormElement)) return;

    if (form.classList.contains('js-unload-form')) {
        var row = form.closest('.ls-row');
        var isActive = !!(row && row.querySelector('.ls-eval-badge.ls-eval-active'));
        if (isActive) {
            event.preventDefault();
            var subjectLabel = form.getAttribute('data-subject-label') || 'This subject';
            showUnloadBlockedModal('Cannot unload while evaluation is active for this subject.', [subjectLabel]);
            return;
        }

        var confirmMessage = form.getAttribute('data-confirm-message') || 'Unload this subject?';
        if (!confirm(confirmMessage)) {
            event.preventDefault();
        }
        return;
    }

    if (form.classList.contains('js-unload-all-form')) {
        var blocked = [];
        document.querySelectorAll('#lsTableBody .ls-row').forEach(function(row) {
            var isActive = !!row.querySelector('.ls-eval-badge.ls-eval-active');
            if (!isActive) return;

            var code = (row.getAttribute('data-view-code') || '').trim();
            var name = (row.getAttribute('data-view-name') || '').trim();
            blocked.push(code + (name ? ' — ' + name : ''));
        });

        if (blocked.length > 0) {
            event.preventDefault();
            showUnloadBlockedModal('Cannot unload all because some subjects have active evaluation.', blocked);
            return;
        }

        var unloadAllConfirm = form.getAttribute('data-confirm-message') || 'Unload all subjects?';
        if (!confirm(unloadAllConfirm)) {
            event.preventDefault();
        }
    }
});

/* ── Print Loaded Subjects ── */
function lsPrint() {
    // Build a clean printable area
    var old = document.getElementById('printArea');
    if (old) old.remove();

    var printDiv = document.createElement('div');
    printDiv.id = 'printArea';

    // Header
    var userName = '{{ app.user.firstName }} {{ app.user.lastName }}';
    var deptName = '{{ app.user.department ? app.user.department.departmentName : "" }}';
    printDiv.innerHTML = '<div class="print-header">' +
        '<h3>Schedule</h3>' +
        '<p>' + userName + (deptName ? ' — ' + deptName : '') + '</p>' +
        '<p style="font-size:7.5pt;color:#94a3b8;margin-top:4px;">Generated on ' + new Date().toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) + '</p>' +
    '</div>';

    // Stats
    printDiv.innerHTML += '<div class="print-stats">' +
        '<div class="print-stat"><div class="print-stat-val">{{ totalSubjects }}</div><div class="print-stat-lbl">Total Subjects</div></div>' +
        '<div class="print-stat"><div class="print-stat-val">{{ totalUnits }}</div><div class="print-stat-lbl">Total Units</div></div>' +
        '<div class="print-stat"><div class="print-stat-val">{{ totalSections }}</div><div class="print-stat-lbl">Sections</div></div>' +
    '</div>';

    // Build table from visible rows
    var table = '<table class="print-table"><thead><tr>' +
        '<th style="width:5%">#</th>' +
        '<th style="width:10%">Code</th>' +
        '<th>Subject Name</th>' +
        '<th style="width:8%">Semester</th>' +
        '<th style="width:5%">Units</th>' +
        '<th style="width:7%">Year Level</th>' +
        '<th style="width:7%">Section</th>' +
        '<th style="width:8%">Schedule/Time</th>' +
        '<th style="width:10%">Department</th>' +
        '</tr></thead><tbody>';

    var rows = document.querySelectorAll('#lsTableBody .ls-row');
    var idx = 0;
    rows.forEach(function(r) {
        if (r.style.display === 'none') return; // skip filtered out
        idx++;
        table += '<tr>' +
            '<td>' + idx + '</td>' +
            '<td class="print-code">' + (r.getAttribute('data-view-code') || '') + '</td>' +
            '<td>' + (r.getAttribute('data-view-name') || '') + '</td>' +
            '<td>' + (r.getAttribute('data-view-semester') || '—') + '</td>' +
            '<td class="print-units">' + (r.getAttribute('data-view-units') || '—') + '</td>' +
            '<td>' + (r.getAttribute('data-view-yearlevel') || '—') + '</td>' +
            '<td>' + (r.getAttribute('data-view-section') || '—') + '</td>' +
            '<td>' + (r.getAttribute('data-view-schedule') || '—') + '</td>' +
            '<td>' + (r.getAttribute('data-view-department') || '—') + '</td>' +
            '</tr>';
    });
    table += '</tbody></table>';
    printDiv.innerHTML += table;

    // Footer
    printDiv.innerHTML += '<div class="print-footer">SET-SEF Evaluation System — Printed ' +
        new Date().toLocaleString('en-US', {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) +
        '</div>';

    // Hidden elements for screen
    printDiv.style.display = 'none';
    document.body.appendChild(printDiv);
    printDiv.style.display = '';
    window.print();
    // Re-hide after print
    setTimeout(function() { printDiv.style.display = 'none'; }, 500);
}

/* ── QR Code for Evaluations ── */
(function() {
    var currentQrUrl = '';
    var qrModal = document.getElementById('lsQrModal');
    if (!qrModal) return;

    var baseUrl = window.location.origin;

    qrModal.addEventListener('show.bs.modal', function(e) {
        var btn = e.relatedTarget;
        if (!btn) return;

        var evalId = btn.getAttribute('data-eval-id');
        var faculty = btn.getAttribute('data-eval-faculty');
        var subject = btn.getAttribute('data-eval-subject');
        var subjectId = btn.getAttribute('data-eval-subject-id');
        var section = btn.getAttribute('data-eval-section');
        var schedule = btn.getAttribute('data-eval-schedule');
        var schoolYear = btn.getAttribute('data-eval-school-year');

        // Fallback for stale/missing button data: rebuild values from the row and active evaluations.
        var row = btn.closest('.ls-row');
        if (row) {
            var rowCode = (row.getAttribute('data-view-code') || '').trim();
            var rowName = (row.getAttribute('data-view-name') || '').trim();
            var rowSubjectId = (row.getAttribute('data-view-id') || '').trim();
            var rowSectionRaw = (row.getAttribute('data-view-section') || '').trim();
            var rowScheduleRaw = (row.getAttribute('data-view-schedule') || '').trim();
            var rowSection = rowSectionRaw === '—' ? '' : rowSectionRaw;
            var rowSchedule = rowScheduleRaw === '—' ? '' : rowScheduleRaw;

            if (!subject && (rowCode || rowName)) {
                subject = rowCode + (rowName ? ' — ' + rowName : '');
            }
            if (!subjectId && rowSubjectId) {
                subjectId = rowSubjectId;
            }
            if (!section && rowSection) {
                section = rowSection;
            }
            if (!schedule && rowSchedule) {
                schedule = rowSchedule;
            }

            var rowMatch = findMatchingEvaluation(rowCode, rowName, section || rowSection);
            if (rowMatch && rowMatch.data) {
                if (!evalId) {
                    evalId = rowMatch.id;
                }
                if (!faculty) {
                    faculty = rowMatch.data.faculty || '';
                }
                if (!schoolYear) {
                    schoolYear = rowMatch.data.schoolYear || rowMatch.data.name || '';
                }
            }
        }

        // Build thevaluation URL with subject ID and section for unique codes
        if (subjectId && section) {
            currentQrUrl = baseUrl + '/evaluation/qr/' + evalId + '/' + subjectId + '/' + encodeURIComponent(section);
        } else if (subjectId) {
            currentQrUrl = baseUrl + '/evaluation/qr/' + evalId + '/' + subjectId;
        } else {
            currentQrUrl = baseUrl + '/evaluation/qr/' + evalId;
        }

        document.getElementById('lsQrSubtitle').textContent = schoolYear || 'Scan to open the evaluation form';
        document.getElementById('lsQrFaculty').textContent = faculty || '—';
        document.getElementById('lsQrSubject').textContent = subject || '—';

        // Build details display with section and schedule if available
        var detailsDisplay = section || '';
        if (schedule) {
            detailsDisplay = (detailsDisplay ? detailsDisplay + ' | ' : '') + schedule;
        }
        document.getElementById('lsQrDetails').textContent = detailsDisplay || '—';

        var detailsRow = document.getElementById('lsQrDetailsRow');
        if (detailsRow) detailsRow.style.display = detailsDisplay ? '' : 'none';

        document.getElementById('lsQrUrl').textContent = currentQrUrl;

        var qrImg = document.getElementById('lsQrImage');
        qrImg.src = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(currentQrUrl);
    });

    window.lsDownloadQR = function() {
        var img = document.getElementById('lsQrImage');
        var link = document.createElement('a');
        link.download = 'evaluation-qr-code.png';
        link.href = img.src;
        link.click();
    };

    window.lsCopyQRLink = function() {
        navigator.clipboard.writeText(currentQrUrl).then(function() {
            var btn = document.querySelector('#lsQrModal .qr-btn-copy');
            var orig = btn.innerHTML;
            btn.innerHTML = '<i class="me-1 bi bi-check"></i>Copied!';
            setTimeout(function() { btn.innerHTML = orig; }, 1500);
        });
    };

    /* ─── Real-time QR Polling ─── */
    const activeEvaluations = JSON.parse('{{ activeEvalMap|json_encode|escape('js') }}');
    const facultyNameCandidates = [
        '{{ app.user.firstName|default('')|e('js') }} {{ app.user.lastName|default('')|e('js') }}',
        '{{ app.user.lastName|default('')|e('js') }}, {{ app.user.firstName|default('')|e('js') }}',
        '{{ app.user.lastName|default('')|e('js') }}'
    ].map(function(v) {
        return (v || '').toLowerCase().trim();
    }).filter(function(v, i, arr) {
        return !!v && arr.indexOf(v) === i;
    });

    let lastPolledTime = 0;
    let currentActiveEvals = activeEvaluations;

    function normalizeText(value) {
        return (value || '').toString().trim().toLowerCase();
    }

    function getEvalSubjectCode(evalSubject) {
        if (!evalSubject) return '';
        var parts = evalSubject.split(' — ');
        return normalizeText(parts[0] || evalSubject);
    }

    function facultyMatches(evalData) {
        var evalFaculty = normalizeText(evalData && evalData.faculty ? evalData.faculty : '');
        if (!evalFaculty) return true;
        if (facultyNameCandidates.length === 0) return true;

        return facultyNameCandidates.some(function(candidate) {
            return evalFaculty === candidate || evalFaculty.indexOf(candidate) !== -1 || candidate.indexOf(evalFaculty) !== -1;
        });
    }

    function subjectMatches(evalData, code, name) {
        var evalSubject = normalizeText(evalData && evalData.subject ? evalData.subject : '');
        if (!evalSubject) return true;

        var codeNorm = normalizeText(code);
        var nameNorm = normalizeText(name);
        var evalCode = getEvalSubjectCode(evalData.subject || '');

        return (evalCode && codeNorm === evalCode) ||
            codeNorm.indexOf(evalSubject) === 0 ||
            evalSubject.indexOf(codeNorm) === 0 ||
            nameNorm.indexOf(evalSubject) !== -1;
    }

    function sectionMatches(evalData, section) {
        var evalSection = normalizeText(evalData && evalData.section ? evalData.section : '');
        if (!evalSection) return true;
        return evalSection === normalizeText(section);
    }

    function findMatchingEvaluation(code, name, section) {
        var entries = Object.entries(currentActiveEvals || {});
        var fallback = null;

        for (var i = 0; i < entries.length; i++) {
            var evalId = entries[i][0];
            var evalData = entries[i][1] || {};

            if (!facultyMatches(evalData)) continue;
            if (!subjectMatches(evalData, code, name)) continue;

            if (sectionMatches(evalData, section)) {
                return { id: evalId, data: evalData };
            }

            if (!fallback) {
                fallback = { id: evalId, data: evalData };
            }
        }

        return fallback;
    }

    function escapeAttr(value) {
        return (value || '').toString()
            .replace(/&/g, '&amp;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    window.pollActiveEvaluationsLS = function(forceImmediate) {
        const now = Date.now();
        if (!forceImmediate && now - lastPolledTime < 5000) return;
        lastPolledTime = now;

        fetch('{{ path("api_active_evaluations") }}')
            .then(response => {
                if (!response.ok) {
                    throw new Error(`API error: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                const newEvals = data.evaluations || [];
                const newEvalMap = {};
                newEvals.forEach(e => {
                    newEvalMap[e.id] = e;
                });

                const oldKeys = Object.keys(currentActiveEvals || {}).sort();
                const newKeys = Object.keys(newEvalMap).sort();

                if (JSON.stringify(oldKeys) !== JSON.stringify(newKeys)) {
                    console.log('Loaded subjects: Evaluation list changed!');
                }

                currentActiveEvals = newEvalMap;
                window.hasActiveEvalLS = newKeys.length > 0;
                window.firstActiveEvalIdLS = newKeys.length > 0 ? newKeys[0] : null;
                updateQRButtons();
            })
            .catch(error => {
                if (error.name !== 'AbortError') {
                    console.error('Poll error:', error);
                }
            });
    };

    function updateQRButtons() {
        document.querySelectorAll('#lsTableBody .ls-row').forEach(row => {
            const statusCell = row.querySelector('td:nth-child(9)');
            const actionsCell = row.querySelector('td:nth-child(10)');
            if (!actionsCell) return;

            const flexDiv = actionsCell.querySelector('.d-flex');
            if (!flexDiv) return;

            const subjectId = row.getAttribute('data-view-id') || '';
            const code = row.getAttribute('data-view-code') || '';
            const name = row.getAttribute('data-view-name') || '';
            const section = row.getAttribute('data-view-section') || '';
            const schedule = row.getAttribute('data-view-schedule') || '';

            const match = findMatchingEvaluation(code, name, section);
            const existingQrBtn = flexDiv.querySelector('.ls-qr-btn');

            if (!match || !match.id) {
                if (statusCell) {
                    statusCell.innerHTML = '<span class="ls-eval-badge ls-eval-none"><i class="bi bi-dash-circle"></i> No Evaluation</span>';
                }
                if (existingQrBtn) {
                    existingQrBtn.remove();
                }
                return;
            }

            if (statusCell) {
                statusCell.innerHTML = '<span class="ls-eval-badge ls-eval-active"><i class="bi bi-check-circle"></i> Active</span>';
            }

            const evalData = match.data || {};
            const evalId = match.id;

            const qrButtonHtml = '<button type="button" class="btn btn-sm ls-action-qr ls-qr-btn" data-bs-toggle="modal" data-bs-target="#lsQrModal" data-eval-id="' + evalId + '" data-eval-faculty="' + escapeAttr(evalData.faculty || '') + '" data-eval-subject="' + escapeAttr(code + ' — ' + name) + '" data-eval-subject-id="' + escapeAttr(subjectId) + '" data-eval-section="' + escapeAttr(section) + '" data-eval-schedule="' + escapeAttr(schedule) + '" data-eval-school-year="' + escapeAttr(evalData.schoolYear || evalData.name || '') + '" title="Generate QR Code"><i class="bi bi-qr-code-scan"></i></button>';

            if (existingQrBtn) {
                existingQrBtn.outerHTML = qrButtonHtml;
            } else {
                flexDiv.insertAdjacentHTML('afterbegin', qrButtonHtml);
            }
        });
    }

    // Start polling
    window.pollActiveEvaluationsLS(true);
    setInterval(() => window.pollActiveEvaluationsLS(), 30000);
})();
</script>
