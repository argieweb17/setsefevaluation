{% extends 'base.html.twig' %}

{% block title %}Change Password | SET-SEF Evaluation{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i  class="bi bi-key me-2"></i>Change Password</h4>
    <div class="page-header-actions">
        <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary btn-sm">
            <i  class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold"><i  class="bi bi-lock me-1"></i> Update Password</div>
            <div class="card-body">
                <form method="post" action="{{ path('app_profile_change_password') }}">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Current Password <span class="text-danger">*</span></label>
                        <input type="password" name="currentPassword" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">New Password <span class="text-danger">*</span></label>
                        <input type="password" name="newPassword" class="form-control" minlength="6" required>
                        <div class="form-text">Minimum 6 characters.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Confirm New Password <span class="text-danger">*</span></label>
                        <input type="password" name="confirmPassword" class="form-control" minlength="6" required>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-norsu"><i  class="bi bi-check-circle-fill me-1"></i>Change Password</button>
                        <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
