{% extends 'base.html.twig' %}
{% set prefix = staffMode|default(false) ? 'staff' : 'admin' %}

{% block title %}{{ faculty.fullName }} | SEF Evaluations{% endblock %}

{% block stylesheets %}
<style>
.fe-header {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    background: #1e3a5f;
}
.fe-header-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 35%, #1e40af 60%, #059669 100%);
    opacity: .95;
}
.fe-header-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(59,130,246,.15) 0%, transparent 50%),
                radial-gradient(circle at 20% 80%, rgba(16,185,129,.15) 0%, transparent 50%);
}
.fe-header-inner {
    position: relative;
    z-index: 1;
    padding: 1.4rem 1.8rem;
}
.fe-avatar {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba(255,255,255,.12);
    border: 2px solid rgba(255,255,255,.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    overflow: hidden;
}
.fe-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.fe-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 4px;
    letter-spacing: -.01em;
}
.fe-sub {
    font-size: .78rem;
    color: rgba(255,255,255,.72);
}
.fe-btn-back {
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.2);
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: .78rem;
    padding: 6px 14px;
}
.fe-btn-back:hover { background: rgba(255,255,255,.2); color: #fff; }
.fe-btn-print {
    background: #fff;
    color: #1e3a5f;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: .78rem;
    padding: 6px 14px;
}
.fe-btn-print:hover { background: #f0f4ff; color: #1e3a5f; }

.fe-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .75rem;
    margin-bottom: 1.25rem;
}
.fe-stat-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.fe-stat-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
}
.stat-blue { background: transparent; color: #2563eb; }
.stat-green { background: transparent; color: #16a34a; }
.stat-purple { background: transparent; color: #7c3aed; }
.fe-stat-label {
    font-size: .72rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: .04em;
    font-weight: 600;
}
.fe-stat-num {
    font-size: 1.35rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.2;
}

.fe-table-wrap {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,.04);
}
.fe-table-title {
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
    padding: .85rem 1rem;
}
.fe-table {
    margin: 0;
    font-size: .82rem;
}
.fe-table thead th {
    background: #f8fafc;
    border-bottom: 2px solid #e5e7eb;
    font-size: .72rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: .03em;
    padding: .7rem .8rem;
}
.fe-table tbody td {
    padding: .75rem .8rem;
    vertical-align: middle;
    border-bottom: 1px solid #f1f5f9;
}
.fe-table tbody tr:last-child td { border-bottom: none; }
.fe-table tbody tr:hover { background: #f8fafc; }

.fe-info-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: .75rem;
    color: #475569;
    background: transparent;
    padding: 0;
    border-radius: 0;
}
.fe-rating-num {
    font-size: .98rem;
    font-weight: 800;
    color: #0f172a;
}
.fe-rating-of {
    font-size: .66rem;
    color: #94a3b8;
}
.fe-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
    font-size: .78rem;
    color: #3b82f6;
    background: transparent;
    border: none;
    text-decoration: none;
    padding: 0;
    transition: all .2s;
}
.fe-action-btn-icon {
    width: 32px;
    height: 32px;
    padding: 0;
}
.fe-action-btn:hover {
    background: transparent;
    color: #1d4ed8;
}
.fe-action-btn-view {
    color: #047857;
    background: transparent;
    border: none;
}
.fe-action-btn-view:hover {
    color: #065f46;
    background: transparent;
}
.fe-action-group {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
}

.fe-empty {
    text-align: center;
    padding: 2.5rem 1rem;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

@media (max-width: 768px) {
    .fe-stats { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block body %}
<div class="fe-header">
    <div class="fe-header-bg"></div>
    <div class="fe-header-inner">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="fe-avatar">
                    {% if faculty.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ faculty.profilePicture) }}" alt="Profile" class="fe-avatar-img">
                    {% else %}
                        {{ faculty.firstName|first|upper }}{{ faculty.lastName|first|upper }}
                    {% endif %}
                </div>
                <div>
                    <h4 class="fe-name">{{ faculty.fullName }}</h4>
                    <div class="fe-sub">SEF evaluation summary</div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ staffMode|default(false) ? path('staff_results', {view: 'sef'}) : path(prefix ~ '_results_superior') }}" class="btn btn-sm fe-btn-back">
                    <i  class="bi bi-arrow-left me-1"></i>Back
                </a>
                {% if evaluations|length > 0 %}
                <a href="{{ path(prefix ~ '_results_superior_print_all', {faculty: faculty.id}) }}" target="_blank" class="btn btn-sm fe-btn-print">
                    <i  class="bi bi-printer me-1"></i>Print Result
                </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="fe-stats">
    <div class="fe-stat-card">
        <div class="fe-stat-icon stat-blue"><i  class="bi bi-card-checklist"></i></div>
        <div>
            <div class="fe-stat-num">{{ evaluations|length }}</div>
            <div class="fe-stat-label">Evaluations</div>
        </div>
    </div>
    <div class="fe-stat-card">
        <div class="fe-stat-icon stat-green"><i  class="bi bi-graph-up-arrow"></i></div>
        <div>
            <div class="fe-stat-num">{{ overallAvg|number_format(2) }}</div>
            <div class="fe-stat-label">Overall Average</div>
        </div>
    </div>
    <div class="fe-stat-card">
        <div class="fe-stat-icon stat-purple"><i  class="bi bi-people"></i></div>
        <div>
            <div class="fe-stat-num">{{ totalPersonnel|default(0) }}</div>
            <div class="fe-stat-label">Total Personnel Evaluated</div>
        </div>
    </div>
</div>

{% if evaluations|length > 0 %}
{% set evaluatedRows = [] %}
{% for item in evaluations %}
    {% set ev = item.evaluation %}
    {% for person in item.evaluatedPersonnel|default([]) %}
        {% set evaluatedRows = evaluatedRows|merge([{
            period: (ev.semester|default('') ~ ' ' ~ ev.schoolYear|default(''))|trim,
            evaluationId: person.evaluationId|default(null),
            facultyId: person.id|default(null),
            name: person.name,
            department: person.department,
            average: person.average
        }]) %}
    {% endfor %}
{% endfor %}

<div class="fe-table-wrap">
    <div class="fe-table-title">Evaluated Faculty Results</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 fe-table">
            <thead>
                <tr>
                    <th>Period</th>
                    <th>Faculty</th>
                    <th>Department</th>
                    <th class="text-center">Average</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for row in evaluatedRows %}
                    <tr>
                        <td><span class="fw-semibold">{{ row.period }}</span></td>
                        <td>{{ row.name }}</td>
                        <td>
                            <span class="fe-info-badge"><i  class="bi bi-buildings"></i>{{ row.department }}</span>
                        </td>
                        <td class="text-center">
                            <span class="fe-rating-num">{{ row.average|number_format(2) }}</span>
                            <span class="fe-rating-of">/ 5</span>
                        </td>
                        <td class="text-center">
                            {% if row.evaluationId and row.facultyId %}
                                <div class="fe-action-group">
                                    <a
                                        href="{{ path(staffMode|default(false) ? 'staff_results_superior_view_form' : 'admin_results_superior_view_form', {evaluation: row.evaluationId, faculty: row.facultyId, evaluator: faculty.id}) }}"
                                        class="fe-action-btn fe-action-btn-icon fe-action-btn-view"
                                        title="View SEF Result Form"
                                        aria-label="View SEF Result Form"
                                    >
                                        <i  class="bi bi-eye"></i>
                                    </a>
                                    <a
                                        href="{{ path(staffMode|default(false) ? 'staff_results_superior_print_setup' : 'admin_results_superior_print_setup', {evaluation: row.evaluationId, faculty: row.facultyId}) }}"
                                        target="_blank"
                                        class="fe-action-btn fe-action-btn-icon"
                                        title="Print Result"
                                        aria-label="Print Result"
                                    >
                                        <i  class="bi bi-printer"></i>
                                    </a>
                                </div>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-3">No evaluated faculty records available.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% else %}
<div class="fe-empty">
    <i  class="bi bi-clipboard-x fs-3 d-block mb-2 text-muted"></i>
    No SEF evaluator activity found for this department head.
</div>
{% endif %}
{% endblock %}
