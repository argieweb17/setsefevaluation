<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SEF Report - {{ faculty.fullName }}</title>
    <style>
        @page {
            size: A4 landscape;
            margin: 8mm 10mm 8mm 10mm;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 0;
            color: #000;
            font-size: 9px;
            line-height: 1.3;
            padding: 12px 20px;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            background-image:
                linear-gradient(to right, #e5e7eb 1px, transparent 1px),
                linear-gradient(to bottom, #e5e7eb 1px, transparent 1px);
            background-size: 24px 24px;
        }

        .sheet {
            width: 100%;
        }

        .header-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 6px;
        }
        .header-left {
            flex-shrink: 0;
            margin-left: 0;
        }
        .header-left img {
            max-height: 90px;
            width: auto;
        }
        .header-right {
            text-align: right;
            padding-top: 4px;
            margin-right: 10px;
        }
        .header-right .office-title {
            font-size: 14px;
            font-weight: 700;
            font-style: italic;
            margin-bottom: 4px;
        }
        .doc-info-table {
            border-collapse: collapse;
            font-size: 9px;
            margin-left: auto;
        }
        .doc-info-table td {
            border: 1px solid #000;
            padding: 1px 8px;
        }
        .doc-info-table .di-lbl {
            font-weight: 700;
            white-space: nowrap;
        }
        .doc-info-table .di-val {
            min-width: 60px;
        }
        .doc-info-table .di-page {
            text-align: center;
            font-weight: 400;
            vertical-align: middle;
            padding: 1px 12px;
            letter-spacing: 2px;
            font-size: 10px;
        }

        .title-block {
            text-align: center;
            margin-bottom: 8px;
        }
        .title-block h2 {
            font-size: 13px;
            font-weight: 700;
            margin: 0;
        }

        .info-row {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
            background: #fff;
        }

        .info-row td {
            border: none;
            padding: 4px 8px 2px;
            font-size: 10px;
        }

        .info-row .lbl {
            font-weight: 700;
            text-align: center;
            white-space: nowrap;
            width: 11%;
        }

        .info-row .val {
            border-bottom: 1px solid #000;
            text-decoration: none;
            width: 14%;
        }

        .main-row {
            display: flex;
            align-items: stretch;
            gap: 10px;
            margin-top: 4px;
            margin-bottom: 8px;
            width: 64%;
        }

        .items-table {
            width: calc(100% - 210px);
            border-collapse: collapse;
            background: #fff;
        }

        .items-table th,
        .items-table td {
            border: 1px solid #000;
            padding: 4px 6px;
            font-size: 10px;
        }

        .items-table thead th {
            font-weight: 700;
            text-align: center;
        }

        .items-table .item {
            text-align: left;
        }

        .items-table .num {
            text-align: center;
            width: 14%;
        }

        .summary-box {
            width: 200px;
            flex-shrink: 0;
            border-collapse: collapse;
            background: #fff;
        }

        .summary-box th,
        .summary-box td {
            border: 1px solid #000;
            padding: 8px 6px;
            text-align: center;
            font-size: 15px;
            font-weight: 700;
        }

        .summary-box th {
            background: #cfe2f3;
            font-size: 18px;
        }

        .summary-box .value {
            font-size: 30px;
            line-height: 1.1;
        }

        .scale {
            margin: 6px 0 8px;
            text-align: center;
            font-size: 9px;
            font-style: italic;
            background: transparent;
            border: none;
            padding: 0;
        }

        .purpose-row {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
            background: transparent;
        }

        .purpose-row td {
            border: none;
            padding: 2px 6px;
            font-size: 10px;
        }

        .purpose-row .lbl {
            width: auto;
            font-weight: 700;
            text-align: left;
            padding-left: 0;
            padding-right: 8px;
        }

        .signature-wrap {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin: 16px 20px 10px;
            font-size: 10px;
        }

        .sig-block {
            width: 38%;
            text-align: center;
        }

        .sig-label {
            text-align: left;
            margin-bottom: 26px;
            font-weight: 700;
        }

        .sig-name {
            border-bottom: 1px solid #000;
            font-weight: 700;
            padding-bottom: 2px;
            margin-bottom: 3px;
        }

        .sig-title {
            font-size: 9px;
        }

        .disclaimer {
            font-size: 8px;
            font-style: italic;
            border-top: none;
            padding-top: 5px;
            margin-top: 34px;
        }

        @media print {
            body { padding: 0; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body>
{% set letters = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'] %}
{% set totalAvg = 0 %}
{% set totalMax = 0 %}
{% set overallValue = overallAverage|default(compositeTotal|default(0)) %}
{% set overallPct = (overallValue / 5) * 100 %}

<div class="sheet">
    <div class="header-row">
        <div class="header-left">
            <img src="{{ absolute_url(asset('images/header.jpg')) }}" alt="NORSU Letterhead">
        </div>
        <div class="header-right">
            <div class="office-title">Office of the University Quality Assurance Management Center</div>
            <table class="doc-info-table">
                <tr>
                    <td class="di-lbl">Document ID</td>
                    <td class="di-val"></td>
                    <td class="di-lbl">Issue Status</td>
                    <td class="di-val"></td>
                    <td rowspan="3" class="di-page">P a g e&nbsp;|<strong>1</strong></td>
                </tr>
                <tr>
                    <td class="di-lbl">Issue Date</td>
                    <td class="di-val">{{ "now"|date("m-d-Y") }}</td>
                    <td class="di-lbl">Approved by</td>
                    <td class="di-val">ODQA</td>
                </tr>
                <tr>
                    <td class="di-lbl">Reviewed &amp; Authorized by</td>
                    <td class="di-val">ODQA</td>
                    <td></td>
                    <td></td>
                </tr>
            </table>
        </div>
    </div>

    <div class="title-block">
        <h2>RESULT OF SUPERIOR EVALUATION FOR FACULTY</h2>
    </div>

    <table class="info-row">
        <tr>
            <td class="lbl">Name of Faculty:</td>
            <td class="val">{{ faculty.lastName }}, {{ faculty.firstName }}</td>
            <td class="lbl">Campus:</td>
            <td class="val">{{ faculty.campus ?? 'Main Campus' }}</td>
            <td class="lbl">Course:</td>
            <td class="val">{{ faculty.department ? faculty.department.departmentName : 'N/A' }}</td>
            <td class="lbl">Sem/SY:</td>
            <td class="val">{{ evaluation.semester ?? '' }} {{ evaluation.schoolYear ?? '' }}</td>
            <td class="lbl">Employment Status:</td>
            <td class="val">{{ faculty.employmentStatus ?? 'Regular Faculty' }}</td>
        </tr>
    </table>

    <div class="main-row">
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:58%;">ITEMS</th>
                    <th class="num">Average<br>Score</th>
                    <th class="num">Max<br>Score</th>
                    <th class="num">Rating<br>%</th>
                </tr>
            </thead>
            <tbody>
                {% for cat in categorySummary %}
                    {% set itemMax = cat.weightPct|default(0) %}
                    {% set itemAvg = (cat.mean|default(0) / 5) * itemMax %}
                    {% set itemPct = (cat.mean|default(0) / 5) * 100 %}
                    {% set totalAvg = totalAvg + itemAvg %}
                    {% set totalMax = totalMax + itemMax %}
                    <tr>
                        <td class="item">{{ letters[loop.index0]|default(loop.index ~ '.') }} {{ cat.name }}</td>
                        <td class="num">{{ itemAvg|round(0, 'common') }}</td>
                        <td class="num">{{ itemMax|round(0, 'common') }}</td>
                        <td class="num">{{ itemPct|round(0, 'common') }}</td>
                    </tr>
                {% endfor %}
                <tr>
                    <td class="item" style="text-align:right;font-weight:700;">Total Score</td>
                    <td class="num" style="font-weight:700;">{{ totalAvg|round(0, 'common') }}</td>
                    <td class="num" style="font-weight:700;">{{ totalMax|round(0, 'common') }}</td>
                    <td class="num" style="font-weight:700;">{{ overallPct|round(0, 'common') }}</td>
                </tr>
            </tbody>
        </table>

        <table class="summary-box">
            <tr>
                <th>Overall Rating</th>
            </tr>
            <tr>
                <td class="value">{{ overallPct|number_format(2) }}</td>
            </tr>
            <tr>
                <th>Verbal Rating</th>
            </tr>
            <tr>
                <td>{{ performanceLevel|default('N/A') }}</td>
            </tr>
        </table>
    </div>

    <div class="scale">
        Rating Scale: 91 - 100% - Always Manifested; 61 - 90% - Often Manifested; 31 - 60% - Sometimes Manifested; 11 - 30% - Seldom Manifested; 0 - 10% - Never/Rarely Manifested
    </div>

    <table class="purpose-row">
        <tr>
            <td class="lbl">Purpose:</td>
            <td>For IPCR Requirement only.</td>
        </tr>
    </table>

    <div class="signature-wrap">
        <div class="sig-block">
            <div class="sig-label">Prepared by:</div>
            <div class="sig-name">Argie Pair Pagbunocan</div>
            <div class="sig-title">QUAMC Staff</div>
        </div>
        <div class="sig-block">
            <div class="sig-label">Noted by:</div>
            <div class="sig-name">CESAR P. ESTROPE, Ed.D</div>
            <div class="sig-title">Director, Quality Assurance Management Center</div>
        </div>
    </div>

    <div class="disclaimer">
        Disclaimer: The information transmitted by this document is intended only for the person or entity to which it is addressed. This document may contain proprietary, business-confidential and/or privileged material. If you are not the intended recipient of this message, be aware that any use, review, retransmission, distribution, reproduction or any action taken in reliance upon this message is strictly prohibited. If you received this in error, please contact the sender. Thank you.
    </div>
</div>

<script>
    window.addEventListener('load', function () {
        setTimeout(function () { window.print(); }, 350);
    });
</script>
</body>
</html>
