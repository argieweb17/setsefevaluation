                </script>
            {% endif %}

            {% if dataPrivacyDisclaimerMessages|length > 0 %}
                <div class="modal fade" id="dataPrivacyDisclaimerModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false" data-error-modal="1">
                    <div class="modal-dialog modal-dialog-centered" style="max-width: 480px;">
                        <div class="modal-content border-0 shadow" style="border-radius: 14px; overflow: hidden;">
                            <div class="modal-body text-center px-4 py-4">
                                <div class="mb-3" style="font-size: 2.25rem; color: #DC2626;">
                                    <i class="bi bi-exclamation-triangle"></i>
                                </div>
                                <h5 class="fw-bold mb-2" style="color:#1E293B;">Data Privacy Disclaimer Required</h5>
                                {% for message in dataPrivacyDisclaimerMessages %}
                                    <p class="text-muted mb-0" style="font-size: .95rem;">{{ message }}</p>
                                {% endfor %}
                                <div class="mt-4">
                                    <button type="button" class="btn btn-norsu px-4" data-bs-dismiss="modal">OK</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <script>
                (function() {
                    function showDataPrivacyDisclaimerModal() {
                        var modalEl = document.getElementById('dataPrivacyDisclaimerModal');
                        if (!modalEl || modalEl.dataset.shown === '1') return;
                        modalEl.dataset.shown = '1';
                        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                        modal.show();
                    }
                    document.addEventListener('DOMContentLoaded', showDataPrivacyDisclaimerModal);
                    document.addEventListener('turbo:load', showDataPrivacyDisclaimerModal);
                })();
                </script>
            {% endif %}

            {% block body %}{% endblock %}
        </div>

        <audio
            id="errorModalSound"
            preload="auto"
            data-preferred-src="{{ asset('sounds/universfield-error-05-199276.mp3') }}"
            data-fallback-src="{{ asset('sounds/successed-295058.mp3') }}">
        </audio>
        <script>
        (function() {
            window.playErrorModalSound = function() {
                var audio = document.getElementById('errorModalSound');
                if (!audio) return;
                try {
                    if (audio.dataset.initialized !== '1') {
                        audio.dataset.initialized = '1';
                        if (audio.dataset.preferredSrc) {
                            audio.src = audio.dataset.preferredSrc;
                            audio.load();
                        }
                    }

                    audio.currentTime = 0;
                    var playPromise = audio.play();
                    if (playPromise && typeof playPromise.catch === 'function') {
                        playPromise.catch(function() {
                            var fallback = audio.dataset.fallbackSrc;
                            if (!fallback || audio.src.indexOf(fallback) !== -1) return;
                            try {
                                audio.src = fallback;
                                audio.load();
                                audio.currentTime = 0;
                                var retry = audio.play();
                                if (retry && typeof retry.catch === 'function') {
                                    retry.catch(function() {});
                                }
                            } catch (e2) {}
                        });
                    }
                } catch (e) {}
            };

            function bindErrorModalSound() {
                document.querySelectorAll('.modal[data-error-modal="1"]').forEach(function(modalEl) {
                    if (modalEl.dataset.errorSoundBound === '1') return;
                    modalEl.dataset.errorSoundBound = '1';
                    modalEl.addEventListener('show.bs.modal', function() {
                        if (typeof window.playErrorModalSound === 'function') {
                            window.playErrorModalSound();
                        }
                    });
                });
            }

            bindErrorModalSound();
            document.addEventListener('DOMContentLoaded', bindErrorModalSound);
            document.addEventListener('turbo:load', bindErrorModalSound);
        })();
        </script>

        <audio id="successModalSound" preload="auto">
            <source src="{{ asset('sounds/successed-295058.mp3') }}" type="audio/mpeg">
        </audio>
        <script>
        (function() {
            window.playSuccessModalSound = function() {
                var audio = document.getElementById('successModalSound');
                if (!audio) return;
                try {
                    audio.currentTime = 0;
                    var playPromise = audio.play();
                    if (playPromise && typeof playPromise.catch === 'function') {
                        playPromise.catch(function() {});
                    }
                } catch (e) {}
            };
        })();
        </script>

        {# ── Global Success Modal ── #}
        {% set successMessages = app.flashes('success') %}
        {% if successMessages|length > 0 %}
        <div class="modal fade" id="globalSuccessModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
                <div class="modal-content border-0 shadow-lg" style="border-radius:1.25rem;overflow:hidden;">
                    <div class="modal-body text-center px-4 py-5 position-relative">
                        {# Confetti decoration #}
                        <div class="success-confetti">
                            <span class="confetti-piece" style="--x:-60px;--y:-40px;--r:45deg;--c:#3B82F6;--d:0.1s"></span>
                            <span class="confetti-piece" style="--x:70px;--y:-50px;--r:-30deg;--c:#10B981;--d:0.2s"></span>
                            <span class="confetti-piece" style="--x:-80px;--y:20px;--r:60deg;--c:#F59E0B;--d:0.15s"></span>
                            <span class="confetti-piece" style="--x:90px;--y:10px;--r:-45deg;--c:#8B5CF6;--d:0.25s"></span>
                            <span class="confetti-piece" style="--x:-40px;--y:-70px;--r:20deg;--c:#EC4899;--d:0.05s"></span>
                            <span class="confetti-piece" style="--x:50px;--y:-65px;--r:-60deg;--c:#06B6D4;--d:0.3s"></span>
                            <span class="confetti-piece" style="--x:-95px;--y:-15px;--r:75deg;--c:#F97316;--d:0.12s"></span>
                            <span class="confetti-piece" style="--x:85px;--y:-25px;--r:-15deg;--c:#14B8A6;--d:0.22s"></span>
                            <span class="confetti-piece confetti-rect" style="--x:60px;--y:40px;--r:30deg;--c:#6366F1;--d:0.18s"></span>
                            <span class="confetti-piece confetti-rect" style="--x:-70px;--y:50px;--r:-50deg;--c:#EF4444;--d:0.08s"></span>
                        </div>

                        {# Animated checkmark circle #}
                        <div class="success-check-wrap mb-3">
                            <svg class="success-check-svg" viewBox="0 0 100 100">
                                <circle class="success-circle" cx="50" cy="50" r="45" fill="none" stroke="#10B981" stroke-width="3"/>
                                <polyline class="success-tick" points="30,52 45,65 70,38" fill="none" stroke="#10B981" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>

                        <h4 class="fw-bold mb-2" style="color:#1E293B;">Success</h4>
                        {% for message in successMessages %}
                        <p class="text-muted mb-0" style="font-size:0.95rem;">{{ message }}</p>
                        {% endfor %}

                        <div class="mt-4">
                            <button type="button" class="btn btn-norsu px-4" data-bs-dismiss="modal">
                                <i class="me-1 bi bi-check"></i>OK
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script>
        (function() {
            var hasShownSuccessModal = false;

            function showSuccessModal() {
                if (hasShownSuccessModal) return;
                var m = document.getElementById('globalSuccessModal');
                if (!m) return;
                if (m.dataset.shown === '1') return;

                hasShownSuccessModal = true;
                m.dataset.shown = '1';

                var modal = bootstrap.Modal.getOrCreateInstance(m);
                if (typeof window.playSuccessModalSound === 'function') {
                    window.playSuccessModalSound();
                }
                m.addEventListener('hidden.bs.modal', function() {
                    // Full cleanup: remove backdrop, body class, and modal element
                    modal.dispose();
                    m.remove();
                    document.body.classList.remove('modal-open');
                    document.body.style.removeProperty('overflow');
                    document.body.style.removeProperty('padding-right');
                    document.querySelectorAll('.modal-backdrop').forEach(function(b) { b.remove(); });
                }, { once: true });
                modal.show();
            }
            document.addEventListener('DOMContentLoaded', showSuccessModal);
            document.addEventListener('turbo:load', showSuccessModal);
        })();
        </script>
        {% endif %}
    </body>
</html>

