{% extends 'base.html.twig' %}

{% block title %}My Profile | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
.pf-chip{display:inline-flex;align-items:center;gap:.25rem;padding:0;border-radius:0;background:transparent;font-weight:600;font-size:.9rem}
.pf-chip-admin{color:#DC2626}
.pf-chip-superior{color:#2563EB}
.pf-chip-faculty{color:#B45309}
.pf-chip-staff{color:#0891B2}
.pf-chip-student{color:#2563EB}
.pf-chip-active{color:#16A34A}
.pf-chip-inactive{color:#64748B}
.pf-chip-verified{color:#16A34A}
.pf-chip-unverified{color:#DC2626}

.sp-wrap { max-width: 980px; margin: 0 auto; }
.sp-head { margin-bottom: 1rem; }
.sp-title { margin: 0; font-size: 1.55rem; font-weight: 800; color: #1f2937; letter-spacing: -.01em; }
.sp-sub { margin: .15rem 0 0; color: #6b7280; font-size: .88rem; }
.sp-card {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
}
.sp-main {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 1rem;
    padding: 1rem;
    margin-bottom: 1rem;
}
.sp-person {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: .9rem;
    text-align: center;
    background: #f8fafc;
}
.sp-avatar {
    width: 86px;
    height: 86px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #ffffff;
    box-shadow: 0 0 0 1px #dbeafe;
    margin-bottom: .55rem;
}
.sp-name { margin: 0; font-weight: 700; color: #0f172a; font-size: .95rem; }
.sp-id { margin-top: .2rem; color: #64748b; font-size: .78rem; }
.sp-badge {
    display: inline-flex;
    margin-top: .45rem;
    padding: .2rem .55rem;
    border-radius: 999px;
    font-size: .72rem;
    font-weight: 700;
}
.sp-badge.is-verified { color: #166534; background: #dcfce7; }
.sp-badge.is-unverified { color: #b91c1c; background: #fee2e2; }
.sp-upload-form { margin-top: .65rem; }
.sp-upload-form .form-control { font-size: .74rem; }

.sp-general { border: 1px solid #e5e7eb; border-radius: 12px; padding: .9rem; }
.sp-section-title { margin: 0 0 .75rem; font-size: .9rem; font-weight: 700; color: #334155; }
.sp-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .7rem;
}
.sp-field-label { display: block; font-size: .7rem; color: #64748b; margin-bottom: .2rem; font-weight: 600; }
.sp-input {
    width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    background: #f8fafc;
    color: #0f172a;
    height: 38px;
    padding: .45rem .65rem;
    font-size: .82rem;
}
.sp-general-actions { margin-top: .75rem; }

.sp-details { padding: 1rem; margin-bottom: 1rem; }
.sp-detail-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: .7rem;
    margin-top: .45rem;
}

.sp-security { padding: 1rem; }
.sp-security-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .7rem;
    margin-top: .45rem;
}
.sp-sec-label { display: block; font-size: .7rem; color: #64748b; margin-bottom: .2rem; font-weight: 600; }
.sp-sec-value {
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    min-height: 38px;
    display: flex;
    align-items: center;
    padding: .35rem .65rem;
    font-size: .82rem;
    color: #1e293b;
    background: #f8fafc;
}
.sp-actions {
    margin-top: .8rem;
    display: flex;
    gap: .6rem;
    flex-wrap: wrap;
}

@media (max-width: 900px) {
    .sp-main { grid-template-columns: 1fr; }
    .sp-detail-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .sp-security-grid { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
    .sp-detail-grid { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block body %}
{% if user.isStudent %}
<div class="sp-wrap">
    <div class="sp-head">
        <h4 class="sp-title">User profile</h4>
        <p class="sp-sub">Manage your details, view your tier status and change your password.</p>
    </div>

    <div class="sp-card sp-main">
        <div class="sp-person">
            <img src="{{ asset('images/' ~ user.profilePictureOrDefault) }}" alt="{{ user.fullName }}" class="sp-avatar">
            <p class="sp-name">{{ user.fullName }}</p>
            <p class="sp-id">{{ user.schoolId ?? 'No student ID yet' }}</p>
            {% if isStudentVerified|default(false) %}
                <span class="sp-badge is-verified">Verified</span>
            {% else %}
                <span class="sp-badge is-unverified">Unverified</span>
            {% endif %}

            <form method="post" action="{{ path('app_profile_upload_picture') }}" enctype="multipart/form-data" class="sp-upload-form">
                <input type="file" name="profilePicture" accept="image/*" class="form-control form-control-sm mb-2">
                <button type="submit" class="btn btn-outline-norsu btn-sm w-100">
                    <i class="bi bi-camera me-1"></i>Update photo
                </button>
            </form>
        </div>

        <div class="sp-general">
            <h6 class="sp-section-title">General information</h6>
            <div class="sp-grid">
                <label>
                    <span class="sp-field-label">First name</span>
                    <input class="sp-input" value="{{ user.firstName }}" readonly>
                </label>
                <label>
                    <span class="sp-field-label">Last name</span>
                    <input class="sp-input" value="{{ user.lastName }}" readonly>
                </label>
                <label>
                    <span class="sp-field-label">Campus</span>
                    <input class="sp-input" value="{{ user.campus ?? '—' }}" readonly>
                </label>
                <label>
                    <span class="sp-field-label">Year level</span>
                    <input class="sp-input" value="{{ user.yearLevel ?? '—' }}" readonly>
                </label>
            </div>
            <div class="sp-general-actions">
                <a href="{{ path('app_profile_edit') }}" class="btn btn-norsu btn-sm">Update</a>
            </div>
        </div>
    </div>

    <div class="sp-card sp-details">
        <h6 class="sp-section-title mb-1">Student details</h6>
        <div class="sp-detail-grid">
            <div>
                <span class="sp-sec-label">Verification</span>
                <div class="sp-sec-value">{{ isStudentVerified|default(false) ? 'Verified' : 'Unverified' }}</div>
            </div>
            <div>
                <span class="sp-sec-label">Student ID</span>
                <div class="sp-sec-value">{{ user.schoolId ?? '—' }}</div>
            </div>
            <div>
                <span class="sp-sec-label">Year level</span>
                <div class="sp-sec-value">{{ user.yearLevel ?? '—' }}</div>
            </div>
            <div>
                <span class="sp-sec-label">Campus</span>
                <div class="sp-sec-value">{{ user.campus ?? '—' }}</div>
            </div>
            <div>
                <span class="sp-sec-label">College</span>
                <div class="sp-sec-value">{{ user.department and user.department.collegeName ? user.department.collegeName : '—' }}</div>
            </div>
            <div>
                <span class="sp-sec-label">Department</span>
                <div class="sp-sec-value">{{ user.department ? user.department.departmentName : '—' }}</div>
            </div>
            <div>
                <span class="sp-sec-label">Account status</span>
                <div class="sp-sec-value">{{ user.accountStatus == 'active' ? 'Active' : 'Inactive' }}</div>
            </div>
            <div>
                <span class="sp-sec-label">Registered</span>
                <div class="sp-sec-value">{{ user.createdAt|date('M d, Y') }}</div>
            </div>
        </div>
    </div>

    <div class="sp-card sp-security">
        <h6 class="sp-section-title mb-1">Security</h6>
        <div class="sp-security-grid">
            <div>
                <span class="sp-sec-label">Email</span>
                <div class="sp-sec-value">{{ user.email ?? '—' }}</div>
            </div>
            <div>
                <span class="sp-sec-label">Password</span>
                <div class="sp-sec-value">••••••••</div>
            </div>
            <div>
                <span class="sp-sec-label">Role</span>
                <div class="sp-sec-value">Student</div>
            </div>
        </div>
        <div class="sp-actions">
            <a href="{{ path('app_profile_change_password') }}" class="btn btn-outline-norsu btn-sm">
                <i class="bi bi-key me-1"></i>Change password
            </a>
            <a href="{{ path('app_profile_edit') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-pencil-square me-1"></i>Edit profile
            </a>
        </div>
    </div>
</div>
{% endif %}

{% if not user.isStudent %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i  class="bi bi-person-circle me-2"></i>My Profile</h4>
    <div class="page-header-actions">
        <a href="{{ path('app_profile_edit') }}" class="btn btn-norsu btn-sm">
            <i  class="bi bi-pencil-square"></i> Edit Profile
        </a>
    </div>
</div>

<div class="row g-4">
    {# ── Profile Card ── #}
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-5">
                <img src="{{ asset('images/' ~ user.profilePictureOrDefault) }}"
                     alt="{{ user.fullName }}" class="rounded-circle mb-3"
                     style="width:90px;height:90px;object-fit:cover">
                <h5 class="fw-bold mb-1">{{ user.fullName }}</h5>
                <p class="text-muted mb-2">{{ user.email }}</p>
                {% if 'ROLE_ADMIN' in user.roles %}
                    <span class="pf-chip pf-chip-admin"><i  class="bi bi-shield-check me-1"></i>Administrator</span>
                {% elseif user.hasAssignedRole('ROLE_SUPERIOR') %}
                    <span class="pf-chip pf-chip-superior"><i  class="bi bi-star-fill me-1"></i>Superior</span>
                {% elseif 'ROLE_FACULTY' in user.roles %}
                    <span class="pf-chip pf-chip-faculty"><i  class="bi bi-mortarboard me-1"></i>Faculty</span>
                {% elseif 'ROLE_STAFF' in user.roles %}
                    <span class="pf-chip pf-chip-staff"><i  class="bi bi-card-checklist me-1"></i>Staff</span>
                {% else %}
                    <span class="pf-chip pf-chip-student"><i  class="bi bi-person me-1"></i>Student</span>
                {% endif %}

                {# Upload Picture #}
                <form method="post" action="{{ path('app_profile_upload_picture') }}" enctype="multipart/form-data" class="mt-3">
                    <input type="file" name="profilePicture" accept="image/*" class="form-control form-control-sm mb-2">
                    <button type="submit" class="btn btn-outline-norsu btn-sm w-100">
                        <i  class="bi bi-camera me-1"></i>Update Photo
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# ── Account Details ── #}
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold"><i  class="bi bi-info-circle me-1"></i> Account Information</div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tbody>
                        {% set _is_assigned_superior = user.hasAssignedRole('ROLE_SUPERIOR') %}
                        <tr>
                            <td class="text-muted" style="width:200px"><i  class="bi bi-person me-2"></i>First Name</td>
                            <td class="fw-semibold">{{ user.firstName }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="bi bi-person me-2"></i>Last Name</td>
                            <td class="fw-semibold">{{ user.lastName }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="bi bi-envelope me-2"></i>Email Address</td>
                            <td class="fw-semibold">{{ user.email }}</td>
                        </tr>
                        {% if 'ROLE_STAFF' not in user.roles and not _is_assigned_superior %}
                        <tr>
                            <td class="text-muted"><i  class="bi bi-buildings me-2"></i>Department</td>
                            <td class="fw-semibold">{{ user.department ? user.department.departmentName : '—' }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="bi bi-bank me-2"></i>College</td>
                            <td class="fw-semibold">{{ user.department and user.department.collegeName ? user.department.collegeName : '—' }}</td>
                        </tr>
                        {% endif %}
                        {% if 'ROLE_STAFF' not in user.roles %}
                        <tr>
                            <td class="text-muted"><i  class="bi bi-geo-alt me-2"></i>Campus</td>
                            <td class="fw-semibold">{{ user.campus ?? '—' }}</td>
                        </tr>
                        {% endif %}
                        {% if _is_assigned_superior %}
                        <tr>
                            <td class="text-muted"><i  class="bi bi-briefcase me-2"></i>Position / Designation</td>
                            <td class="fw-semibold">{{ user.position ?? '—' }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="bi bi-award me-2"></i>Academic Rank</td>
                            <td class="fw-semibold">{{ user.academicRank ?? '—' }}</td>
                        </tr>
                        {% endif %}
                        {% if user.isStudent %}
                        <tr>
                            <td class="text-muted"><i  class="bi bi-person-vcard me-2"></i>Student ID</td>
                            <td class="fw-semibold">{{ user.schoolId ?? '—' }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="bi bi-patch-check me-2"></i>Verification</td>
                            <td>
                                {% if isStudentVerified|default(false) %}
                                    <span class="pf-chip pf-chip-verified">Verified</span>
                                {% else %}
                                    <span class="pf-chip pf-chip-unverified">Unverified</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="bi bi-mortarboard me-2"></i>Year Level</td>
                            <td class="fw-semibold">{{ user.yearLevel ?? '—' }}</td>
                        </tr>
                        {% endif %}
                        <tr>
                            <td class="text-muted"><i  class="bi bi-shield me-2"></i>Role</td>
                            <td>
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <span class="pf-chip pf-chip-admin me-1">Admin</span>
                                {% endif %}
                                {% if user.hasAssignedRole('ROLE_SUPERIOR') %}
                                    <span class="pf-chip pf-chip-superior me-1">Superior</span>
                                {% endif %}
                                {% if 'ROLE_FACULTY' in user.roles %}
                                    <span class="pf-chip pf-chip-faculty me-1">Faculty</span>
                                {% endif %}
                                {% if 'ROLE_STAFF' in user.roles %}
                                    <span class="pf-chip pf-chip-staff me-1">Staff</span>
                                {% endif %}
                                {% if not ('ROLE_ADMIN' in user.roles or 'ROLE_FACULTY' in user.roles or 'ROLE_STAFF' in user.roles) %}
                                    <span class="pf-chip pf-chip-student me-1">Student</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="bi bi-check-circle-fill me-2"></i>Account Status</td>
                            <td>
                                {% if user.accountStatus == 'active' %}
                                    <span class="pf-chip pf-chip-active">Active</span>
                                {% else %}
                                    <span class="pf-chip pf-chip-inactive">Inactive</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="bi bi-calendar3 me-2"></i>Registered</td>
                            <td class="fw-semibold">{{ user.createdAt|date('F d, Y \\a\\t h:i A') }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        {# ── Security Section ── #}
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-white fw-semibold"><i  class="bi bi-lock me-1"></i> Security</div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 fw-semibold">Password</p>
                        <p class="text-muted mb-0 small">Update your password regularly for security.</p>
                    </div>
                    <a href="{{ path('app_profile_change_password') }}" class="btn btn-outline-norsu btn-sm">
                        <i  class="bi bi-key me-1"></i>Change Password
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
