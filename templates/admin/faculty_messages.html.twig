{% extends 'base.html.twig' %}

{% block title %}Faculty Messages | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ═══════════════════════════════════════
   PAGE HEADER
   ═══════════════════════════════════════ */
.fm-page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem;}
.fm-header-left{display:flex;align-items:center;gap:14px;}
.fm-header-icon{width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,#1E3A8A,#3B82F6);color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.4rem;box-shadow:0 4px 14px rgba(30,58,138,.25);}
.fm-header-title{font-size:1.35rem;font-weight:800;color:#0F172A;margin:0;letter-spacing:-.3px;}
.fm-header-subtitle{font-size:.82rem;color:#64748B;margin:2px 0 0;line-height:1;}
.fm-header-right{display:flex;align-items:center;gap:8px;}
.fm-pending-chip{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:10px;font-size:.78rem;font-weight:700;background:linear-gradient(135deg,#FEF2F2,#FEE2E2);color:#DC2626;border:1px solid #FECACA;animation:fmPulse 2s ease-in-out infinite;}
.fm-pending-dot{width:8px;height:8px;border-radius:50%;background:#DC2626;animation:fmBlink 1.4s ease-in-out infinite;}
.fm-total-chip{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:10px;font-size:.78rem;font-weight:600;background:#F8FAFC;color:#475569;border:1px solid #E2E8F0;}

@keyframes fmPulse{0%,100%{box-shadow:0 0 0 0 rgba(220,38,38,.15)}50%{box-shadow:0 0 0 6px rgba(220,38,38,0)}}
@keyframes fmBlink{0%,100%{opacity:1}50%{opacity:.3}}

/* ═══════════════════════════════════════
   STATS ROW
   ═══════════════════════════════════════ */
.fm-stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:1.25rem;}
.fm-stat-card{display:flex;align-items:center;gap:12px;padding:16px 18px;border-radius:14px;background:#fff;border:1px solid #E2E8F0;cursor:pointer;transition:all .2s ease;box-shadow:0 1px 3px rgba(0,0,0,.04);}
.fm-stat-card:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.08);}
.fm-stat-icon{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;}
.fm-stat-all .fm-stat-icon{background:linear-gradient(135deg,#EFF6FF,#DBEAFE);color:#2563EB;}
.fm-stat-pending .fm-stat-icon{background:linear-gradient(135deg,#FFF7ED,#FFEDD5);color:#EA580C;}
.fm-stat-reviewed .fm-stat-icon{background:linear-gradient(135deg,#EFF6FF,#DBEAFE);color:#2563EB;}
.fm-stat-resolved .fm-stat-icon{background:linear-gradient(135deg,#F0FDF4,#DCFCE7);color:#16A34A;}
.fm-stat-info{display:flex;flex-direction:column;}
.fm-stat-number{font-size:1.35rem;font-weight:800;color:#0F172A;line-height:1;}
.fm-stat-label{font-size:.72rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:.5px;margin-top:2px;}

/* ═══════════════════════════════════════
   TOOLBAR
   ═══════════════════════════════════════ */
.fm-toolbar{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1rem;flex-wrap:wrap;}
.fm-tabs{display:flex;gap:4px;background:#F1F5F9;padding:4px;border-radius:12px;}
.fm-tab{display:inline-flex;align-items:center;gap:5px;padding:8px 16px;border:none;background:transparent;border-radius:9px;font-size:.78rem;font-weight:600;color:#64748B;cursor:pointer;transition:all .2s ease;white-space:nowrap;}
.fm-tab:hover{color:#1E3A8A;background:rgba(255,255,255,.6);}
.fm-tab.active{background:#fff;color:#1E3A8A;box-shadow:0 1px 4px rgba(0,0,0,.08);}
.fm-tab-badge{font-size:.65rem;padding:2px 7px;border-radius:10px;background:rgba(0,0,0,.06);font-weight:700;min-width:20px;text-align:center;line-height:1.4;}
.fm-tab.active .fm-tab-badge{background:#EFF6FF;color:#2563EB;}
.fm-badge-warn{background:#FEF2F2!important;color:#DC2626!important;}
.fm-search-box{position:relative;width:280px;flex-shrink:0;}
.fm-search-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#94A3B8;font-size:.82rem;pointer-events:none;}
.fm-search-input{width:100%;padding:9px 14px 9px 36px;border:1.5px solid #E2E8F0;border-radius:12px;font-size:.82rem;color:#1E293B;background:#fff;outline:none;transition:all .2s;}
.fm-search-input:focus{border-color:#3B82F6;box-shadow:0 0 0 3px rgba(59,130,246,.12);}
.fm-search-input::placeholder{color:#CBD5E1;}

/* ═══════════════════════════════════════
   MESSAGE CARD
   ═══════════════════════════════════════ */
.fm-message-list{display:flex;flex-direction:column;gap:10px;margin-bottom:2rem;}
.fm-message-card{background:#fff;border:1.5px solid #E8ECF1;border-radius:14px;overflow:hidden;transition:all .2s ease;box-shadow:0 1px 3px rgba(0,0,0,.03);}
.fm-message-card:hover{border-color:#CBD5E1;box-shadow:0 4px 16px rgba(0,0,0,.06);}
.fm-card-pending{border-left:4px solid #F97316;}
.fm-card-header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;gap:16px;transition:background .15s;}
.fm-card-header:hover{background:#FAFBFC;}
.fm-card-left{display:flex;align-items:flex-start;gap:14px;flex:1;min-width:0;}
.fm-card-right{display:flex;align-items:center;gap:12px;flex-shrink:0;}

/* ── Avatar ── */
.fm-avatar{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;flex-shrink:0;overflow:hidden;color:#fff;letter-spacing:.5px;}
.fm-avatar img{width:100%;height:100%;object-fit:cover;}
.fm-avatar-pending{background:linear-gradient(135deg,#F97316,#FB923C);}
.fm-avatar-reviewed{background:linear-gradient(135deg,#2563EB,#60A5FA);}
.fm-avatar-resolved{background:linear-gradient(135deg,#16A34A,#4ADE80);}

/* ── Card Info ── */
.fm-card-info{flex:1;min-width:0;}
.fm-card-top-line{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:4px;}
.fm-sender-name{font-size:.88rem;font-weight:700;color:#0F172A;}
.fm-badge{display:inline-flex;align-items:center;gap:4px;padding:2px 9px;border-radius:6px;font-size:.65rem;font-weight:700;white-space:nowrap;letter-spacing:.3px;}
.fm-badge-pending{background:#FFF7ED;color:#EA580C;border:1px solid #FED7AA;}
.fm-badge-reviewed{background:#EFF6FF;color:#2563EB;border:1px solid #BFDBFE;}
.fm-badge-resolved{background:#F0FDF4;color:#16A34A;border:1px solid #BBF7D0;}
.fm-card-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:3px;}
.fm-meta-tag{display:inline-flex;align-items:center;gap:4px;font-size:.7rem;color:#64748B;font-weight:500;}
.fm-meta-tag i{font-size:.68rem;}
.fm-meta-eval{color:#7C3AED;font-weight:600;}
.fm-card-subject{font-size:.78rem;color:#475569;font-weight:500;display:flex;align-items:center;gap:5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.fm-card-subject i{color:#94A3B8;font-size:.68rem;}

/* ── Date & Expand ── */
.fm-card-date{text-align:right;}
.fm-date-main{display:block;font-size:.75rem;font-weight:600;color:#475569;}
.fm-date-time{display:block;font-size:.65rem;color:#94A3B8;margin-top:1px;}
.fm-expand-btn{width:32px;height:32px;border-radius:8px;border:1.5px solid #E2E8F0;background:#FAFBFC;color:#64748B;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;font-size:.8rem;}
.fm-expand-btn:hover{background:#EFF6FF;border-color:#BFDBFE;color:#2563EB;}
.fm-expand-btn.open{background:#2563EB;border-color:#2563EB;color:#fff;transform:rotate(180deg);}

/* ── Delete Button ── */
.fm-delete-btn{width:32px;height:32px;border-radius:8px;border:1.5px solid #FECACA;background:#FEF2F2;color:#DC2626;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;font-size:.8rem;}
.fm-delete-btn:hover{background:#FEE2E2;border-color:#F87171;transform:translateY(-1px);box-shadow:0 2px 8px rgba(220,38,38,.15);}

/* ── Delete Modal ── */
.fm-modal-header-danger{background:linear-gradient(135deg,#991B1B,#DC2626 50%,#F87171);padding:1rem 1.25rem;display:flex;align-items:center;justify-content:space-between;}
.fm-modal-icon{width:36px;height:36px;background:rgba(255,255,255,.15);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1rem;backdrop-filter:blur(4px);}
.fm-delete-preview{background:#F8FAFC;border:1px solid #E2E8F0;border-radius:8px;padding:10px 14px;}
.fm-delete-preview-sender{font-size:.82rem;font-weight:600;color:#1E293B;margin-bottom:2px;}
.fm-delete-preview-subject{font-size:.78rem;color:#475569;margin-bottom:2px;}
.fm-delete-preview-date{font-size:.72rem;color:#94A3B8;}

/* ═══════════════════════════════════════
   CARD BODY (EXPANDED)
   ═══════════════════════════════════════ */
.fm-card-body{padding:0 20px 20px;border-top:1px solid #F1F5F9;margin-top:0;animation:fmSlideDown .2s ease;}
@keyframes fmSlideDown{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}

/* ── Chat Bubbles ── */
.fm-bubble{padding:14px 16px;border-radius:12px;margin:16px 0 8px;position:relative;}
.fm-bubble-incoming{background:#F8FAFC;border:1px solid #E2E8F0;border-left:3px solid #3B82F6;margin-right:40px;}
.fm-bubble-outgoing{background:linear-gradient(135deg,#F0FDF4,#ECFDF5);border:1px solid #BBF7D0;border-left:3px solid #16A34A;margin-left:40px;}
.fm-bubble-header{display:flex;align-items:center;gap:6px;font-size:.72rem;color:#64748B;margin-bottom:6px;flex-wrap:wrap;}
.fm-bubble-header strong{color:#1E293B;}
.fm-bubble-header i{color:#3B82F6;font-size:.75rem;}
.fm-bubble-outgoing .fm-bubble-header i{color:#16A34A;}
.fm-bubble-time{font-size:.65rem;color:#94A3B8;margin-left:auto;}
.fm-bubble-by{font-size:.65rem;color:#64748B;font-weight:500;}
.fm-bubble-text{font-size:.82rem;color:#1E293B;line-height:1.65;white-space:pre-wrap;}

/* ── Attachment ── */
.fm-attachment-display{margin:8px 0 12px;}
.fm-attachment-link{display:inline-flex;align-items:center;gap:8px;padding:8px 14px;border-radius:10px;background:linear-gradient(135deg,#FEF2F2,#FFF1F2);border:1px solid #FECDD3;color:#BE123C;font-size:.78rem;font-weight:600;text-decoration:none;transition:all .15s;}
.fm-attachment-link:hover{background:#FEE2E2;color:#9F1239;transform:translateY(-1px);box-shadow:0 2px 8px rgba(190,18,60,.12);}
.fm-attachment-link i:first-child{font-size:1.1rem;}
.fm-attach-arrow{font-size:.65rem;opacity:.5;}

/* ── Reply Form ── */
.fm-reply-form{margin-top:12px;background:#FAFBFC;border-radius:12px;border:1.5px solid #E8ECF1;overflow:hidden;}
.fm-reply-header{padding:10px 16px;font-size:.75rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.5px;display:flex;align-items:center;gap:6px;border-bottom:1px solid #E8ECF1;background:#F8FAFC;}
.fm-reply-header i{color:#3B82F6;}
.fm-reply-editor{padding:12px 16px 0;}
.fm-textarea{width:100%;padding:10px 14px;border:1.5px solid #E2E8F0;border-radius:10px;font-size:.82rem;color:#1E293B;outline:none;resize:vertical;min-height:80px;background:#fff;transition:all .2s;font-family:inherit;}
.fm-textarea:focus{border-color:#3B82F6;box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.fm-textarea::placeholder{color:#CBD5E1;}
.fm-reply-footer{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;gap:12px;flex-wrap:wrap;}
.fm-reply-actions-left{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.fm-file-btn{display:inline-flex;align-items:center;gap:6px;padding:7px 12px;border:1.5px dashed #CBD5E1;border-radius:8px;font-size:.75rem;font-weight:500;color:#64748B;cursor:pointer;transition:all .15s;white-space:nowrap;}
.fm-file-btn:hover{border-color:#3B82F6;color:#2563EB;background:#EFF6FF;}
.fm-file-btn i{font-size:.85rem;}
.fm-file-name{max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.fm-status-select{padding:7px 10px;border:1.5px solid #E2E8F0;border-radius:8px;font-size:.75rem;color:#475569;outline:none;background:#fff;cursor:pointer;font-weight:500;transition:border-color .2s;}
.fm-status-select:focus{border-color:#3B82F6;}
.fm-send-btn{display:inline-flex;align-items:center;gap:7px;padding:9px 22px;border-radius:10px;font-size:.8rem;font-weight:700;border:none;background:linear-gradient(135deg,#1E3A8A,#2563EB);color:#fff;cursor:pointer;transition:all .2s;box-shadow:0 2px 8px rgba(37,99,235,.2);}
.fm-send-btn:hover{background:linear-gradient(135deg,#1E3A8A,#1D4ED8);box-shadow:0 4px 16px rgba(37,99,235,.3);transform:translateY(-1px);}

/* ═══════════════════════════════════════
   EMPTY STATE
   ═══════════════════════════════════════ */
.fm-empty-state{text-align:center;padding:60px 20px;background:#fff;border:1.5px solid #E8ECF1;border-radius:16px;box-shadow:0 1px 3px rgba(0,0,0,.03);}
.fm-empty-icon{width:80px;height:80px;border-radius:20px;background:linear-gradient(135deg,#F1F5F9,#E2E8F0);display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;font-size:2rem;color:#94A3B8;}
.fm-empty-title{font-size:1.1rem;font-weight:700;color:#475569;margin-bottom:4px;}
.fm-empty-text{font-size:.84rem;color:#94A3B8;margin:0;}

/* ═══════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════ */
@media(max-width:992px){
    .fm-stats-row{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:768px){
    .fm-page-header{flex-direction:column;align-items:flex-start;}
    .fm-toolbar{flex-direction:column;align-items:stretch;}
    .fm-tabs{overflow-x:auto;-webkit-overflow-scrolling:touch;}
    .fm-search-box{width:100%;}
    .fm-stats-row{grid-template-columns:1fr 1fr;}
    .fm-card-header{flex-direction:column;align-items:flex-start;gap:10px;}
    .fm-card-right{align-self:flex-end;}
    .fm-bubble-incoming{margin-right:0;}
    .fm-bubble-outgoing{margin-left:0;}
    .fm-reply-footer{flex-direction:column;align-items:stretch;}
    .fm-reply-actions-left{flex-direction:column;}
    .fm-send-btn{justify-content:center;}
}
@media(max-width:480px){
    .fm-stats-row{grid-template-columns:1fr;}
    .fm-stat-card{padding:12px 14px;}
}

/* ── Animation ── */
.fm-message-card{animation:fmCardIn .3s ease both;}
@keyframes fmCardIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.fm-message-list .fm-message-card:nth-child(1){animation-delay:.02s}
.fm-message-list .fm-message-card:nth-child(2){animation-delay:.06s}
.fm-message-list .fm-message-card:nth-child(3){animation-delay:.10s}
.fm-message-list .fm-message-card:nth-child(4){animation-delay:.14s}
.fm-message-list .fm-message-card:nth-child(5){animation-delay:.18s}
</style>
{% endblock %}

{% block body %}
{# ── Page Header ── #}
<div class="fm-page-header">
    <div class="fm-header-left">
        <div class="fm-header-icon">
            <i class="bi bi-envelope-open-fill"></i>
        </div>
        <div>
            <h4 class="fm-header-title">Faculty Messages</h4>
            <p class="fm-header-subtitle">Review and respond to faculty evaluation requests</p>
        </div>
    </div>
    <div class="fm-header-right">
        {% if pendingCount > 0 %}
        <div class="fm-pending-chip">
            <span class="fm-pending-dot"></span>
            {{ pendingCount }} pending
        </div>
        {% endif %}
        <div class="fm-total-chip">
            <i class="bi bi-chat-square-text"></i>
            {{ messages|length }} total
        </div>
    </div>
</div>

{# ── Stats Row ── #}
{% set pendingMessages = messages|filter(m => m.status == 'pending') %}
{% set reviewedMessages = messages|filter(m => m.status == 'reviewed') %}
{% set resolvedMessages = messages|filter(m => m.status == 'resolved') %}
<div class="fm-stats-row">
    <div class="fm-stat-card fm-stat-all" onclick="fmFilter('all')">
        <div class="fm-stat-icon"><i class="bi bi-inbox-fill"></i></div>
        <div class="fm-stat-info">
            <span class="fm-stat-number">{{ messages|length }}</span>
            <span class="fm-stat-label">All Messages</span>
        </div>
    </div>
    <div class="fm-stat-card fm-stat-pending" onclick="fmFilter('pending')">
        <div class="fm-stat-icon"><i class="bi bi-hourglass-split"></i></div>
        <div class="fm-stat-info">
            <span class="fm-stat-number">{{ pendingMessages|length }}</span>
            <span class="fm-stat-label">Pending</span>
        </div>
    </div>
    <div class="fm-stat-card fm-stat-reviewed" onclick="fmFilter('reviewed')">
        <div class="fm-stat-icon"><i class="bi bi-eye-fill"></i></div>
        <div class="fm-stat-info">
            <span class="fm-stat-number">{{ reviewedMessages|length }}</span>
            <span class="fm-stat-label">Reviewed</span>
        </div>
    </div>
    <div class="fm-stat-card fm-stat-resolved" onclick="fmFilter('resolved')">
        <div class="fm-stat-icon"><i class="bi bi-check-circle-fill"></i></div>
        <div class="fm-stat-info">
            <span class="fm-stat-number">{{ resolvedMessages|length }}</span>
            <span class="fm-stat-label">Resolved</span>
        </div>
    </div>
</div>

{# ── Toolbar ── #}
<div class="fm-toolbar">
    <div class="fm-tabs">
        <button class="fm-tab active" data-filter="all" onclick="fmFilter('all')">
            <i class="bi bi-grid-3x3-gap-fill"></i> All
            <span class="fm-tab-badge">{{ messages|length }}</span>
        </button>
        <button class="fm-tab" data-filter="pending" onclick="fmFilter('pending')">
            <i class="bi bi-hourglass-split"></i> Pending
            <span class="fm-tab-badge{% if pendingMessages|length > 0 %} fm-badge-warn{% endif %}">{{ pendingMessages|length }}</span>
        </button>
        <button class="fm-tab" data-filter="reviewed" onclick="fmFilter('reviewed')">
            <i class="bi bi-eye"></i> Reviewed
            <span class="fm-tab-badge">{{ reviewedMessages|length }}</span>
        </button>
        <button class="fm-tab" data-filter="resolved" onclick="fmFilter('resolved')">
            <i class="bi bi-check2-all"></i> Resolved
            <span class="fm-tab-badge">{{ resolvedMessages|length }}</span>
        </button>
    </div>
    <div class="fm-search-box">
        <i class="bi bi-search fm-search-icon"></i>
        <input type="text" id="fmSearch" class="fm-search-input" placeholder="Search by name, department, subject..." oninput="fmSearchMessages()">
    </div>
</div>

{# ── Flash Messages ── #}
{% for label, msgs in app.flashes %}
<div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" style="font-size:.82rem;border-radius:10px;">
    {% for m in msgs %}{{ m }}{% endfor %}
    <button type="button" class="btn-close" data-bs-dismiss="alert" style="font-size:.65rem;"></button>
</div>
{% endfor %}

{# ── Messages List ── #}
{% if messages|length > 0 %}
<div class="fm-message-list" id="fmMessageList">
    {% for msg in messages %}
    <div class="fm-message-card{% if msg.status == 'pending' %} fm-card-pending{% endif %}"
         data-status="{{ msg.status }}"
         data-search="{{ msg.sender.fullName|lower }} {{ msg.sender.department ? msg.sender.department.departmentName|lower : '' }} {{ msg.subject|lower }}">

        {# ── Card Header ── #}
        <div class="fm-card-header" onclick="fmToggleDetail(this)">
            <div class="fm-card-left">
                <div class="fm-avatar{% if msg.status == 'pending' %} fm-avatar-pending{% elseif msg.status == 'reviewed' %} fm-avatar-reviewed{% else %} fm-avatar-resolved{% endif %}">
                    {% if msg.sender.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ msg.sender.profilePicture) }}" alt="">
                    {% else %}
                        {{ msg.sender.firstName|first }}{{ msg.sender.lastName|first }}
                    {% endif %}
                </div>
                <div class="fm-card-info">
                    <div class="fm-card-top-line">
                        <span class="fm-sender-name">{{ msg.sender.fullName }}</span>
                        {% if msg.status == 'pending' %}
                            <span class="fm-badge fm-badge-pending"><i class="bi bi-clock-fill"></i> Pending</span>
                        {% elseif msg.status == 'reviewed' %}
                            <span class="fm-badge fm-badge-reviewed"><i class="bi bi-eye-fill"></i> Reviewed</span>
                        {% else %}
                            <span class="fm-badge fm-badge-resolved"><i class="bi bi-check-circle-fill"></i> Resolved</span>
                        {% endif %}
                    </div>
                    <div class="fm-card-meta">
                        {% if msg.sender.department %}
                            <span class="fm-meta-tag"><i class="bi bi-building"></i> {{ msg.sender.department.departmentName }}</span>
                        {% endif %}
                        {% if msg.evaluationPeriod %}
                            <span class="fm-meta-tag fm-meta-eval"><i class="bi bi-clipboard2-check"></i> {{ msg.evaluationPeriod.evaluationType }} — {{ msg.evaluationPeriod.semester ?? '' }} {{ msg.evaluationPeriod.schoolYear ?? '' }}</span>
                        {% endif %}
                    </div>
                    <div class="fm-card-subject">
                        <i class="bi bi-tag-fill"></i> {{ msg.subject }}
                    </div>
                </div>
            </div>
            <div class="fm-card-right">
                <div class="fm-card-date">
                    <span class="fm-date-main">{{ msg.createdAt|date('M d, Y') }}</span>
                    <span class="fm-date-time">{{ msg.createdAt|date('h:i A') }}</span>
                </div>
                <button type="button" class="fm-delete-btn" title="Delete message"
                        onclick="event.stopPropagation()" data-bs-toggle="modal" data-bs-target="#fmDeleteMsg{{ msg.id }}">
                    <i class="bi bi-trash3"></i>
                </button>
                <button class="fm-expand-btn" type="button" title="Expand">
                    <i class="bi bi-chevron-down"></i>
                </button>
            </div>
        </div>

        {# ── Card Body (collapsible) ── #}
        <div class="fm-card-body" style="display:none">
            {# Faculty message bubble #}
            <div class="fm-bubble fm-bubble-incoming">
                <div class="fm-bubble-header">
                    <i class="bi bi-person-fill"></i>
                    <strong>{{ msg.sender.firstName }}</strong>
                    <span class="fm-bubble-time">{{ msg.createdAt|date('M d, Y — h:i A') }}</span>
                </div>
                <div class="fm-bubble-text">{{ msg.message|nl2br }}</div>
            </div>

            {# Existing reply bubble #}
            {% if msg.adminReply %}
            <div class="fm-bubble fm-bubble-outgoing">
                <div class="fm-bubble-header">
                    <i class="bi bi-shield-fill-check"></i>
                    <strong>Admin Reply</strong>
                    {% if msg.repliedBy %}<span class="fm-bubble-by">{{ msg.repliedBy.fullName }}</span>{% endif %}
                    {% if msg.repliedAt %}<span class="fm-bubble-time">{{ msg.repliedAt|date('M d, Y — h:i A') }}</span>{% endif %}
                </div>
                <div class="fm-bubble-text">{{ msg.adminReply|nl2br }}</div>
            </div>
            {% endif %}

            {# Attachment display #}
            {% if msg.attachment %}
            <div class="fm-attachment-display">
                <a href="{{ asset('uploads/attachments/' ~ msg.attachment) }}" target="_blank" class="fm-attachment-link">
                    <i class="bi bi-file-earmark-pdf-fill"></i>
                    <span>{{ msg.attachmentOriginalName }}</span>
                    <i class="bi bi-box-arrow-up-right fm-attach-arrow"></i>
                </a>
            </div>
            {% endif %}

            {# Reply form #}
            <form method="post" action="{{ path(replyRoute|default('admin_faculty_message_reply'), {id: msg.id}) }}" enctype="multipart/form-data" class="fm-reply-form">
                <div class="fm-reply-header">
                    <i class="bi bi-reply-fill"></i>
                    {{ msg.adminReply ? 'Update Reply' : 'Write Reply' }}
                </div>
                <div class="fm-reply-editor">
                    <textarea name="reply" class="fm-textarea" rows="3" placeholder="Type your response...">{{ msg.adminReply }}</textarea>
                </div>

                <div class="fm-reply-footer">
                    <div class="fm-reply-actions-left">
                        <label class="fm-file-btn" title="Attach PDF">
                            <i class="bi bi-paperclip"></i>
                            <span class="fm-file-name">{{ msg.attachment ? msg.attachmentOriginalName : 'Attach PDF' }}</span>
                            <input type="file" name="attachment" accept=".pdf" class="d-none" onchange="this.closest('.fm-file-btn').querySelector('.fm-file-name').textContent=this.files[0]?this.files[0].name:'Attach PDF'">
                        </label>
                        <select name="status" class="fm-status-select">
                            <option value="reviewed" {% if msg.status == 'reviewed' %}selected{% endif %}>Mark as Reviewed</option>
                            <option value="resolved" {% if msg.status == 'resolved' %}selected{% endif %}>Mark as Resolved</option>
                        </select>
                    </div>
                    <button type="submit" class="fm-send-btn">
                        <i class="bi bi-send-fill"></i> Send Reply
                    </button>
                </div>
            </form>
        </div>
    </div>
    {% endfor %}
</div>

{# ── Delete Confirmation Modals ── #}
{% for msg in messages %}
<div class="modal fade" id="fmDeleteMsg{{ msg.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">
            <form method="post" action="{{ path(deleteRoute|default('admin_faculty_message_delete'), {id: msg.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_msg' ~ msg.id) }}">
                <div class="fm-modal-header-danger">
                    <div class="d-flex align-items-center gap-2">
                        <div class="fm-modal-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                        <h6 class="modal-title text-white fw-bold mb-0">Delete Message</h6>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="small text-muted mb-2">Are you sure you want to delete this message?</p>
                    <div class="fm-delete-preview">
                        <div class="fm-delete-preview-sender"><i class="bi bi-person me-1"></i>{{ msg.sender.fullName }}</div>
                        <div class="fm-delete-preview-subject"><i class="bi bi-tag me-1"></i>{{ msg.subject }}</div>
                        <div class="fm-delete-preview-date"><i class="bi bi-clock me-1"></i>{{ msg.createdAt|date('M d, Y h:i A') }}</div>
                    </div>
                    <p class="small text-danger mb-0 mt-2"><i class="bi bi-info-circle me-1"></i>This action cannot be undone.</p>
                </div>
                <div class="modal-footer border-top-0" style="background:#f8fafc;padding:.75rem 1.25rem;">
                    <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash3 me-1"></i>Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endfor %}

{% else %}
<div class="fm-empty-state">
    <div class="fm-empty-icon">
        <i class="bi bi-envelope-open"></i>
    </div>
    <h5 class="fm-empty-title">No messages yet</h5>
    <p class="fm-empty-text">Faculty messages and evaluation requests will appear here.</p>
</div>
{% endif %}




{# ─── Script ─── #}
<script>
function fmFilter(status){
    document.querySelectorAll('.fm-tab').forEach(t=>t.classList.remove('active'));
    var activeTab=document.querySelector('.fm-tab[data-filter="'+status+'"]');
    if(activeTab) activeTab.classList.add('active');

    // Highlight stat card
    document.querySelectorAll('.fm-stat-card').forEach(c=>c.style.outline='none');
    var statClass={'all':'.fm-stat-all','pending':'.fm-stat-pending','reviewed':'.fm-stat-reviewed','resolved':'.fm-stat-resolved'};
    var sc=document.querySelector(statClass[status]);
    if(sc) sc.style.outline='2px solid #3B82F6';

    document.querySelectorAll('#fmMessageList .fm-message-card').forEach(function(card){
        var show=status==='all'||card.dataset.status===status;
        card.style.display=show?'':'none';
        // Collapse body when filtering
        var body=card.querySelector('.fm-card-body');
        if(body) body.style.display='none';
        var btn=card.querySelector('.fm-expand-btn');
        if(btn) btn.classList.remove('open');
    });
}

function fmSearchMessages(){
    var q=(document.getElementById('fmSearch').value||'').toLowerCase();
    document.querySelectorAll('#fmMessageList .fm-message-card').forEach(function(card){
        var show=card.dataset.search.includes(q);
        card.style.display=show?'':'none';
        if(!show){
            var body=card.querySelector('.fm-card-body');
            if(body) body.style.display='none';
            var btn=card.querySelector('.fm-expand-btn');
            if(btn) btn.classList.remove('open');
        }
    });
}

function fmToggleDetail(header){
    var card=header.closest('.fm-message-card');
    var body=card.querySelector('.fm-card-body');
    var btn=card.querySelector('.fm-expand-btn');
    if(body){
        var isOpen=body.style.display!=='none';
        body.style.display=isOpen?'none':'block';
        if(btn) btn.classList.toggle('open',!isOpen);
    }
}
</script>
{% endblock %}
