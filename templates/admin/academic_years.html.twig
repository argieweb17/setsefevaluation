{% extends 'base.html.twig' %}

{% block title %}Academic Years | SET-SEF Evaluation{% endblock %}

{% set prefix = staffMode|default(false) ? 'staff' : 'admin' %}
{% set isReadOnly = readOnly|default(false) %}

{% block stylesheets %}
<style>
/* ─── Header ─── */
.ay-header{border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);box-shadow:0 4px 24px rgba(26,86,219,.15);margin-bottom:16px;}
.ay-header-inner{padding:22px 26px 18px;}
.ay-header-icon{width:50px;height:50px;border-radius:14px;background:rgba(255,255,255,.12);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;flex-shrink:0;}
.ay-meta-pill{display:inline-flex;align-items:center;background:rgba(255,255,255,.1);color:rgba(255,255,255,.82);padding:2px 10px;border-radius:20px;font-weight:500;backdrop-filter:blur(4px);}
.ay-meta-active{background:rgba(52,211,153,.2);color:#34d399;}
.ay-meta-warn{background:rgba(251,191,36,.2);color:#fbbf24;}
.ay-stats-row{display:flex;gap:0;margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,255,255,.1);}
.ay-stat{flex:1;text-align:center;}
.ay-stat-val{display:block;font-size:1.15rem;font-weight:700;color:#fff;line-height:1.2;}
.ay-stat-lbl{display:block;font-size:.6rem;color:rgba(255,255,255,.55);text-transform:uppercase;letter-spacing:.8px;margin-top:2px;}
.ay-stat-divider{width:1px;background:rgba(255,255,255,.1);margin:0 2px;}
.ay-val-info{color:#38bdf8!important;}
.ay-val-success{color:#34d399!important;}
.ay-val-warn{color:#fbbf24!important;}

/* ─── Spotlight / Current AY ─── */
.ay-spotlight{display:flex;align-items:center;gap:16px;background:#fff;border:1px solid #e8ecf1;border-radius:12px;padding:16px 20px;margin-bottom:16px;box-shadow:0 1px 4px rgba(0,0,0,.03);flex-wrap:wrap;}
.ay-spotlight-icon{width:48px;height:48px;min-width:48px;border-radius:12px;background:rgba(16,185,129,.1);color:#10b981;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;}
.ay-spotlight-body{flex:1;min-width:200px;}
.ay-spotlight-label{font-size:.65rem;font-weight:700;color:#10b981;text-transform:uppercase;letter-spacing:.8px;margin-bottom:2px;}
.ay-spotlight-title{font-size:1.1rem;font-weight:700;color:#1e293b;line-height:1.3;}
.ay-spotlight-dates{font-size:.78rem;color:#64748b;margin-top:2px;}
.ay-spotlight-empty .ay-spotlight-label{color:#92400e;}
.ay-spotlight-badge{display:inline-flex;align-items:center;font-size:.7rem;font-weight:600;padding:4px 12px;border-radius:20px;margin-left:auto;}
.ay-badge-upcoming{background:#eff6ff;color:#2563eb;}
.ay-badge-ended{background:#f0fdf4;color:#16a34a;}
.ay-spotlight-progress{margin-left:auto;min-width:140px;text-align:right;}
.ay-progress-label{font-size:.65rem;font-weight:600;color:#64748b;margin-bottom:4px;}
.ay-progress-bar{width:140px;height:6px;background:#e2e8f0;border-radius:8px;overflow:hidden;margin-left:auto;}
.ay-progress-fill{height:100%;background:linear-gradient(90deg,#10b981,#34d399);border-radius:8px;transition:width .4s ease;}

/* ─── Table ─── */
.ay-table-wrap{background:#fff;border:1px solid #e8ecf1;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.03);}
.ay-table{width:100%;border-collapse:collapse;font-size:.82rem;}
.ay-table thead{background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-bottom:2px solid #e2e8f0;}
.ay-table thead th{padding:10px 14px;font-size:.7rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.6px;white-space:nowrap;border:none;}
.ay-table tbody tr{border-bottom:1px solid #f1f5f9;transition:background .12s ease;}
.ay-table tbody tr:last-child{border-bottom:none;}
.ay-table tbody tr:hover{background:#f8faff;}
.ay-table tbody td{padding:10px 14px;vertical-align:middle;}
.ay-row-current{background:#f0fdf4!important;}
.ay-row-current:hover{background:#ecfdf5!important;}

/* Label cell */
.ay-label-cell{display:flex;align-items:center;gap:10px;}
.ay-label-avatar{width:36px;height:36px;min-width:36px;border-radius:9px;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);color:#4338ca;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:800;letter-spacing:.3px;flex-shrink:0;}
.ay-label-text{font-weight:700;color:#1e293b;font-size:.88rem;line-height:1.3;}
.ay-current-badge{display:inline-flex;align-items:center;font-size:.6rem;font-weight:700;color:#059669;background:#ecfdf5;padding:1px 8px;border-radius:10px;margin-top:2px;}

/* Semester pills */
.ay-pill{display:inline-flex;align-items:center;padding:3px 10px;border-radius:6px;font-size:.72rem;font-weight:600;white-space:nowrap;}
.ay-pill-sem-1{background:#eff6ff;color:#2563eb;}
.ay-pill-sem-2{background:#faf5ff;color:#7c3aed;}
.ay-pill-sem-summer{background:#fef3c7;color:#b45309;}
.ay-empty{color:#cbd5e1;font-size:.78rem;font-style:italic;}

/* Date range */
.ay-date-range{font-size:.78rem;color:#475569;white-space:nowrap;}
.ay-date-sep{margin:0 4px;color:#94a3b8;font-weight:600;}

/* Status badge */
.ay-status-badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:.68rem;font-weight:600;white-space:nowrap;}
.ay-status-active{background:#ecfdf5;color:#059669;}
.ay-status-active i{font-size:.45rem;color:#10b981;}
.ay-status-inactive{background:#f8fafc;color:#94a3b8;border:1px solid #e2e8f0;}
.ay-status-inactive i{font-size:.45rem;}

/* Created */
.ay-text-muted{color:#64748b;font-size:.78rem;}

/* Actions */
.ay-th-actions{text-align:center;width:120px;}
.ay-td-actions{text-align:center;}
.ay-actions{display:flex;align-items:center;gap:4px;justify-content:center;}
.ay-action-btn{width:30px;height:30px;border:none;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;font-size:.72rem;cursor:pointer;transition:all .15s ease;background:transparent;color:#94a3b8;}
.ay-action-activate{color:#10b981;}
.ay-action-activate:hover{background:#ecfdf5;color:#059669;transform:scale(1.1);}
.ay-action-edit{color:#3b82f6;}
.ay-action-edit:hover{background:#eff6ff;color:#1d4ed8;transform:scale(1.1);}
.ay-action-delete{color:#ef4444;}
.ay-action-delete:hover{background:#fef2f2;color:#dc2626;transform:scale(1.1);}

/* Empty state */
.ay-empty-state{padding:20px 0;}
.ay-empty-icon{width:64px;height:64px;border-radius:50%;background:#f1f5f9;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:1.6rem;color:#94a3b8;}

/* ─── Modals ─── */
.ay-modal-content{border:none;box-shadow:0 24px 48px rgba(0,0,0,.12);}
.ay-modal-header-gradient{display:flex;align-items:center;justify-content:space-between;padding:18px 22px;background:linear-gradient(135deg,#0f172a 0%,#1a56db 60%,#3b82f6 100%);color:#fff;}
.ay-form-label{font-size:.78rem;font-weight:600;color:#475569;margin-bottom:4px;}

/* ─── Responsive ─── */
@media(max-width:768px){
    .ay-stats-row{flex-wrap:wrap;gap:8px;}
    .ay-stat{min-width:45%;}
    .ay-stat-divider{display:none;}
    .ay-spotlight{flex-direction:column;align-items:flex-start;}
    .ay-spotlight-progress{margin-left:0;width:100%;}
    .ay-progress-bar{width:100%;}
    .ay-table{font-size:.75rem;}
    .ay-table thead th{padding:8px 10px;font-size:.62rem;}
    .ay-table tbody td{padding:8px 10px;}
    .ay-th-created,.ay-td-created{display:none;}
}

/* Animations */
.ay-header,.ay-spotlight,.ay-table-wrap{animation:ayFadeIn .25s ease;}
@keyframes ayFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.ay-row{animation:ayRowIn .2s ease backwards;}
@keyframes ayRowIn{from{opacity:0;transform:translateX(-8px);}to{opacity:1;transform:translateX(0);}}
</style>
{% endblock %}

{% block body %}
{# ═══════════════════════════════════════
   COMPUTE STATS
   ═══════════════════════════════════════ #}
{% set totalAY = academicYears|length %}
{% set semCounts = {} %}
{% set yearSet = [] %}
{% for ay in academicYears %}
    {% if ay.yearLabel not in yearSet %}
        {% set yearSet = yearSet|merge([ay.yearLabel]) %}
    {% endif %}
    {% if ay.semester %}
        {% set semCounts = semCounts|merge({(ay.semester): (semCounts[ay.semester]|default(0)) + 1}) %}
    {% endif %}
{% endfor %}

{# ═══════════════════════════════════════
   PROFESSIONAL HEADER
   ═══════════════════════════════════════ #}
<div class="ay-header">
    <div class="ay-header-inner">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="ay-header-icon">
                    <i  class="bi bi-calendar3"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">Academic Year Management</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                        <span class="ay-meta-pill"><i  class="bi bi-database me-1"></i>{{ totalAY }} Record{{ totalAY != 1 ? 's' : '' }}</span>
                        {% if currentAY %}
                            <span class="ay-meta-pill ay-meta-active"><i  class="bi bi-check-circle-fill me-1"></i>{{ currentAY.label }}</span>
                        {% else %}
                            <span class="ay-meta-pill ay-meta-warn"><i  class="bi bi-exclamation-triangle-fill me-1"></i>No Active Year</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% if not isReadOnly %}
            <div class="d-flex gap-2 mt-1">
                <button type="button" class="btn btn-sm btn-light fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#addAYModal">
                    <i  class="bi bi-plus me-1"></i>New Academic Year
                </button>
            </div>
            {% endif %}
        </div>
        <div class="ay-stats-row">
            <div class="ay-stat">
                <span class="ay-stat-val">{{ totalAY }}</span>
                <span class="ay-stat-lbl">Total Records</span>
            </div>
            <div class="ay-stat-divider"></div>
            <div class="ay-stat">
                <span class="ay-stat-val ay-val-info">{{ yearSet|length }}</span>
                <span class="ay-stat-lbl">Unique Years</span>
            </div>
            <div class="ay-stat-divider"></div>
            <div class="ay-stat">
                <span class="ay-stat-val ay-val-success">{{ currentAY ? '1' : '0' }}</span>
                <span class="ay-stat-lbl">Active</span>
            </div>
            <div class="ay-stat-divider"></div>
            <div class="ay-stat">
                <span class="ay-stat-val ay-val-warn">{{ totalAY > 0 ? totalAY - (currentAY ? 1 : 0) : 0 }}</span>
                <span class="ay-stat-lbl">Inactive</span>
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════
   CURRENT ACADEMIC YEAR SPOTLIGHT
   ═══════════════════════════════════════ #}
{% if currentAY %}
<div class="ay-spotlight">
    <div class="ay-spotlight-icon">
        <i  class="bi bi-calendar-check"></i>
    </div>
    <div class="ay-spotlight-body">
        <div class="ay-spotlight-label">Current Academic Year</div>
        <div class="ay-spotlight-title">{{ currentAY.label }}</div>
        {% if currentAY.startDate and currentAY.endDate %}
            <div class="ay-spotlight-dates">
                <i  class="bi bi-calendar-range me-1"></i>
                {{ currentAY.startDate|date('M d, Y') }} — {{ currentAY.endDate|date('M d, Y') }}
            </div>
        {% endif %}
    </div>
    {% if currentAY.startDate and currentAY.endDate %}
        {% set now = "now"|date("U") %}
        {% set start = currentAY.startDate|date("U") %}
        {% set end = currentAY.endDate|date("U") %}
        {% if now >= start and now <= end %}
            {% set total = end - start %}
            {% set elapsed = now - start %}
            {% set pct = total > 0 ? ((elapsed / total) * 100)|round : 0 %}
            <div class="ay-spotlight-progress">
                <div class="ay-progress-label">{{ pct }}% elapsed</div>
                <div class="ay-progress-bar">
                    <div class="ay-progress-fill" style="width:{{ pct }}%"></div>
                </div>
            </div>
        {% elseif now < start %}
            <div class="ay-spotlight-badge ay-badge-upcoming"><i  class="bi bi-clock me-1"></i>Upcoming</div>
        {% else %}
            <div class="ay-spotlight-badge ay-badge-ended"><i  class="bi bi-check2-all me-1"></i>Ended</div>
        {% endif %}
    {% endif %}
</div>
{% else %}
<div class="ay-spotlight ay-spotlight-empty">
    <div class="ay-spotlight-icon" style="background:rgba(245,158,11,.12);color:#f59e0b;">
        <i  class="bi bi-exclamation-triangle-fill"></i>
    </div>
    <div class="ay-spotlight-body">
        <div class="ay-spotlight-label" style="color:#92400e;">No Active Academic Year</div>
        <div class="ay-spotlight-dates">Create one and mark it as current to get started.</div>
    </div>
</div>
{% endif %}

{# ═══════════════════════════════════════
   ACADEMIC YEARS TABLE
   ═══════════════════════════════════════ #}
<div class="ay-table-wrap">
    <table class="ay-table">
        <thead>
            <tr>
                <th class="ay-th-label">Academic Year</th>
                <th class="ay-th-sem">Semester</th>
                <th class="ay-th-dates">Date Range</th>
                <th class="ay-th-status">Status</th>
                <th class="ay-th-created">Created</th>
                {% if not isReadOnly %}
                <th class="ay-th-actions">Actions</th>
                {% endif %}
            </tr>
        </thead>
        <tbody>
            {% for ay in academicYears %}
            <tr class="ay-row {{ ay.isCurrent ? 'ay-row-current' : '' }}" style="animation-delay:{{ loop.index0 * 0.03 }}s">
                <td class="ay-td-label">
                    <div class="ay-label-cell">
                        <span class="ay-label-avatar">
                            {% set parts = ay.yearLabel|split('-') %}
                            {{ parts[0]|default('??')|slice(-2) }}
                        </span>
                        <div>
                            <div class="ay-label-text">{{ ay.yearLabel }}</div>
                            {% if ay.isCurrent %}
                                <span class="ay-current-badge"><i  class="bi bi-check-circle-fill me-1"></i>Current</span>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td class="ay-td-sem">
                    {% if ay.semester %}
                        <span class="ay-pill ay-pill-sem-{{ ay.semester == '1st Semester' ? '1' : (ay.semester == '2nd Semester' ? '2' : 'summer') }}">{{ ay.semester }}</span>
                    {% else %}
                        <span class="ay-empty">Full Year</span>
                    {% endif %}
                </td>
                <td class="ay-td-dates">
                    {% if ay.startDate or ay.endDate %}
                        <div class="ay-date-range">
                            <i  class="bi bi-calendar-range me-1 text-muted"></i>
                            {% if ay.startDate %}{{ ay.startDate|date('M d, Y') }}{% endif %}
                            {% if ay.startDate and ay.endDate %}<span class="ay-date-sep">→</span>{% endif %}
                            {% if ay.endDate %}{{ ay.endDate|date('M d, Y') }}{% endif %}
                        </div>
                    {% else %}
                        <span class="ay-empty">No dates set</span>
                    {% endif %}
                </td>
                <td class="ay-td-status">
                    {% if ay.isCurrent %}
                        <span class="ay-status-badge ay-status-active"><i  class="bi bi-circle-fill me-1"></i>Active</span>
                    {% else %}
                        <span class="ay-status-badge ay-status-inactive"><i  class="bi bi-circle-fill me-1"></i>Inactive</span>
                    {% endif %}
                </td>
                <td class="ay-td-created">
                    <span class="ay-text-muted">{{ ay.createdAt|date('M d, Y') }}</span>
                </td>
                {% if not isReadOnly %}
                <td class="ay-td-actions">
                    <div class="ay-actions">
                        {% if not ay.isCurrent %}
                        <form method="post" action="{{ path(prefix ~ '_academic_year_set_current', {id: ay.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('set_current_ay' ~ ay.id) }}">
                            <button class="ay-action-btn ay-action-activate" title="Set as Current">
                                <i  class="bi bi-check-circle-fill"></i>
                            </button>
                        </form>
                        {% endif %}
                        <button class="ay-action-btn ay-action-edit" title="Edit" data-bs-toggle="modal" data-bs-target="#editAYModal{{ ay.id }}">
                            <i  class="bi bi-pencil-square"></i>
                        </button>
                        <form method="post" action="{{ path(prefix ~ '_academic_year_delete', {id: ay.id}) }}" class="d-inline"
                              onsubmit="return confirm('Delete academic year \'{{ ay.label|e('js') }}\'?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_ay' ~ ay.id) }}">
                            <button class="ay-action-btn ay-action-delete" title="Delete">
                                <i  class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </td>
                {% endif %}
            </tr>

            {% if not isReadOnly %}
            {# ── Edit Modal ── #}
            <div class="modal fade" id="editAYModal{{ ay.id }}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content ay-modal-content" style="border-radius:16px;overflow:hidden;">
                        <form method="post" action="{{ path(prefix ~ '_academic_year_edit', {id: ay.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('edit_ay' ~ ay.id) }}">
                            <div class="ay-modal-header-gradient">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:42px;height:42px;border-radius:12px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:#fff;"><i  class="bi bi-pencil-square"></i></div>
                                    <div>
                                        <h5 class="fw-bold mb-0 text-white" style="font-size:1.05rem;">Edit Academic Year</h5>
                                        <span style="font-size:.72rem;color:rgba(255,255,255,.65);">{{ ay.label }}</span>
                                    </div>
                                </div>
                                <button type="button" class="btn-close btn-close-white" style="font-size:.7rem;" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body p-4">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label ay-form-label">Year Label <span class="text-danger">*</span></label>
                                        <input type="text" name="yearLabel" class="form-control form-control-sm" placeholder="e.g. 2025-2026" value="{{ ay.yearLabel }}" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label ay-form-label">Semester</label>
                                        <select name="semester" class="form-select form-select-sm">
                                            <option value="">— No semester —</option>
                                            <option value="1st Semester" {{ ay.semester == '1st Semester' ? 'selected' }}>1st Semester</option>
                                            <option value="2nd Semester" {{ ay.semester == '2nd Semester' ? 'selected' }}>2nd Semester</option>
                                            <option value="Summer" {{ ay.semester == 'Summer' ? 'selected' }}>Summer</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label ay-form-label">Start Date</label>
                                        <input type="date" name="startDate" class="form-control form-control-sm" value="{{ ay.startDate ? ay.startDate|date('Y-m-d') : '' }}">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label ay-form-label">End Date</label>
                                        <input type="date" name="endDate" class="form-control form-control-sm" value="{{ ay.endDate ? ay.endDate|date('Y-m-d') : '' }}">
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check">
                                            <input type="checkbox" name="isCurrent" value="1" class="form-check-input" id="editIsCurrent{{ ay.id }}" {{ ay.isCurrent ? 'checked' }}>
                                            <label class="form-check-label ay-form-label" for="editIsCurrent{{ ay.id }}">Set as current academic year</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer border-top px-4 py-3" style="background:#f8fafc;">
                                <button type="button" class="btn btn-sm btn-light rounded-pill px-3" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3"><i  class="bi bi-check-circle-fill me-1"></i>Save Changes</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            {% endif %}
            {% else %}
            <tr>
                <td colspan="{{ isReadOnly ? 5 : 6 }}" class="text-center py-5">
                    <div class="ay-empty-state">
                        <div class="ay-empty-icon"><i  class="bi bi-calendar3"></i></div>
                        <div class="fw-semibold text-muted mb-1">No Academic Years</div>
                        <div class="text-muted mb-3" style="font-size:.8rem;">{% if isReadOnly %}No academic years have been created yet.{% else %}Get started by creating your first academic year{% endif %}</div>
                        {% if not isReadOnly %}
                        <button class="btn btn-sm btn-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addAYModal">
                            <i  class="bi bi-plus me-1"></i>New Academic Year
                        </button>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# ═══════════════════════════════════════
   ADD ACADEMIC YEAR MODAL
   ═══════════════════════════════════════ #}
{% if not isReadOnly %}
<div class="modal fade" id="addAYModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ay-modal-content" style="border-radius:16px;overflow:hidden;">
            <form id="addAYForm" method="post" action="{{ path(prefix ~ '_academic_year_create') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('create_ay') }}">
                <div class="ay-modal-header-gradient">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:42px;height:42px;border-radius:12px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:#fff;"><i  class="bi bi-calendar-plus"></i></div>
                        <div>
                            <h5 class="fw-bold mb-0 text-white" style="font-size:1.05rem;">New Academic Year</h5>
                            <span style="font-size:.72rem;color:rgba(255,255,255,.65);">Fill in the details below</span>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" style="font-size:.7rem;" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" name="autoGenerateNext" value="1" class="form-check-input" id="addAutoGenerateNext">
                                <label class="form-check-label ay-form-label" for="addAutoGenerateNext">Auto-generate next term</label>
                                <div class="form-text" style="font-size:.72rem;">Cycle: 1st Semester → 2nd Semester → Summer → next academic year 1st Semester</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" name="autoCalendarNow" value="1" class="form-check-input" id="addAutoCalendarNow">
                                <label class="form-check-label ay-form-label" for="addAutoCalendarNow">Auto-create current calendar term (now)</label>
                                <div class="form-text" style="font-size:.72rem;">Uses today to auto-fill year, semester, and date range.</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" name="createSemesterDates" value="1" class="form-check-input" id="addCreateSemesterDates">
                                <label class="form-check-label ay-form-label" for="addCreateSemesterDates">Add semester dates (1st, 2nd, Summer)</label>
                                <div class="form-text" style="font-size:.72rem;">Creates three records for the same year label using the date ranges below.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ay-form-label">Year Label <span class="text-danger">*</span></label>
                            <input id="addYearLabelInput" type="text" name="yearLabel" class="form-control form-control-sm" placeholder="e.g. 2025-2026" required>
                            <div class="form-text" style="font-size:.7rem;">Format: YYYY-YYYY</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ay-form-label">Semester</label>
                            <select id="addSemesterSelect" name="semester" class="form-select form-select-sm">
                                <option value="">— No semester (full year) —</option>
                                <option value="1st Semester">1st Semester</option>
                                <option value="2nd Semester">2nd Semester</option>
                                <option value="Summer">Summer</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ay-form-label">Start Date</label>
                            <input id="addSingleStartDate" type="date" name="startDate" class="form-control form-control-sm">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ay-form-label">End Date</label>
                            <input id="addSingleEndDate" type="date" name="endDate" class="form-control form-control-sm">
                        </div>

                        <div class="col-12 d-none" id="addSemesterDateGrid">
                            <div class="border rounded-3 p-3" style="background:#f8fafc;border-color:#e2e8f0!important;">
                                <div class="fw-semibold mb-2" style="font-size:.8rem;color:#334155;">Semester Date Ranges</div>
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-4">
                                        <label class="form-label ay-form-label">1st Semester Start</label>
                                        <input type="date" name="firstStartDate" id="firstStartDate" class="form-control form-control-sm">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label ay-form-label">1st Semester End</label>
                                        <input type="date" name="firstEndDate" id="firstEndDate" class="form-control form-control-sm">
                                    </div>
                                </div>
                                <div class="row g-2 align-items-end mt-1">
                                    <div class="col-md-4">
                                        <label class="form-label ay-form-label">2nd Semester Start</label>
                                        <input type="date" name="secondStartDate" id="secondStartDate" class="form-control form-control-sm">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label ay-form-label">2nd Semester End</label>
                                        <input type="date" name="secondEndDate" id="secondEndDate" class="form-control form-control-sm">
                                    </div>
                                </div>
                                <div class="row g-2 align-items-end mt-1">
                                    <div class="col-md-4">
                                        <label class="form-label ay-form-label">Summer Start</label>
                                        <input type="date" name="summerStartDate" id="summerStartDate" class="form-control form-control-sm">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label ay-form-label">Summer End</label>
                                        <input type="date" name="summerEndDate" id="summerEndDate" class="form-control form-control-sm">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" name="isCurrent" value="1" class="form-check-input" id="addIsCurrent">
                                <label class="form-check-label ay-form-label" for="addIsCurrent">Set as current academic year</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top px-4 py-3" style="background:#f8fafc;">
                    <button type="button" class="btn btn-sm btn-light rounded-pill px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3"><i  class="bi bi-plus-circle-fill me-1"></i>Create</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}


<script>
(function () {
    var form = document.getElementById('addAYForm');
    var auto = document.getElementById('addAutoGenerateNext');
    var calendarNow = document.getElementById('addAutoCalendarNow');
    var semesterDates = document.getElementById('addCreateSemesterDates');
    var yearInput = document.getElementById('addYearLabelInput');
    var semSelect = document.getElementById('addSemesterSelect');
    var singleStart = document.getElementById('addSingleStartDate');
    var singleEnd = document.getElementById('addSingleEndDate');
    var dateGrid = document.getElementById('addSemesterDateGrid');
    var firstStart = document.getElementById('firstStartDate');
    var firstEnd = document.getElementById('firstEndDate');
    var secondStart = document.getElementById('secondStartDate');
    var secondEnd = document.getElementById('secondEndDate');
    var summerStart = document.getElementById('summerStartDate');
    var summerEnd = document.getElementById('summerEndDate');
    var isCurrentToggle = document.getElementById('addIsCurrent');

    if (!form || !auto || !calendarNow || !semesterDates || !yearInput || !semSelect || !singleStart || !singleEnd || !dateGrid || !isCurrentToggle) {
        return;
    }

    function calendarTermForToday() {
        var now = new Date();
        var year = now.getFullYear();
        var month = now.getMonth() + 1;

        if (month >= 8) {
            return {
                yearLabel: year + '-' + (year + 1),
                semester: '1st Semester',
                startDate: year + '-08-01',
                endDate: year + '-12-31'
            };
        }

        if (month >= 6) {
            return {
                yearLabel: (year - 1) + '-' + year,
                semester: 'Summer',
                startDate: year + '-06-01',
                endDate: year + '-07-31'
            };
        }

        return {
            yearLabel: (year - 1) + '-' + year,
            semester: '2nd Semester',
            startDate: year + '-01-01',
            endDate: year + '-05-31'
        };
    }

    function semesterRangesForYearLabel(label) {
        var m = String(label || '').trim().match(/^(\d{4})\s*-\s*(\d{4})$/);
        if (!m) {
            return null;
        }

        var startYear = Number(m[1]);
        var endYear = Number(m[2]);

        return {
            firstStartDate: startYear + '-08-01',
            firstEndDate: startYear + '-12-31',
            secondStartDate: endYear + '-01-01',
            secondEndDate: endYear + '-05-31',
            summerStartDate: endYear + '-06-01',
            summerEndDate: endYear + '-07-31'
        };
    }

    function autoFillSemesterDateGrid() {
        if (!semesterDates.checked) {
            return;
        }

        if (!yearInput.value.trim()) {
            var nowTerm = calendarTermForToday();
            yearInput.value = nowTerm.yearLabel;
        }

        var ranges = semesterRangesForYearLabel(yearInput.value);
        if (!ranges) {
            return;
        }

        firstStart.value = ranges.firstStartDate;
        firstEnd.value = ranges.firstEndDate;
        secondStart.value = ranges.secondStartDate;
        secondEnd.value = ranges.secondEndDate;
        summerStart.value = ranges.summerStartDate;
        summerEnd.value = ranges.summerEndDate;
    }

    function syncAutoMode() {
        var autoEnabled = auto.checked;
        var calendarEnabled = calendarNow.checked;
        var multiEnabled = semesterDates.checked;

        if (autoEnabled || calendarEnabled) {
            semesterDates.checked = false;
            semesterDates.disabled = true;
            multiEnabled = false;
        } else {
            semesterDates.disabled = false;
        }

        if (autoEnabled || multiEnabled) {
            calendarNow.checked = false;
            calendarNow.disabled = true;
            calendarEnabled = false;
        } else {
            calendarNow.disabled = false;
        }

        if (calendarEnabled || multiEnabled) {
            auto.checked = false;
            auto.disabled = true;
            autoEnabled = false;
        } else {
            auto.disabled = false;
        }

        yearInput.readOnly = autoEnabled || calendarEnabled;
        yearInput.required = !(autoEnabled || calendarEnabled);
        if (autoEnabled) {
            yearInput.value = '';
        }

        semSelect.disabled = autoEnabled || calendarEnabled || multiEnabled;
        if (autoEnabled || multiEnabled) {
            semSelect.value = '';
        }

        singleStart.disabled = multiEnabled || autoEnabled || calendarEnabled;
        singleEnd.disabled = multiEnabled || autoEnabled || calendarEnabled;
        if (multiEnabled || autoEnabled) {
            singleStart.value = '';
            singleEnd.value = '';
        }

        if (calendarEnabled) {
            var term = calendarTermForToday();
            yearInput.value = term.yearLabel;
            semSelect.value = term.semester;
            singleStart.value = term.startDate;
            singleEnd.value = term.endDate;
        }

        isCurrentToggle.disabled = calendarEnabled;
        if (calendarEnabled) {
            isCurrentToggle.checked = true;
        }

        if (multiEnabled) {
            autoFillSemesterDateGrid();
        }

        dateGrid.classList.toggle('d-none', !multiEnabled);

        [firstStart, firstEnd, secondStart, secondEnd, summerStart, summerEnd].forEach(function (el) {
            if (!el) return;
            el.required = multiEnabled;
            el.disabled = !multiEnabled;
            if (!multiEnabled) {
                el.value = '';
            }
        });
    }

    auto.addEventListener('change', syncAutoMode);
    calendarNow.addEventListener('change', syncAutoMode);
    semesterDates.addEventListener('change', syncAutoMode);
    yearInput.addEventListener('change', autoFillSemesterDateGrid);
    syncAutoMode();
})();
</script>



{% endblock %}
