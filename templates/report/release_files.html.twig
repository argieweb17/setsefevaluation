{% extends 'base.html.twig' %}

{% block title %}{{ title|default('Release Files') }} | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
.rl-card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;box-shadow:0 1px 5px rgba(15,23,42,.05);overflow:hidden;}
.rl-header{padding:14px 16px;border-bottom:1px solid #e5e7eb;background:linear-gradient(135deg,#eff6ff,#f8fafc);display:flex;align-items:center;justify-content:space-between;gap:10px;}
.rl-title{font-size:1rem;font-weight:700;color:#1e3a8a;margin:0;}
.rl-sub{font-size:.78rem;color:#64748b;}
.rl-badge{display:inline-flex;align-items:center;gap:6px;font-size:.72rem;font-weight:600;padding:4px 10px;border-radius:999px;background:#dbeafe;color:#1e3a8a;}
.rl-toolbar{padding:12px 14px;border-bottom:1px solid #e5e7eb;background:#fbfdff;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;}
.rl-search-wrap{position:relative;min-width:200px;max-width:320px;flex:0 1 320px;}
.rl-search-wrap i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.82rem;}
.rl-search{width:100%;border:1px solid #dbe2ec;border-radius:10px;padding:7px 10px 7px 30px;font-size:.82rem;outline:none;}
.rl-search:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.08);}
.rl-meta{font-size:.75rem;color:#64748b;}
.rl-table{width:100%;border-collapse:collapse;}
.rl-table thead{background:#f8fafc;border-bottom:1px solid #e5e7eb;}
.rl-table th{padding:11px 12px;font-size:.72rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.35px;}
.rl-th-wrap{display:inline-flex;align-items:center;gap:4px;}
.rl-th-sort{font-size:.66rem;color:#cbd5e1;line-height:1;}
.rl-table td{padding:11px 12px;border-bottom:1px solid #f1f5f9;font-size:.84rem;color:#0f172a;vertical-align:middle;}
.rl-table tbody tr:hover{background:#f8fbff;}
.rl-pill{display:inline-flex;align-items:center;border-radius:999px;padding:3px 10px;font-size:.7rem;font-weight:700;letter-spacing:.2px;}
.rl-pill-set{background:#dbeafe;color:#1e3a8a;}
.rl-pill-sef{background:#dcfce7;color:#166534;}
.rl-file-link{display:inline-flex;align-items:center;gap:5px;border:1px solid #cbd5e1;background:#fff;color:#1e3a8a;text-decoration:none;border-radius:8px;padding:4px 10px;font-size:.72rem;font-weight:700;}
.rl-file-link:hover{background:#eff6ff;color:#1e3a8a;border-color:#93c5fd;}
.rl-empty{padding:32px 20px;text-align:center;color:#64748b;}
.rl-empty i{font-size:1.5rem;color:#94a3b8;display:block;margin-bottom:8px;}
.rl-no-match td{text-align:center;color:#64748b;font-style:italic;padding:16px 12px;}
</style>
{% endblock %}

{% block body %}
<div class="rl-card">
    <div class="rl-header">
        <div>
            <h1 class="rl-title">Release Files</h1>
            <div class="rl-sub">{{ subtitle|default('Released PDF files and release dates.') }}</div>
        </div>
        <span class="rl-badge"><i  class="bi bi-folder-check"></i> {{ records|length }} release{{ records|length != 1 ? 's' : '' }}</span>
    </div>

    {% if records is empty %}
    <div class="rl-empty">
        <i  class="bi bi-inbox"></i>
        No released files yet.
    </div>
    {% else %}
    <div class="rl-toolbar">
        <div class="rl-search-wrap">
            <i  class="bi bi-search"></i>
            <input type="search" id="rlSearch" class="rl-search" placeholder="Search release, received by, type, date...">
        </div>
        <div class="rl-meta" id="rlMeta">Showing {{ records|length }} of {{ records|length }}</div>
    </div>

    <div class="table-responsive">
        <table class="rl-table">
            <thead>
                <tr>
                    <th><span class="rl-th-wrap">Release <i  class="bi bi-arrow-down-up rl-th-sort"></i></span></th>
                    <th style="width:120px;"><span class="rl-th-wrap">Type <i  class="bi bi-arrow-down-up rl-th-sort"></i></span></th>
                    <th style="width:220px;"><span class="rl-th-wrap">Faculty Name <i  class="bi bi-arrow-down-up rl-th-sort"></i></span></th>
                    <th style="width:190px;"><span class="rl-th-wrap">Received By <i  class="bi bi-arrow-down-up rl-th-sort"></i></span></th>
                    <th style="width:180px;"><span class="rl-th-wrap">Release Date <i  class="bi bi-arrow-down-up rl-th-sort"></i></span></th>
                    <th style="width:120px;"><span class="rl-th-wrap">File <i  class="bi bi-arrow-down-up rl-th-sort"></i></span></th>
                </tr>
            </thead>
            <tbody>
                {% for row in records %}
                <tr class="rl-row" data-search="{{ row.correspondenceId }} {{ row.evaluationType }} {{ row.facultyName ?: 'N/A' }} {{ row.receivedByName ?: (row.releasedBy ? row.releasedBy.fullName : 'System') }} {{ row.releasedAt ? row.releasedAt|date('M d, Y h:i A') : '' }}">
                    <td>{{ row.correspondenceId }}</td>
                    <td>
                        <span class="rl-pill {{ row.evaluationType == 'SEF' ? 'rl-pill-sef' : 'rl-pill-set' }}">{{ row.evaluationType }}</span>
                    </td>
                    <td>{{ row.facultyName ?: 'N/A' }}</td>
                    <td>{{ row.receivedByName ?: (row.releasedBy ? row.releasedBy.fullName : 'System') }}</td>
                    <td>{{ row.releasedAt ? row.releasedAt|date('M d, Y h:i A') : '' }}</td>
                    <td>
                        <a href="{{ path('staff_correspondence_file', {id: row.id}) }}" class="rl-file-link" target="_blank" rel="noopener noreferrer">
                            <i  class="bi bi-file-earmark-arrow-down"></i> PDF
                        </a>
                    </td>
                </tr>
                {% endfor %}
                <tr id="rlNoMatch" class="rl-no-match" style="display:none;">
                    <td colspan="6">No release records match your search.</td>
                </tr>
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    var searchInput = document.getElementById('rlSearch');
    var rows = Array.from(document.querySelectorAll('.rl-row'));
    var noMatch = document.getElementById('rlNoMatch');
    var meta = document.getElementById('rlMeta');

    if (!searchInput || rows.length === 0) {
        return;
    }

    var total = rows.length;

    function applySearch() {
        var term = (searchInput.value || '').trim().toLowerCase();
        var visible = 0;

        rows.forEach(function (row) {
            var haystack = (row.getAttribute('data-search') || '').toLowerCase();
            var show = !term || haystack.indexOf(term) !== -1;
            row.style.display = show ? '' : 'none';
            if (show) {
                visible++;
            }
        });

        if (noMatch) {
            noMatch.style.display = visible === 0 ? '' : 'none';
        }

        if (meta) {
            meta.textContent = 'Showing ' + visible + ' of ' + total;
        }
    }

    searchInput.addEventListener('input', applySearch);
});
</script>
{% endblock %}
