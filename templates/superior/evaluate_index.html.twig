{% extends 'base.html.twig' %}

{% block title %}Evaluate Personnel | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
.sp-page { max-width: 1200px; margin: 0 auto; }
.sp-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
.sp-header-title { margin: 0; font-size: 1.65rem; font-weight: 800; color: #0f172a; letter-spacing: -0.01em; }
.sp-header-sub { margin-top: .3rem; color: #64748b; font-size: .86rem; }

.sp-toolbar {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: .75rem;
    display: flex;
    flex-wrap: wrap;
    gap: .55rem;
    margin-bottom: 1rem;
}
.sp-filter-group {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: .2rem .45rem;
}
.sp-filter-label { font-size: .73rem; color: #475569; font-weight: 600; }
.sp-filter-control {
    border: none;
    background: transparent;
    font-size: .79rem;
    color: #1e293b;
    padding: .25rem .3rem;
    min-width: 130px;
}
.sp-filter-control:focus { outline: none; }
.sp-search-box {
    position: relative;
    min-width: 210px;
    flex: 1;
    max-width: 370px;
}
.sp-search-box i {
    position: absolute;
    left: .72rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: .8rem;
}
.sp-search-box input {
    width: 100%;
    border: 1px solid #dbe3ee;
    border-radius: 10px;
    padding: .47rem .72rem .47rem 2rem;
    background: #fff;
    color: #0f172a;
    font-size: .8rem;
}
.sp-search-box input:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.1); }

.sp-panel {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1rem;
}
.sp-panel.is-hidden { display: none; }
.sp-panel-head {
    padding: .85rem 1rem;
    border-bottom: 1px solid #eef2f7;
    background: #fbfcfe;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    flex-wrap: wrap;
}
.sp-panel-title { margin: 0; font-size: .95rem; font-weight: 700; color: #0f172a; display: inline-flex; align-items: center; gap: .45rem; }
.sp-panel-title i { color: #2563eb; }
.sp-panel-note { font-size: .76rem; color: #64748b; }

.sp-table-wrap { overflow-x: auto; }
.sp-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    min-width: 860px;
}
.sp-table thead th {
    text-align: left;
    font-size: .68rem;
    text-transform: uppercase;
    letter-spacing: .045em;
    color: #516484;
    font-weight: 700;
    padding: .58rem .82rem;
    border-bottom: 1px solid #e8edf4;
    background: #f5f8fc;
}
.sp-th-sort {
    margin-left: .3rem;
    color: #9aa8bd;
    font-size: .65rem;
    vertical-align: middle;
}
.sp-table tbody td {
    padding: .58rem .82rem;
    border-bottom: 1px solid #edf2f7;
    vertical-align: middle;
    font-size: .76rem;
    color: #1e293b;
}
.sp-table tbody tr:hover { background: #fbfdff; }
.sp-table tbody tr:last-child td { border-bottom: none; }

.sp-type-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    border-radius: 8px;
    padding: .2rem .42rem;
    font-size: .72rem;
    font-weight: 700;
    color: #0f53d7;
    background: #dbeafe;
}

.sp-person {
    display: flex;
    align-items: center;
    gap: .52rem;
    min-width: 190px;
}
.sp-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: center;
}
.sp-avatar img { width: 100%; height: 100%; object-fit: cover; }
.sp-avatar-fallback { color: #fff; font-size: .72rem; font-weight: 700; letter-spacing: .02em; }
.sp-person-name { font-weight: 700; color: #0f172a; font-size: .78rem; }
.sp-person-meta { margin-top: .08rem; color: #64748b; font-size: .68rem; }

.sp-role {
    display: inline-flex;
    align-items: center;
    gap: .28rem;
    border-radius: 8px;
    padding: .2rem .42rem;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .02em;
    line-height: 1;
    width: fit-content;
    max-width: 100%;
    white-space: nowrap;
}
.sp-role-dean { background: #fef3c7; color: #92400e; }
.sp-role-head { background: #d9e9ff; color: #0c5f99; }
.sp-role-lead { background: #f3e8ff; color: #6b21a8; }
.sp-role i {
    margin-top: 0;
    flex-shrink: 0;
    font-size: .7rem;
}

.sp-department-chip {
    display: inline-flex;
    align-items: center;
    gap: .28rem;
    border-radius: 8px;
    padding: .2rem .42rem;
    font-size: .72rem;
    font-weight: 600;
    background: #e9eef5;
    border: 1px solid #d5deea;
    color: #25364f;
    line-height: 1;
    width: fit-content;
    max-width: 100%;
    white-space: nowrap;
}
.sp-department-chip i {
    font-size: .7rem;
    margin-top: 0;
    flex-shrink: 0;
}

.sp-status {
    display: inline-flex;
    align-items: center;
    gap: .24rem;
    border-radius: 999px;
    padding: .16rem .5rem;
    font-size: .64rem;
    font-weight: 600;
}
.sp-status-submitted { background: #dcfce7; color: #166534; }
.sp-status-pending { background: #f1f5f9; color: #475569; }
.sp-status-note {
    margin-top: .14rem;
    color: #6b7280;
    font-size: .64rem;
    font-weight: 600;
}

.sp-period-title { font-weight: 600; color: #0f172a; font-size: .82rem; }
.sp-period-meta { margin-top: .08rem; font-size: .66rem; color: #64748b; }

.sp-action {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    border-radius: 8px;
    text-decoration: none;
    border: none;
    font-weight: 700;
    font-size: .75rem;
    padding: .42rem .72rem;
    white-space: nowrap;
}
.sp-action-view { background: #2563eb; color: #fff; }
.sp-action-view:hover { background: #1d4ed8; color: #fff; }
.sp-action-evaluate { background: #059669; color: #fff; }
.sp-action-evaluate:hover { background: #047857; color: #fff; }
.sp-action-icon {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    border: 1px solid #cfd9e6;
    background: #fff;
    color: #315b93;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: .78rem;
}
.sp-action-icon:hover {
    background: #edf3fe;
    border-color: #b7c9e5;
    color: #1d4ed8;
}

.sp-empty { padding: 2.3rem 1rem; text-align: center; color: #64748b; font-size: .85rem; }
.sp-no-results { display: none; }
.sp-no-results td { text-align: center; color: #64748b; font-style: italic; padding: 1.2rem 1rem; }

@media (max-width: 900px) {
    .sp-header-title { font-size: 1.35rem; }
    .sp-toolbar { padding: .65rem; }
    .sp-filter-control { min-width: 110px; }
}
</style>
{% endblock %}

{% block body %}
<div class="sp-page">
    <div class="sp-header">
        <div>
            <h1 class="sp-header-title">Evaluate Personnel</h1>
            <div class="sp-header-sub">SEF Workflow &middot; President &rarr; Vice President &rarr; Campus Director &rarr; Dean &rarr; Department Head</div>
        </div>
    </div>

    {% set hasOpenRecords = (openEvals|length > 0 and totalEvaluatees > 0) %}
    {% set hasHistoryRecords = historyItems|length > 0 %}
    {% set defaultRecordType = hasOpenRecords ? 'open' : 'previous' %}

    {% if hasOpenRecords or hasHistoryRecords %}
    <div class="sp-toolbar">
        <div class="sp-search-box">
            <i class="bi bi-search"></i>
            <input type="search" id="spSearch" placeholder="Search personnel, role, department, or period...">
        </div>

        <div class="sp-filter-group">
            <span class="sp-filter-label">Records</span>
            <select id="spRecordType" class="sp-filter-control">
                {% if hasOpenRecords %}<option value="open" {{ defaultRecordType == 'open' ? 'selected' : '' }}>Open evaluations</option>{% endif %}
                {% if hasHistoryRecords %}<option value="previous" {{ defaultRecordType == 'previous' ? 'selected' : '' }}>Previous submitted</option>{% endif %}
            </select>
        </div>

        <div class="sp-filter-group" id="spOpenStatusWrap"{% if defaultRecordType != 'open' %} style="display:none"{% endif %}>
            <span class="sp-filter-label">Status</span>
            <select id="spOpenStatus" class="sp-filter-control">
                <option value="all">All status</option>
                <option value="pending">Pending</option>
                <option value="submitted">Submitted</option>
            </select>
        </div>

        <div class="sp-filter-group" id="spOpenPeriodWrap"{% if defaultRecordType != 'open' %} style="display:none"{% endif %}>
            <span class="sp-filter-label">Period</span>
            <select id="spOpenPeriod" class="sp-filter-control">
                <option value="all">All open periods</option>
                {% for eval in openEvals %}
                <option value="{{ eval.id }}">{{ eval.evaluationType == 'SUPERIOR' ? 'SEF' : eval.evaluationType }} - {{ eval.schoolYear ?? '' }} {{ eval.semester ?? '' }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="sp-filter-group" id="spHistoryYearWrap"{% if defaultRecordType != 'previous' %} style="display:none"{% endif %}>
            <span class="sp-filter-label">Academic Year</span>
            <select id="spHistoryYear" class="sp-filter-control">
                <option value="all">All years</option>
                {% for sy in historyYears %}
                <option value="{{ sy }}" {{ selectedHistoryYear == sy ? 'selected' : '' }}>{{ sy }}</option>
                {% endfor %}
            </select>
        </div>

    </div>
    {% endif %}

    <div class="sp-panel {{ defaultRecordType != 'open' ? 'is-hidden' : '' }}" id="spOpenPanel">
        <div class="sp-panel-head">
            <h2 class="sp-panel-title">Open Evaluations</h2>
            <div class="sp-panel-note">Active evaluation records.</div>
        </div>

        {% if hasOpenRecords %}
        <div class="sp-table-wrap">
            <table class="sp-table" id="spOpenTable">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Period <i class="bi bi-arrow-down-up sp-th-sort"></i></th>
                        <th>Faculty <i class="bi bi-arrow-down-up sp-th-sort"></i></th>
                        <th>Position <i class="bi bi-arrow-down-up sp-th-sort"></i></th>
                        <th>Department <i class="bi bi-arrow-down-up sp-th-sort"></i></th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% set colors = ['#0f766e','#1d4ed8','#6d28d9','#c2410c','#be123c','#0e7490','#475569'] %}
                    {% for eval in openEvals %}
                        {% set evalEvaluatees = evaluateesByEval[eval.id]|default([]) %}
                        {% for item in evalEvaluatees %}
                            {% set key = eval.id ~ '-' ~ item.user.id %}
                            {% set colorIdx = loop.index0 % colors|length %}
                            {% set parts = item.user.fullName|split(' ') %}
                            {% set initials = parts[0][:1]|upper ~ (parts|length > 1 ? parts[parts|length - 1][:1]|upper : '') %}
                            {% set isSubmitted = submissions[key] is defined and submissions[key] %}
                            {% set rowStatus = isSubmitted ? 'submitted' : 'pending' %}
                            <tr class="sp-open-row" data-search="{{ item.user.fullName }} {{ item.label }} {{ item.user.department ? item.user.department.departmentName : '' }} {{ eval.schoolYear }} {{ eval.semester }} {{ item.subjectPreview }}" data-status="{{ rowStatus }}" data-period="{{ eval.id }}">
                                <td>
                                    <span class="sp-type-badge">{{ eval.evaluationType == 'SUPERIOR' ? 'SEF' : eval.evaluationType }}</span>
                                </td>
                                <td>
                                    <div class="sp-period-title">{{ eval.schoolYear ?? '-' }} {{ eval.semester ?? '' }}</div>
                                    <div class="sp-period-meta">{{ eval.startDate|date('M d, Y h:i A') }} - {{ eval.endDate|date('M d, Y h:i A') }}</div>
                                </td>
                                <td>
                                    <div class="sp-person">
                                        <span class="sp-avatar">
                                            <img src="{{ asset('images/' ~ item.user.profilePictureOrDefault) }}" alt="{{ item.user.fullName }} profile" onerror="this.onerror=null;this.src='{{ asset('images/default-profile.svg') }}';">
                                        </span>
                                        <div>
                                            <div class="sp-person-name">{{ item.user.fullName }}</div>
                                            <div class="sp-person-meta">{{ item.subjectCount }} subject{{ item.subjectCount != 1 ? 's' : '' }}{% if item.subjectPreview %} &middot; {{ item.subjectPreview }}{% endif %}</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="sp-role {{ item.type == 'dean' ? 'sp-role-dean' : (item.type == 'department_head' ? 'sp-role-head' : 'sp-role-lead') }}"><i class="bi bi-person-badge"></i> {{ item.label }}</span>
                                </td>
                                <td>
                                    <span class="sp-department-chip"><i class="bi bi-building"></i> {{ item.user.department ? item.user.department.departmentName : 'N/A' }}</span>
                                </td>
                                <td>
                                    {% if isSubmitted %}
                                        <span class="sp-status sp-status-submitted"><i class="bi bi-check-circle-fill"></i> Submitted</span>
                                    {% else %}
                                        <span class="sp-status sp-status-pending"><i class="bi bi-clock"></i> Pending</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if isSubmitted %}
                                        <a href="{{ path('superior_evaluate_view', {evalId: eval.id, evaluateeId: item.user.id}) }}" class="sp-action-icon" title="View evaluation"><i class="bi bi-eye"></i></a>
                                    {% else %}
                                        <a href="{{ path('superior_evaluate_form', {evalId: eval.id, evaluateeId: item.user.id}) }}" class="sp-action-icon" title="Evaluate"><i class="bi bi-pencil-square"></i></a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endfor %}
                    <tr id="spOpenNoResults" class="sp-no-results">
                        <td colspan="7">No records match your filter selection.</td>
                    </tr>
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="sp-empty">No personnel are currently available for open evaluation periods.</div>
        {% endif %}
    </div>

    {% if historyYears|length > 0 or historyItems|length > 0 %}
    <div class="sp-panel {{ defaultRecordType != 'previous' ? 'is-hidden' : '' }}" id="spHistoryPanel">
        <div class="sp-panel-head">
            <h2 class="sp-panel-title"><i class="bi bi-clock-history"></i> Previous Submitted Evaluations</h2>
            <div class="sp-panel-note">Completed submissions archive.</div>
        </div>

        {% if historyItems|length > 0 %}
        <div class="sp-table-wrap">
            <table class="sp-table" id="spHistoryTable">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Period <i class="bi bi-arrow-down-up sp-th-sort"></i></th>
                        <th>Faculty <i class="bi bi-arrow-down-up sp-th-sort"></i></th>
                        <th>Position <i class="bi bi-arrow-down-up sp-th-sort"></i></th>
                        <th>Department <i class="bi bi-arrow-down-up sp-th-sort"></i></th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in historyItems %}
                    {% set p = item.evaluatee.fullName|split(' ') %}
                    {% set initials = p[0][:1]|upper ~ (p|length > 1 ? p[p|length - 1][:1]|upper : '') %}
                    <tr class="sp-history-row" data-search="{{ item.evaluatee.fullName }} {{ item.evaluateeLabel }} {{ item.evaluatee.department ? item.evaluatee.department.departmentName : '' }} {{ item.evaluation.schoolYear }} {{ item.evaluation.semester }}" data-year="{{ item.evaluation.schoolYear ?: '' }}">
                        <td>
                            <span class="sp-type-badge">{{ item.evaluation.evaluationType == 'SUPERIOR' ? 'SEF' : item.evaluation.evaluationType }}</span>
                        </td>
                        <td>
                            <div class="sp-period-title">{{ item.evaluation.schoolYear ?: '-' }} {{ item.evaluation.semester ?: '' }}</div>
                            <div class="sp-period-meta">Submitted {{ item.submittedAt|date('M d, Y h:i A') }}</div>
                        </td>
                        <td>
                            <div class="sp-person">
                                <span class="sp-avatar">
                                    <img src="{{ asset('images/' ~ item.evaluatee.profilePictureOrDefault) }}" alt="{{ item.evaluatee.fullName }} profile" onerror="this.onerror=null;this.src='{{ asset('images/default-profile.svg') }}';">
                                </span>
                                <div>
                                    <div class="sp-person-name">{{ item.evaluatee.fullName }}</div>
                                    <div class="sp-person-meta">Archived evaluation</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="sp-role {{ item.evaluateeLabel == 'Dean' ? 'sp-role-dean' : (item.evaluateeLabel == 'Department Head' ? 'sp-role-head' : 'sp-role-lead') }}">{{ item.evaluateeLabel }}</span>
                        </td>
                        <td>
                            <span class="sp-department-chip"><i class="bi bi-building"></i> {{ item.evaluatee.department ? item.evaluatee.department.departmentName : 'N/A' }}</span>
                        </td>
                        <td>
                            <span class="sp-status sp-status-submitted"><i class="bi bi-check-circle-fill"></i> Submitted</span>
                            <div class="sp-status-note">Avg: {{ item.averageRating|number_format(2) }}/5</div>
                        </td>
                        <td>
                            <a href="{{ path('superior_evaluate_view', {evalId: item.evaluation.id, evaluateeId: item.evaluatee.id}) }}" class="sp-action-icon" title="View evaluation"><i class="bi bi-eye"></i></a>
                        </td>
                    </tr>
                    {% endfor %}
                    <tr id="spHistoryNoResults" class="sp-no-results">
                        <td colspan="7">No previous submissions match your filter selection.</td>
                    </tr>
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="sp-empty">No previous evaluations found for the selected filter.</div>
        {% endif %}
    </div>
    {% endif %}

    {% if not hasOpenRecords and not hasHistoryRecords %}
    <div class="sp-panel">
        <div class="sp-empty">No evaluations are available at this time.</div>
    </div>
    {% endif %}
</div>

<script>
(() => {
    const initSuperiorEvaluateFilters = () => {
    const pageRoot = document.querySelector('.sp-page');
    if (!pageRoot || pageRoot.dataset.filtersBound === '1') {
        return;
    }
    pageRoot.dataset.filtersBound = '1';

    const searchInput = document.getElementById('spSearch');
    const recordType = document.getElementById('spRecordType');
    const openStatus = document.getElementById('spOpenStatus');
    const openPeriod = document.getElementById('spOpenPeriod');
    const historyYear = document.getElementById('spHistoryYear');

    const openPanel = document.getElementById('spOpenPanel');
    const historyPanel = document.getElementById('spHistoryPanel');

    const openStatusWrap = document.getElementById('spOpenStatusWrap');
    const openPeriodWrap = document.getElementById('spOpenPeriodWrap');
    const historyYearWrap = document.getElementById('spHistoryYearWrap');

    const openRows = Array.from(document.querySelectorAll('.sp-open-row'));
    const historyRows = Array.from(document.querySelectorAll('.sp-history-row'));

    const openNoResults = document.getElementById('spOpenNoResults');
    const historyNoResults = document.getElementById('spHistoryNoResults');

    if (!recordType && !searchInput) {
        return;
    }

    const getSearchTerm = () => (searchInput ? searchInput.value.trim().toLowerCase() : '');
    const getMode = () => {
        if (recordType) {
            return recordType.value;
        }

        return historyPanel && !openPanel ? 'previous' : 'open';
    };

    const applyOpenFilters = () => {
        let visibleCount = 0;
        const term = getSearchTerm();
        const status = openStatus ? openStatus.value : 'all';
        const period = openPeriod ? openPeriod.value : 'all';

        openRows.forEach((row) => {
            const rowSearch = (row.dataset.search || '').toLowerCase();
            const rowStatus = row.dataset.status || '';
            const rowPeriod = row.dataset.period || '';

            const matchesSearch = !term || rowSearch.includes(term);
            const matchesStatus = status === 'all' || rowStatus === status;
            const matchesPeriod = period === 'all' || rowPeriod === period;

            const visible = matchesSearch && matchesStatus && matchesPeriod;
            row.style.display = visible ? '' : 'none';
            if (visible) visibleCount++;
        });

        if (openNoResults) {
            openNoResults.style.display = visibleCount === 0 ? '' : 'none';
        }
    };

    const applyHistoryFilters = () => {
        let visibleCount = 0;
        const term = getSearchTerm();
        const year = historyYear ? historyYear.value : 'all';

        historyRows.forEach((row) => {
            const rowSearch = (row.dataset.search || '').toLowerCase();
            const rowYear = row.dataset.year || '';

            const matchesSearch = !term || rowSearch.includes(term);
            const matchesYear = year === 'all' || rowYear === year;

            const visible = matchesSearch && matchesYear;
            row.style.display = visible ? '' : 'none';
            if (visible) visibleCount++;
        });

        if (historyNoResults) {
            historyNoResults.style.display = visibleCount === 0 ? '' : 'none';
        }
    };

    const togglePanels = () => {
        const mode = getMode();

        if (openPanel) {
            openPanel.classList.toggle('is-hidden', mode !== 'open');
        }
        if (historyPanel) {
            historyPanel.classList.toggle('is-hidden', mode !== 'previous');
        }

        if (openStatusWrap) {
            openStatusWrap.style.display = mode === 'open' ? '' : 'none';
        }
        if (openPeriodWrap) {
            openPeriodWrap.style.display = mode === 'open' ? '' : 'none';
        }
        if (historyYearWrap) {
            historyYearWrap.style.display = mode === 'previous' ? '' : 'none';
        }

        if (mode === 'open') {
            applyOpenFilters();
        } else {
            applyHistoryFilters();
        }
    };

    if (searchInput) {
        searchInput.addEventListener('input', () => {
            const mode = getMode();
            if (mode === 'open') {
                applyOpenFilters();
            } else {
                applyHistoryFilters();
            }
        });
    }

    if (recordType) {
        recordType.addEventListener('change', togglePanels);
    }
    if (openStatus) {
        openStatus.addEventListener('change', applyOpenFilters);
    }
    if (openPeriod) {
        openPeriod.addEventListener('change', applyOpenFilters);
    }
    if (historyYear) {
        historyYear.addEventListener('change', applyHistoryFilters);
    }

    togglePanels();
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSuperiorEvaluateFilters, { once: true });
    } else {
        initSuperiorEvaluateFilters();
    }
    document.addEventListener('turbo:load', initSuperiorEvaluateFilters);
})();
</script>
{% endblock %}
