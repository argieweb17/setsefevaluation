<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>All Evaluations — {{ faculty.fullName }}</title>
    <style>
        /* ══════════════════════════════════════════════
           PRINT ALL — CONSOLIDATED MULTI-COURSE LAYOUT
           Matches Official NORSU QUAMC format.
           ══════════════════════════════════════════════ */

        @page {
            size: A4 landscape;
            margin: 8mm 10mm 8mm 10mm;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 0;
            padding: 12px 20px;
            color: #000;
            font-size: 9px;
            line-height: 1.3;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        /* ── Header Row: letterhead left + office info right ── */
        .header-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 6px;
        }
        .header-left {
            flex-shrink: 0;
            margin-left: 0;
        }
        .header-left img {
            max-height: 90px;
            width: auto;
        }
        .header-right {
            text-align: right;
            padding-top: 4px;
            margin-right: 10px;
        }
        .header-right .office-title {
            font-size: 14px;
            font-weight: 700;
            font-style: italic;
            margin-bottom: 4px;
        }
        .doc-info-table {
            border-collapse: collapse;
            font-size: 9px;
            margin-left: auto;
        }
        .doc-info-table td {
            border: 1px solid #000;
            padding: 1px 8px;
        }
        .doc-info-table .di-lbl {
            font-weight: 700;
            white-space: nowrap;
        }
        .doc-info-table .di-val {
            min-width: 60px;
        }
        .doc-info-table .di-page {
            text-align: center;
            font-weight: 400;
            vertical-align: middle;
            padding: 1px 12px;
            letter-spacing: 2px;
            font-size: 10px;
        }

        /* ── Title Block ── */
        .title-block {
            text-align: center;
            margin-bottom: 8px;
        }
        .title-block h2 {
            font-size: 13px;
            font-weight: 700;
            margin: 0;
        }

        /* ── Faculty Info Table ── */
        .info-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
            font-size: 10px;
        }
        .info-table td {
            padding: 4px 6px;
            border: none;
            vertical-align: bottom;
        }
        .info-table .lbl {
            font-weight: 700;
            white-space: nowrap;
        }
        .info-table .val {
            font-weight: 700;
            border-bottom: 1px solid #000;
            padding-left: 8px;
        }

        /* ── Main Content Area ── */
        .content-area {
            display: flex;
            gap: 8px;
            align-items: stretch;
            margin-bottom: 12px;
        }
        .table-area {
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .side-area {
            flex-shrink: 0;
            width: 165px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            align-items: center;
        }

        /* ── Results Table ── */
        .results-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 8px;
            border: 1px solid #000;
            margin: 0;
            padding: 0;
        }
        .results-table:first-child {
            margin-bottom: 0;
        }
        .results-table + .results-table {
            margin-top: 0;
        }
        .results-table th,
        .results-table td {
            border: 1px solid #000;
            padding: 3px 5px;
            text-align: center;
            vertical-align: middle;
        }
        .results-table th {
            font-weight: 700;
            font-size: 8px;
            background: #fff;
        }
        .results-table .item-cell {
            text-align: left;
            font-weight: 700;
            padding-left: 6px;
        }
        .results-table .empty-cell {
            background-color: #E8DCC8;
            color: #999;
        }
        .results-table .course-header {
            white-space: nowrap;
            font-size: 8px;
            font-weight: 700;
        }
        .results-table .total-row td {
            font-weight: 700;
        }
        .results-table .verbal-row td {
            font-weight: 700;
            font-size: 8px;
        }

        /* ── Rating Scale Box ── */
        .rating-scale-box {
            border: 1.5px solid #000;
            padding: 4px 4px;
            font-size: 7.5px;
            flex-shrink: 0;
            width: 100%;
            max-width: 150px;
        }
        .rating-scale-box .rs-title {
            font-weight: 700;
            font-size: 8px;
            margin-bottom: 4px;
            text-align: center;
            line-height: 1.3;
        }
        .rating-scale-box table {
            width: 100%;
            border-collapse: collapse;
            margin: 0;
        }
        .rating-scale-box tr {
            border-bottom: 0.5px solid #ccc;
        }
        .rating-scale-box tr:last-child {
            border-bottom: none;
        }
        .rating-scale-box td {
            padding: 3px 2px;
            font-size: 7px;
        }
        .rating-scale-box .rs-range {
            text-align: right;
            white-space: nowrap;
            font-weight: 600;
            padding-right: 3px;
        }
        .rating-scale-box .rs-label {
            font-weight: 700;
            text-align: left;
            padding-left: 3px;
        }

        /* ── Composite Rating Box ── */
        .composite-box {
            border: 2px solid #000;
            font-size: 7.5px;
            flex-shrink: 0;
            margin-top: auto;
            margin-bottom: auto;
            padding: 0;
            width: 100%;
            max-width: 150px;
        }
        .composite-box .cb-title {
            font-weight: 700;
            font-size: 8px;
            text-align: center;
            padding: 5px 2px;
            border-bottom: 2px solid #000;
            line-height: 1.4;
        }
        .composite-box table {
            width: 100%;
            border-collapse: collapse;
            margin: 0;
            border-spacing: 0;
        }
        .composite-box th {
            border: 1px solid #000;
            border-bottom: 1px solid #000;
            padding: 2px 2px;
            text-align: center;
            font-size: 6.5px;
            font-weight: 700;
            line-height: 1.1;
        }
        .composite-box td {
            border: 1px solid #000;
            padding: 2px 2px;
            text-align: center;
            font-size: 7px;
            font-weight: normal;
        }
        .composite-box .cb-total td {
            font-weight: 700;
            font-size: 8px;
            border-top: 2px solid #000;
            border-bottom: 2px solid #000;
            padding: 3px 2px;
        }
        .composite-box .cb-verbal td {
            font-weight: 700;
            font-size: 8px;
            padding: 3px 2px;
        }

        /* ── Purpose ── */
        .purpose {
            margin-top: 8px;
            font-size: 8px;
            font-style: italic;
        }
        .purpose strong { font-style: normal; }

        /* ── Signatures ── */
        .signature-section {
            margin-top: 60px;
            font-size: 10px;
            display: flex;
            justify-content: flex-start;
            gap: 100px;
        }
        .sig-block {
            text-align: left;
        }
        .sig-label {
            margin-bottom: 8px;
        }
        .sig-slot {
            height: 40px;
            margin-bottom: 4px;
            display: flex;
            align-items: flex-end;
        }
        .sig-image {
            display: block;
            max-width: 180px;
            max-height: 38px;
            width: auto;
            height: auto;
            object-fit: contain;
        }
        .sig-name {
            font-weight: 700;
            font-size: 10px;
        }
        .sig-title {
            font-size: 9px;
        }

        /* ── Disclaimer ── */
        .disclaimer {
            margin-top: 24px;
            font-size: 9px;
            line-height: 1.3;
        }
        .disclaimer strong { font-style: normal; }

        /* ── Print-specific ── */
        @media print {
            body { padding: 0; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body>

    {# ═══════════════════════════════════════════
       HEADER: Letterhead (left) + Office Info (right)
       ═══════════════════════════════════════════ #}
    <div class="header-row">
        <div class="header-left">
            <img src="{{ absolute_url(asset('images/header.jpg')) }}" alt="NORSU Letterhead">
        </div>
        <div class="header-right">
            <div class="office-title">Office of the University Quality Assurance Management Center</div>
            <table class="doc-info-table">
                <tr>
                    <td class="di-lbl">Document ID</td>
                    <td class="di-val">{{ correspondenceId|default('DTAL-OTUP-ODQA-F1249-V002') }}</td>
                    <td class="di-lbl">Issue Status</td>
                    <td class="di-val">3</td>
                    <td rowspan="3" class="di-page">P a g e&nbsp;|<strong>1</strong></td>
                </tr>
                <tr>
                    <td class="di-lbl">Issue Date</td>
                    <td class="di-val">{{ "now"|date("m-d-Y") }}</td>
                    <td class="di-lbl">Approved by</td>
                    <td class="di-val">ODQA</td>
                </tr>
                <tr>
                    <td class="di-lbl">Reviewed &amp; Authorized by</td>
                    <td class="di-val">ODQA</td>
                    <td></td>
                    <td></td>
                </tr>
            </table>
        </div>
    </div>

    {# ═══════════════════════════════════════════
       TITLE
       ═══════════════════════════════════════════ #}
    <div class="title-block">
        <h2>RESULT OF {{ evaluationType == 'SET' ? "STUDENT EVALUATION FOR TEACHER" : "SUPERIOR EVALUATION FOR FACULTY" }}</h2>
    </div>

    {# ═══════════════════════════════════════════
       FACULTY INFO
       ═══════════════════════════════════════════ #}
    <table class="info-table">
        <tr>
            <td class="lbl">Name of Faculty:</td>
            <td class="val">{{ faculty.lastName|upper }}, {{ faculty.firstName|upper }}</td>
            <td class="lbl">Campus:</td>
            <td class="val">{{ faculty.campus ?? 'N/A' }}</td>
            <td class="lbl">Course:</td>
            <td class="val">{{ faculty.department ? faculty.department.departmentName : 'N/A' }}</td>
            <td class="lbl">Sem/SY:</td>
            <td class="val">{{ semester ?? current_academic_year().semester ?? '' }} {{ schoolYear ?? '' }}</td>
            <td class="lbl" style="text-align:right;">Employment<br>Status:</td>
            <td class="val">{{ faculty.employmentStatus ?? 'N/A' }}</td>
        </tr>
    </table>

    {# ═══════════════════════════════════════════
       MAIN CONTENT: BACCALAUREATE TABLE + SIDE BOXES
       ═══════════════════════════════════════════ #}
    <div class="content-area">
        {# Baccalaureate Table on Left #}
        <div class="table-area">
            <table class="results-table">
                <thead>
                    <tr>
                        <th rowspan="3" style="width:auto;min-width:90px;">Item</th>
                        <th colspan="21" style="text-align:center; font-weight:700;">Baccalaureate Course</th>
                    </tr>
                    <tr>
                        {% for courseNum in 1..7 %}
                        <th colspan="3" class="course-header">Course {{ courseNum }}</th>
                        {% endfor %}
                    </tr>
                    <tr>
                        {% for courseNum in 1..7 %}
                        <th>Wx</th>
                        <th>W%</th>
                        <th>Rating</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for catName in categoryNames %}
                    <tr>
                        <td class="item-cell">{{ catName }}</td>
                        {% for courseEval in baccEvaluations %}
                            {% set categoryData = null %}
                            {% if courseEval.categorySummary %}
                                {% for cat in courseEval.categorySummary %}
                                    {% if cat.name == catName %}
                                        {% set categoryData = cat %}
                                    {% endif %}
                                {% endfor %}
                            {% endif %}
                            {% if categoryData %}
                                <td>{{ categoryData.mean|number_format(2) }}</td>
                                <td>{{ categoryData.weightPct }}%</td>
                                <td>{{ categoryData.weightedRating|number_format(2) }}</td>
                            {% else %}
                                <td class="empty-cell">0.00</td>
                                <td class="empty-cell">0%</td>
                                <td class="empty-cell">0.00</td>
                            {% endif %}
                        {% endfor %}
                    </tr>
                    {% endfor %}

                    <tr class="total-row">
                        <td class="item-cell">TOTAL</td>
                        {% for courseEval in baccEvaluations %}
                            {% if courseEval.compositeTotal %}
                            <td></td>
                            <td>100%</td>
                            <td>{{ courseEval.compositeTotal|number_format(2) }}</td>
                            {% else %}
                            <td class="empty-cell"></td>
                            <td class="empty-cell">100%</td>
                            <td class="empty-cell">0.00</td>
                            {% endif %}
                        {% endfor %}
                    </tr>

                    <tr class="verbal-row">
                        <td class="item-cell">RATING</td>
                        {% for courseEval in baccEvaluations %}
                            {% if courseEval.level and courseEval.level != 'N/A' %}
                            <td colspan="3">{{ courseEval.level }}</td>
                            {% else %}
                            <td colspan="3" class="empty-cell" style="font-style:italic; color:#999;">N/A</td>
                            {% endif %}
                        {% endfor %}
                    </tr>
                </tbody>
            </table>

            {# Graduate Table - Same Width as Baccalaureate #}
            <table class="results-table">
                <thead>
                    <tr>
                        <th rowspan="3" style="width:auto;min-width:90px;">Item</th>
                        <th colspan="21" style="text-align:center; font-weight:700;">Graduate Course</th>
                    </tr>
                    <tr>
                        {% for courseNum in 1..7 %}
                        <th colspan="3" class="course-header">Course {{ 7 + courseNum }}</th>
                        {% endfor %}
                    </tr>
                    <tr>
                        {% for courseNum in 1..7 %}
                        <th>Wx</th>
                        <th>W%</th>
                        <th>Rating</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for catName in categoryNames %}
                    <tr>
                        <td class="item-cell">{{ catName }}</td>
                        {% for courseEval in gradEvaluations %}
                            {% set categoryData = null %}
                            {% if courseEval.categorySummary %}
                                {% for cat in courseEval.categorySummary %}
                                    {% if cat.name == catName %}
                                        {% set categoryData = cat %}
                                    {% endif %}
                                {% endfor %}
                            {% endif %}
                            {% if categoryData %}
                                <td>{{ categoryData.mean|number_format(2) }}</td>
                                <td>{{ categoryData.weightPct }}%</td>
                                <td>{{ categoryData.weightedRating|number_format(2) }}</td>
                            {% else %}
                                <td class="empty-cell">0.00</td>
                                <td class="empty-cell">0%</td>
                                <td class="empty-cell">0.00</td>
                            {% endif %}
                        {% endfor %}
                    </tr>
                    {% endfor %}

                    <tr class="total-row">
                        <td class="item-cell">TOTAL</td>
                        {% for courseEval in gradEvaluations %}
                            {% if courseEval.compositeTotal %}
                            <td></td>
                            <td>100%</td>
                            <td>{{ courseEval.compositeTotal|number_format(2) }}</td>
                            {% else %}
                            <td class="empty-cell"></td>
                            <td class="empty-cell">100%</td>
                            <td class="empty-cell">0.00</td>
                            {% endif %}
                        {% endfor %}
                    </tr>

                    <tr class="verbal-row">
                        <td class="item-cell">RATING</td>
                        {% for courseEval in gradEvaluations %}
                            {% if courseEval.level and courseEval.level != 'N/A' %}
                            <td colspan="3">{{ courseEval.level }}</td>
                            {% else %}
                            <td colspan="3" class="empty-cell" style="font-style:italic; color:#999;">N/A</td>
                            {% endif %}
                        {% endfor %}
                    </tr>
                </tbody>
            </table>
        </div>

        {# Rating Scale + Composite on Right #}
        <div class="side-area">
            {# Rating Scale Interpretation #}
            <div class="rating-scale-box">
                <div class="rs-title">Rating Scale<br>Interpretation</div>
                <table>
                    <tr>
                        <td class="rs-range">5.00–4.21</td>
                        <td class="rs-label">Excellent</td>
                    </tr>
                    <tr>
                        <td class="rs-range">4.20–3.41</td>
                        <td class="rs-label">Very Good</td>
                    </tr>
                    <tr>
                        <td class="rs-range">3.40–2.61</td>
                        <td class="rs-label">Good</td>
                    </tr>
                    <tr>
                        <td class="rs-range">2.60–1.81</td>
                        <td class="rs-label">Fair</td>
                    </tr>
                    <tr>
                        <td class="rs-range">1.80–1.00</td>
                        <td class="rs-label">Poor</td>
                    </tr>
                </table>
            </div>

            {# Composite Rating #}
            <div class="composite-box">
                <div class="cb-title">Composite<br>Rating</div>
                <table>
                    <thead>
                        <tr>
                            <th>Weighted<br>Mean</th>
                            <th>Weighted<br>Rating</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for cc in compositeCategories %}
                        <tr>
                            <td>{{ cc.weightedMean|number_format(2) }}</td>
                            <td>{{ cc.weightedRating|number_format(2) }}</td>
                        </tr>
                        {% endfor %}
                        <tr class="cb-total">
                            <td colspan="2">{{ compositeGrandTotal|number_format(2) }}</td>
                        </tr>
                        <tr class="cb-verbal">
                            <td colspan="2">{{ compositeLevel }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════
       PURPOSE
       ═══════════════════════════════════════════ #}
    <div class="purpose">
        <strong>Purpose:</strong> For IPCR purpose only.
    </div>

    {# ═══════════════════════════════════════════
       SIGNATURES
       ═══════════════════════════════════════════ #}
    <div class="signature-section">
        <div class="sig-block">
            <div class="sig-label">Prepared by:</div>
            <div class="sig-slot">
                {% if preparedSignature is defined and preparedSignature is not empty %}
                    <img src="{{ preparedSignature }}" alt="Prepared signature" class="sig-image">
                {% endif %}
            </div>
            <div class="sig-name">{{ preparedBy|default('Argie Pair Pagbunocan') }}</div>
            <div class="sig-title">{{ preparedTitle|default('QUAMC Staff') }}</div>
        </div>
        <div class="sig-block">
            <div class="sig-label">Certified by:</div>
            <div class="sig-slot">
                {% if certifiedSignature is defined and certifiedSignature is not empty %}
                    <img src="{{ certifiedSignature }}" alt="Certified signature" class="sig-image">
                {% endif %}
            </div>
            <div class="sig-name">{{ certifiedBy|default('CESAR P. ESTROPE, Ed.D') }}</div>
            <div class="sig-title">{{ certifiedTitle|default('Director, Quality Assurance Management Center') }}</div>
        </div>
    </div>

    {# ═══════════════════════════════════════════
       DISCLAIMER
       ═══════════════════════════════════════════ #}
    <div class="disclaimer">
        <strong><em>Disclaimer:</em></strong> <em>The information transmitted by this document is intended only for the person or entity to which it is addressed. This document may contain proprietary, business-confidential and/or privileged material. If you are not the intended recipient of this message, be aware that any use, review, retransmission, distribution, reproduction or any action taken in reliance upon this message is strictly prohibited. If you received this in error, please contact the sender. Thank you</em>
    </div>

    {# Auto-trigger print dialog #}
    <script>
        window.addEventListener('load', function() {
            setTimeout(function() { window.print(); }, 400);
        });
    </script>
</body>
</html>
