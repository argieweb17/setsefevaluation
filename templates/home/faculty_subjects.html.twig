                            <label class="form-label fw-semibold" style="font-size:.75rem;">Subject Code <span class="text-danger">*</span></label>
                            <input type="text" name="subjectCode" class="form-control form-control-sm" placeholder="e.g. CS 101" required style="border-radius:8px;font-size:.82rem;">
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold" style="font-size:.75rem;">Subject Name <span class="text-danger">*</span></label>
                            <input type="text" name="subjectName" class="form-control form-control-sm" placeholder="e.g. Introduction to Computing" required style="border-radius:8px;font-size:.82rem;">
