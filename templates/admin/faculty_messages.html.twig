{% extends 'base.html.twig' %}
{% set prefix = staffMode|default(false) ? 'staff' : 'admin' %}

{% block title %}Faculty Messages | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ═══════════════════════════════════════
   CSS VARIABLES - Modern Chat Style
   ═══════════════════════════════════════ */
:root {
    --chat-blue: #2563eb;
    --chat-blue-light: #3b82f6;
    --chat-bg: #f8f9fa;
    --chat-sidebar-bg: #ffffff;
    --chat-border: #e5e7eb;
    --chat-text-primary: #1f2937;
    --chat-text-secondary: #6b7280;
    --chat-text-muted: #9ca3af;
    --chat-bubble-out: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    --chat-bubble-in: #ffffff;
    --chat-radius: 20px;
    --chat-radius-sm: 12px;
    --chat-success: #10b981;
    --chat-warning: #f59e0b;
    --chat-danger: #ef4444;
}

/* ═══════════════════════════════════════
   MAIN CONTAINER
   ═══════════════════════════════════════ */
.fm-app {
    display: flex;
    height: calc(100vh - 100px);
    min-height: 600px;
    background: var(--chat-bg);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,.08);
}

/* ═══════════════════════════════════════
   SIDEBAR - Clean Contact List
   ═══════════════════════════════════════ */
.fm-sidebar {
    width: 340px;
    min-width: 300px;
    background: var(--chat-sidebar-bg);
    border-right: 1px solid var(--chat-border);
    display: flex;
    flex-direction: column;
}

/* Filter Tabs */
.fm-filter-section {
    padding: 16px;
    border-bottom: 1px solid var(--chat-border);
}
.fm-filter-tabs {
    display: flex;
    gap: 4px;
    background: var(--chat-bg);
    padding: 4px;
    border-radius: 24px;
}
.fm-filter-tab {
    flex: 1;
    padding: 8px 6px;
    border: none;
    background: transparent;
    border-radius: 20px;
    font-size: .75rem;
    font-weight: 600;
    color: var(--chat-text-secondary);
    cursor: pointer;
    transition: all .2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
}
.fm-filter-tab:hover {
    color: var(--chat-text-primary);
}
.fm-filter-tab.active {
    background: var(--chat-bubble-out);
    color: #fff;
}
.fm-filter-count {
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 9px;
    background: rgba(0,0,0,.08);
    font-size: .65rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
.fm-filter-tab.active .fm-filter-count {
    background: rgba(255,255,255,.25);
    color: #fff;
}

/* Search Section */
.fm-search-section {
    padding: 12px 16px;
    border-bottom: 1px solid var(--chat-border);
}
.fm-search-wrap {
    position: relative;
}
.fm-search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--chat-text-muted);
    font-size: .9rem;
    pointer-events: none;
}
.fm-search-input {
    width: 100%;
    padding: 10px 16px 10px 42px;
    border: none;
    border-radius: 24px;
    font-size: .85rem;
    color: var(--chat-text-primary);
    background: var(--chat-bg);
    outline: none;
    transition: all .2s ease;
}
.fm-search-input:focus {
    box-shadow: 0 0 0 2px var(--chat-blue);
}
.fm-search-input::placeholder {
    color: var(--chat-text-muted);
}

/* Conversation List */
.fm-conv-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
}
.fm-conv-list::-webkit-scrollbar {
    width: 4px;
}
.fm-conv-list::-webkit-scrollbar-track {
    background: transparent;
}
.fm-conv-list::-webkit-scrollbar-thumb {
    background: #ddd;
    border-radius: 2px;
}

.fm-conv-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    cursor: pointer;
    transition: background .15s ease;
    border-left: 3px solid transparent;
}
.fm-conv-item:hover {
    background: var(--chat-bg);
}
.fm-conv-item.active {
    background: #eff6ff;
    border-left-color: var(--chat-blue);
}
.fm-conv-item.unread {
    background: #fffbeb;
    border-left-color: var(--chat-warning);
}

/* Avatar - Round with photo */
.fm-avatar {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .85rem;
    font-weight: 600;
    flex-shrink: 0;
    overflow: hidden;
}
.fm-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Conversation Info */
.fm-conv-info {
    flex: 1;
    min-width: 0;
}
.fm-conv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2px;
}
.fm-conv-name {
    font-size: .9rem;
    font-weight: 600;
    color: var(--chat-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-conv-time {
    font-size: .7rem;
    color: var(--chat-text-muted);
    flex-shrink: 0;
}
.fm-conv-preview {
    font-size: .8rem;
    color: var(--chat-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-conv-item.active .fm-conv-preview {
    color: var(--chat-blue);
}
.fm-status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
}
.fm-status-dot.pending { background: var(--chat-warning); }
.fm-status-dot.reviewed { background: var(--chat-blue); }
.fm-status-dot.resolved { background: var(--chat-success); }

/* ═══════════════════════════════════════
   CHAT PANEL - Clean Modern Style
   ═══════════════════════════════════════ */
.fm-chat {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--chat-bg);
}

/* Chat Header - Simple */
.fm-chat-header {
    padding: 14px 20px;
    background: #fff;
    border-bottom: 1px solid var(--chat-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}
.fm-chat-user {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
}
.fm-chat-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .85rem;
    font-weight: 600;
    flex-shrink: 0;
    overflow: hidden;
}
.fm-chat-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.fm-chat-details {
    flex: 1;
    min-width: 0;
}
.fm-chat-details h5 {
    font-size: .95rem;
    font-weight: 600;
    color: var(--chat-text-primary);
    margin: 0 0 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-chat-meta {
    font-size: .75rem;
    color: var(--chat-text-secondary);
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}
.fm-chat-meta i {
    font-size: .7rem;
    margin-right: 3px;
}
.fm-chat-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
}
.fm-status-badge {
    padding: 6px 12px;
    border-radius: 20px;
    font-size: .7rem;
    font-weight: 600;
    text-transform: uppercase;
}
.fm-status-pending { background: #fef3c7; color: #b45309; }
.fm-status-reviewed { background: #dbeafe; color: #2563eb; }
.fm-status-resolved { background: #d1fae5; color: #059669; }
.fm-action-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--chat-border);
    background: #fff;
    color: var(--chat-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .9rem;
    transition: all .2s ease;
}
.fm-action-btn:hover {
    border-color: var(--chat-danger);
    color: var(--chat-danger);
    background: #fef2f2;
}

/* Chat Body */
.fm-chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.fm-thread {
    display: flex;
    flex-direction: column;
    gap: 12px;
}
.fm-chat-body::-webkit-scrollbar {
    width: 4px;
}
.fm-chat-body::-webkit-scrollbar-track {
    background: transparent;
}
.fm-chat-body::-webkit-scrollbar-thumb {
    background: #ddd;
    border-radius: 2px;
}

/* Date Separator */
.fm-date-sep {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 12px 0;
}
.fm-date-sep span {
    font-size: .72rem;
    font-weight: 500;
    color: var(--chat-text-muted);
    padding: 5px 12px;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 1px 2px rgba(0,0,0,.05);
}

/* Message Bubbles - Clean Style */
.fm-message {
    display: flex;
    flex-direction: column;
    max-width: 70%;
    width: fit-content;
    margin-bottom: 4px;
}
.fm-message.incoming {
    align-self: flex-start;
    align-items: flex-start;
}
.fm-message.outgoing {
    align-self: flex-end;
    align-items: flex-end;
}

.fm-message-sender {
    font-size: .72rem;
    font-weight: 500;
    color: var(--chat-text-secondary);
    margin-bottom: 4px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    width: max-content;
}
.fm-message-sender i {
    color: var(--chat-blue);
    font-size: .65rem;
}

.fm-bubble {
    display: inline-block;
    width: max-content;
    max-width: 100%;
    padding: 10px 14px;
    font-size: .88rem;
    line-height: 1.5;
    white-space: pre-line;
    word-break: break-word;
}

/* Incoming - White bubble (from faculty) */
.fm-message.incoming .fm-bubble {
    background: var(--chat-bubble-in);
    color: var(--chat-text-primary);
    border-radius: var(--chat-radius) var(--chat-radius) var(--chat-radius) 6px;
    box-shadow: 0 1px 2px rgba(0,0,0,.08);
}

/* Outgoing - Purple bubble (admin/staff reply) */
.fm-message.outgoing .fm-bubble {
    background: var(--chat-bubble-out);
    color: #fff;
    border-radius: var(--chat-radius) var(--chat-radius) 6px var(--chat-radius);
}

.fm-message-time {
    font-size: .68rem;
    color: var(--chat-text-muted);
    margin-top: 4px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: max-content;
}
.fm-message.outgoing .fm-message-time {
    justify-content: flex-end;
}
.fm-message-time .read-icon {
    color: #60a5fa;
}

/* Attachment */
.fm-attachment {
    margin-top: 10px;
    padding: 10px 12px;
    background: rgba(0,0,0,.03);
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
}
.fm-message.outgoing .fm-attachment {
    background: rgba(0,0,0,.03);
}
.fm-attachment-icon {
    width: 36px;
    height: 36px;
    background: var(--chat-blue);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1rem;
}
.fm-message.outgoing .fm-attachment-icon {
    background: var(--chat-blue);
}
.fm-attachment-info {
    flex: 1;
    min-width: 0;
}
.fm-attachment-name {
    font-size: .85rem;
    font-weight: 500;
    color: var(--chat-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-message.outgoing .fm-attachment-name {
    color: var(--chat-text-primary);
}
.fm-attachment-size {
    font-size: .75rem;
    color: var(--chat-text-muted);
}
.fm-message.outgoing .fm-attachment-size {
    color: var(--chat-text-muted);
}
.fm-attachment-download {
    width: 32px;
    height: 32px;
    background: var(--chat-blue);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
    font-size: .9rem;
    transition: all .2s ease;
}
.fm-attachment-download:hover {
    background: var(--chat-blue-light);
    transform: scale(1.05);
}
.fm-message.outgoing .fm-attachment-download {
    background: var(--chat-blue);
}
.fm-message.outgoing .fm-attachment-download:hover {
    background: var(--chat-blue-light);
}
.fm-attachment-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: .78rem;
    font-weight: 500;
    text-decoration: none;
    transition: all .15s ease;
}
.fm-message.incoming .fm-attachment-link {
    background: var(--chat-bg);
    color: var(--chat-text-secondary);
}
.fm-message.incoming .fm-attachment-link:hover {
    background: #e5e7eb;
}
.fm-message.outgoing .fm-attachment-link {
    background: rgba(255,255,255,.2);
    color: #fff;
}
.fm-message.outgoing .fm-attachment-link:hover {
    background: rgba(255,255,255,.3);
}

/* Empty State */
.fm-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    text-align: center;
}
.fm-empty-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--chat-blue);
    margin-bottom: 20px;
}
.fm-empty-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--chat-text-primary);
    margin: 0 0 8px;
}
.fm-empty-text {
    font-size: .88rem;
    color: var(--chat-text-secondary);
    max-width: 280px;
    line-height: 1.5;
    margin: 0;
}

/* Compose Area - Simple */
.fm-compose {
    padding: 14px 20px;
    background: #fff;
    border-top: 1px solid var(--chat-border);
}
.fm-compose-inner {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    background: var(--chat-bg);
    border-radius: 24px;
    padding: 8px 8px 8px 16px;
}
.fm-compose-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.fm-textarea {
    width: 100%;
    padding: 8px 0;
    border: none;
    font-size: .88rem;
    color: var(--chat-text-primary);
    background: transparent;
    outline: none;
    resize: none;
    min-height: 24px;
    max-height: 120px;
    font-family: inherit;
    line-height: 1.5;
}
.fm-textarea::placeholder {
    color: var(--chat-text-muted);
}
.fm-compose-tools {
    display: flex;
    align-items: center;
    gap: 8px;
}
.fm-tool-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--chat-text-muted);
    cursor: pointer;
    transition: all .15s ease;
    font-size: .9rem;
}
.fm-tool-btn:hover {
    background: #fff;
    color: var(--chat-blue);
}
.fm-status-select {
    padding: 6px 10px;
    border: 1px solid var(--chat-border);
    border-radius: 16px;
    font-size: .75rem;
    font-weight: 500;
    color: var(--chat-text-secondary);
    background: #fff;
    cursor: pointer;
    outline: none;
}
.fm-status-select:focus {
    border-color: var(--chat-blue);
}
.fm-send-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: none;
    background: var(--chat-bubble-out);
    color: #fff;
    font-size: 1rem;
    cursor: pointer;
    transition: all .2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.fm-send-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(124,58,237,.3);
}
.fm-file-name {
    font-size: .72rem;
    color: var(--chat-text-secondary);
    display: flex;
    align-items: center;
    gap: 4px;
}

/* Delete Modal */
.fm-modal-danger-header {
    background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%);
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
}
.fm-modal-icon {
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.1rem;
}

/* ═══════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════ */
@media (max-width: 992px) {
    .fm-app {
        flex-direction: column;
        height: auto;
        min-height: calc(100vh - 80px);
    }
    .fm-sidebar {
        width: 100%;
        min-width: 100%;
        max-height: 350px;
        border-right: none;
        border-bottom: 1px solid var(--chat-border);
    }
    .fm-conv-list {
        max-height: 180px;
    }
    .fm-chat-body {
        min-height: 400px;
    }
    .fm-message {
        max-width: 85%;
    }
}
@media (max-width: 576px) {
    .fm-chat-header {
        padding: 12px 14px;
        flex-wrap: wrap;
    }
    .fm-chat-body {
        padding: 14px;
    }
    .fm-compose {
        padding: 10px 14px;
    }
    .fm-message {
        max-width: 90%;
    }
}

/* Animations */
.fm-conv-item {
    animation: fm-slide-in .2s ease;
}
@keyframes fm-slide-in {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
}
.fm-message {
    animation: fm-fade-up .2s ease;
}
@keyframes fm-fade-up {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>
{% endblock %}

{% block body %}
{% set pendingMessages = messages|filter(m => m.status == 'pending')|length %}
{% set reviewedMessages = messages|filter(m => m.status == 'reviewed')|length %}
{% set resolvedMessages = messages|filter(m => m.status == 'resolved')|length %}

<div class="fm-app">
    {# ═══════════════════════════════════════
       SIDEBAR - Clean Contact List
       ═══════════════════════════════════════ #}
    <aside class="fm-sidebar">
        <div class="fm-filter-section">
            <div class="fm-filter-tabs">
                <button class="fm-filter-tab active" data-filter="all" onclick="filterMessages('all', this)">
                    All <span class="fm-filter-count">{{ messages|length }}</span>
                </button>
                <button class="fm-filter-tab" data-filter="pending" onclick="filterMessages('pending', this)">
                    Pending <span class="fm-filter-count">{{ pendingMessages }}</span>
                </button>
                <button class="fm-filter-tab" data-filter="reviewed" onclick="filterMessages('reviewed', this)">
                    Reviewed <span class="fm-filter-count">{{ reviewedMessages }}</span>
                </button>
                <button class="fm-filter-tab" data-filter="resolved" onclick="filterMessages('resolved', this)">
                    Done <span class="fm-filter-count">{{ resolvedMessages }}</span>
                </button>
            </div>
        </div>

        <div class="fm-search-section">
            <div class="fm-search-wrap">
                <i class="bi bi-search fm-search-icon"></i>
                <input type="text" class="fm-search-input" id="searchInput" placeholder="Search..." oninput="searchMessages()">
            </div>
        </div>

        <div class="fm-conv-list" id="convList">
            {% for msg in messages %}
            {% set lastMessage = msg.message %}
            {% if repliesMap[msg.id] is defined and repliesMap[msg.id]|length > 0 %}
                {% set lastReply = repliesMap[msg.id]|last %}
                {% set lastMessage = lastReply.message %}
            {% elseif msg.adminReply %}
                {% set lastMessage = msg.adminReply %}
            {% endif %}
            <div class="fm-conv-item{% if loop.first %} active{% endif %}{% if msg.status == 'pending' %} unread{% endif %}"
                 data-msg-id="{{ msg.id }}"
                 data-status="{{ msg.status }}"
                 data-search="{{ msg.sender.fullName|lower }} {{ msg.sender.department ? msg.sender.department.departmentName|lower : '' }} {{ msg.subject|lower }}"
                 onclick="selectConversation(this, {{ msg.id }})">
                <div class="fm-avatar">
                    <img src="{{ asset('images/' ~ msg.sender.profilePictureOrDefault) }}" alt="">
                </div>
                <div class="fm-conv-info">
                    <div class="fm-conv-header">
                        <span class="fm-conv-name">{{ msg.sender.fullName }}</span>
                        <span class="fm-conv-time">{{ msg.createdAt|date('M d') }}</span>
                    </div>
                    <div class="fm-conv-preview">
                        <span class="fm-status-dot {{ msg.status }}"></span>
                        {{ lastMessage|slice(0, 35) }}{% if lastMessage|length > 35 %}...{% endif %}
                    </div>
                </div>
            </div>
            {% else %}
            <div class="fm-empty-state" style="padding:40px 20px;">
                <div class="fm-empty-icon" style="width:60px;height:60px;font-size:1.5rem;margin-bottom:14px;">
                    <i class="bi bi-inbox"></i>
                </div>
                <h5 class="fm-empty-title" style="font-size:.95rem;">No messages</h5>
                <p class="fm-empty-text" style="font-size:.8rem;margin-bottom:0;">Messages will appear here</p>
            </div>
            {% endfor %}
        </div>
    </aside>

    {# ═══════════════════════════════════════
       CHAT PANEL - Clean Style
       ═══════════════════════════════════════ #}
    <main class="fm-chat">
        {% if messages|length > 0 %}
        {% set firstMsg = messages|first %}

        <header class="fm-chat-header" id="chatHeader">
            <div class="fm-chat-user">
                <div class="fm-chat-avatar" id="chatAvatar">
                    <img src="{{ asset('images/' ~ firstMsg.sender.profilePictureOrDefault) }}" alt="">
                </div>
                <div class="fm-chat-details">
                    <h5 id="chatName">{{ firstMsg.sender.fullName }}</h5>
                    <div class="fm-chat-meta">
                        {% if firstMsg.sender.department %}
                        <span id="chatDept"><i class="bi bi-building"></i>{{ firstMsg.sender.department.departmentName }}</span>
                        {% endif %}
                        {% if firstMsg.evaluationPeriod %}
                        <span id="chatEval"><i class="bi bi-clipboard2-check"></i>{{ firstMsg.evaluationPeriod.evaluationType }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="fm-chat-actions">
                <span class="fm-status-badge fm-status-{{ firstMsg.status }}" id="chatStatusBadge">
                    {{ firstMsg.status|capitalize }}
                </span>
                <button type="button" class="fm-action-btn" title="Delete" data-bs-toggle="modal" data-bs-target="#deleteCurrentMsg">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>
        </header>

        <div class="fm-chat-body" id="chatBody">
            {% for msg in messages %}
            <div class="fm-thread" id="thread-{{ msg.id }}"{% if not loop.first %} style="display:none"{% endif %} data-msg-id="{{ msg.id }}">
                <div class="fm-date-sep">
                    <span>{{ msg.createdAt|date('M d, Y') }}</span>
                </div>

                {# Faculty's message (incoming - white) #}
                <div class="fm-message incoming">
                    <div class="fm-message-sender">
                        <i class="bi bi-circle-fill"></i> {{ msg.sender.fullName }}
                    </div>
                    <div class="fm-bubble">{{- msg.message|trim -}}</div>
                    {%- if msg.attachment %}
                    <div class="fm-attachment">
                        <div class="fm-attachment-icon"><i class="bi bi-file-earmark-text"></i></div>
                        <div class="fm-attachment-info">
                            <div class="fm-attachment-name">{{ msg.attachmentOriginalName }}</div>
                            <div class="fm-attachment-size">Click to download</div>
                        </div>
                        <a href="{{ asset('uploads/attachments/' ~ msg.attachment) }}" download="{{ msg.attachmentOriginalName }}" class="fm-attachment-download"><i class="bi bi-download"></i></a>
                    </div>
                    {%- endif %}
                    <div class="fm-message-time">{{ msg.createdAt|date('h:i A') }}</div>
                </div>

                {# Old admin reply (backward compatibility) #}
                {% if msg.adminReply %}
                <div class="fm-message outgoing">
                    <div class="fm-bubble">{{- msg.adminReply|trim -}}</div>
                    <div class="fm-message-time">
                        {{ msg.repliedAt|date('h:i A') }}
                        <i class="bi bi-check2-all read-icon"></i>
                    </div>
                </div>
                {% endif %}

                {# Conversation thread replies #}
                {% if repliesMap[msg.id] is defined %}
                {% for reply in repliesMap[msg.id] %}
                {% if reply.senderType == 'faculty' %}
                {# Faculty's reply (incoming - white) #}
                <div class="fm-message incoming">
                    <div class="fm-message-sender">
                        <i class="bi bi-circle-fill"></i> {{ reply.sender.fullName }}
                    </div>
                    <div class="fm-bubble">{{- reply.message|trim -}}</div>
                    {%- if reply.attachment %}
                    <div class="fm-attachment">
                        <div class="fm-attachment-icon"><i class="bi bi-file-earmark-text"></i></div>
                        <div class="fm-attachment-info">
                            <div class="fm-attachment-name">{{ reply.attachmentOriginalName }}</div>
                            <div class="fm-attachment-size">Click to download</div>
                        </div>
                        <a href="{{ asset('uploads/attachments/' ~ reply.attachment) }}" download="{{ reply.attachmentOriginalName }}" class="fm-attachment-download"><i class="bi bi-download"></i></a>
                    </div>
                    {%- endif %}
                    <div class="fm-message-time">{{ reply.createdAt|date('h:i A') }}</div>
                </div>
                {% else %}
                {# Admin/Staff reply (outgoing - purple) #}
                <div class="fm-message outgoing">
                    <div class="fm-bubble">{{- reply.message|trim -}}</div>
                    {%- if reply.attachment %}
                    <div class="fm-attachment">
                        <div class="fm-attachment-icon"><i class="bi bi-file-earmark-text"></i></div>
                        <div class="fm-attachment-info">
                            <div class="fm-attachment-name">{{ reply.attachmentOriginalName }}</div>
                            <div class="fm-attachment-size">Click to download</div>
                        </div>
                    </div>
                    {%- endif %}
                    <div class="fm-message-time">
                        {{ reply.createdAt|date('h:i A') }}
                        <i class="bi bi-check2-all read-icon"></i>
                    </div>
                </div>
                {% endif %}
                {% endfor %}
                {% endif %}
            </div>
            {% endfor %}
        </div>

        {# Compose areas #}
        {% for msg in messages %}
        <div class="fm-compose" id="compose-{{ msg.id }}"{% if not loop.first %} style="display:none"{% endif %}>
            <form method="post" action="{{ path(prefix ~ '_faculty_message_reply', {id: msg.id}) }}" enctype="multipart/form-data">
                <div class="fm-compose-inner">
                    <div class="fm-compose-left">
                        <textarea name="reply" class="fm-textarea" placeholder="Type a message..." required></textarea>
                        <div class="fm-compose-tools">
                            <label class="fm-tool-btn" title="Attach file">
                                <i class="bi bi-paperclip"></i>
                                <input type="file" name="attachment" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.jpg,.jpeg,.png" class="d-none" onchange="updateFileName(this, {{ msg.id }})">
                            </label>
                            <select name="status" class="fm-status-select">
                                <option value="pending" {% if msg.status == 'pending' %}selected{% endif %}>Pending</option>
                                <option value="reviewed" {% if msg.status == 'reviewed' %}selected{% endif %}>Reviewed</option>
                                <option value="resolved" {% if msg.status == 'resolved' %}selected{% endif %}>Resolved</option>
                            </select>
                            <span class="fm-file-name" id="fileName-{{ msg.id }}"></span>
                        </div>
                    </div>
                    <button type="submit" class="fm-send-btn">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </form>
        </div>
        {% endfor %}

        {% else %}
        <div class="fm-empty-state">
            <div class="fm-empty-icon">
                <i class="bi bi-envelope-open"></i>
            </div>
            <h5 class="fm-empty-title">No messages yet</h5>
            <p class="fm-empty-text">Faculty messages will appear here when they reach out.</p>
        </div>
        {% endif %}
    </main>
</div>

{# Delete Modal #}
<div class="modal fade" id="deleteCurrentMsg" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">
            <form method="post" id="deleteCurrentForm" action="{% if messages|length > 0 %}{{ path(prefix ~ '_faculty_message_delete', {id: messages|first.id}) }}{% endif %}">
                <input type="hidden" name="_token" id="deleteCurrentToken" value="{% if messages|length > 0 %}{{ csrf_token('admin_delete_msg' ~ messages|first.id) }}{% endif %}">
                <div class="fm-modal-danger-header">
                    <div class="fm-modal-icon">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div>
                        <h6 class="text-white fw-bold mb-0">Delete Message</h6>
                        <small class="text-white-50">Cannot be undone</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-3" style="font-size:.88rem;color:var(--chat-text-secondary);">
                        Delete conversation with <strong id="deleteCurrentName" style="color:var(--chat-text-primary);">{% if messages|length > 0 %}{{ messages|first.sender.fullName }}{% endif %}</strong>?
                    </p>
                    <div class="p-3 rounded" style="background:var(--chat-bg);border:1px solid var(--chat-border);">
                        <strong class="d-block mb-1" style="font-size:.82rem;color:var(--chat-text-primary);" id="deleteCurrentSubject">{% if messages|length > 0 %}{{ messages|first.subject }}{% endif %}</strong>
                        <small style="color:var(--chat-text-muted);" id="deleteCurrentDate">{% if messages|length > 0 %}{{ messages|first.createdAt|date('M d, Y') }}{% endif %}</small>
                    </div>
                </div>
                <div class="modal-footer" style="background:var(--chat-bg);border-top:1px solid var(--chat-border);padding:14px 18px;">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal" style="font-weight:600;border-radius:20px;">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4" style="font-weight:600;border-radius:20px;">
                        <i class="bi bi-trash3 me-1"></i> Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{# Flash Messages #}
{% for label, msgs in app.flashes %}
<div class="position-fixed top-0 end-0 p-3" style="z-index:9999;">
    <div class="toast show align-items-center text-white bg-{{ label == 'error' ? 'danger' : label }}" role="alert" style="border-radius:12px;">
        <div class="d-flex">
            <div class="toast-body fw-semibold">{% for m in msgs %}{{ m }}{% endfor %}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>
{% endfor %}

<script>
const messagesData = {
    {% for msg in messages %}
    {{ msg.id }}: {
        id: {{ msg.id }},
        senderName: "{{ msg.sender.fullName|e('js') }}",
        senderPhoto: "{{ asset('images/' ~ msg.sender.profilePictureOrDefault) }}",
        department: {% if msg.sender.department %}"{{ msg.sender.department.departmentName|e('js') }}"{% else %}null{% endif %},
        subject: "{{ msg.subject|e('js') }}",
        status: "{{ msg.status }}",
        createdAt: "{{ msg.createdAt|date('M d, Y') }}",
        evalLabel: {% if msg.evaluationPeriod %}"{{ msg.evaluationPeriod.evaluationType }}"{% else %}null{% endif %},
        deleteUrl: "{{ path(prefix ~ '_faculty_message_delete', {id: msg.id}) }}",
        deleteToken: "{{ csrf_token('admin_delete_msg' ~ msg.id) }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
};

let currentMsgId = {{ messages|length > 0 ? messages|first.id : 'null' }};

function selectConversation(el, msgId) {
    currentMsgId = msgId;

    document.querySelectorAll('.fm-conv-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');

    document.querySelectorAll('.fm-thread').forEach(t => t.style.display = 'none');
    document.querySelectorAll('.fm-compose').forEach(c => c.style.display = 'none');

    const thread = document.getElementById('thread-' + msgId);
    const compose = document.getElementById('compose-' + msgId);
    if (thread) thread.style.display = 'flex';
    if (compose) compose.style.display = 'block';

    const msg = messagesData[msgId];
    if (msg) {
        const avatarEl = document.getElementById('chatAvatar');
        avatarEl.innerHTML = '<img src="' + msg.senderPhoto + '" alt="">';

        document.getElementById('chatName').textContent = msg.senderName;

        const deptEl = document.getElementById('chatDept');
        if (deptEl) {
            if (msg.department) {
                deptEl.innerHTML = '<i class="bi bi-building"></i>' + msg.department;
                deptEl.style.display = '';
            } else {
                deptEl.style.display = 'none';
            }
        }

        const evalEl = document.getElementById('chatEval');
        if (evalEl) {
            if (msg.evalLabel) {
                evalEl.innerHTML = '<i class="bi bi-clipboard2-check"></i>' + msg.evalLabel;
                evalEl.style.display = '';
            } else {
                evalEl.style.display = 'none';
            }
        }

        const statusBadge = document.getElementById('chatStatusBadge');
        statusBadge.className = 'fm-status-badge fm-status-' + msg.status;
        statusBadge.textContent = msg.status.charAt(0).toUpperCase() + msg.status.slice(1);

        document.getElementById('deleteCurrentForm').action = msg.deleteUrl;
        document.getElementById('deleteCurrentToken').value = msg.deleteToken;
        document.getElementById('deleteCurrentName').textContent = msg.senderName;
        document.getElementById('deleteCurrentSubject').textContent = msg.subject;
        document.getElementById('deleteCurrentDate').textContent = msg.createdAt;
    }

    const chatBody = document.getElementById('chatBody');
    chatBody.scrollTop = chatBody.scrollHeight;
}

function filterMessages(status, btn) {
    document.querySelectorAll('.fm-filter-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');

    document.querySelectorAll('.fm-conv-item').forEach(item => {
        const show = status === 'all' || item.dataset.status === status;
        item.style.display = show ? '' : 'none';
    });
}

function searchMessages() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.fm-conv-item').forEach(item => {
        const searchText = item.dataset.search || '';
        item.style.display = searchText.includes(query) ? '' : 'none';
    });
}

function updateFileName(input, msgId) {
    const nameEl = document.getElementById('fileName-' + msgId);
    if (input.files[0]) {
        nameEl.innerHTML = '<i class="bi bi-paperclip"></i> ' + input.files[0].name;
    } else {
        nameEl.innerHTML = '';
    }
}

document.querySelectorAll('.fm-textarea').forEach(textarea => {
    textarea.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });
});

document.addEventListener('DOMContentLoaded', function() {
    const chatBody = document.getElementById('chatBody');
    if (chatBody) chatBody.scrollTop = chatBody.scrollHeight;

    document.querySelectorAll('.toast').forEach(toast => {
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transition = 'opacity .3s';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    });
});
</script>
{% endblock %}
