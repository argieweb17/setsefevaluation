{% extends 'base.html.twig' %}

{% block title %}Set Password | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
.sp-header {
    background: linear-gradient(90deg, #1e3a8a 0%, #1e40af 58%, #0f766e 100%);
    color: #fff;
}

.sp-save-btn {
    background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 55%, #0f766e 100%);
    border: 0;
    color: #fff;
}

.sp-save-btn:hover,
.sp-save-btn:focus {
    background: linear-gradient(90deg, #1e40af 0%, #1e3a8a 55%, #0f766e 100%);
    color: #fff;
}
</style>
{% endblock %}

{% block body %}
<div class="container" style="max-width:560px; margin-top:2rem; margin-bottom:2rem;">
    <div class="card border-0 shadow-sm" style="border-radius:14px; overflow:hidden;">
        <div class="card-header sp-header">
            <h5 class="mb-1 fw-bold"><i  class="bi bi-shield me-2"></i>Set Your Password</h5>
            <small class="opacity-75">Required for student accounts that logged in using Student ID only.</small>
        </div>
        <div class="card-body p-4">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} mb-3" role="alert">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% if saved %}
                <div class="alert alert-success" role="alert">
                    Password added successfully.
                </div>
                {% if next == 'logout' %}
                    <div class="d-flex justify-content-end">
                        <a href="{{ path('app_logout') }}" class="btn sp-save-btn">Continue Logout</a>
                    </div>
                {% endif %}
            {% else %}

            {% if error %}
                <div class="alert alert-danger" role="alert">{{ error }}</div>
            {% endif %}

            <form method="post">
                <input type="hidden" name="next" value="{{ next }}">

                <div class="mb-3">
                    <label class="form-label fw-semibold">New Password <span class="text-danger">*</span></label>
                    <input type="password" name="new_password" class="form-control" minlength="8" required>
                    <small class="text-muted">Use at least 8 characters.</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Confirm Password <span class="text-danger">*</span></label>
                    <input type="password" name="confirm_password" class="form-control" minlength="8" required>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    {% if next != 'logout' %}
                        <a href="{{ path('evaluation_history') }}" class="btn btn-outline-secondary">Cancel</a>
                    {% endif %}
                    <button type="submit" class="btn sp-save-btn">Save Password</button>
                </div>
            </form>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
