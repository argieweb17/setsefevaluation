<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SEF Report - {{ faculty.fullName }}</title>
    <link rel="icon" type="image/png" href="{{ asset('images/quamc-logo.png') }}">
    <style>
        @page {
            size: 13in 8.5in;
            margin: 8mm 10mm 8mm 10mm;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Geist, Arial, Helvetica, sans-serif;
            margin: 0;
            color: #000;
            font-size: 9px;
            line-height: 1.3;
            padding: 12px 20px;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            background-image:
                linear-gradient(to right, #e5e7eb 1px, transparent 1px),
                linear-gradient(to bottom, #e5e7eb 1px, transparent 1px);
            background-size: 24px 24px;
        }

        .sheet {
            width: 100%;
        }

        .header-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 6px;
        }
        .header-left {
            flex-shrink: 0;
            margin-left: 0;
        }
        .header-left img {
            max-height: 90px;
            width: auto;
        }
        .header-right {
            text-align: right;
            padding-top: 4px;
            margin-right: 10px;
        }
        .header-right .office-title {
            font-size: 14px;
            font-weight: 700;
            font-style: italic;
            margin-bottom: 4px;
        }
        .doc-info-table {
            border-collapse: collapse;
            font-size: 9px;
            margin-left: auto;
        }
        .doc-info-table td {
            border: 1px solid #000;
            padding: 1px 8px;
        }
        .doc-info-table .di-lbl {
            font-weight: 700;
            white-space: nowrap;
        }
        .doc-info-table .di-val {
            min-width: 60px;
        }
        .doc-info-table .di-page {
            text-align: center;
            font-weight: 400;
            vertical-align: middle;
            padding: 1px 12px;
            letter-spacing: 2px;
            font-size: 10px;
        }

        .title-block {
            text-align: center;
            margin-bottom: 8px;
        }
        .title-block h2 {
            font-size: 13px;
            font-weight: 700;
            margin: 0;
        }

        .info-row {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
            background: #fff;
        }

        .info-row td {
            border: none;
            padding: 4px 8px 2px;
            font-size: 10px;
        }

        .info-row .lbl {
            font-weight: 700;
            text-align: center;
            white-space: nowrap;
            width: 11%;
        }

        .info-row .val {
            border-bottom: 1px solid #000;
            text-decoration: none;
            width: 14%;
        }

        .main-row {
            display: flex;
            align-items: stretch;
            gap: 12px;
            margin-top: 4px;
            margin-bottom: 8px;
            width: 100%;
        }

        .items-table {
            flex: 1 1 auto;
            width: auto;
            border-collapse: collapse;
            background: #fff;
        }

        .items-table th,
        .items-table td {
            border: 1px solid #000;
            padding: 4px 6px;
            font-size: 10px;
        }

        .items-table thead th {
            font-weight: 700;
            text-align: center;
        }

        .items-table .item {
            text-align: left;
        }

        .items-table .num {
            text-align: center;
            width: 14%;
        }

        .summary-box {
            width: 220px;
            flex-shrink: 0;
            border-collapse: collapse;
            background: #fff;
        }

        .summary-box th,
        .summary-box td {
            border: 1px solid #000;
            padding: 8px 6px;
            text-align: center;
            font-size: 15px;
            font-weight: 700;
        }

        .summary-box th {
            background: #cfe2f3;
            font-size: 18px;
        }

        .summary-box .value {
            font-size: 30px;
            line-height: 1.1;
        }

        .comments-section {
            margin-top: 8px;
            background: #fff;
            padding: 12px 14px;
        }

        .comments-section h3 {
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .comments-meta {
            font-size: 10px;
            color: #475569;
            margin-bottom: 10px;
        }

        .comments-section ol {
            margin: 0;
            padding-left: 20px;
            font-size: 10px;
        }

        .comments-section ol li {
            margin-bottom: 7px;
            line-height: 1.45;
        }

        .no-comments {
            font-size: 10px;
            font-style: italic;
            color: #475569;
        }

        .scale {
            margin: 6px 0 8px;
            text-align: center;
            font-size: 9px;
            font-style: italic;
            background: transparent;
            border: none;
            padding: 0;
        }

        .purpose-row {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
            background: transparent;
        }

        .purpose-row td {
            border: none;
            padding: 2px 6px;
            font-size: 10px;
        }

        .purpose-row .lbl {
            width: auto;
            font-weight: 700;
            text-align: left;
            padding-left: 0;
            padding-right: 8px;
        }

        .signature-wrap {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin: 16px 20px 10px;
            font-size: 10px;
        }

        .sig-block {
            width: 38%;
            text-align: center;
        }

        .sig-label {
            text-align: left;
            margin-bottom: 26px;
            font-weight: 700;
        }

        .sig-name {
            border-bottom: 1px solid #000;
            font-weight: 700;
            padding-bottom: 2px;
            margin-bottom: 3px;
        }

        .sig-image {
            display: block;
            max-width: 220px;
            max-height: 52px;
            width: auto;
            height: auto;
            margin: 0 auto 4px;
            object-fit: contain;
        }

        .sig-title {
            font-size: 9px;
        }

        .disclaimer {
            font-size: 8px;
            font-style: italic;
            border-top: none;
            margin-top: 34px;
        }

        .page-break {
            page-break-after: always;
            break-after: page;
        }

        @media print {
            body { padding: 0; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body>
{% set letters = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'] %}
{% set totalAvg = 0 %}
{% set totalMax = 0 %}
{% set overallValue = overallAverage|default(compositeTotal|default(0)) %}
{% set overallPct = (overallValue / 5) * 100 %}
{% set hasCommentsPage = comments|length > 0 %}
{% set totalPages = hasCommentsPage ? 2 : 1 %}

<div class="sheet">
    <div class="header-row">
        <div class="header-left">
            <img src="{{ absolute_url(asset('images/header.jpg')) }}" alt="NORSU Letterhead">
        </div>
        <div class="header-right">
            <div class="office-title">Office of the University Quality Assurance Management Center</div>
            <table class="doc-info-table">
                <tr>
                    <td class="di-lbl">Document ID</td>
                    <td class="di-val">{{ correspondenceId|default('DTAL-OTUP-ODQA-F1249-V002') }}</td>
                    <td class="di-lbl">Issue Status</td>
                    <td class="di-val"></td>
                    <td rowspan="3" class="di-page">P a g e&nbsp;|<strong>1</strong>{% if totalPages > 1 %}/{{ totalPages }}{% endif %}</td>
                </tr>
                <tr>
                    <td class="di-lbl">Issue Date</td>
                    <td class="di-val">{{ "now"|date("m-d-Y") }}</td>
                    <td class="di-lbl">Approved by</td>
                    <td class="di-val">ODQA</td>
                </tr>
                <tr>
                    <td class="di-lbl">Reviewed &amp; Authorized by</td>
                    <td class="di-val">ODQA</td>
                    <td></td>
                    <td></td>
                </tr>
            </table>
        </div>
    </div>

    <div class="title-block">
        <h2>RESULT OF SUPERIOR EVALUATION FOR FACULTY</h2>
    </div>

    <table class="info-row">
        <tr>
            <td class="lbl">Name of Faculty:</td>
            <td class="val">{{ faculty.lastName }}, {{ faculty.firstName }}</td>
            <td class="lbl">Campus:</td>
            <td class="val">{{ faculty.campus ?? 'Main Campus' }}</td>
            <td class="lbl">College:</td>
            <td class="val">{{ collegeLabel|default('N/A') }}</td>
            <td class="lbl">Sem/SY:</td>
            <td class="val">{{ semSyLabel|default('N/A') }}</td>
            <td class="lbl">Employment Status:</td>
            <td class="val">{{ employmentStatusLabel|default('Regular') }}</td>
        </tr>
    </table>

    <div class="main-row">
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:58%;">ITEMS</th>
                    <th class="num">Average<br>Score</th>
                    <th class="num">Max<br>Score</th>
                    <th class="num">Rating</th>
                </tr>
            </thead>
            <tbody>
                {% for cat in categorySummary %}
                    {% set itemMax = cat.weightPct|default(0) %}
                    {% set itemAvg = (cat.mean|default(0) / 5) * itemMax %}
                    {% set itemRating = itemMax > 0 ? (itemAvg / itemMax) * 100 : 0 %}
                    {% set totalAvg = totalAvg + itemAvg %}
                    {% set totalMax = totalMax + itemMax %}
                    <tr>
                        <td class="item">{{ letters[loop.index0]|default(loop.index ~ '.') }} {{ cat.name }}</td>
                        <td class="num">{{ itemAvg|round(0, 'common') }}</td>
                        <td class="num">{{ itemMax|round(0, 'common') }}</td>
                        <td class="num">{{ itemRating|round(0, 'common') }}</td>
                    </tr>
                {% endfor %}
                {% set overallPercent = totalMax > 0 ? (totalAvg / totalMax) * 100 : 0 %}
                <tr>
                    <td class="item" style="text-align:right;font-weight:700;">Total Score</td>
                    <td class="num" style="font-weight:700;">{{ totalAvg|round(0, 'common') }}</td>
                    <td class="num" style="font-weight:700;">{{ totalMax|round(0, 'common') }}</td>
                    <td class="num" style="font-weight:700;">{{ overallPercent|round(0, 'common') }}</td>
                </tr>
            </tbody>
        </table>

        <table class="summary-box">
            <tr>
                <th>Overall Rating</th>
            </tr>
            <tr>
                <td class="value">{{ overallPercent|round(0, 'common') }}</td>
            </tr>
            <tr>
                <th>Verbal Rating</th>
            </tr>
            <tr>
                <td>{{ performanceLevel|default('N/A') }}</td>
            </tr>
        </table>
    </div>

    <div class="scale">
        Rating Scale: 91 - 100% - Always Manifested; 61 - 90% - Often Manifested; 31 - 60% - Sometimes Manifested; 11 - 30% - Seldom Manifested; 0 - 10% - Never/Rarely Manifested
    </div>

    <table class="purpose-row">
        <tr>
            <td class="lbl">Purpose:</td>
            <td>{{ purposeText|default('For IPCR purpose only.') }}</td>
        </tr>
    </table>

    <div class="signature-wrap">
        <div class="sig-block">
            <div class="sig-label">Prepared by:</div>
            {% if preparedSignature is defined and preparedSignature is not empty %}
                <img src="{{ preparedSignature }}" alt="Prepared signature" class="sig-image">
            {% endif %}
            <div class="sig-name">{{ preparedBy|default('Argie Pair Pagbunocan') }}</div>
            <div class="sig-title">{{ preparedTitle|default('QUAMC Staff') }}</div>
        </div>
        <div class="sig-block">
            <div class="sig-label">Noted by:</div>
            {% if certifiedSignature is defined and certifiedSignature is not empty %}
                <img src="{{ certifiedSignature }}" alt="Certified signature" class="sig-image">
            {% endif %}
            <div class="sig-name">{{ certifiedBy|default('CESAR P. ESTROPE, Ed.D') }}</div>
            <div class="sig-title">{{ certifiedTitle|default('Director, Quality Assurance Management Center') }}</div>
        </div>
    </div>

    <div class="disclaimer">
        Disclaimer: The information transmitted by this document is intended only for the person or entity to which it is addressed. This document may contain proprietary, business-confidential and/or privileged material. If you are not the intended recipient of this message, be aware that any use, review, retransmission, distribution, reproduction or any action taken in reliance upon this message is strictly prohibited. If you received this in error, please contact the sender. Thank you.
    </div>
</div>

{% if hasCommentsPage %}
<div class="page-break"></div>

<div class="sheet">
    <div class="header-row">
        <div class="header-left">
            <img src="{{ absolute_url(asset('images/header.jpg')) }}" alt="NORSU Letterhead">
        </div>
        <div class="header-right">
            <div class="office-title">Office of the University Quality Assurance Management Center</div>
            <table class="doc-info-table">
                <tr>
                    <td class="di-lbl">Document ID</td>
                    <td class="di-val">{{ correspondenceId|default('DTAL-OTUP-ODQA-F1249-V002') }}</td>
                    <td class="di-lbl">Issue Status</td>
                    <td class="di-val"></td>
                    <td rowspan="3" class="di-page">P a g e&nbsp;|<strong>2</strong>/{{ totalPages }}</td>
                </tr>
                <tr>
                    <td class="di-lbl">Issue Date</td>
                    <td class="di-val">{{ "now"|date("m-d-Y") }}</td>
                    <td class="di-lbl">Approved by</td>
                    <td class="di-val">ODQA</td>
                </tr>
                <tr>
                    <td class="di-lbl">Reviewed &amp; Authorized by</td>
                    <td class="di-val">ODQA</td>
                    <td></td>
                    <td></td>
                </tr>
            </table>
        </div>
    </div>

    <div class="title-block">
        <h2>RESULT OF SUPERIOR EVALUATION FOR FACULTY - COMMENTS</h2>
    </div>

    <table class="info-row">
        <tr>
            <td class="lbl">Name of Faculty:</td>
            <td class="val">{{ faculty.lastName }}, {{ faculty.firstName }}</td>
            <td class="lbl">Campus:</td>
            <td class="val">{{ faculty.campus ?? 'Main Campus' }}</td>
            <td class="lbl">College:</td>
            <td class="val">{{ collegeLabel|default('N/A') }}</td>
            <td class="lbl">Sem/SY:</td>
            <td class="val">{{ semSyLabel|default('N/A') }}</td>
            <td class="lbl">Employment Status:</td>
            <td class="val">{{ employmentStatusLabel|default('Regular') }}</td>
        </tr>
    </table>

    <div class="comments-section">
        <h3>Evaluator Comments</h3>
        <div class="comments-meta">
            <strong>Evaluators:</strong> {{ evaluatorCount }} &nbsp; | &nbsp; <strong>Comments:</strong> {{ comments|length }}
        </div>
        {% if comments|length > 0 %}
        <ol>
            {% for c in comments %}
                <li>{{ c }}</li>
            {% endfor %}
        </ol>
        {% else %}
        <p class="no-comments">No comments were submitted for this evaluation.</p>
        {% endif %}
    </div>

    <div class="signature-wrap">
        <div class="sig-block">
            <div class="sig-label">Prepared by:</div>
            {% if preparedSignature is defined and preparedSignature is not empty %}
                <img src="{{ preparedSignature }}" alt="Prepared signature" class="sig-image">
            {% endif %}
            <div class="sig-name">{{ preparedBy|default('Argie Pair Pagbunocan') }}</div>
            <div class="sig-title">{{ preparedTitle|default('QUAMC Staff') }}</div>
        </div>
        <div class="sig-block">
            <div class="sig-label">Noted by:</div>
            {% if certifiedSignature is defined and certifiedSignature is not empty %}
                <img src="{{ certifiedSignature }}" alt="Certified signature" class="sig-image">
            {% endif %}
            <div class="sig-name">{{ certifiedBy|default('CESAR P. ESTROPE, Ed.D') }}</div>
            <div class="sig-title">{{ certifiedTitle|default('Director, Quality Assurance Management Center') }}</div>
        </div>
    </div>

    <div class="disclaimer">
        Disclaimer: The information transmitted by this document is intended only for the person or entity to which it is addressed. This document may contain proprietary, business-confidential and/or privileged material. If you are not the intended recipient of this message, be aware that any use, review, retransmission, distribution, reproduction or any action taken in reliance upon this message is strictly prohibited. If you received this in error, please contact the sender. Thank you.
    </div>
</div>
{% endif %}

<script>
    window.addEventListener('load', function () {
        setTimeout(function () { window.print(); }, 350);
    });
</script>
</body>
</html>
