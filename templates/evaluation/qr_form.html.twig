<script>
document.addEventListener('DOMContentLoaded', function () {
    var mismatchModalEl = document.getElementById('loadslipMismatchModal');
    if (mismatchModalEl && window.bootstrap && window.bootstrap.Modal) {
        var mismatchModal = new bootstrap.Modal(mismatchModalEl);
        mismatchModal.show();
    }

    var studentNotFoundModalEl = document.getElementById('studentNotFoundModal');
    if (studentNotFoundModalEl && window.bootstrap && window.bootstrap.Modal) {
        var studentNotFoundModal = new bootstrap.Modal(studentNotFoundModalEl);
        studentNotFoundModal.show();
    }

    var loadslipUnverifiedModalEl = document.getElementById('loadslipUnverifiedModal');
    if (loadslipUnverifiedModalEl && window.bootstrap && window.bootstrap.Modal) {
        var loadslipUnverifiedModal = new bootstrap.Modal(loadslipUnverifiedModalEl);
        loadslipUnverifiedModal.show();
    }

    var privacyConsentRequiredModalEl = document.getElementById('privacyConsentRequiredModal');
    if (privacyConsentRequiredModalEl && window.bootstrap && window.bootstrap.Modal) {
        var privacyConsentRequiredModal = new bootstrap.Modal(privacyConsentRequiredModalEl);
        privacyConsentRequiredModal.show();
    }

    var form = document.getElementById('qrEvalForm');
    if (form) {
        var privacyAgree = document.getElementById('privacyAgree');
        var privacyDisagree = document.getElementById('privacyDisagree');
        var privacyGateButton = form.querySelector('button[name="_action"][value="privacy_gate"]');

        var submitPrivacyGate = function () {
            if (!privacyGateButton) {
                return;
            }

            if (typeof form.requestSubmit === 'function') {
                form.requestSubmit(privacyGateButton);
                return;
            }

            privacyGateButton.click();
        };

        if (privacyAgree) {
            privacyAgree.addEventListener('change', function () {
                if (privacyAgree.checked) {
                    submitPrivacyGate();
                }
            });
        }

        if (privacyDisagree) {
            privacyDisagree.addEventListener('change', function () {
                if (privacyDisagree.checked) {
                    submitPrivacyGate();
                }
            });
        }

        form.addEventListener('submit', function (event) {
            var action = (event.submitter && event.submitter.value) ? event.submitter.value : '';
            if (action !== 'privacy_gate') {
                return;
            }

            var consentSelected = form.querySelector('input[name="privacy_consent"]:checked');
            if (!consentSelected) {
                event.preventDefault();
                alert('Please select Agree or Disagree for the Data Privacy Disclaimer before continuing.');
                var agree = document.getElementById('privacyAgree');
                if (agree) agree.focus();
            }
        });
    }
});
</script>

</body>
</html>
