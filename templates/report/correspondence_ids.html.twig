{% extends 'base.html.twig' %}

{% block title %}{{ title }} | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
.cr-header{border-radius:14px;overflow:hidden;background:linear-gradient(135deg,#0f172a 0%,#1e40af 55%,#2563eb 100%);box-shadow:0 4px 18px rgba(30,64,175,.2);margin-bottom:14px;}
.cr-header-inner{padding:20px 22px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
.cr-title{color:#fff;font-size:1.15rem;font-weight:700;margin:0;}
.cr-sub{color:rgba(255,255,255,.75);font-size:.78rem;}
.cr-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:#fff;border-radius:999px;padding:5px 10px;font-size:.75rem;font-weight:600;}
.cr-card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;box-shadow:0 2px 12px rgba(2,6,23,.04);overflow:hidden;}
.cr-toolbar{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;padding:12px 14px;border-bottom:1px solid #e5e7eb;background:#fbfdff;}
.cr-search-wrap{position:relative;min-width:170px;flex:0 1 280px;max-width:280px;}
.cr-search-wrap i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.82rem;pointer-events:none;}
.cr-search{width:100%;border:1px solid #dbe2ec;border-radius:10px;padding:7px 10px 7px 30px;font-size:.82rem;color:#0f172a;outline:none;background:#fff;transition:border-color .18s,box-shadow .18s;}
.cr-search:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.08);}
.cr-filter-select{border:1px solid #dbe2ec;border-radius:10px;padding:7px 10px;font-size:.8rem;color:#334155;background:#fff;min-width:170px;outline:none;}
.cr-meta{font-size:.75rem;color:#64748b;white-space:nowrap;}
.cr-table{width:100%;border-collapse:collapse;}
.cr-table thead{background:#f8fafc;border-bottom:1px solid #e5e7eb;}
.cr-table th{padding:11px 12px;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.35px;}
.cr-table td{padding:11px 12px;border-bottom:1px solid #f1f5f9;font-size:.84rem;color:#0f172a;vertical-align:middle;}
.cr-table tr:last-child td{border-bottom:0;}
.cr-table tbody tr:hover{background:#f8fbff;}
.cr-id{font-weight:700;color:#1e40af;}
.cr-pill{display:inline-flex;align-items:center;border-radius:999px;padding:3px 10px;font-size:.7rem;font-weight:700;letter-spacing:.25px;}
.cr-pill-set{background:#dbeafe;color:#1e3a8a;}
.cr-pill-sef{background:#dcfce7;color:#166534;}
.cr-muted{color:#64748b;}
.cr-empty{padding:32px 20px;text-align:center;color:#64748b;}
.cr-empty i{font-size:1.5rem;color:#94a3b8;display:block;margin-bottom:8px;}
.cr-file-link{display:inline-flex;align-items:center;gap:5px;border:1px solid #cbd5e1;background:#fff;color:#1e3a8a;text-decoration:none;border-radius:8px;padding:4px 10px;font-size:.72rem;font-weight:700;}
.cr-file-link:hover{background:#eff6ff;color:#1e3a8a;border-color:#93c5fd;}
.cr-action-cell{white-space:nowrap;}
.cr-delete-btn{display:inline-flex;align-items:center;gap:5px;border:1px solid #fecaca;background:#fff1f2;color:#b91c1c;border-radius:8px;padding:4px 10px;font-size:.72rem;font-weight:700;cursor:pointer;}
.cr-delete-btn:hover{background:#ffe4e6;color:#991b1b;border-color:#fca5a5;}
.cr-no-match td{text-align:center;color:#64748b;font-style:italic;padding:16px 12px;}
@media(max-width:768px){
    .cr-toolbar{padding:10px;}
    .cr-search-wrap{max-width:220px;min-width:140px;flex:0 1 220px;}
    .cr-filter-select{min-width:140px;}
    .cr-meta{width:100%;}
    .cr-table{font-size:.78rem;}
    .cr-table th,.cr-table td{padding:9px 8px;}
}
</style>
{% endblock %}

{% block body %}
<div class="cr-header">
    <div class="cr-header-inner">
        <div>
            <h1 class="cr-title">{{ title }}</h1>
            <div class="cr-sub">Saved correspondence IDs from generated print files.</div>
        </div>
        <span class="cr-badge"><i class="bi bi-archive"></i> {{ records|length }} record{{ records|length != 1 ? 's' : '' }}</span>
    </div>
</div>

<div class="cr-card">
    {% if records is empty %}
    <div class="cr-empty">
        <i class="bi bi-inbox"></i>
        No correspondence IDs saved yet for {{ idType }}.
    </div>
    {% else %}
    {% set academicYears = [] %}
    {% for row in records %}
        {% if row.createdAt %}
            {% set startYear = row.createdAt|date('Y') %}
            {% set ay = startYear ~ '-' ~ (startYear + 1) %}
            {% if ay not in academicYears %}
                {% set academicYears = academicYears|merge([ay]) %}
            {% endif %}
        {% endif %}
    {% endfor %}
    {% set academicYears = academicYears|sort|reverse %}

    <div class="cr-toolbar">
        <div class="cr-search-wrap">
            <i class="bi bi-search"></i>
            <input type="search" id="crSearchInput" class="cr-search" placeholder="Search correspondence ID, scope, saved by, or date...">
        </div>
        <select id="crYearFilter" class="cr-filter-select" aria-label="Filter by academic year">
            <option value="">All Academic Years</option>
            {% for ay in academicYears %}
                <option value="{{ ay }}">{{ ay }}</option>
            {% endfor %}
        </select>
        <div class="cr-meta" id="crFilterMeta">Showing {{ records|length }} of {{ records|length }}</div>
    </div>
    <div class="table-responsive">
        <table class="cr-table">
            <thead>
                <tr>
                    <th style="width:90px;">Record ID</th>
                    <th>Correspondence ID</th>
                    <th style="width:120px;">Type</th>
                    <th style="width:130px;">Print Scope</th>
                    <th style="width:190px;">Saved By</th>
                    <th style="width:180px;">Saved At</th>
                    <th style="width:120px;">PDF File</th>
                    <th style="width:130px;">Action</th>
                </tr>
            </thead>
            <tbody>
                {% for row in records %}
                <tr class="cr-row"
                    data-academic-year="{{ row.createdAt ? (row.createdAt|date('Y') ~ '-' ~ ((row.createdAt|date('Y')) + 1)) : '' }}"
                    data-search="#{{ row.id }} {{ row.correspondenceId }} {{ row.printScope ?: 'print' }} {% if row.createdBy %}{{ row.createdBy.fullName }}{% else %}System{% endif %} {{ row.createdAt ? row.createdAt|date('M d, Y h:i A') : '' }} {{ row.evaluationType }}">
                    <td class="cr-id">#{{ row.id }}</td>
                    <td>{{ row.correspondenceId }}</td>
                    <td>
                        <span class="cr-pill {{ row.evaluationType == 'SEF' ? 'cr-pill-sef' : 'cr-pill-set' }}">{{ row.evaluationType }}</span>
                    </td>
                    <td>{{ row.printScope ?: 'print' }}</td>
                    <td>
                        {% if row.createdBy %}
                            {{ row.createdBy.fullName }}
                        {% else %}
                            <span class="cr-muted">System</span>
                        {% endif %}
                    </td>
                    <td>{{ row.createdAt ? row.createdAt|date('M d, Y h:i A') : '' }}</td>
                    <td>
                        <a href="{{ path('staff_correspondence_file', {id: row.id}) }}" class="cr-file-link" target="_blank" rel="noopener noreferrer">
                            <i class="bi bi-file-earmark-arrow-down"></i> PDF
                        </a>
                    </td>
                    <td class="cr-action-cell">
                        <form method="post" action="{{ path('staff_correspondence_delete', {id: row.id}) }}" onsubmit="return confirm('Delete this correspondence record?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_correspondence' ~ row.id) }}">
                            <button type="submit" class="cr-delete-btn">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
                <tr id="crNoMatchRow" class="cr-no-match" style="display:none;">
                    <td colspan="8">No records match your filter.</td>
                </tr>
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const searchInput = document.getElementById('crSearchInput');
    const yearFilter = document.getElementById('crYearFilter');
    const rows = Array.from(document.querySelectorAll('.cr-row'));
    const noMatchRow = document.getElementById('crNoMatchRow');
    const meta = document.getElementById('crFilterMeta');

    if (!searchInput || !yearFilter || rows.length === 0) {
        return;
    }

    const total = rows.length;

    const applyFilters = function () {
        const term = (searchInput.value || '').trim().toLowerCase();
        const selectedYear = (yearFilter.value || '').trim();
        let visible = 0;

        rows.forEach(function (row) {
            const haystack = (row.getAttribute('data-search') || '').toLowerCase();
            const rowYear = (row.getAttribute('data-academic-year') || '').trim();
            const passText = !term || haystack.includes(term);
            const passYear = !selectedYear || rowYear === selectedYear;
            const show = passText && passYear;

            row.style.display = show ? '' : 'none';
            if (show) {
                visible++;
            }
        });

        if (noMatchRow) {
            noMatchRow.style.display = visible === 0 ? '' : 'none';
        }

        if (meta) {
            meta.textContent = 'Showing ' + visible + ' of ' + total;
        }
    };

    searchInput.addEventListener('input', applyFilters);
    yearFilter.addEventListener('change', applyFilters);
});
</script>
{% endblock %}
