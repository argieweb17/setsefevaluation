{% extends 'base.html.twig' %}
{% set prefix = staffMode|default(false) ? 'staff' : 'admin' %}

{% block title %}Create Question | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ─── Header ─── */
.qc-header{border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);box-shadow:0 4px 24px rgba(26,86,219,.15);margin-bottom:20px;}
.qc-header-inner{padding:22px 26px 18px;}
.qc-header-icon{width:50px;height:50px;border-radius:14px;background:rgba(255,255,255,.12);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;flex-shrink:0;}
.qc-meta-pill{display:inline-flex;align-items:center;background:rgba(255,255,255,.1);color:rgba(255,255,255,.82);padding:2px 10px;border-radius:20px;font-weight:500;backdrop-filter:blur(4px);}

/* ─── Card ─── */
.qc-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;box-shadow:0 2px 16px rgba(0,0,0,.05);overflow:hidden;margin-bottom:20px;}
.qc-card-header{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-bottom:2px solid #e2e8f0;}
.qc-card-icon{width:32px;height:32px;border-radius:9px;background:linear-gradient(135deg,#1e40af,#3b82f6);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.8rem;}
.qc-card-body{padding:28px 28px 24px;}
.qc-label{font-size:.82rem;font-weight:600;color:#374151;margin-bottom:6px;display:block;}
.qc-input{font-size:.85rem;border-radius:8px;border:1px solid #e5e7eb;transition:border-color .15s,box-shadow .15s;}
.qc-input:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.08);}
.qc-hint{font-size:.72rem;color:#9ca3af;margin-top:4px;}
.qc-divider{height:1px;background:linear-gradient(to right,transparent,#e2e8f0,transparent);margin:20px 0;}

/* ─── Preview ─── */
.qc-preview{border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;background:#fafbfc;}
.qc-preview-header{padding:12px 18px;background:linear-gradient(135deg,#f0f4fa,#e8eff8);border-bottom:1px solid #e2e8f0;}
.qc-preview-badge{display:inline-flex;padding:3px 10px;border-radius:6px;font-size:.68rem;font-weight:600;letter-spacing:.2px;}
.qc-preview-type{background:#dbeafe;color:#1e40af;}
.qc-preview-cat{background:#f1f5f9;color:#475569;}
.qc-preview-req{background:#fef3c7;color:#b45309;}
.qc-preview-body{padding:18px;}
.qc-preview-rating{display:flex;flex-direction:column;align-items:center;gap:4px;}
.qc-preview-radio{width:22px;height:22px;border-radius:50%;border:2px solid #cbd5e1;background:#fff;}
.qc-preview-rating-num{font-size:.68rem;color:#94a3b8;font-weight:600;}

/* ─── Responsive ─── */
@media(max-width:768px){
    .qc-card-body{padding:18px;}
}

/* ─── Animations ─── */
.qc-header,.qc-card{animation:qcFadeIn .25s ease;}
@keyframes qcFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
</style>
{% endblock %}

{% block body %}
{# ═══════════════════════════════════════
   GRADIENT HEADER
   ═══════════════════════════════════════ #}
<div class="qc-header">
    <div class="qc-header-inner">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="qc-header-icon">
                    <i class="bi bi-plus-circle"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">Create New Question</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                        <span class="qc-meta-pill"><i class="bi bi-tag-fill me-1"></i>{{ selectedType }}</span>
                        <span class="qc-meta-pill"><i class="bi bi-clipboard2-check me-1"></i>{{ selectedType == 'SET' ? 'Student Evaluation for Teacher' : 'Superior Evaluation for Faculty' }}</span>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-1">
                <a href="{{ path(prefix ~ '_questions', {type: selectedType}) }}" class="btn btn-sm btn-outline-light fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════
   FORM CARD
   ═══════════════════════════════════════ #}
<div class="row justify-content-center">
    <div class="col-lg-9 col-xl-8">
        <div class="qc-card">
            <div class="qc-card-header">
                <div class="d-flex align-items-center gap-2">
                    <div class="qc-card-icon"><i class="bi bi-pencil-square"></i></div>
                    <h6 class="fw-bold mb-0">Question Details</h6>
                </div>
            </div>
            <div class="qc-card-body">
                <form method="post" action="{{ path(prefix ~ '_question_create') }}" id="createQuestionForm">
                    <input type="hidden" name="_token" value="{{ csrf_token('create_question') }}">

                    {# ── Question Text ── #}
                    <div class="mb-4">
                        <label for="questionText" class="qc-label">
                            Question Text <span class="text-danger">*</span>
                        </label>
                        <textarea name="questionText" id="questionText" class="form-control qc-input" rows="4"
                                  placeholder="Enter the evaluation question here..." required></textarea>
                        <div class="qc-hint">Write a clear, specific question for the evaluation form.</div>
                    </div>

                    <div class="qc-divider"></div>

                    {# ── Category & Evaluation Type ── #}
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label for="category" class="qc-label">
                                <i class="bi bi-tag me-1 text-muted"></i>Category
                            </label>
                            <input type="text" name="category" id="category" class="form-control qc-input"
                                   list="categoryList"
                                   placeholder="e.g. Teaching Effectiveness">
                            <datalist id="categoryList">
                                {% for cat in categories %}
                                    <option value="{{ cat }}">
                                {% endfor %}
                            </datalist>
                            <div class="qc-hint">Select an existing category or type a new one.</div>
                        </div>
                        <div class="col-md-6">
                            <label for="evaluationType" class="qc-label">
                                <i class="bi bi-collection me-1 text-muted"></i>Evaluation Type <span class="text-danger">*</span>
                            </label>
                            <select name="evaluationType" id="evaluationType" class="form-select qc-input">
                                <option value="SET" {{ selectedType == 'SET' ? 'selected' }}>SET — Student Evaluation for Teacher</option>
                                <option value="SEF" {{ selectedType == 'SEF' ? 'selected' }}>SEF — Superior Evaluation for Faculty</option>
                            </select>
                        </div>
                    </div>

                    {# ── Weight, Sort Order, Options ── #}
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label for="weight" class="qc-label">
                                <i class="bi bi-speedometer me-1 text-muted"></i>Weight
                            </label>
                            <input type="number" name="weight" id="weight" class="form-control qc-input"
                                   value="1.0" step="0.1" min="0" max="10">
                            <div class="qc-hint">Relative scoring weight (default: 1.0).</div>
                        </div>
                        <div class="col-md-4">
                            <label for="sortOrder" class="qc-label">
                                <i class="bi bi-sort-numeric-down me-1 text-muted"></i>Sort Order
                            </label>
                            <input type="number" name="sortOrder" id="sortOrder" class="form-control qc-input"
                                   value="0" min="0">
                            <div class="qc-hint">Display position within its category.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="qc-label d-block">
                                <i class="bi bi-gear me-1 text-muted"></i>Options
                            </label>
                            <div class="mt-2">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" name="isRequired"
                                           id="isRequired" value="1" checked>
                                    <label class="form-check-label" for="isRequired">Required question</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="qc-divider"></div>

                    {# ── Live Preview ── #}
                    <div class="mb-4">
                        <label class="qc-label text-muted">
                            <i class="bi bi-eye me-1"></i>Live Preview
                        </label>
                        <div class="qc-preview" id="questionPreview">
                            <div class="qc-preview-header">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <span class="qc-preview-badge qc-preview-type" id="previewType">{{ selectedType }}</span>
                                    <span class="qc-preview-badge qc-preview-cat" id="previewCategory">Uncategorized</span>
                                    <span class="qc-preview-badge qc-preview-req" id="previewRequired">Required</span>
                                </div>
                            </div>
                            <div class="qc-preview-body">
                                <p class="mb-2 text-muted fst-italic" id="previewText">Your question will appear here...</p>
                                <div class="d-flex gap-3 mt-2">
                                    {% for i in 1..5 %}
                                    <div class="qc-preview-rating">
                                        <span class="qc-preview-radio"></span>
                                        <span class="qc-preview-rating-num">{{ i }}</span>
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>

                    {# ── Submit ── #}
                    <div class="d-flex justify-content-end gap-2 pt-2">
                        <a href="{{ path(prefix ~ '_questions', {type: selectedType}) }}" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle-fill me-1"></i>Create Question
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



{# ═══════════════════════════════════════
   LIVE PREVIEW SCRIPT
   ═══════════════════════════════════════ #}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const textInput = document.getElementById('questionText');
    const catInput = document.getElementById('category');
    const typeInput = document.getElementById('evaluationType');
    const reqInput = document.getElementById('isRequired');
    const previewText = document.getElementById('previewText');
    const previewCategory = document.getElementById('previewCategory');
    const previewType = document.getElementById('previewType');
    const previewRequired = document.getElementById('previewRequired');

    function updatePreview() {
        previewText.textContent = textInput.value || 'Your question will appear here...';
        previewText.classList.toggle('fst-italic', !textInput.value);
        previewText.classList.toggle('text-muted', !textInput.value);
        previewText.classList.toggle('text-dark', !!textInput.value);
        previewCategory.textContent = catInput.value || 'Uncategorized';
        previewType.textContent = typeInput.value;
        previewRequired.textContent = reqInput.checked ? 'Required' : 'Optional';
        previewRequired.className = reqInput.checked
            ? 'qc-preview-badge qc-preview-req'
            : 'qc-preview-badge qc-preview-cat';
    }

    textInput.addEventListener('input', updatePreview);
    catInput.addEventListener('input', updatePreview);
    typeInput.addEventListener('change', updatePreview);
    reqInput.addEventListener('change', updatePreview);
});
</script>
{% endblock %}
