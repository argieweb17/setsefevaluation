{% extends 'base.html.twig' %}

{% block title %}About | Faculty Evaluation System{% endblock %}

{% block body_class %}no-navbar{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
{% include 'home/_fes_styles.html.twig' %}
</style>
{% endblock %}

{% block body %}
<div class="fes-page">
    {% include 'home/_fes_header.html.twig' with {active: 'about'} %}

    {# ── About Section ── #}
    <section class="fes-about" id="about">
        <div class="container">
            <div class="fes-section-title">
                <h2>About the System</h2>
                <p>The Faculty Evaluation System is an online platform for transparent and meaningful academic assessment of faculty performance.</p>
            </div>
            <div class="row g-4">
                <div class="col-md-6">
                    <h5 class="text-danger"><i data-lucide="lock" class="me-2"></i>Secure & Confidential</h5>
                    <p class="text-muted">All evaluations are anonymous, ensuring honest and unbiased feedback from every participant.</p>
                </div>
                <div class="col-md-6">
                    <h5 class="text-danger"><i data-lucide="zap" class="me-2"></i>Real-Time Results</h5>
                    <p class="text-muted">Administrators and faculty can access evaluation data as soon as the evaluation period closes.</p>
                </div>
            </div>
        </div>
    </section>

    {% include 'home/_fes_footer.html.twig' %}
</div>
{% endblock %}
