<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Login | SET-SEF Evaluation</title>
    <link rel="icon" type="image/png" href="{{ asset('images/quamc-logo.png') }}">
    <link href="{{ asset('vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('vendor/bootstrap-icons/font/bootstrap-icons.min.css') }}" rel="stylesheet">
</head>
<body class="sl-body">

<div class="sl-page">
    {# ── LEFT PANEL: Decorative branding ── #}
    <div class="sl-brand-panel">
        <div class="sl-brand-bg"></div>
        <div class="sl-brand-content">
            <div class="sl-brand-logo-wrap">
                <img src="{{ asset('images/quamc-logo.png') }}" alt="QUAMC" class="sl-brand-logo">
            </div>
            <h1 class="sl-brand-title">Student Evaluation Portal</h1>
            <p class="sl-brand-sub">Access your evaluation records using your Student ID</p>

            <div class="sl-brand-features">
                <div class="sl-feature-item">
                    <div class="sl-feature-icon"><i class="bi bi-clock-history"></i></div>
                    <div>
                        <strong>Evaluation History</strong>
                        <span>View all your past and current evaluation submissions</span>
                    </div>
                </div>
                <div class="sl-feature-item">
                    <div class="sl-feature-icon"><i class="bi bi-shield-check"></i></div>
                    <div>
                        <strong>Anonymous & Secure</strong>
                        <span>Your responses are confidential and protected</span>
                    </div>
                </div>
                <div class="sl-feature-item">
                    <div class="sl-feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <div>
                        <strong>Track Progress</strong>
                        <span>Monitor which subjects you've already evaluated</span>
                    </div>
                </div>
            </div>

            <div class="sl-brand-footer">
                <p>&copy; {{ 'now'|date('Y') }} Negros Oriental State University</p>
            </div>
        </div>
    </div>

    {# ── RIGHT PANEL: Login form ── #}
    <div class="sl-form-panel">
        <div class="sl-form-scroll">
            <div class="sl-form-inner">

                {# Mobile logo (hidden on desktop) #}
                <div class="sl-mobile-header d-lg-none">
                    <img src="{{ asset('images/quamc-logo.png') }}" alt="QUAMC" class="sl-mobile-logo">
                </div>

                {# Header #}
                <div class="sl-header">
                    <h2 class="sl-title">Student Login</h2>
                    <p class="sl-subtitle">Enter your Student ID to view your evaluation history</p>
                </div>

                {# Error alert #}
                {% if error %}
                <div class="sl-error-alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>{{ error }}</span>
                </div>
                {% endif %}

                {# Login form #}
                <form method="post" class="sl-form" id="studentLoginForm">
                    <div class="sl-section">
                        <div class="sl-field">
                            <label for="inputSchoolId" class="sl-label">
                                Student ID <span class="text-danger">*</span>
                            </label>
                            <div class="sl-input-wrap">
                                <i class="bi bi-person-badge"></i>
                                <input type="text" name="school_id" id="inputSchoolId"
                                       class="form-control sl-input" required autofocus
                                       placeholder="e.g. 2023-1234" autocomplete="off">
                            </div>
                            <div class="sl-field-hint">
                                <i class="bi bi-info-circle me-1"></i>Use the ID on your school registration form
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="sl-submit-btn" id="slSubmitBtn">
                        <span class="sl-submit-text">
                            <i class="bi bi-box-arrow-in-right me-2"></i>View My Evaluations
                        </span>
                        <span class="sl-submit-loading d-none">
                            <span class="sl-loading-spinner"></span>
                            <span>Signing In</span>
                            <span class="sl-loading-dots"><span>.</span><span>.</span><span>.</span></span>
                        </span>
                        <span class="sl-btn-progress"></span>
                    </button>

                    <div class="sl-divider">
                        <span>or</span>
                    </div>

                    <a href="{{ path('app_login') }}" class="sl-alt-login-btn">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign in with Email & Password
                    </a>

                    <div class="sl-register-link">
                        Don't have an account? <a href="{{ path('app_register') }}">Create one here</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

