{% extends 'base.html.twig' %}
{% set prefix = staffMode|default(false) ? 'staff' : 'admin' %}

{% block title %}Questionnaire | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ─── Header ─── */
.qq-header{border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);box-shadow:0 4px 24px rgba(26,86,219,.15);margin-bottom:16px;}
.qq-header-inner{padding:22px 26px 18px;}
.qq-header-icon{width:50px;height:50px;border-radius:14px;background:transparent;backdrop-filter:none;display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;flex-shrink:0;}
.qq-meta-pill{display:inline-flex;align-items:center;background:transparent;color:rgba(255,255,255,.82);padding:0;border-radius:0;font-weight:500;backdrop-filter:none;}
.qq-meta-type{background:transparent;color:#fbbf24;}
.qq-stats-row{display:flex;gap:0;margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,255,255,.1);}
.qq-stat{flex:1;text-align:center;}
.qq-stat-val{display:block;font-size:1.15rem;font-weight:700;color:#fff;line-height:1.2;}
.qq-stat-lbl{display:block;font-size:.6rem;color:rgba(255,255,255,.55);text-transform:uppercase;letter-spacing:.8px;margin-top:2px;}
.qq-stat-divider{width:1px;background:rgba(255,255,255,.1);margin:0 2px;}
.qq-val-success{color:#34d399!important;}
.qq-val-warn{color:#fbbf24!important;}

/* ─── Privacy Disclaimer ─── */
.qq-disclaimer{background:#fff;border:1px solid #e8ecf1;border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.03);margin-bottom:16px;}
.qq-disclaimer-head{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:10px 14px;background:#1E3A8A;color:#fff;font-size:.8rem;font-weight:700;letter-spacing:.2px;}
.qq-disclaimer-body{padding:12px 14px;font-size:.8rem;line-height:1.6;color:#475569;background:#f8fafc;}
.qq-disclaimer-body p{margin:0 0 8px 0;}
.qq-disclaimer-body p:last-child{margin-bottom:0;}
.qq-disclaimer-sub{display:block;font-size:.75rem;font-weight:500;opacity:.85;margin-top:1px;}
.qq-disclaimer-edit{font-size:.72rem;font-weight:600;border-color:rgba(255,255,255,.45)!important;color:#fff!important;}
.qq-disclaimer-edit:hover{background:rgba(255,255,255,.18)!important;border-color:rgba(255,255,255,.7)!important;}

/* ─── Toolbar ─── */
.qq-toolbar{display:flex;align-items:center;gap:12px;flex-wrap:wrap;background:#fff;border:1px solid #e8ecf1;border-radius:12px;padding:8px 12px;margin-bottom:16px;box-shadow:0 1px 3px rgba(0,0,0,.03);}
.qq-search-wrap{position:relative;flex:1;min-width:200px;max-width:360px;}
.qq-search-wrap>i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:.8rem;pointer-events:none;}
.qq-search{width:100%;border:1px solid #e5e7eb;border-radius:8px;padding:7px 12px 7px 32px;font-size:.82rem;outline:none;transition:border-color .15s,box-shadow .15s;background:#fafbfc;}
.qq-search:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.08);background:#fff;}
.qq-filter-group{position:relative;display:flex;align-items:center;}
.qq-filter-icon{position:absolute;left:10px;color:#6b7280;font-size:.8rem;pointer-events:none;z-index:1;}
.qq-filter-select{border:1px solid #e5e7eb;border-radius:8px;padding:7px 12px 7px 32px;font-size:.82rem;outline:none;background:#fafbfc;min-width:180px;cursor:pointer;transition:border-color .15s;}
.qq-filter-select:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.08);}
.qq-toolbar-info{margin-left:auto;}
.qq-result-count{font-size:.75rem;color:#9ca3af;font-weight:500;}

/* ─── Paper ─── */
.qq-paper{background:#fff;border:1px solid #e2e8f0;border-radius:14px;box-shadow:0 2px 16px rgba(0,0,0,.05);overflow:hidden;margin-bottom:20px;}

/* ─── Letterhead ─── */
.qq-letterhead{display:flex;align-items:center;gap:16px;padding:18px 28px;border-bottom:3px solid #1e40af;background:linear-gradient(135deg,#f0f4fa 0%,#e8eff8 100%);}
.qq-letterhead-logo{width:64px;height:64px;object-fit:contain;flex-shrink:0;}
.qq-letterhead-center{flex:1;display:flex;flex-direction:column;align-items:center;text-align:center;gap:0;}
.qq-letterhead-ra{font-size:.62rem;font-weight:600;color:#64748b;letter-spacing:.5px;}
.qq-letterhead-sub{font-size:.72rem;color:#475569;}
.qq-letterhead-name{margin:2px 0;font-size:1.05rem;font-weight:800;color:#1e3a5f;letter-spacing:.8px;text-transform:uppercase;}
.qq-letterhead-hist{font-size:.62rem;color:#64748b;font-weight:500;letter-spacing:.3px;}
.qq-letterhead-addr{font-size:.62rem;color:#64748b;margin-top:2px;}
.qq-letterhead-contact{font-size:.58rem;color:#94a3b8;}
.qq-paper-header{display:flex;align-items:center;gap:14px;padding:18px 24px;border-bottom:2px solid #1e40af;background:linear-gradient(135deg,#f0f4fa 0%,#e8eff8 100%);}
.qq-paper-logo{width:52px;height:52px;object-fit:contain;flex-shrink:0;}
.qq-type-badge{display:inline-flex;padding:5px 16px;border-radius:8px;font-size:.75rem;font-weight:700;letter-spacing:.5px;}
.qq-type-set{background:#dbeafe;color:#1e40af;}
.qq-type-sef{background:#dcfce7;color:#166534;}
.qq-instructions{background:#fffbeb;border-bottom:1px solid #fde68a;padding:10px 24px;font-size:.82rem;color:#92400e;display:grid;grid-template-columns:auto minmax(0,1fr);align-items:start;column-gap:10px;line-height:1.6;}
.qq-instructions>i{font-size:.92rem;color:#d97706;line-height:1.4;margin-top:.08rem;}
.qq-instructions strong{color:#78350f;}
.qq-instructions-content{display:grid;gap:.35rem;min-width:0;}
.qq-instructions-title{margin:0;}
.qq-scale{display:grid;gap:.15rem;}
.qq-scale-item{display:grid;grid-template-columns:1.2rem auto minmax(0,1fr);align-items:baseline;column-gap:.35rem;}
.qq-scale-score{font-weight:700;color:#78350f;text-align:right;}
.qq-scale-separator{font-weight:600;color:#b45309;}

/* ─── Category ─── */
.qq-section{border-bottom:1px solid #e5e7eb;}
.qq-section:last-child{border-bottom:none;}
.qq-category-bar{display:flex;align-items:center;justify-content:space-between;background:#1E3A8A;color:#fff;padding:10px 24px;}
.qq-category-comments{background:linear-gradient(135deg,#475569 0%,#64748b 100%);}
.qq-category-num{width:26px;height:26px;border-radius:7px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;flex-shrink:0;}
.qq-category-label{font-weight:700;font-size:.85rem;letter-spacing:.3px;text-transform:uppercase;}
.qq-category-count{font-size:.72rem;color:rgba(255,255,255,.55);font-weight:500;}
.qq-category-description{background:#eff6ff;border-bottom:1px solid #bfdbfe;padding:12px 24px;font-size:.82rem;color:#1e3a5f;line-height:1.6;}
.qq-category-description strong{color:#1e293b;font-size:.88rem;}
.qq-category-description em{color:#475569;font-style:italic;}
.qq-desc-btn{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25);border-radius:6px;color:rgba(255,255,255,.7);font-size:.68rem;font-weight:600;padding:3px 10px;cursor:pointer;transition:all .15s;letter-spacing:.2px;}
.qq-desc-btn:hover{background:rgba(255,255,255,.22);color:#fff;border-color:rgba(255,255,255,.45);}

/* ─── Table ─── */
.qq-table{width:100%;border-collapse:collapse;font-size:.84rem;}
.qq-table thead{background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-bottom:2px solid #e2e8f0;}
.qq-table thead th{padding:10px 12px;font-size:.68rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.4px;vertical-align:bottom;border:none;}
.qq-table thead th small{display:block;font-weight:500;font-size:.58rem;color:#94a3b8;text-transform:capitalize;letter-spacing:0;margin-top:1px;}
.qq-th-num{width:42px;text-align:center;}
.qq-th-question{text-align:left;padding-left:20px!important;}
.qq-th-evidence{text-align:left;min-width:220px;}
.qq-th-rating{width:58px;text-align:center;}
.qq-th-actions{width:100px;text-align:center;}

/* ─── Table Body ─── */
.qq-table tbody tr{border-bottom:1px solid #f1f5f9;transition:background .12s ease;}
.qq-table tbody tr:last-child{border-bottom:none;}
.qq-table tbody tr:hover{background:#f8faff;}
.qq-table tbody td{padding:12px 12px;vertical-align:middle;}
.qq-td-num{text-align:center;font-weight:600;color:#94a3b8;font-size:.8rem;}
.qq-td-question{padding-left:20px!important;}
.qq-td-evidence{min-width:220px;}
.qq-question-text{color:#1e293b;font-weight:500;line-height:1.5;}
.qq-question-main{display:flex;align-items:flex-start;gap:.3rem;flex-wrap:wrap;}
.qq-question-sub{margin-top:.55rem;color:#475569;font-style:italic;line-height:1.5;}
.qq-question-meta{display:flex;gap:5px;margin-top:4px;flex-wrap:wrap;}
.qq-evidence-list{display:flex;flex-direction:column;gap:4px;}
.qq-evidence-item{display:flex;align-items:flex-start;gap:7px;font-size:.72rem;color:#475569;line-height:1.35;}
.qq-evidence-item input{margin-top:2px;pointer-events:none;}
.qq-evidence-empty{font-size:.72rem;color:#94a3b8;font-style:italic;}
.qq-badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:5px;font-size:.62rem;font-weight:600;letter-spacing:.2px;}
.qq-badge-active{background:#ecfdf5;color:#059669;}
.qq-badge-inactive{background:#f1f5f9;color:#64748b;}
.qq-badge-required{background:#fef3c7;color:#b45309;}
.qq-badge-optional{background:#f0f9ff;color:#0284c7;}
.qq-badge-weight{background:#f5f3ff;color:#7c3aed;}
.qq-optional-tag{display:inline-block;font-size:.6rem;font-weight:700;color:#0284c7;background:#e0f2fe;padding:1px 8px;border-radius:4px;letter-spacing:.3px;text-transform:uppercase;margin-bottom:2px;}
.qq-td-rating{text-align:center;}
.qq-radio{display:inline-block;width:20px;height:20px;border-radius:50%;border:2px solid #cbd5e1;background:#fff;transition:all .2s ease;vertical-align:middle;}
.qq-table tbody tr:hover .qq-radio{border-color:#93c5fd;box-shadow:0 0 0 2px rgba(59,130,246,.06);}
.qq-td-actions{text-align:center;}

/* ─── Actions ─── */
.qq-actions{display:flex;align-items:center;gap:4px;justify-content:center;}
.qq-action-btn{width:32px;height:32px;border:none;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;font-size:.78rem;cursor:pointer;transition:all .15s ease;background:transparent;color:#94a3b8;}
.qq-action-edit{color:#3b82f6;}
.qq-action-edit:hover{background:#eff6ff;color:#1d4ed8;transform:scale(1.1);}
.qq-action-delete{color:#ef4444;}
.qq-action-delete:hover{background:#fef2f2;color:#dc2626;transform:scale(1.1);}

/* ─── Empty / Comment ─── */
.qq-empty-state{text-align:center;padding:48px 20px;}
.qq-empty-icon{width:64px;height:64px;border-radius:50%;background:#f1f5f9;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:1.6rem;color:#94a3b8;}
.qq-comment-box{border:2px dashed #d1d5db;border-radius:10px;min-height:80px;background:#fafbfc;display:flex;align-items:center;justify-content:center;gap:8px;transition:border-color .2s;}
.qq-comment-box:hover{border-color:#93c5fd;}

/* ─── Modal ─── */
.qq-modal-content{border:none;border-radius:0;overflow:hidden;box-shadow:0 24px 48px rgba(0,0,0,.12);}
.qq-modal-header{display:flex;align-items:center;justify-content:space-between;padding:18px 22px;background:linear-gradient(135deg,#0f172a 0%,#1e40af 60%,#3b82f6 100%);color:#fff;}
.qq-modal-header-blue{background:linear-gradient(135deg,#1e3a8a,#2563eb);}
.qq-modal-icon{width:38px;height:38px;min-width:38px;border-radius:10px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;font-size:.9rem;backdrop-filter:blur(4px);}
.qq-form-label{font-size:.78rem;font-weight:600;color:#475569;margin-bottom:4px;}

/* ─── Responsive ─── */
@media(max-width:768px){
    .qq-stats-row{flex-wrap:wrap;gap:8px;}
    .qq-stat{min-width:45%;}
    .qq-stat-divider{display:none;}
    .qq-toolbar{flex-direction:column;align-items:stretch;}
    .qq-search-wrap{max-width:100%;}
    .qq-toolbar-info{margin-left:0;text-align:right;}
    .qq-table{font-size:.75rem;}
    .qq-table thead th{padding:8px 8px;font-size:.6rem;}
    .qq-table tbody td{padding:8px 8px;}
    .qq-th-evidence,.qq-td-evidence{min-width:170px;}
    .qq-th-rating{width:40px;}
    .qq-paper-header{flex-direction:column;text-align:center;gap:8px;}
}

/* ─── Animations ─── */
.qq-header,.qq-toolbar,.qq-paper{animation:qqFadeIn .25s ease;}
@keyframes qqFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.qq-row{animation:qqRowIn .2s ease backwards;}
@keyframes qqRowIn{from{opacity:0;transform:translateX(-8px);}to{opacity:1;transform:translateX(0);}}
</style>
{% endblock %}

{% block body %}
{# ═══════════════════════════════════════
   COMPUTE STATS
   ═══════════════════════════════════════ #}
{% set totalQ = questions|length %}
{% set requiredCount = 0 %}
{% set optionalCount = 0 %}
{% set activeCount = 0 %}
{% set inactiveCount = 0 %}
{% for q in questions %}
    {% if q.isRequired %}{% set requiredCount = requiredCount + 1 %}{% else %}{% set optionalCount = optionalCount + 1 %}{% endif %}
    {% if q.isActive %}{% set activeCount = activeCount + 1 %}{% else %}{% set inactiveCount = inactiveCount + 1 %}{% endif %}
{% endfor %}

{# ═══════════════════════════════════════
   GRADIENT HEADER
   ═══════════════════════════════════════ #}
<div class="qq-header">
    <div class="qq-header-inner">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="qq-header-icon">
                    <i  class="bi bi-clipboard-check"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">Questionnaire Management</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                        <span class="qq-meta-pill"><i  class="bi bi-database me-1"></i>{{ totalQ }} Question{{ totalQ != 1 ? 's' : '' }}</span>
                        <span class="qq-meta-pill"><i  class="bi bi-folder me-1"></i>{{ categories|length }} Section{{ categories|length != 1 ? 's' : '' }}</span>
                        <span class="qq-meta-pill qq-meta-type"><i  class="bi bi-tag me-1"></i>{{ selectedType }}</span>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-1 align-items-center">
                <div class="btn-group btn-group-sm">
                    <a href="{{ path(prefix ~ '_questions', {type: 'SET'}) }}"
                       class="btn btn-sm {{ selectedType == 'SET' ? 'btn-light fw-bold' : 'btn-outline-light' }}">SET</a>
                    <a href="{{ path(prefix ~ '_questions', {type: 'SEF'}) }}"
                       class="btn btn-sm {{ selectedType == 'SEF' ? 'btn-light fw-bold' : 'btn-outline-light' }}">SEF</a>
                </div>
                <a href="{{ path(prefix ~ '_question_create_form', {type: selectedType}) }}" class="btn btn-sm btn-light fw-semibold shadow-sm">
                    <i  class="bi bi-plus me-1"></i>Add Question
                </a>
            </div>
        </div>
        <div class="qq-stats-row">
            <div class="qq-stat">
                <span class="qq-stat-val">{{ totalQ }}</span>
                <span class="qq-stat-lbl">Total Questions</span>
            </div>
            <div class="qq-stat-divider"></div>
            <div class="qq-stat">
                <span class="qq-stat-val">{{ categories|length }}</span>
                <span class="qq-stat-lbl">Sections</span>
            </div>
            <div class="qq-stat-divider"></div>
            <div class="qq-stat">
                <span class="qq-stat-val qq-val-success">{{ activeCount }}</span>
                <span class="qq-stat-lbl">Active</span>
            </div>
            <div class="qq-stat-divider"></div>
            <div class="qq-stat">
                <span class="qq-stat-val qq-val-warn">{{ requiredCount }}</span>
                <span class="qq-stat-lbl">Required</span>
            </div>
        </div>
    </div>
</div>

<div class="qq-disclaimer">
    <div class="qq-disclaimer-head">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-shield-lock"></i>
            <div>
                <div>Data Privacy Disclaimer</div>
                <span class="qq-disclaimer-sub">Please read before proceeding</span>
            </div>
        </div>
        <button type="button" class="btn btn-sm btn-outline-light qq-disclaimer-edit" data-bs-toggle="modal" data-bs-target="#disclaimerModal">
            <i class="bi bi-pencil-square me-1"></i>Edit Text
        </button>
    </div>
    <div class="qq-disclaimer-body">
        {{ questionnaireDisclaimerHtml|raw }}
    </div>
</div>

{# ═══════════════════════════════════════
   TOOLBAR
   ═══════════════════════════════════════ #}
<div class="qq-toolbar">
    <div class="qq-search-wrap">
        <i  class="bi bi-search"></i>
        <input type="text" class="qq-search" id="qqSearch" placeholder="Search questions..." autocomplete="off">
    </div>
    <div class="qq-filter-group">
        <i  class="bi bi-funnel qq-filter-icon"></i>
        <select class="qq-filter-select" id="qqCatFilter">
            <option value="">All Sections</option>
            {% for cat in categories %}
            <option value="{{ cat }}">{{ cat }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="qq-filter-group">
        <i  class="bi bi-check-circle-fill qq-filter-icon"></i>
        <select class="qq-filter-select" id="qqStatusFilter" style="min-width:140px;">
            <option value="">All Status</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
        </select>
    </div>
    <div class="qq-toolbar-info">
        <span class="qq-result-count" id="qqResultCount">{{ totalQ }} question{{ totalQ != 1 ? 's' : '' }}</span>
    </div>
</div>

{# ═══════════════════════════════════════
   FORM PAPER
   ═══════════════════════════════════════ #}
<div class="qq-paper">
    {# University Letterhead #}
    <div style="text-align:center;padding:16px 24px;border-bottom:3px solid #1e40af;background:#fff;">
        <img src="{{ asset('images/header.jpg') }}" alt="NORSU Letterhead" style="max-width:100%;height:auto;">
    </div>
    <div style="text-align:center;padding:10px 0 8px;border-bottom:2px solid #1e40af;background:#f8fafc;">
        <span class="qq-type-badge {{ selectedType == 'SET' ? 'qq-type-set' : 'qq-type-sef' }}" style="font-size:.85rem;padding:6px 20px;">{{ selectedType == 'SET' ? 'Student Evaluation for Teacher (SET)' : 'Superior Evaluation for Faculty (SEF)' }}</span>
    </div>
    <div style="text-align:center;padding:12px 32px 14px;background:#fff;border-bottom:1px solid #e2e8f0;">
        <div style="font-size:.82rem;font-weight:600;color:#475569;margin-bottom:6px;">(NBC 461 Evaluation Instrument for Teaching Effectiveness)</div>
        <p style="font-size:.78rem;color:#64748b;line-height:1.6;margin:0;">It's time to evaluate your teacher. Please answer honestly based on your experience. All responses are confidential, and your identity will not be shared with faculty members. Your feedback is valuable in improving the quality of teaching.</p>
    </div>

    {# Instructions Banner #}
    <div class="qq-instructions">
        <i  class="bi bi-info-circle"></i>
        <div class="qq-instructions-content">
            <div class="qq-instructions-title"><strong>Instructions:</strong> Rate each item using the scale:</div>
            <div class="qq-scale">
                <div class="qq-scale-item"><span class="qq-scale-score">5</span><span class="qq-scale-separator">–</span><span>Always manifested</span></div>
                <div class="qq-scale-item"><span class="qq-scale-score">4</span><span class="qq-scale-separator">–</span><span>Often manifested</span></div>
                <div class="qq-scale-item"><span class="qq-scale-score">3</span><span class="qq-scale-separator">–</span><span>Sometimes manifested</span></div>
                <div class="qq-scale-item"><span class="qq-scale-score">2</span><span class="qq-scale-separator">–</span><span>Seldom manifested</span></div>
                <div class="qq-scale-item"><span class="qq-scale-score">1</span><span class="qq-scale-separator">–</span><span>Never/Rarely manifested</span></div>
            </div>
        </div>
    </div>

    {# Sections #}
    {% set globalNum = 1 %}
    {% for category in categories %}
    <div class="qq-section" data-category="{{ category }}">
        <div class="qq-category-bar">
            <div class="d-flex align-items-center gap-2">
                <span class="qq-category-num">{{ loop.index }}</span>
                <span class="qq-category-label">{{ category ?? 'Uncategorized' }}</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button type="button" class="qq-desc-btn" data-bs-toggle="modal" data-bs-target="#descModal{{ loop.index }}" title="Edit section description">
                    <i  class="bi bi-pencil-square me-1"></i>Description
                </button>
                <span class="qq-category-count">{{ questions|filter(q => q.category == category)|length }} question{{ questions|filter(q => q.category == category)|length != 1 ? 's' : '' }}</span>
            </div>
        </div>
        {% if categoryDescriptions[category] is defined and categoryDescriptions[category] %}
        <div class="qq-category-description">
            <em>{{ categoryDescriptions[category]|replace({' (': "\n\n("})|replace({') and ': ")\n\nand "})|nl2br }}</em>
        </div>
        {% endif %}
        <table class="qq-table">
            <thead>
                <tr>
                    <th class="qq-th-num">#</th>
                    <th class="qq-th-question">Question</th>
                    {% if selectedType == 'SEF' %}
                    <th class="qq-th-evidence">Means of Verification</th>
                    {% endif %}
                        <th class="qq-th-rating">1<br><small>Never/Rarely manifested</small></th>
                        <th class="qq-th-rating">2<br><small>Seldom manifested</small></th>
                        <th class="qq-th-rating">3<br><small>Sometimes manifested</small></th>
                        <th class="qq-th-rating">4<br><small>Often manifested</small></th>
                        <th class="qq-th-rating">5<br><small>Always manifested</small></th>
                    <th class="qq-th-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% set counter = 1 %}
                {% for q in questions|filter(q => q.category == category) %}
                {% set rowSearchText = q.questionText %}
                {% if selectedType == 'SEF' %}
                    {% set rowSearchText = rowSearchText ~ ' ' ~ ((q.evidenceItems ?? [])|join(' ')) %}
                {% endif %}
                <tr class="qq-row" data-question="{{ rowSearchText|lower }}" data-status="{{ q.isActive ? 'active' : 'inactive' }}">
                    <td class="qq-td-num">{{ counter }}.</td>
                    <td class="qq-td-question">
                        {% if not q.isRequired %}
                            <span class="qq-optional-tag">Optional</span>
                        {% endif %}
                        <div class="qq-question-text">
                            {% set questionParts = q.questionText|split('(', 2) %}
                            {% if questionParts|length > 1 %}
                                <div class="qq-question-main">
                                    <span>{{ questionParts[0]|trim }}</span>
                                    {% if q.isRequired %}
                                        <span class="text-danger fw-bold" title="Required">*</span>
                                    {% endif %}
                                </div>
                                <div class="qq-question-sub">({{ questionParts[1]|trim }}</div>
                            {% else %}
                                {{ q.questionText }}
                                {% if q.isRequired %}
                                    <span class="text-danger fw-bold" title="Required">*</span>
                                {% endif %}
                            {% endif %}
                        </div>
                        <div class="qq-question-meta">
                            {% if not q.isActive %}
                                <span class="qq-badge qq-badge-inactive"><i  class="bi bi-pause-circle-fill me-1"></i>Inactive</span>
                            {% else %}
                                <span class="qq-badge qq-badge-active"><i  class="bi bi-check-circle-fill me-1"></i>Active</span>
                            {% endif %}
                            {% if q.isRequired %}
                                <span class="qq-badge qq-badge-required"><i  class="bi bi-asterisk me-1"></i>Required</span>
                            {% else %}
                                <span class="qq-badge qq-badge-optional">Optional</span>
                            {% endif %}
                            {% if q.weight != 1 %}
                                <span class="qq-badge qq-badge-weight"><i  class="bi bi-speedometer2 me-1"></i>{{ q.weight }}x</span>
                            {% endif %}
                        </div>
                    </td>
                    {% if selectedType == 'SEF' %}
                    <td class="qq-td-evidence">
                        {% set evidenceItems = q.evidenceItems ?? [] %}
                        {% if evidenceItems|length > 0 %}
                        <div class="qq-evidence-list">
                            {% for evidence in evidenceItems %}
                            <label class="qq-evidence-item">
                                <input type="checkbox" disabled>
                                <span>{{ evidence }}</span>
                            </label>
                            {% endfor %}
                        </div>
                        {% else %}
                        <span class="qq-evidence-empty">No checklist items</span>
                        {% endif %}
                    </td>
                    {% endif %}
                    <td class="qq-td-rating"><span class="qq-radio"></span></td>
                    <td class="qq-td-rating"><span class="qq-radio"></span></td>
                    <td class="qq-td-rating"><span class="qq-radio"></span></td>
                    <td class="qq-td-rating"><span class="qq-radio"></span></td>
                    <td class="qq-td-rating"><span class="qq-radio"></span></td>
                    <td class="qq-td-actions">
                        <div class="qq-actions">
                            <button class="qq-action-btn qq-action-edit" title="Edit Question"
                                    data-bs-toggle="modal" data-bs-target="#editModal{{ q.id }}">
                                <i  class="bi bi-pencil-square"></i>
                            </button>
                            <form method="post" action="{{ path(prefix ~ '_question_delete', {id: q.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Delete this question?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_q' ~ q.id) }}">
                                <button class="qq-action-btn qq-action-delete" title="Delete Question">
                                    <i  class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% set counter = counter + 1 %}
                {% set globalNum = globalNum + 1 %}
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="qq-empty-state">
        <div class="qq-empty-icon"><i  class="bi bi-journal-plus"></i></div>
        <h6 class="fw-bold text-muted mb-1">No Questions Found</h6>
        <p class="text-muted mb-3" style="font-size:.85rem;">No questions found for <strong>{{ selectedType }}</strong>.</p>
        <a href="{{ path(prefix ~ '_question_create_form', {type: selectedType}) }}" class="btn btn-sm btn-primary">
            <i  class="bi bi-plus me-1"></i>Add First Question
        </a>
    </div>
    {% endfor %}

    {# Comments Section Preview #}
    {% if categories|length > 0 %}
    <div class="qq-section">
        <div class="qq-category-bar qq-category-comments">
            <div class="d-flex align-items-center gap-2">
                <span class="qq-category-num" style="background:rgba(255,255,255,.2);"><i  style="font-size:.65rem;" class="bi bi-chat-dots"></i></span>
                <span class="qq-category-label">Comments / Feedback</span>
            </div>
        </div>
        <div class="p-4">
            <div class="qq-comment-box">
                <i  class="bi bi-pencil text-muted"></i>
                <span class="text-muted" style="font-size:.82rem;">Student comments will appear here...</span>
            </div>
        </div>
    </div>
    {% endif %}
</div>

{# ═══════════════════════════════════════
   EDIT MODALS
   ═══════════════════════════════════════ #}
{% for category in categories %}
{% for q in questions|filter(q => q.category == category) %}
<div class="modal fade" id="editModal{{ q.id }}" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content qq-modal-content">
            <form method="post" action="{{ path(prefix ~ '_question_edit', {id: q.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('edit_q' ~ q.id) }}">
                <div class="qq-modal-header qq-modal-header-blue">
                    <div class="d-flex align-items-center gap-3">
                        <div class="qq-modal-icon"><i  class="bi bi-pencil-square"></i></div>
                        <div>
                            <h6 class="fw-bold mb-0 text-white">Edit Question</h6>
                            <span style="font-size:.75rem;color:rgba(255,255,255,.65);">ID #{{ q.id }} &middot; {{ q.category ?? 'Uncategorized' }}</span>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="qq-form-label">Question Text <span class="text-danger">*</span></label>
                        <textarea name="questionText" class="form-control" rows="3" required>{{ q.questionText }}</textarea>
                    </div>
                    {% if selectedType == 'SEF' %}
                    <div class="mb-3">
                        <label class="qq-form-label">Means of Verification (optional)</label>
                        <textarea name="evidenceItemsText" class="form-control" rows="4" placeholder="One item per line">{{ (q.evidenceItems ?? [])|join("\n") }}</textarea>
                        <div class="form-text">Enter one checklist item per line. These will appear as checkboxes in the middle column.</div>
                    </div>
                    {% endif %}
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="qq-form-label">Category</label>
                            <input type="text" name="category" class="form-control" value="{{ q.category }}" list="editCatList{{ q.id }}">
                            <datalist id="editCatList{{ q.id }}">
                                {% for cat in categories %}<option value="{{ cat }}">{% endfor %}
                            </datalist>
                        </div>
                        <div class="col-md-3">
                            <label class="qq-form-label">Weight</label>
                            <input type="number" name="weight" class="form-control" value="{{ q.weight }}" step="0.1" min="0">
                        </div>
                        <div class="col-md-3">
                            <label class="qq-form-label">Sort Order</label>
                            <input type="number" name="sortOrder" class="form-control" value="{{ q.sortOrder }}">
                        </div>
                    </div>
                    <div class="d-flex gap-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="isRequired" value="1"
                                   id="reqEdit{{ q.id }}" {{ q.isRequired ? 'checked' }}>
                            <label class="form-check-label" for="reqEdit{{ q.id }}">Required</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="isActive" value="1"
                                   id="activeEdit{{ q.id }}" {{ q.isActive ? 'checked' }}>
                            <label class="form-check-label" for="activeEdit{{ q.id }}">Active</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top" style="background:#f8fafc;">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-primary px-4">
                        <i  class="bi bi-check me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endfor %}
{% endfor %}

{# ═══════════════════════════════════════
   DESCRIPTION MODALS
   ═══════════════════════════════════════ #}
{% for category in categories %}
<div class="modal fade" id="descModal{{ loop.index }}" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content qq-modal-content">
            <form method="post" action="{{ path(prefix ~ '_question_category_description') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('cat_desc') }}">
                <input type="hidden" name="evaluationType" value="{{ selectedType }}">
                <input type="hidden" name="category" value="{{ category }}">
                <div class="qq-modal-header qq-modal-header-blue">
                    <div class="d-flex align-items-center gap-3">
                        <div class="qq-modal-icon"><i  class="bi bi-file-earmark-text"></i></div>
                        <div>
                            <h6 class="fw-bold mb-0 text-white">Section Description</h6>
                            <span style="font-size:.75rem;color:rgba(255,255,255,.65);">{{ category }}</span>
