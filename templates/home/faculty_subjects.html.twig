{# ═══════════════════════════════════════
   JAVASCRIPT
   ═══════════════════════════════════════ #}
<script>
/* ── Global active evaluations map ── */
let activeEvaluations = {};

try {
    activeEvaluations = {{ activeEvalMap|json_encode|raw }};
    window.hasActiveEval = Object.keys(activeEvaluations).length > 0;
    window.firstActiveEvalId = Object.keys(activeEvaluations).length > 0 ? Object.keys(activeEvaluations)[0] : null;
    console.log('Active Evaluations loaded successfully:', Object.keys(activeEvaluations).length, 'evaluations');
} catch (e) {
    console.error('Failed to load active evaluations:', e);
    window.hasActiveEval = false;
    window.firstActiveEvalId = null;
    activeEvaluations = {};
}

// Make it available globally if needed
window.activeEvaluations = activeEvaluations;

// Faculty and evaluation data for QR modals
// Get faculty name from user object
let facultyFirstName = '{{ app.user.firstName|e("js") }}'.trim();
let facultyLastName = '{{ app.user.lastName|e("js") }}'.trim();

// Build full name with proper fallbacks
let facultyFullName = '';
if (facultyFirstName && facultyLastName) {
    facultyFullName = facultyFirstName + ' ' + facultyLastName;
} else if (facultyFirstName) {
    facultyFullName = facultyFirstName;
} else if (facultyLastName) {
    facultyFullName = facultyLastName;
}

// Try alternatives if both are empty
if (!facultyFullName) {
    let altName = '{{ app.user.fullName|e("js") }}'.trim();
    if (altName) facultyFullName = altName;
}

if (!facultyFullName) {
    let altEmail = '{{ app.user.email|e("js") }}'.trim();
    if (altEmail) facultyFullName = altEmail.split('@')[0]; // Use username part of email
}

if (!facultyFullName) {
    facultyFullName = 'Faculty';
}

window.facultyName = facultyFullName;
window.facultyNameCandidates = [];
if (facultyFirstName && facultyLastName) {
    window.facultyNameCandidates.push((facultyFirstName + ' ' + facultyLastName).toLowerCase());
    window.facultyNameCandidates.push((facultyLastName + ', ' + facultyFirstName).toLowerCase());
    window.facultyNameCandidates.push(facultyLastName.toLowerCase());
}
if (facultyFullName) {
    window.facultyNameCandidates.push(facultyFullName.toLowerCase());
}

// Remove duplicates / empty values
window.facultyNameCandidates = window.facultyNameCandidates.filter(function(v, i, arr) {
    return !!v && arr.indexOf(v) === i;
});

console.log('Faculty Name Resolution:', {
    firstName: '{{ app.user.firstName|e("js") }}',
    lastName: '{{ app.user.lastName|e("js") }}',
    firstName_trimmed: facultyFirstName,
    lastName_trimmed: facultyLastName,
    finalFacultyName: window.facultyName
});

function normalizeQrText(value) {
    return (value || '').toString().trim().toLowerCase();
}

function getEvalSubjectCode(evalSubject) {
    if (!evalSubject) return '';
    var parts = evalSubject.split(' — ');
    return normalizeQrText(parts[0] || evalSubject);
}

function facultyMatchesEvaluation(evalData) {
    var evalFaculty = normalizeQrText(evalData && evalData.faculty ? evalData.faculty : '');
    if (!evalFaculty) return true;
    if (!window.facultyNameCandidates || window.facultyNameCandidates.length === 0) return true;

    return window.facultyNameCandidates.some(function(candidate) {
        return evalFaculty === candidate || evalFaculty.indexOf(candidate) !== -1 || candidate.indexOf(evalFaculty) !== -1;
    });
}

function subjectMatchesEvaluation(evalData, subjectCode, subjectName) {
    var evalSubject = normalizeQrText(evalData && evalData.subject ? evalData.subject : '');
    if (!evalSubject) return true;

    var code = normalizeQrText(subjectCode);
    var name = normalizeQrText(subjectName);
    var evalCode = getEvalSubjectCode(evalData.subject || '');

    return (evalCode && code === evalCode) ||
        code.indexOf(evalSubject) === 0 ||
        evalSubject.indexOf(code) === 0 ||
        name.indexOf(evalSubject) !== -1;
}

function sectionMatchesEvaluation(evalData, section) {
    var evalSection = normalizeQrText(evalData && evalData.section ? evalData.section : '');
    if (!evalSection) return true;
    return evalSection === normalizeQrText(section);
}

function findMatchingEvaluationForSubject(subjectCode, subjectName, section) {
    var entries = Object.entries(window.activeEvaluations || {});
    var fallbackMatch = null;

    for (var i = 0; i < entries.length; i++) {
        var evalId = entries[i][0];
        var evalData = entries[i][1] || {};

        if (!facultyMatchesEvaluation(evalData)) continue;
        if (!subjectMatchesEvaluation(evalData, subjectCode, subjectName)) continue;

        if (sectionMatchesEvaluation(evalData, section)) {
            return { id: evalId, data: evalData };
        }

        if (!fallbackMatch) {
            fallbackMatch = { id: evalId, data: evalData };
        }
    }

    return fallbackMatch;
}

function escapeHtmlAttr(value) {
    return (value || '').toString()
        .replace(/&/g, '&amp;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

// Debug log
console.log('Faculty subjects page loaded');
console.log('  - Has active evaluations:', window.hasActiveEval);
console.log('  - Faculty:', window.facultyName);

/* ── Checked count ── */
function updateCheckedCount() {
    var count = document.querySelectorAll('.subject-check:checked').length;
    document.getElementById('checkedCount').textContent = count;
}

/* ── Toggle department sections ── */
function toggleDept(deptId) {
    if (!deptId) {
        console.warn('toggleDept called without deptId');
        return;
    }

    const bodyId = 'deptBody' + deptId;
    const sectionId = 'deptSection' + deptId;

    const body = document.getElementById(bodyId);
    const section = document.getElementById(sectionId);

    if (!body || !section) {
        console.warn('toggleDept: Could not find elements', { bodyId, sectionId, bodyExists: !!body, sectionExists: !!section });
        return;
    }

    // Toggle the body open class
    body.classList.toggle('open');

    // Toggle the chevron open class
    const chevron = section.querySelector('.sb-dept-chevron');
    if (chevron) {
        chevron.classList.toggle('open');
    }

    console.log('Department toggled:', deptId, 'now open:', body.classList.contains('open'));
}

/* ═══════════════════════════════════════════════════════
   FILTER SYSTEM - DEPARTMENTS, YEAR LEVELS, SEARCH
   ═══════════════════════════════════════════════════════ */

function applyFilters() {
    const searchBox = document.getElementById('subjectSearchInput');
    const deptDropdown = document.getElementById('departmentFilter');
    const yearDropdown = document.getElementById('yearLevelFilter');

    if (!searchBox || !deptDropdown || !yearDropdown) {
        console.warn('Filter elements not found');
        return;
    }

    const searchText = searchBox.value.toLowerCase().trim();
    const selectedDeptId = deptDropdown.value.trim(); // Empty string or department ID
    const selectedYear = yearDropdown.value.toLowerCase().trim(); // Empty string or year level

    console.log('FILTER APPLIED:', { search: searchText, dept: selectedDeptId, year: selectedYear });

    let totalMatches = 0;

    // Loop through all department sections
    document.querySelectorAll('.sb-dept-section').forEach(function(section) {
        const sectionId = section.id; // e.g., "deptSection1"
        if (!sectionId) return;

        const sectionDeptId = sectionId.replace('deptSection', '').trim();

        // Check if this section's department matches the filter
        const deptFilterMatch = selectedDeptId === '' || sectionDeptId === selectedDeptId;

        if (!deptFilterMatch) {
            // Hide entire section if department doesn't match
            section.style.display = 'none';
            return;
        }

        // Department matches - now filter the rows within this section
        let visibleRowCount = 0;
        let totalRowCount = 0;

        const rows = section.querySelectorAll('.sb-row');

        rows.forEach(function(row) {
            totalRowCount++;

            const rowSearchText = (row.getAttribute('data-search') || '').toLowerCase();
            const rowYear = (row.getAttribute('data-yearlevel') || '').toLowerCase().trim();

            // Check if row matches all active filters
            const matchesSearch = searchText === '' || rowSearchText.includes(searchText);
            const matchesYear = selectedYear === '' || rowYear === selectedYear;

            const rowShouldShow = matchesSearch && matchesYear;

            if (rowShouldShow) {
                row.style.display = '';
                visibleRowCount++;
                totalMatches++;
            } else {
                row.style.display = 'none';
            }
        });

        // Update section display: show if rows match, or if no filters applied
        const hasActiveFilters = searchText !== '' || selectedYear !== '' || selectedDeptId !== '';

        if (visibleRowCount > 0) {
            section.style.display = '';
        } else if (!hasActiveFilters) {
            section.style.display = '';
        } else {
            section.style.display = 'none';
        }

        // Update section meta text
        const metaEl = section.querySelector('.sb-dept-meta');
        if (metaEl && totalRowCount > 0) {
            if (hasActiveFilters && (searchText !== '' || selectedYear !== '')) {
                metaEl.textContent = visibleRowCount + ' of ' + totalRowCount + ' subject' + (totalRowCount !== 1 ? 's' : '') + ' shown';
            } else {
                metaEl.textContent = totalRowCount + ' subject' + (totalRowCount !== 1 ? 's' : '') + ' available';
            }
        }
    });

    console.log('Filter complete - total matching rows:', totalMatches);
}

function searchSubjects(value) {
    applyFilters();
}

function filterByDepartment(value) {
    console.log('Department selected:', value);
    applyFilters();
}

function filterByYearLevel(value) {
    console.log('Year level selected:', value);
    applyFilters();
}

/* ── Semester filter ── */
function filterBySemester(val) {
    console.log('filterBySemester called with:', val);
    /* Fade out content then navigate for smooth transition */
    var mc = document.querySelector('.main-content');
    if (mc) {
        mc.style.transition = 'opacity .12s ease';
        mc.style.opacity = '0';
    }
    var url = val
        ? '{{ path('faculty_subjects') }}?semester=' + encodeURIComponent(val)
        : '{{ path('faculty_subjects') }}';
    setTimeout(function() {
        /* Use a temporary Turbo-driven link for smooth navigation */
        var a = document.createElement('a');
        a.href = url;
        a.style.display = 'none';
        document.body.appendChild(a);
        a.click();
        a.remove();
    }, 120);
}

/* ── Unload ── */
var unloadTargetId = null;
var loadedSubjectIds = [{% for id in loadedSubjectIds %}{{ id }}{% if not loop.last %},{% endif %}{% endfor %}];

function unloadSubject(subjectId, subjectCode) {
    unloadTargetId = subjectId;
    document.getElementById('unloadSubjectName').textContent = subjectCode;
    new bootstrap.Modal(document.getElementById('unloadModal')).show();
}

function quickLoadSubject(subjectId) {
    /* Validate section is filled before quick-loading */
    var sectionInput = document.querySelector('.sb-section-input[data-subject-id="' + subjectId + '"]');
    if (sectionInput && !sectionInput.value.trim()) {
        sectionInput.style.borderColor = '#ef4444';
        sectionInput.style.boxShadow = '0 0 0 3px rgba(239,68,68,.15)';
        sectionInput.focus();
        alert('Please fill in the Section before picking this subject.');
        return;
    }
    var cb = document.getElementById('subj_' + subjectId);
    if (cb) {
        cb.checked = true;
        cb.dispatchEvent(new Event('change', { bubbles: true }));
        updateCheckedCount();
    }
    document.getElementById('loadForm').submit();
}

/* ── Pick Again Modal ── */
function openPickAgainModal(subjectId, subjectCode, subjectName) {
    document.getElementById('pickAgainSubjectId').value = subjectId;
    document.getElementById('pickAgainSubjectLabel').textContent = subjectCode + ' — ' + subjectName;
    new bootstrap.Modal(document.getElementById('pickAgainModal')).show();
}

/* ── Remove additional FSL entry ── */
function removeFslEntry(fslId, token) {
    if (!confirm('Remove this section?')) return;
    var form = document.getElementById('removeFslForm');
    form.action = '{{ path('faculty_subject_unload_fsl', {id: '__ID__'}) }}'.replace('__ID__', fslId);
    document.getElementById('removeFslToken').value = token;
    form.submit();
}

/* ── Update row visuals when checkbox changes ── */
function updateRowVisual(cb) {
    var row = cb.closest('.sb-row');
    if (!row) return;
    var statusCell = row.querySelector('.sb-td-status');
    var actionCell = row.querySelector('.sb-action-btns');
    var sid = cb.dataset.subjectId;
    var code = row.querySelector('.sb-code-text') ? row.querySelector('.sb-code-text').textContent : '';

    if (cb.checked) {
        row.classList.add('is-loaded');
        if (statusCell) statusCell.innerHTML = '<span class="sb-status-badge loaded"><i  class="bi bi-check-circle-fill"></i> Loaded</span>';

        // Check for active evaluations immediately (bypass debounce)
        // Use setTimeout to allow the fetch to complete before rendering buttons
        window.pollActiveEvaluations(true);

        // Small delay to let polling update the state
        setTimeout(function() {
            console.log('Loading subject:', code);
            if (typeof window.updateQRButtonsForLoadedSubjects === 'function') {
                window.updateQRButtonsForLoadedSubjects();
            }
        }, 200);  // 200ms delay for network fetch to complete
    } else {
        row.classList.remove('is-loaded');
        if (statusCell) statusCell.innerHTML = '<span class="sb-status-badge available"><i  class="bi bi-circle-fill"></i> Available</span>';

        if (actionCell) actionCell.innerHTML = '<button type="button" class="sb-btn-pick" onclick="quickLoadSubject(' + sid + ')"><i  class="bi bi-plus-circle-fill"></i> Pick</button>';
    }
}

/* ── Stagger row animations */
function initializeEventListeners() {
    document.querySelectorAll('.sb-row').forEach(function(r, i) {
        r.style.animationDelay = (i * 0.02) + 's';
    });

    /* Attach checkbox change events */
    document.querySelectorAll('.subject-check').forEach(function(cb) {
        cb.addEventListener('change', function() {
            updateRowVisual(this);
            updateCheckedCount();
        });
    });

    /* Attach select-all per department */
    document.querySelectorAll('.sb-check-all').forEach(function(allCb) {
        allCb.addEventListener('change', function() {
            var deptId = this.dataset.dept;
            var body = document.getElementById('deptBody' + deptId);
            if (!body) return;
            body.querySelectorAll('.subject-check').forEach(function(cb) {
                cb.checked = allCb.checked;
                // Trigger change event to update row visuals
                cb.dispatchEvent(new Event('change', { bubbles: true }));
            });
            updateCheckedCount();
        });
    });

    /* Unload confirmation button */
    var confirmUnloadBtn = document.getElementById('confirmUnloadBtn');
    if (confirmUnloadBtn) {
        confirmUnloadBtn.addEventListener('click', function() {
            if (!unloadTargetId) return;
            var container = document.getElementById('unloadFormSubjects');
            container.innerHTML = '';
            loadedSubjectIds.forEach(function(id) {
                if (id !== unloadTargetId) {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'subject_ids[]';
                    input.value = id;
                    container.appendChild(input);
                }
            });
            document.getElementById('unloadForm').submit();
        });
    }

    /* Validate: require section for checked subjects only */
    var loadForm = document.getElementById('loadForm');
    if (loadForm) {
        loadForm.addEventListener('submit', function(e) {
            var missing = [];
            document.querySelectorAll('.subject-check:checked').forEach(function(cb) {
                var sid = cb.value;
                var sectionInput = document.querySelector('.sb-section-input[data-subject-id="' + sid + '"]');
                if (sectionInput && !sectionInput.value.trim()) {
                    missing.push(sectionInput);
                    sectionInput.style.borderColor = '#ef4444';
                    sectionInput.style.boxShadow = '0 0 0 3px rgba(239,68,68,.15)';
                }
            });
            if (missing.length > 0) {
                e.preventDefault();
                missing[0].focus();
                alert('Please fill in the Section for all selected subjects.');
                return false;
            }
        });
    }

    /* Clear error styling on input */
    document.querySelectorAll('.sb-section-input').forEach(function(inp) {
        inp.addEventListener('input', function() {
            this.style.borderColor = '';
            this.style.boxShadow = '';
        });
    });

    /* QR Code Modal */
    window.showQRModal = function(subjectId, subjectCode, subjectName, section, evalId, evalType, faculty, schoolYear, schedule) {
        console.log('showQRModal called with:', {subjectId, subjectCode, subjectName, section, evalId, evalType, faculty, schoolYear, schedule});

        // If evaluation data is incomplete, try to fetch from activeEvaluations
        if (!faculty || !schoolYear) {
            if (window.activeEvaluations && window.activeEvaluations[evalId]) {
                const evalData = window.activeEvaluations[evalId];
                faculty = faculty || evalData.faculty || '';
                schoolYear = schoolYear || evalData.schoolYear || evalData.name || '';
                console.log('Filled in missing eval data from activeEvaluations:', {faculty, schoolYear});
            }
        }

        const qrUrl = '{{ path('evaluation_qr_redirect_with_section', {'id': '__EVAL_ID__', 'subjectId': '__SUBJECT_ID__', 'section': '__SECTION__'}) }}'
            .replace('__EVAL_ID__', evalId)
            .replace('__SUBJECT_ID__', subjectId)
            .replace('__SECTION__', encodeURIComponent(section || ''));

        const fullUrl = window.location.origin + qrUrl;
        window.currentQrUrl = fullUrl;

        // Populate modal fields
        const typeBadge = document.getElementById('qrEvalType');
        if (typeBadge) typeBadge.textContent = evalType || 'SET';

        const facultyEl = document.getElementById('qrEvalFaculty');
        if (facultyEl) {
            facultyEl.textContent = faculty || '';
            console.log('Set faculty element to:', facultyEl.textContent);
        }

        const subjectEl = document.getElementById('qrEvalSubject');
        if (subjectEl) {
            subjectEl.textContent = `${subjectCode}${subjectName ? ' — ' + subjectName : ''}`;
            console.log('Set subject element to:', subjectEl.textContent);
        }

        // Show section and schedule
        var detailsText = [];
        if (section) detailsText.push(section);
        if (schedule) detailsText.push(schedule);

        const detailsEl = document.getElementById('qrEvalDetails');
        if (detailsEl) {
            detailsEl.textContent = detailsText.join(' | ') || '';
            console.log('Set details element to:', detailsEl.textContent);
        }

        const detailsRow = document.getElementById('qrEvalDetailsRow');
        if (detailsRow) detailsRow.style.display = detailsText.length > 0 ? '' : 'none';

        const urlEl = document.getElementById('qrUrl');
        if (urlEl) urlEl.textContent = fullUrl;

        // Generate QR code
        const qrContainer = document.getElementById('qrContainer');
        if (qrContainer) {
            qrContainer.innerHTML = '';

            // Using QRCode.js library
            if (typeof QRCode !== 'undefined') {
                new QRCode(qrContainer, {
                    text: fullUrl,
                    width: 180,
                    height: 180,
                    colorDark: '#000000',
                    colorLight: '#ffffff'
                });
            } else {
                // Fallback to QR server
                qrContainer.innerHTML = '<img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&amp;data=' + encodeURIComponent(fullUrl) + '" alt="QR Code" style="max-width:180px;height:auto;">';
            }
        }

        const modal = new bootstrap.Modal(document.getElementById('qrCodeModal'));
        modal.show();
    };

    window.copyQRLink = function(btn) {
        if (!btn) btn = event.target;
        navigator.clipboard.writeText(window.currentQrUrl).then(function() {
            var orig = btn.innerHTML;
            btn.innerHTML = '<i  class="bi bi-check me-1"></i>Copied!';
            setTimeout(function() { btn.innerHTML = orig; }, 1500);
        });
    };

    window.downloadQRCode = function() {
        const canvas = document.querySelector('#qrContainer canvas');
        const img = document.querySelector('#qrContainer img');

        if (canvas) {
            const link = document.createElement('a');
            link.href = canvas.toDataURL('image/png');
            link.download = 'evaluation-qr-' + new Date().getTime() + '.png';
            link.click();
        } else if (img) {
            const link = document.createElement('a');
            link.href = img.src;
            link.download = 'evaluation-qr-' + new Date().getTime() + '.png';
            link.click();
        }
    };
}

/* Initialize on page load */
document.addEventListener('DOMContentLoaded', initializeEventListeners);

/* Re-initialize after Turbo navigation (for semester filter) */
document.addEventListener('turbo:load', initializeEventListeners);

/* ─── Real-time QR Evaluation Updates ─── */
let lastCheckTime = 0;
let currentActiveEvals = activeEvaluations;

/**
 * Poll for active evaluations and update QR buttons if new ones appear
 * @param {boolean} forceImmediate - If true, bypass debounce check (e.g., when user loads a subject)
 */
window.pollActiveEvaluations = function(forceImmediate) {
    // Debounce: don't poll more frequently than every 5 seconds (unless forceImmediate)
    const now = Date.now();
    if (!forceImmediate && now - lastCheckTime < 5000) return;
    lastCheckTime = now;

    fetch('{{ path("api_active_evaluations") }}')
        .then(response => {
            if (!response.ok) throw new Error('Failed to fetch evaluations');
            return response.json();
        })
        .then(data => {
            const newEvals = data.evaluations || [];
            console.log('API response - Active evaluations:', newEvals, 'Count:', newEvals.length);

            // Check if evaluations have changed
            const newEvalMap = {};
            newEvals.forEach(e => {
                newEvalMap[e.id] = e;
            });

            const oldKeys = Object.keys(currentActiveEvals || {}).sort();
            const newKeys = Object.keys(newEvalMap).sort();

            // Debug log
            if (newKeys.length > 0 || oldKeys.length > 0) {
                console.log('Poll update - Old evaluations:', oldKeys, 'New evaluations:', newKeys);
            }

            // Only update if evaluation list actually changed
            if (JSON.stringify(oldKeys) !== JSON.stringify(newKeys)) {
                console.log('Evaluation list changed! Updating UI...');
                console.log('Updated activeEvaluations:', newEvalMap);
            }

            currentActiveEvals = newEvalMap;
            activeEvaluations = newEvalMap;
            window.activeEvaluations = newEvalMap;
            window.firstActiveEvalId = newKeys.length > 0 ? newKeys[0] : null;
            window.hasActiveEval = newKeys.length > 0;

            // Always refresh button data so section/schedule edits and modal info stay in sync.
            updateQRButtonsForLoadedSubjects();
        })
        .catch(error => {
            console.error('Evaluation poll error:', error);
        });
};

/**
 * Update QR buttons for all loaded subjects based on current active evaluations
 */
window.updateQRButtonsForLoadedSubjects = function() {
    // Get all rows with a loaded subject
    const loadedRows = document.querySelectorAll('tbody tr[data-subject-id]');

    loadedRows.forEach(row => {
        const checkbox = row.querySelector('.subject-check');
        if (!checkbox || !checkbox.checked) return; // Skip unloaded subjects

        const subjectId = parseInt(row.getAttribute('data-subject-id'));
        const codeCell = row.querySelector('.sb-code-text');
        const subjectCode = codeCell ? codeCell.textContent.trim() : '';

        // Get full subject name
        const nameCell = row.querySelector('.sb-subject-name');
        const subjectName = nameCell ? nameCell.textContent.trim() : '';

        // Find section from the section input field
        const sectionInput = row.querySelector('.sb-section-input');
        const section = sectionInput ? sectionInput.value.trim() : '';

        // Get schedule from the schedule select
        const scheduleSelect = row.querySelector('.sb-inline-select');
        const schedule = scheduleSelect ? scheduleSelect.value.trim() : '';

        console.log('Refreshing action buttons for loaded subject:', {
            subjectCode: subjectCode,
            subjectName: subjectName,
            section: section,
            schedule: schedule
        });

        // Update action buttons (QR hidden from action column)
        const actionCell = row.querySelector('.sb-action-btns');
        if (!actionCell) return;

        let actionsHtml = '';

        // Add other action buttons
        actionsHtml += '<button type="button" class="sb-btn-pick" onclick="openPickAgainModal(' + subjectId + ', \'' + subjectCode.replace(/'/g,"\\'") + '\', \'' + subjectName.replace(/'/g,"\\'") + '\')" title="Pick again with different section"><i  class="bi bi-plus-circle-fill"></i> Pick</button>';

        actionCell.innerHTML = actionsHtml;
    });
};

/* ── Event delegation for QR button clicks (both column and action buttons) ── */
document.addEventListener('click', function(event) {
    const qrBtn = event.target.closest('.sb-qr-btn, .sb-qr-btn-column');
    if (qrBtn) {
        const subjectId = qrBtn.getAttribute('data-subject-id');
        const subjectCode = qrBtn.getAttribute('data-subject-code');
        const subjectName = qrBtn.getAttribute('data-subject-name');
        const section = qrBtn.getAttribute('data-section');
        const schedule = qrBtn.getAttribute('data-schedule');
        const evalId = qrBtn.getAttribute('data-eval-id');
        const evalType = qrBtn.getAttribute('data-eval-type');
        const faculty = qrBtn.getAttribute('data-faculty');
        const schoolYear = qrBtn.getAttribute('data-school-year');

        console.log('QR Button clicked:', {subjectId, subjectCode, subjectName, section, schedule, evalId, evalType, faculty, schoolYear});

        if (subjectId && subjectCode && evalId) {
            window.showQRModal(parseInt(subjectId), subjectCode, subjectName, section || '', parseInt(evalId), evalType, faculty, schoolYear, schedule || '');
        }
    }
});

// Start polling for new evaluations immediately on load, then every 30 seconds
window.pollActiveEvaluations(true);  // Initial poll with forceImmediate to get fresh data
setInterval(pollActiveEvaluations, 30000);  // Then every 30 seconds with debounce
</script>

{# ── Add Subject Modal ── #}
<div class="modal fade" id="addSubjectModal" tabindex="-1">
