{% for c in curricula %}
{% for s in c.subjects %}
<div class="modal fade" id="editSubjectModal{{ s.id }}" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">
            <form method="post" action="{{ path(prefix ~ '_subject_edit', {id: s.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('edit_subject' ~ s.id) }}">
                <div class="cm-modal-header">
                    <div class="d-flex align-items-center gap-3">
                        <div class="cm-modal-icon"><i  class="bi bi-pencil"></i></div>
                        <div>
                            <h5 class="modal-title fw-bold text-white mb-0">Edit Subject</h5>
                            <small class="text-white-50">{{ s.subjectCode }} — {{ s.subjectName }}</small>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Subject Code <span class="text-danger">*</span></label>
                            <input type="text" name="subjectCode" class="form-control" value="{{ s.subjectCode }}" required>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Subject Name <span class="text-danger">*</span></label>
                            <input type="text" name="subjectName" class="form-control" value="{{ s.subjectName }}" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Semester</label>
                            <input type="text" name="semester" class="form-control" value="{{ s.semester }}" placeholder="e.g. 1st Semester">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">School Year</label>
                            <input type="text" name="schoolYear" class="form-control" value="{{ s.schoolYear }}" placeholder="e.g. 2025-2026">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Units</label>
                            <input type="number" name="units" class="form-control" min="0" value="{{ s.units }}" placeholder="e.g. 3">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Year Level</label>
                            <select name="yearLevel" class="form-select">
                                <option value="">— Select —</option>
                                <option value="First Year" {{ s.yearLevel == 'First Year' ? 'selected' : '' }}>First Year</option>
                                <option value="Second Year" {{ s.yearLevel == 'Second Year' ? 'selected' : '' }}>Second Year</option>
                                <option value="Third Year" {{ s.yearLevel == 'Third Year' ? 'selected' : '' }}>Third Year</option>
                                <option value="Fourth Year" {{ s.yearLevel == 'Fourth Year' ? 'selected' : '' }}>Fourth Year</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Term</label>
                            <select name="term" class="form-select">
                                <option value="">— Select —</option>
                                <option value="Prelim" {{ s.term == 'Prelim' ? 'selected' : '' }}>Prelim</option>
                                <option value="Midterm" {{ s.term == 'Midterm' ? 'selected' : '' }}>Midterm</option>
                                <option value="Semi-Final" {{ s.term == 'Semi-Final' ? 'selected' : '' }}>Semi-Final</option>
                                <option value="Final" {{ s.term == 'Final' ? 'selected' : '' }}>Final</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Section</label>
                            <input type="text" name="section" class="form-control" value="{{ s.section }}" placeholder="e.g. BSIT-3A">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Room</label>
                            <input type="text" name="room" class="form-control" value="{{ s.room }}" placeholder="e.g. Room 201">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Schedule / Time</label>
                            <input type="text" name="schedule" class="form-control" value="{{ s.schedule }}" placeholder="e.g. MWF 9:00-10:00 AM">
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-norsu btn-sm"><i  class="bi bi-check-circle-fill me-1"></i>Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endfor %}
{% endfor %}


