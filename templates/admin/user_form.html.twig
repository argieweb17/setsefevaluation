{% extends 'base.html.twig' %}

{% block title %}{{ title }} | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
.uf-header{border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);box-shadow:0 10px 40px rgba(30,58,138,.18);margin-bottom:1.5rem;position:relative;}
.uf-header::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") repeat;pointer-events:none;}
.uf-header-inner{position:relative;z-index:1;padding:1.5rem 1.75rem 1.25rem;}
.uf-header-icon{width:48px;height:48px;background:rgba(255,255,255,.15);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.35rem;color:#fff;backdrop-filter:blur(4px);flex-shrink:0;}
.uf-meta-pill{background:rgba(255,255,255,.13);color:rgba(255,255,255,.9);padding:2px 10px;border-radius:20px;font-size:.75rem;backdrop-filter:blur(4px);}
.uf-form-card{background:#fff;border:1px solid #e5e7eb;border-radius:.75rem;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04);margin-bottom:1.5rem;}
.uf-form-header{background:linear-gradient(135deg,#1e3a8a,#1e40af 60%,#059669);color:#fff;padding:.65rem 1.1rem;font-size:.85rem;font-weight:600;}
@keyframes ufFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.uf-form-card{animation:ufFadeIn .25s ease;}
/* Role checkboxes */
.uf-role-checkboxes{display:flex;flex-wrap:wrap;gap:.45rem;}
.uf-role-chip{display:inline-flex;align-items:center;gap:2px;padding:5px 14px;border-radius:20px;font-size:.8rem;font-weight:500;cursor:pointer;border:1.5px solid #dee2e6;background:#f8f9fa;color:#495057;transition:all .15s ease;user-select:none;}
.uf-role-chip:hover{border-color:var(--chip-color);background:color-mix(in srgb,var(--chip-color) 8%,#fff);}
.uf-role-chip--active{border-color:var(--chip-color);background:color-mix(in srgb,var(--chip-color) 12%,#fff);color:var(--chip-color);font-weight:600;box-shadow:0 0 0 2px color-mix(in srgb,var(--chip-color) 15%,transparent);}
.uf-role-cb{display:none;}
</style>
{% endblock %}

{% block body %}
{# ═══════════════════════════════════════
   USER FORM — CREATE / EDIT
   ═══════════════════════════════════════ #}

{% set isEdit = user is defined and user %}
{% set realEmail = (isEdit and user.email and user.email is not same as('') and '@placeholder.local' not in user.email) ? user.email : '' %}

{# ── Professional Header Card ── #}
<div class="uf-header">
    <div class="uf-header-inner">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="uf-header-icon">
                    <i class="bi {{ isEdit ? 'bi-pencil-square' : 'bi-person-plus-fill' }}"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">{{ title }}</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                        {% if isEdit %}
                        <span class="uf-meta-pill"><i  class="bi bi-person me-1"></i>{{ user.fullName }}</span>
                        {% if realEmail %}
                        <span class="uf-meta-pill"><i  class="bi bi-envelope me-1"></i>{{ realEmail }}</span>
                        {% endif %}
                        {% else %}
                        <span class="uf-meta-pill"><i  class="bi bi-info-circle me-1"></i>Fill in the details below</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <a href="{{ path('admin_users') }}" class="btn btn-sm btn-outline-light fw-semibold">
                <i  class="bi bi-arrow-left me-1"></i>Back to Users
            </a>
        </div>
    </div>
</div>

{# ── Form Card ── #}
<div class="uf-form-card">
    <div class="uf-form-header">
        <span><i  class="bi bi-list-check me-2"></i>{{ isEdit ? 'Edit User Details' : 'New User Details' }}</span>
    </div>
    <div class="p-4">
        <form method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-muted"><i  class="bi bi-person me-1"></i>First Name</label>
                    <input type="text" name="firstName" class="form-control"
                           value="{{ isEdit ? user.firstName : '' }}" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-muted"><i  class="bi bi-person me-1"></i>Last Name</label>
                    <input type="text" name="lastName" class="form-control"
                           value="{{ isEdit ? user.lastName : '' }}" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-muted"><i  class="bi bi-envelope me-1"></i>Email</label>
                    <input type="email" name="email" class="form-control"
                           value="{{ realEmail }}">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-muted"><i  class="bi bi-shield me-1"></i>Roles</label>
                    <div class="uf-role-checkboxes">
                        {% set userRoles = isEdit ? user.roles : [] %}
                        {% set roleOptions = [
                            { value: 'student',  label: 'Student',  icon: 'bi-mortarboard',  color: '#6c757d' },
                            { value: 'faculty',  label: 'Faculty',  icon: 'bi-journal-text', color: '#0d6efd' },
                            { value: 'staff',    label: 'Staff',    icon: 'bi-briefcase',    color: '#198754' },
                            { value: 'admin',    label: 'Admin',    icon: 'bi-shield-lock',  color: '#dc3545' },
                        ] %}
                        {% set roleToConst = { student: '', faculty: 'ROLE_FACULTY', staff: 'ROLE_STAFF', admin: 'ROLE_ADMIN' } %}
                        {# Student is checked when no special role is present #}
                        {% set isStudent = isEdit and ('ROLE_FACULTY' not in userRoles) and ('ROLE_STAFF' not in userRoles) and ('ROLE_SUPERIOR' not in userRoles) and ('ROLE_ADMIN' not in userRoles) %}
                        {% for opt in roleOptions %}
                            {% set isChecked = (opt.value == 'student') ? isStudent : (roleToConst[opt.value] in userRoles) %}
                            <label class="uf-role-chip {{ isChecked ? 'uf-role-chip--active' }}" style="--chip-color:{{ opt.color }};">
                                <input type="checkbox" name="roles[]" value="{{ opt.value }}" {{ isChecked ? 'checked' }} class="uf-role-cb">
                                <i class="bi {{ opt.icon }} me-1"></i>{{ opt.label }}
                            </label>
                        {% endfor %}
                    </div>
                    <div class="form-text mt-1" style="font-size:.72rem;">You can assign multiple roles to this user. Superior access is automatic for faculty with Department Head or Chair employment status.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-muted"><i  class="bi bi-buildings me-1"></i>Department</label>
                    <select name="department" class="form-select">
                        <option value="">— None —</option>
                        {% for dept in departments %}
                            <option value="{{ dept.id }}"
                                {{ (isEdit and user.department and user.department.id == dept.id) ? 'selected' }}>
                                {{ dept.departmentName }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-muted"><i  class="bi bi-person-vcard me-1"></i>Employment Status / Designation</label>
                    <select name="employmentStatus" class="form-select">
                        {% set empStatus = isEdit ? user.employmentStatus : '' %}
                        <option value="" {{ empStatus is empty ? 'selected' }}>— None —</option>
                        <option value="Dean" {{ empStatus == 'Dean' ? 'selected' }}>Dean</option>
                        <option value="Department Head" {{ empStatus == 'Department Head' ? 'selected' }}>Department Head</option>
                        <option value="Chair" {{ empStatus == 'Chair' ? 'selected' }}>Chair</option>
                        <option value="Faculty" {{ empStatus == 'Faculty' ? 'selected' }}>Faculty</option>
                        <option value="Staff" {{ empStatus == 'Staff' ? 'selected' }}>Staff</option>
                        <option value="Instructor" {{ empStatus == 'Instructor' ? 'selected' }}>Instructor</option>
                        <option value="Professor" {{ empStatus == 'Professor' ? 'selected' }}>Professor</option>
                    </select>
                    <div class="form-text" style="font-size:.72rem;">Set to "Dean", "Department Head", or "Chair" for Superior evaluation targets.</div>
                </div>
                {% if not isEdit %}
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-muted"><i  class="bi bi-key me-1"></i>Password</label>
                    <input type="password" name="password" class="form-control"
                           placeholder="Default: password123" value="password123">
                </div>
                {% endif %}
            </div>

            <hr class="my-4" style="border-color:#e5e7eb;">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-norsu">
                    <i  class="bi bi-check-circle-fill me-1"></i>{{ isEdit ? 'Update User' : 'Create User' }}
                </button>
                <a href="{{ path('admin_users') }}" class="btn btn-light">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.uf-role-cb').forEach(function(cb) {
        cb.addEventListener('change', function() {
            this.closest('.uf-role-chip').classList.toggle('uf-role-chip--active', this.checked);
        });
    });
});
</script>
{% endblock %}
