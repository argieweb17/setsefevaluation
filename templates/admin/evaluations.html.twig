{% extends 'base.html.twig' %}
{% set prefix = staffMode|default(false) ? 'staff' : 'admin' %}

{% block title %}Evaluation Periods | SET-SEF Evaluation{% endblock %}

{% block body %}
{# ═══════════════════════════════════════
   COMPUTE STATS
   ═══════════════════════════════════════ #}
{% set totalEvals   = evaluations|length %}
{% set openEvals    = evaluations|filter(e => e.status)|length %}
{% set closedEvals  = evaluations|filter(e => not e.status)|length %}
{% set setCount     = evaluations|filter(e => e.evaluationType == 'SET')|length %}
{% set sefCount     = evaluations|filter(e => e.evaluationType == 'SEF' or e.evaluationType == 'SUPERIOR')|length %}
{% set totalResponses = 0 %}
{% for ev in evaluations %}
    {% set totalResponses = totalResponses + (evaluatorCounts[ev.id] ?? 0) %}
{% endfor %}

{% set expiredEvals = [] %}
{% set activeEvals = [] %}
{% for eval in evaluations %}
    {% set now = "now"|date("U") %}
    {% set endTs = eval.endDate|date("U") %}
    {% if now > endTs or not eval.status %}
        {% set expiredEvals = expiredEvals|merge([eval]) %}
    {% else %}
        {% set activeEvals = activeEvals|merge([eval]) %}
    {% endif %}
{% endfor %}

{# ═══════════════════════════════════════
   PROFESSIONAL HEADER
   ═══════════════════════════════════════ #}
<div class="ev-header">
    <div class="ev-header-inner">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="ev-header-icon">
                    <i class="bi bi-clipboard2-check"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">Evaluation Period Management</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                        <span class="ev-meta-pill"><i class="bi bi-database me-1"></i>{{ totalEvals }} Period{{ totalEvals != 1 ? 's' : '' }}</span>
                        {% if currentAY %}
                            <span class="ev-meta-pill ev-meta-active"><i class="bi bi-check-circle-fill me-1"></i>{{ currentAY.label }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-1">
                <button type="button" class="btn btn-sm btn-light fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#createEvalModal">
                    <i class="bi bi-plus-lg me-1"></i>New SET Evaluation
                </button>
                <button type="button" class="btn btn-sm btn-light fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#createSuperiorEvalModal">
                    <i class="bi bi-plus-lg me-1"></i>New SEF Evaluation
                </button>
            </div>
        </div>
        <div class="ev-stats-row">
            <div class="ev-stat">
                <span class="ev-stat-val">{{ totalEvals }}</span>
                <span class="ev-stat-lbl">Total Periods</span>
            </div>
            <div class="ev-stat-divider"></div>
            <div class="ev-stat">
                <span class="ev-stat-val ev-val-success">{{ openEvals }}</span>
                <span class="ev-stat-lbl">Open</span>
            </div>
            <div class="ev-stat-divider"></div>
            <div class="ev-stat">
                <span class="ev-stat-val ev-val-warn">{{ closedEvals }}</span>
                <span class="ev-stat-lbl">Closed</span>
            </div>
            <div class="ev-stat-divider"></div>
            <div class="ev-stat">
                <span class="ev-stat-val" style="color:#fca5a5">{{ expiredEvals|length }}</span>
                <span class="ev-stat-lbl">Expired</span>
            </div>
            <div class="ev-stat-divider"></div>
            <div class="ev-stat">
                <span class="ev-stat-val ev-val-info">{{ totalResponses }}</span>
                <span class="ev-stat-lbl">Total Evaluators</span>
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════
   FILTER TOOLBAR
   ═══════════════════════════════════════ #}
<div class="ev-toolbar">
    <div class="d-flex align-items-center flex-nowrap gap-2">
        {# Tab switches #}
        <div class="ev-filter-group" id="evSectionTabs">
            <button class="ev-filter-btn active" onclick="switchSection('active', this)">
                <i class="bi bi-play-circle me-1"></i>Active <span class="ev-filter-count">{{ activeEvals|length }}</span>
            </button>
            <button class="ev-filter-btn" onclick="switchSection('previous', this)">
                <i class="bi bi-clock-history me-1"></i>Previous <span class="ev-filter-count">{{ expiredEvals|length }}</span>
            </button>
        </div>
        <div class="ev-filter-group" id="evTypeFilter">
            <button class="ev-filter-btn active" data-type="SET" onclick="filterType('SET', this)">SET <span class="ev-filter-count">{{ setCount }}</span></button>
            <button class="ev-filter-btn" data-type="SEF" onclick="filterType('SEF', this)">SEF <span class="ev-filter-count">{{ sefCount }}</span></button>
        </div>
        {# Filter dropdowns #}
        <select class="ev-filter-select" id="evFilterCollege" onchange="applyAllFilters()">
            <option value="">All Colleges</option>
            {% for col in colleges %}
                <option value="{{ col }}">{{ col }}</option>
            {% endfor %}
        </select>
        <select class="ev-filter-select" id="evFilterDept" onchange="applyAllFilters()">
            <option value="">All Departments</option>
            {% for dept in departments %}
                <option value="{{ dept.departmentName }}">{{ dept.departmentName }}</option>
            {% endfor %}
        </select>
        <select class="ev-filter-select" id="evFilterFaculty" onchange="applyAllFilters()">
            <option value="">All Faculty</option>
            {% for f in facultyUsers %}
                <option value="{{ f.fullName }}">{{ f.lastName }}, {{ f.firstName }}</option>
            {% endfor %}
        </select>
        <div class="ev-search-box">
            <i class="bi bi-search ev-search-icon"></i>
            <input type="text" class="ev-search-input" id="evSearchInput" placeholder="Search..." oninput="applyAllFilters()">
        </div>
    </div>
</div>

{# ═══════════════════════════════════════
   ACTIVE EVALUATIONS TABLE
   ═══════════════════════════════════════ #}
<div id="activeSection">
    <div class="ev-table-container">
        <table class="ev-table" id="activeTable">
            <thead>
                <tr>
                    <th class="ev-th-type">Type</th>
                    <th class="ev-th-sortable" onclick="sortTable('activeTable',1)">Period <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('activeTable',2)">Faculty <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('activeTable',3)">Position <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('activeTable',4)">Department <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('activeTable',5)">Subject <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('activeTable',6)">Year <i class="bi bi-arrow-down-up"></i></th>
                    <th>Schedule</th>
                    <th>Status</th>
                    <th class="ev-th-sortable" onclick="sortTable('activeTable',9)">Evaluators <i class="bi bi-arrow-down-up"></i></th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for eval in activeEvals %}
                {% set now = "now"|date("U") %}
                {% set startTs = eval.startDate|date("U") %}
                {% set endTs = eval.endDate|date("U") %}
                {% set isActive = eval.status and now >= startTs and now <= endTs %}
                {% set isPending = now < startTs %}
                {% set responseCount = evaluatorCounts[eval.id] ?? 0 %}
                {% set totalDuration = endTs - startTs %}
                {% set elapsed = now - startTs %}
                {% set progress = totalDuration > 0 ? ((elapsed / totalDuration) * 100)|round : 0 %}
                <tr class="ev-row" data-type="{{ eval.evaluationType }}" data-college="{{ eval.college ?? '' }}" data-dept="{{ eval.department ? eval.department.departmentName : '' }}" data-faculty="{{ eval.faculty ?? '' }}" data-year="{{ eval.yearLevel ?? '' }}" data-search="{{ eval.evaluationType }} {{ eval.schoolYear }} {{ eval.faculty }} {{ eval.subject }} {{ eval.college }} {{ eval.department ? eval.department.departmentName : '' }} {{ eval.section }}">
                    <td><span class="ev-type-badge {{ eval.evaluationType == 'SET' ? 'ev-type-set' : 'ev-type-sef' }}">{{ eval.evaluationType == 'SUPERIOR' ? 'SEF' : eval.evaluationType }}</span></td>
                    <td>
                        <div class="ev-cell-period">
                            <strong>{{ eval.semester ? eval.semester ~ ' — ' : '' }}{{ eval.schoolYear ?? 'N/A' }}</strong>
                            <small class="text-muted d-block">{{ eval.startDate|date('M d, Y g:i A') }} → {{ eval.endDate|date('M d, Y g:i A') }}</small>
                        </div>
                    </td>
                    <td>{{ eval.faculty ?? '—' }}</td>
                    <td>
                        {% set pos = facultyPositionMap[eval.faculty] ?? '' %}
                        {% if pos %}<span class="ev-badge ev-badge-info"><i class="bi bi-person-badge me-1"></i>{{ pos }}</span>{% else %}—{% endif %}
                    </td>
                    <td>
                        {% if eval.department %}<span class="ev-badge ev-badge-dark"><i class="bi bi-building me-1"></i>{{ eval.department.departmentName }}</span>{% else %}—{% endif %}
                    </td>
                    <td>
                        {% if eval.evaluationType == 'SET' and eval.subject %}<span class="ev-badge ev-badge-success"><i class="bi bi-journal-text me-1"></i>{{ eval.subject }}</span>{% elseif eval.evaluationType == 'SET' %}—{% else %}—{% endif %}
                    </td>
                    <td>{{ eval.evaluationType == 'SET' ? (eval.yearLevel ?? '—') : '—' }}</td>
                    <td>
                        {% if eval.evaluationType == 'SET' %}
                            <div class="ev-cell-schedule">
                                {% if eval.time %}<small><i class="bi bi-clock me-1"></i>{{ eval.time }}</small>{% endif %}
                                {% if eval.section %}<small><i class="bi bi-diagram-3 me-1"></i>{{ eval.section }}</small>{% endif %}
                            </div>
                        {% else %}—{% endif %}
                    </td>
                    <td>
                        {% if isActive %}
                            <span class="ev-status-pill ev-status-active"><span class="ev-dot ev-dot-success"></span>Active</span>
                            <div class="ev-mini-progress" title="{{ progress }}% elapsed">
                                <div class="ev-mini-progress-fill" style="width:{{ progress }}%"></div>
                            </div>
                        {% elseif isPending %}
                            <span class="ev-status-pill ev-status-pending"><span class="ev-dot ev-dot-warning"></span>Scheduled</span>
                        {% endif %}
                    </td>
                    <td class="text-center"><span class="fw-semibold">{{ responseCount }}</span></td>
                    <td>
                        <div class="ev-actions-cell">
                            <button class="ev-action-btn ev-action-edit" title="Edit" data-bs-toggle="modal" data-bs-target="#editEvalModal{{ eval.id }}"><i class="bi bi-pencil-square"></i></button>
                            <button class="ev-action-btn ev-action-qr" title="QR Code" data-bs-toggle="modal" data-bs-target="#qrCodeModal" data-eval-id="{{ eval.id }}" data-eval-type="{{ eval.evaluationType }}" data-eval-faculty="{{ eval.faculty ?? '' }}" data-eval-subject="{{ eval.subject ?? '' }}" data-eval-section="{{ eval.section ?? '' }}" data-eval-school-year="{{ eval.schoolYear ?? '' }}"><i class="bi bi-qr-code"></i></button>
                            <form method="post" action="{{ path(prefix ~ '_evaluation_toggle', {id: eval.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle_eval' ~ eval.id) }}">
                                <button class="ev-action-btn ev-action-warning" title="Close"><i class="bi bi-pause-circle"></i></button>
                            </form>
                            <form method="post" action="{{ path(prefix ~ '_evaluation_lock_results', {id: eval.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('lock' ~ eval.id) }}">
                                <button class="ev-action-btn {{ eval.resultsLocked ? 'ev-action-danger' : 'ev-action-success' }}" title="{{ eval.resultsLocked ? 'Unlock' : 'Lock' }} results"><i class="bi {{ eval.resultsLocked ? 'bi-lock-fill' : 'bi-unlock-fill' }}"></i></button>
                            </form>
                            <form method="post" action="{{ path(prefix ~ '_evaluation_delete', {id: eval.id}) }}" class="d-inline" onsubmit="return confirm('Delete this evaluation period and all its responses?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_eval' ~ eval.id) }}">
                                <button class="ev-action-btn ev-action-delete" title="Delete"><i class="bi bi-trash3"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="11" class="text-center text-muted py-4"><i class="bi bi-inbox me-2"></i>No active evaluation periods</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ═══════════════════════════════════════
   PREVIOUS / EXPIRED EVALUATIONS TABLE
   ═══════════════════════════════════════ #}
<div id="previousSection" style="display:none;">
    {# Academic Year Filter for Previous Evals #}
    <div class="d-flex align-items-center gap-2 mb-3 px-1">
        <i class="bi bi-calendar3 text-muted"></i>
        <select class="ev-filter-select" id="evPrevAYFilter" onchange="filterPreviousByAY()" style="min-width:200px;">
            <option value="">All Academic Years</option>
            {% set prevYears = [] %}
            {% for eval in expiredEvals %}
                {% if eval.schoolYear and eval.schoolYear not in prevYears %}
                    {% set prevYears = prevYears|merge([eval.schoolYear]) %}
                {% endif %}
            {% endfor %}
            {% for yr in prevYears %}
                <option value="{{ yr }}">{{ yr }}</option>
            {% endfor %}
        </select>
        <select class="ev-filter-select" id="evPrevSemFilter" onchange="filterPreviousByAY()" style="min-width:180px;">
            <option value="">All Semesters</option>
            <option value="1st Semester">1st Semester</option>
            <option value="2nd Semester">2nd Semester</option>
            <option value="Summer">Summer</option>
        </select>
    </div>
    <div class="ev-table-container">
        <table class="ev-table" id="previousTable">
            <thead>
                <tr>
                    <th class="ev-th-type">Type</th>
                    <th class="ev-th-sortable" onclick="sortTable('previousTable',1)">Period <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('previousTable',2)">Faculty <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('previousTable',3)">Position <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('previousTable',4)">Department <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('previousTable',5)">Subject <i class="bi bi-arrow-down-up"></i></th>
                    <th class="ev-th-sortable" onclick="sortTable('previousTable',6)">Year <i class="bi bi-arrow-down-up"></i></th>
                    <th>Schedule</th>
                    <th>Ended</th>
                    <th>Status</th>
                    <th class="ev-th-sortable" onclick="sortTable('previousTable',10)">Evaluators <i class="bi bi-arrow-down-up"></i></th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for eval in expiredEvals %}
                {% set responseCount = evaluatorCounts[eval.id] ?? 0 %}
                <tr class="ev-row ev-row-expired" data-type="{{ eval.evaluationType }}" data-college="{{ eval.college ?? '' }}" data-dept="{{ eval.department ? eval.department.departmentName : '' }}" data-faculty="{{ eval.faculty ?? '' }}" data-year="{{ eval.yearLevel ?? '' }}" data-school-year="{{ eval.schoolYear ?? '' }}" data-semester="{{ eval.semester ?? '' }}" data-search="{{ eval.evaluationType }} {{ eval.schoolYear }} {{ eval.faculty }} {{ eval.subject }} {{ eval.college }} {{ eval.department ? eval.department.departmentName : '' }} {{ eval.section }}">
                    <td><span class="ev-type-badge {{ eval.evaluationType == 'SET' ? 'ev-type-set' : 'ev-type-sef' }}">{{ eval.evaluationType == 'SUPERIOR' ? 'SEF' : eval.evaluationType }}</span></td>
                    <td>
                        <div class="ev-cell-period">
                            <strong>{{ eval.semester ? eval.semester ~ ' — ' : '' }}{{ eval.schoolYear ?? 'N/A' }}</strong>
                            <small class="text-muted d-block">{{ eval.startDate|date('M d, Y') }} → {{ eval.endDate|date('M d, Y') }}</small>
                        </div>
                    </td>
                    <td>{{ eval.faculty ?? '—' }}</td>
                    <td>
                        {% set pos = facultyPositionMap[eval.faculty] ?? '' %}
                        {% if pos %}<span class="ev-badge ev-badge-info"><i class="bi bi-person-badge me-1"></i>{{ pos }}</span>{% else %}—{% endif %}
                    </td>
                    <td>
                        {% if eval.department %}<span class="ev-badge ev-badge-dark"><i class="bi bi-building me-1"></i>{{ eval.department.departmentName }}</span>{% else %}—{% endif %}
                    </td>
                    <td>
                        {% if eval.evaluationType == 'SET' and eval.subject %}<span class="ev-badge ev-badge-success"><i class="bi bi-journal-text me-1"></i>{{ eval.subject }}</span>{% elseif eval.evaluationType == 'SET' %}—{% else %}—{% endif %}
                    </td>
                    <td>{{ eval.evaluationType == 'SET' ? (eval.yearLevel ?? '—') : '—' }}</td>
                    <td>
                        {% if eval.evaluationType == 'SET' %}
                            <div class="ev-cell-schedule">
                                {% if eval.time %}<small><i class="bi bi-clock me-1"></i>{{ eval.time }}</small>{% endif %}
                                {% if eval.section %}<small><i class="bi bi-diagram-3 me-1"></i>{{ eval.section }}</small>{% endif %}
                            </div>
                        {% else %}—{% endif %}
                    </td>
                    <td><small class="text-muted">{{ eval.endDate|date('M d, Y g:i A') }}</small></td>
                    <td>
                        {% if not eval.status %}
                            <span class="ev-status-pill ev-status-closed"><span class="ev-dot ev-dot-muted"></span>Closed</span>
                        {% else %}
                            <span class="ev-status-pill ev-status-expired"><span class="ev-dot ev-dot-danger"></span>Expired</span>
                        {% endif %}
                        <div class="d-flex gap-1 mt-1">
                            {% if eval.anonymousMode %}
                                <span class="ev-mini-badge ev-mini-success"><i class="bi bi-eye-slash"></i></span>
                            {% endif %}
                            {% if eval.resultsLocked %}
                                <span class="ev-mini-badge ev-mini-danger"><i class="bi bi-lock-fill"></i></span>
                            {% else %}
                                <span class="ev-mini-badge ev-mini-success"><i class="bi bi-unlock-fill"></i></span>
                            {% endif %}
                        </div>
                    </td>
                    <td class="text-center"><span class="fw-semibold">{{ responseCount }}</span></td>
                    <td>
                        <div class="ev-actions-cell">
                            {# View Results #}
                            <a href="{{ path(prefix ~ '_results', {evaluation: eval.id}) }}" class="ev-action-btn ev-action-view" title="View Results"><i class="bi bi-eye"></i></a>
                            {# QR Code #}
                            <button class="ev-action-btn ev-action-qr" title="QR Code" data-bs-toggle="modal" data-bs-target="#qrCodeModal" data-eval-id="{{ eval.id }}" data-eval-type="{{ eval.evaluationType }}" data-eval-faculty="{{ eval.faculty ?? '' }}" data-eval-subject="{{ eval.subject ?? '' }}" data-eval-section="{{ eval.section ?? '' }}" data-eval-school-year="{{ eval.schoolYear ?? '' }}"><i class="bi bi-qr-code"></i></button>
                            {# Reopen #}
                            <form method="post" action="{{ path(prefix ~ '_evaluation_toggle', {id: eval.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle_eval' ~ eval.id) }}">
                                <button class="ev-action-btn ev-action-reopen" title="Reopen evaluation"><i class="bi bi-arrow-counterclockwise"></i></button>
                            </form>
                            {# Edit #}
                            <button class="ev-action-btn ev-action-edit" title="Edit" data-bs-toggle="modal" data-bs-target="#editEvalModal{{ eval.id }}"><i class="bi bi-pencil-square"></i></button>
                            {# Lock/Unlock Results #}
                            <form method="post" action="{{ path(prefix ~ '_evaluation_lock_results', {id: eval.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('lock' ~ eval.id) }}">
                                <button class="ev-action-btn {{ eval.resultsLocked ? 'ev-action-danger' : 'ev-action-success' }}" title="{{ eval.resultsLocked ? 'Unlock' : 'Lock' }} results"><i class="bi {{ eval.resultsLocked ? 'bi-lock-fill' : 'bi-unlock-fill' }}"></i></button>
                            </form>
                            {# Delete #}
                            <form method="post" action="{{ path(prefix ~ '_evaluation_delete', {id: eval.id}) }}" class="d-inline" onsubmit="return confirm('Delete this expired evaluation and all its responses?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_eval' ~ eval.id) }}">
                                <button class="ev-action-btn ev-action-delete" title="Delete"><i class="bi bi-trash3"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="12" class="text-center text-muted py-4"><i class="bi bi-inbox me-2"></i>No previous evaluation periods</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

    {# ═══════════════════════════════════════
       EDIT MODAL FOR EACH EVALUATION
       ═══════════════════════════════════════ #}
    {% for eval in evaluations %}
    <div class="modal fade" id="editEvalModal{{ eval.id }}" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content ev-modal">
                <div class="ev-modal-header">
                    <div class="d-flex align-items-center gap-2">
                        <div class="ev-modal-icon"><i class="bi bi-pencil-square"></i></div>
                        <div>
                            <h5 class="mb-0 fw-bold text-white">Edit {{ eval.evaluationType == 'SUPERIOR' ? 'SEF ' : '' }}Evaluation Period</h5>
                            <small class="text-white-50">{{ eval.evaluationType == 'SUPERIOR' ? 'SEF' : eval.evaluationType }} — {{ eval.schoolYear ?? 'N/A' }}</small>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" action="{{ path(prefix ~ '_evaluation_edit', {id: eval.id}) }}" data-turbo="false">
                    <input type="hidden" name="_token" value="{{ csrf_token('edit_eval' ~ eval.id) }}">
                    <div class="modal-body p-4">
                        <div class="row g-3">
                            {% if eval.evaluationType == 'SUPERIOR' %}
                                {# ── Superior: simplified fields ── #}
                                <input type="hidden" name="evaluationType" value="SUPERIOR">
                                <div class="col-md-6">
                                    <label class="form-label ev-form-label">School Year</label>
                                    <select name="schoolYear" class="form-select ev-form-control">
                                        <option value="">— Select —</option>
                                        {% for ay in academicYears|default([]) %}
                                            <option value="{{ ay.yearLabel }}" {{ eval.schoolYear == ay.yearLabel ? 'selected' : '' }}>{{ ay.yearLabel }}{% if ay.isCurrent %} (Current){% endif %}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label ev-form-label">Start Date & Time</label>
                                    <input type="datetime-local" name="startDate" class="form-control ev-form-control" value="{{ eval.startDate|date('Y-m-d\\TH:i') }}" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label ev-form-label">End Date & Time</label>
                                    <input type="datetime-local" name="endDate" class="form-control ev-form-control" value="{{ eval.endDate|date('Y-m-d\\TH:i') }}" required>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-check form-switch mt-2">
                                        <input class="form-check-input" type="checkbox" name="status" id="editStatus{{ eval.id }}" value="1" {{ eval.status ? 'checked' : '' }}>
                                        <label class="form-check-label ev-form-label" for="editStatus{{ eval.id }}">Open</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-check form-switch mt-2">
                                        <input class="form-check-input" type="checkbox" name="anonymousMode" id="editAnon{{ eval.id }}" value="1" {{ eval.anonymousMode ? 'checked' : '' }}>
                                        <label class="form-check-label ev-form-label" for="editAnon{{ eval.id }}">Anonymous</label>
                                    </div>
                                </div>
                            {% else %}
                                {# ── SET / SEF: full fields ── #}
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">Evaluation Type</label>
                                    <select name="evaluationType" class="form-select ev-form-control" required>
                                        <option value="SET" {{ eval.evaluationType == 'SET' ? 'selected' : '' }}>SET (Student Eval)</option>
                                        <option value="SEF" {{ eval.evaluationType == 'SEF' ? 'selected' : '' }}>SEF (Superior Eval)</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">School Year</label>
                                    <select name="schoolYear" class="form-select ev-form-control">
                                        <option value="">— Select —</option>
                                        {% for ay in academicYears|default([]) %}
                                            <option value="{{ ay.yearLabel }}" {{ eval.schoolYear == ay.yearLabel ? 'selected' : '' }}>{{ ay.yearLabel }}{% if ay.isCurrent %} (Current){% endif %}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">Year Level</label>
                                    <select name="yearLevel" class="form-select ev-form-control">
                                        <option value="">All Year Levels</option>
                                        {% for yr in ['1st Year','2nd Year','3rd Year','4th Year','5th Year'] %}
                                            <option value="{{ yr }}" {{ eval.yearLevel == yr ? 'selected' : '' }}>{{ yr }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">College</label>
                                    <select name="college" class="form-select ev-form-control college-select">
                                        <option value="">All Colleges</option>
                                        {% for col in colleges %}
                                            <option value="{{ col }}" {{ eval.college == col ? 'selected' : '' }}>{{ col }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">Department</label>
                                    <select name="department" class="form-select ev-form-control dept-select">
                                        <option value="">All Departments</option>
                                        {% for dept in departments %}
                                            <option value="{{ dept.id }}" data-college="{{ dept.collegeName }}" {{ eval.department and eval.department.id == dept.id ? 'selected' : '' }}>{{ dept.departmentName }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">Faculty</label>
                                    <select name="faculty" class="form-select ev-form-control faculty-select" data-target-subject="#editSubject{{ eval.id }}">
                                        <option value="" data-faculty-id="" data-department="">— Select Faculty —</option>
                                        {% for f in facultyUsers %}
                                            <option value="{{ f.fullName }}" data-faculty-id="{{ f.id }}" data-department="{{ f.department ? f.department.id : '' }}" {{ eval.faculty == f.fullName ? 'selected' : '' }}>{{ f.lastName }}, {{ f.firstName }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">Subject</label>
                                    <select name="subject" id="editSubject{{ eval.id }}" class="form-select ev-form-control subject-select" data-target-time="#editTime{{ eval.id }}" data-target-section="#editSection{{ eval.id }}" data-current-value="{{ eval.subject }}">
                                        <option value="" data-schedule="" data-section="">— Select Subject —</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">Time</label>
                                    <input type="text" name="time" id="editTime{{ eval.id }}" class="form-control ev-form-control" value="{{ eval.time }}" placeholder="Auto-filled from subject" readonly>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">Section</label>
                                    <input type="text" name="section" id="editSection{{ eval.id }}" class="form-control ev-form-control" value="{{ eval.section }}" placeholder="Auto-filled from subject" readonly>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">Start Date & Time</label>
                                    <input type="datetime-local" name="startDate" class="form-control ev-form-control" value="{{ eval.startDate|date('Y-m-d\\TH:i') }}" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label ev-form-label">End Date & Time</label>
                                    <input type="datetime-local" name="endDate" class="form-control ev-form-control" value="{{ eval.endDate|date('Y-m-d\\TH:i') }}" required>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-check form-switch mt-4">
                                        <input class="form-check-input" type="checkbox" name="status" id="editStatus{{ eval.id }}" value="1" {{ eval.status ? 'checked' : '' }}>
                                        <label class="form-check-label ev-form-label" for="editStatus{{ eval.id }}">Open</label>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-check form-switch mt-4">
                                        <input class="form-check-input" type="checkbox" name="anonymousMode" id="editAnon{{ eval.id }}" value="1" {{ eval.anonymousMode ? 'checked' : '' }}>
                                        <label class="form-check-label ev-form-label" for="editAnon{{ eval.id }}">Anon</label>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="modal-footer border-0 rounded-bottom-4 px-4 py-3" style="background:#f8f9fa;">
                        <button type="button" class="btn btn-sm btn-secondary px-3" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-sm px-3 fw-semibold" style="background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(5,150,105,.85));color:#fff;border:none;">
                            <i class="bi bi-check-circle me-1"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {% endfor %}

