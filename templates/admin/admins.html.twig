{% extends 'base.html.twig' %}

{% block title %}Manage Admins | SET-SEF Evaluation{% endblock %}

{% block body %}
{% set totalAdmins = users|length %}
{% set activeCount = 0 %}
{% for u in users %}
    {% if u.accountStatus == 'active' %}{% set activeCount = activeCount + 1 %}{% endif %}
{% endfor %}

{# ── Header ── #}
<div class="rl-header">
    <div class="rl-header-inner">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="rl-header-icon"><i  class="bi bi-shield"></i></div>
                <div>
                    <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">Manage Admins</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                        <span class="rl-meta-pill"><i  class="bi bi-person-check me-1"></i>{{ activeCount }} Active</span>
                        <span class="rl-meta-pill"><i  class="bi bi-database me-1"></i>{{ totalAdmins }} Total</span>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-1">
                <a href="{{ path('admin_users') }}" class="btn btn-sm btn-outline-light fw-semibold">
                    <i  class="bi bi-arrow-left me-1"></i>All Users
                </a>
                <a href="{{ path('admin_user_create') }}" class="btn btn-sm btn-light fw-semibold shadow-sm">
                    <i  class="bi bi-person-plus me-1"></i>Add Admin
                </a>
            </div>
        </div>
        <div class="rl-stats-row">
            <div class="rl-stat">
                <span class="rl-stat-val">{{ totalAdmins }}</span>
                <span class="rl-stat-lbl">Total Admins</span>
            </div>
            <div class="rl-stat-divider"></div>
            <div class="rl-stat">
                <span class="rl-stat-val">{{ activeCount }}</span>
                <span class="rl-stat-lbl">Active</span>
            </div>
        </div>
    </div>
</div>

{# ── Filter Toolbar ── #}
<div class="rl-toolbar">
    <div class="rl-search-wrap">
        <i  class="bi bi-search"></i>
        <input type="text" class="rl-search" id="rlSearch" placeholder="Search by name or email..." autocomplete="off">
    </div>
    <div class="rl-filter-form">
        <div class="rl-filter-group">
            <i  class="bi bi-arrow-down rl-filter-icon"></i>
            <select class="rl-filter-select" id="rlSort" style="min-width:150px;">
                <option value="name-asc">Name (A–Z)</option>
                <option value="name-desc">Name (Z–A)</option>
                <option value="date-desc">Newest First</option>
                <option value="date-asc">Oldest First</option>
            </select>
        </div>
        <button type="button" class="rl-clear-btn" id="rlReset" title="Reset all filters">
            <i  class="bi bi-x-lg"></i>
        </button>
    </div>
    <div class="rl-toolbar-info">
        <span class="rl-result-count" id="rlCount"></span>
    </div>
</div>

{# ── Admins Table ── #}
<div class="rl-table-card">
    <div class="rl-table-header" style="background:linear-gradient(135deg,#be185d,#ec4899 60%,#f9a8d4);">
        <span><i  class="bi bi-shield me-2"></i>Administrators</span>
        <span class="rl-table-badge">{{ totalAdmins }} admin{{ totalAdmins != 1 ? 's' : '' }}</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="rlTable">
            <thead>
                <tr class="small text-muted" style="font-size:.78rem;background:#f8fafc;border-bottom:2px solid #e2e8f0;">
                    <th class="ps-3 fw-semibold" style="width:50px">#</th>
                    <th class="fw-semibold">Name</th>
                    <th class="fw-semibold">Email</th>
                    <th class="fw-semibold">Department</th>
                    <th class="fw-semibold text-center">Status</th>
                    <th class="fw-semibold">Registered</th>
                    <th class="fw-semibold text-end pe-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr class="rl-row"
                    data-name="{{ user.fullName|lower }}"
                    data-email="{{ user.email|lower }}"
                    data-date="{{ user.createdAt|date('Y-m-d') }}">
                    <td class="ps-3"><span class="fw-bold text-muted rl-num">{{ loop.index }}</span></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="rl-avatar" style="background:linear-gradient(135deg,rgba(190,24,93,.12),rgba(249,168,212,.12));color:#be185d;">{{ user.firstName|first|upper }}{{ user.lastName|first|upper }}</div>
                            <div>
                                <div class="fw-semibold small">{{ user.fullName }}</div>
                                {% if user == app.user %}
                                <span class="badge bg-warning text-dark" style="font-size:.6rem;">You</span>
                                {% endif %}
                            </div>
                        </div>
                    </td>
                    <td><span class="small text-muted">{{ user.email }}</span></td>
                    <td><span class="small">{{ user.department ? user.department.departmentName : '—' }}</span></td>
                    <td class="text-center">
                        {% if user.accountStatus == 'active' %}
                            <span class="rl-status-badge status-active"><i  class="bi bi-check-circle-fill me-1"></i>Active</span>
                        {% else %}
                            <span class="rl-status-badge status-inactive"><i  class="bi bi-pause-circle-fill me-1"></i>Inactive</span>
                        {% endif %}
                    </td>
                    <td><span class="small text-muted">{{ user.createdAt|date('M d, Y') }}</span></td>
                    <td class="text-end pe-3">
                        <div class="d-flex gap-1 justify-content-end">
                            <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-sm btn-outline-primary rl-action-btn" title="Edit"><i  class="bi bi-pencil-square"></i></a>
                            {% if user != app.user %}
                            <form method="post" action="{{ path('admin_user_toggle_status', {id: user.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                <button class="btn btn-sm btn-outline-{{ user.accountStatus == 'active' ? 'secondary' : 'success' }} rl-action-btn" title="{{ user.accountStatus == 'active' ? 'Deactivate' : 'Activate' }}">
                                    <i class="bi {{ user.accountStatus == 'active' ? 'bi-pause-circle' : 'bi-play-circle' }}"></i>
                                </button>
                            </form>
                            <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" class="d-inline" onsubmit="return confirm('Delete this admin permanently?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                <button class="btn btn-sm btn-outline-danger rl-action-btn" title="Delete"><i  class="bi bi-trash"></i></button>
                            </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="7" class="text-center py-5">
                    <i  class="bi bi-shield display-4 text-muted d-block mb-2"></i>
                    <span class="text-muted">No administrators found.</span>
                </td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% include 'admin/_role_list_styles.html.twig' %}

<script>
(function(){
    var search=document.getElementById('rlSearch'),sort=document.getElementById('rlSort'),reset=document.getElementById('rlReset'),countEl=document.getElementById('rlCount');
    if(!search)return;
    function applyFilters(){
        var q=search.value.trim().toLowerCase(),rows=document.querySelectorAll('.rl-row'),vis=0;
        rows.forEach(function(r){var show=true;
            if(q){var n=r.getAttribute('data-name'),e=r.getAttribute('data-email');if(n.indexOf(q)===-1&&e.indexOf(q)===-1)show=false;}
            r.style.display=show?'':'none';if(show)vis++;
        });
        if(countEl)countEl.textContent='Showing '+vis+' of '+rows.length+' admins';
        applySort();
    }
    function applySort(){
        var val=sort.value,tb=document.querySelector('#rlTable tbody');if(!tb)return;
        var rows=Array.from(tb.querySelectorAll('.rl-row'));
        rows.sort(function(a,b){switch(val){
            case'name-asc':return a.getAttribute('data-name').localeCompare(b.getAttribute('data-name'));
            case'name-desc':return b.getAttribute('data-name').localeCompare(a.getAttribute('data-name'));
            case'date-desc':return b.getAttribute('data-date').localeCompare(a.getAttribute('data-date'));
            case'date-asc':return a.getAttribute('data-date').localeCompare(b.getAttribute('data-date'));
            default:return 0;}});
        rows.forEach(function(r){tb.appendChild(r);});
        var num=0;rows.forEach(function(r){if(r.style.display==='none')return;num++;var c=r.querySelector('.rl-num');if(c)c.textContent=num;});
    }
    search.addEventListener('input',applyFilters);sort.addEventListener('change',function(){applySort();});
    reset.addEventListener('click',function(){search.value='';sort.value='name-asc';applyFilters();});
    applyFilters();
})();
</script>
{% endblock %}
