{% extends 'base.html.twig' %}

{% block title %}Messages | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ═══════════════════════════════════════
   CSS VARIABLES - Modern Chat Style
   ═══════════════════════════════════════ */
:root {
    --chat-blue: #2563eb;
    --chat-blue-light: #3b82f6;
    --chat-bg: #f8f9fa;
    --chat-sidebar-bg: #ffffff;
    --chat-border: #e5e7eb;
    --chat-text-primary: #1f2937;
    --chat-text-secondary: #6b7280;
    --chat-text-muted: #9ca3af;
    --chat-bubble-out: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    --chat-bubble-in: #ffffff;
    --chat-radius: 20px;
    --chat-radius-sm: 12px;
}

/* ═══════════════════════════════════════
   MAIN CONTAINER
   ═══════════════════════════════════════ */
.fm-app {
    display: flex;
    height: calc(100vh - 100px);
    min-height: 600px;
    background: var(--chat-bg);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,.08);
}

/* ═══════════════════════════════════════
   SIDEBAR - Clean Contact List
   ═══════════════════════════════════════ */
.fm-sidebar {
    width: 320px;
    min-width: 280px;
    background: var(--chat-sidebar-bg);
    border-right: 1px solid var(--chat-border);
    display: flex;
    flex-direction: column;
}

/* Search Section */
.fm-search-section {
    padding: 20px 16px;
    border-bottom: 1px solid var(--chat-border);
}
.fm-search-wrap {
    position: relative;
}
.fm-search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--chat-text-muted);
    font-size: .9rem;
    pointer-events: none;
}
.fm-search-input {
    width: 100%;
    padding: 12px 16px 12px 42px;
    border: none;
    border-radius: 24px;
    font-size: .9rem;
    color: var(--chat-text-primary);
    background: var(--chat-bg);
    outline: none;
    transition: all .2s ease;
}
.fm-search-input:focus {
    box-shadow: 0 0 0 2px var(--chat-blue);
}
.fm-search-input::placeholder {
    color: var(--chat-text-muted);
}

/* Conversation List */
.fm-conv-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
}
.fm-conv-list::-webkit-scrollbar {
    width: 4px;
}
.fm-conv-list::-webkit-scrollbar-track {
    background: transparent;
}
.fm-conv-list::-webkit-scrollbar-thumb {
    background: #ddd;
    border-radius: 2px;
}

.fm-conv-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    cursor: pointer;
    transition: background .15s ease;
    border-left: 3px solid transparent;
}
.fm-conv-item:hover {
    background: var(--chat-bg);
}
.fm-conv-item.active {
    background: #eff6ff;
    border-left-color: var(--chat-blue);
}

/* Avatar - Round with image */
.fm-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
    border: 2px solid #eff6ff;
}
.fm-avatar img {
    width: 70%;
    height: 70%;
    object-fit: contain;
}

/* Conversation Info */
.fm-conv-info {
    flex: 1;
    min-width: 0;
}
.fm-conv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 4px;
}
.fm-conv-name {
    font-size: .95rem;
    font-weight: 600;
    color: var(--chat-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-conv-time {
    font-size: .75rem;
    color: var(--chat-text-muted);
    flex-shrink: 0;
}
.fm-conv-preview {
    font-size: .85rem;
    color: var(--chat-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-conv-item.active .fm-conv-preview {
    color: var(--chat-blue);
}

/* New Message Button */
.fm-new-msg-wrap {
    padding: 16px;
    border-top: 1px solid var(--chat-border);
}
.fm-new-msg-btn {
    width: 100%;
    padding: 12px 20px;
    border: none;
    border-radius: 24px;
    background: var(--chat-bubble-out);
    color: #fff;
    font-size: .9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}
.fm-new-msg-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(124,58,237,.3);
}
.fm-new-msg-btn i {
    font-size: 1rem;
}

/* ═══════════════════════════════════════
   CHAT PANEL - Clean Modern Style
   ═══════════════════════════════════════ */
.fm-chat {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--chat-bg);
}

/* Chat Header - Simple */
.fm-chat-header {
    padding: 16px 24px;
    background: #fff;
    border-bottom: 1px solid var(--chat-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}
.fm-chat-user {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    flex: 1;
}
.fm-chat-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
    border: 2px solid #eff6ff;
}
.fm-chat-avatar img {
    width: 70%;
    height: 70%;
    object-fit: contain;
}
.fm-chat-details h5 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--chat-text-primary);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-chat-status {
    font-size: .8rem;
    color: var(--chat-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-chat-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
}
.fm-chat-delete-btn {
    border: 1px solid #fecaca;
    background: #fff;
    color: #dc2626;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: .78rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    line-height: 1;
    transition: all .15s ease;
}
.fm-chat-delete-btn:hover {
    background: #fef2f2;
    border-color: #fca5a5;
}

/* Chat Body */
.fm-chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.fm-thread {
    display: flex;
    flex-direction: column;
    gap: 12px;
}
.fm-chat-body::-webkit-scrollbar {
    width: 4px;
}
.fm-chat-body::-webkit-scrollbar-track {
    background: transparent;
}
.fm-chat-body::-webkit-scrollbar-thumb {
    background: #ddd;
    border-radius: 2px;
}

/* Date Separator */
.fm-date-sep {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 16px 0;
}
.fm-date-sep span {
    font-size: .75rem;
    font-weight: 500;
    color: var(--chat-text-muted);
    padding: 6px 14px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 1px 2px rgba(0,0,0,.05);
}

/* Message Bubbles - Clean Style */
.fm-message {
    display: flex;
    flex-direction: column;
    max-width: 70%;
    width: fit-content;
    margin-bottom: 4px;
}
.fm-message.incoming {
    align-self: flex-start;
    align-items: flex-start;
}
.fm-message.outgoing {
    align-self: flex-end;
    align-items: flex-end;
}

.fm-bubble {
    display: inline-block;
    width: max-content;
    max-width: 100%;
    padding: 10px 14px;
    font-size: .9rem;
    line-height: 1.5;
    white-space: pre-line;
    word-break: break-word;
}

/* Outgoing - Purple bubble */
.fm-message.outgoing .fm-bubble {
    background: var(--chat-bubble-out);
    color: #fff;
    border-radius: var(--chat-radius) var(--chat-radius) 6px var(--chat-radius);
}

/* Incoming - White bubble */
.fm-message.incoming .fm-bubble {
    background: var(--chat-bubble-in);
    color: var(--chat-text-primary);
    border-radius: var(--chat-radius) var(--chat-radius) var(--chat-radius) 6px;
    box-shadow: 0 1px 2px rgba(0,0,0,.08);
}

.fm-message-sender {
    font-size: .75rem;
    font-weight: 500;
    color: var(--chat-text-secondary);
    margin-bottom: 4px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    width: max-content;
}
.fm-message-sender i {
    color: var(--chat-blue);
    font-size: .7rem;
}

.fm-message-time {
    font-size: .7rem;
    color: var(--chat-text-muted);
    margin-top: 4px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: max-content;
}
.fm-message.outgoing .fm-message-time {
    justify-content: flex-end;
}
.fm-message-time .read-icon {
    color: #60a5fa;
}

/* Typing Indicator */
.fm-typing {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 12px 16px;
    background: #fff;
    border-radius: var(--chat-radius);
    box-shadow: 0 1px 2px rgba(0,0,0,.08);
    width: fit-content;
}
.fm-typing-dot {
    width: 8px;
    height: 8px;
    background: var(--chat-text-muted);
    border-radius: 50%;
    animation: typing-bounce 1.4s infinite ease-in-out both;
}
.fm-typing-dot:nth-child(1) { animation-delay: -0.32s; }
.fm-typing-dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes typing-bounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
    40% { transform: scale(1); opacity: 1; }
}

/* Waiting Message */
.fm-waiting {
    align-self: flex-start;
}
.fm-waiting .fm-bubble {
    background: #fff;
    color: var(--chat-text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
    border-radius: var(--chat-radius);
    box-shadow: 0 1px 2px rgba(0,0,0,.08);
}
.fm-waiting .fm-bubble i {
    animation: fm-spin 2s linear infinite;
    color: var(--chat-blue);
}
@keyframes fm-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* Attachment Display */
.fm-attachment {
    margin-top: 10px;
    padding: 10px 12px;
    background: rgba(0,0,0,.03);
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
}
.fm-attachment-icon {
    width: 36px;
    height: 36px;
    background: var(--chat-blue);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1rem;
}
.fm-attachment-info {
    flex: 1;
    min-width: 0;
}
.fm-attachment-name {
    font-size: .85rem;
    font-weight: 500;
    color: var(--chat-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-attachment-size {
    font-size: .75rem;
    color: var(--chat-text-muted);
}
.fm-attachment-download {
    width: 32px;
    height: 32px;
    background: var(--chat-blue);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
    font-size: .9rem;
    transition: all .2s ease;
}
.fm-attachment-download:hover {
    background: var(--chat-blue-light);
    transform: scale(1.05);
}

/* Compose Area - Simple */
.fm-compose {
    padding: 16px 24px;
    background: #fff;
    border-top: 1px solid var(--chat-border);
}
.fm-compose-inner {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    background: var(--chat-bg);
    border-radius: 24px;
    padding: 8px 8px 8px 20px;
}
.fm-textarea {
    flex: 1;
    padding: 8px 0;
    border: none;
    font-size: .9rem;
    color: var(--chat-text-primary);
    background: transparent;
    outline: none;
    resize: none;
    min-height: 24px;
    max-height: 120px;
    font-family: inherit;
    line-height: 1.5;
}
.fm-textarea::placeholder {
    color: var(--chat-text-muted);
}
.fm-send-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: var(--chat-bubble-out);
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all .2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.fm-send-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(124,58,237,.3);
}

/* Empty State */
.fm-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    text-align: center;
}
.fm-empty-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--chat-blue);
    margin-bottom: 20px;
}
.fm-empty-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--chat-text-primary);
    margin: 0 0 8px;
}
.fm-empty-text {
    font-size: .9rem;
    color: var(--chat-text-secondary);
    max-width: 280px;
    line-height: 1.5;
    margin: 0 0 20px;
}
.fm-empty-btn {
    padding: 12px 28px;
    border-radius: 24px;
    border: none;
    background: var(--chat-bubble-out);
    color: #fff;
    font-size: .9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}
.fm-empty-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(124,58,237,.3);
}

/* ═══════════════════════════════════════
   NEW MESSAGE MODAL - Clean Style
   ═══════════════════════════════════════ */
.fm-modal-header {
    background: var(--chat-bubble-out);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
}
.fm-modal-icon {
    width: 44px;
    height: 44px;
    background: rgba(255,255,255,.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.1rem;
}
.fm-modal-title {
    color: #fff;
    font-weight: 600;
    font-size: 1.1rem;
    margin: 0;
}
.fm-modal-body {
    padding: 24px;
}
.fm-form-group {
    margin-bottom: 18px;
}
.fm-form-group:last-child {
    margin-bottom: 0;
}
.fm-form-label {
    display: block;
    font-size: .85rem;
    font-weight: 600;
    color: var(--chat-text-primary);
    margin-bottom: 8px;
}
.fm-form-label .optional {
    font-weight: 400;
    color: var(--chat-text-muted);
}
.fm-form-input,
.fm-form-select,
.fm-form-textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--chat-border);
    border-radius: var(--chat-radius-sm);
    font-size: .9rem;
    color: var(--chat-text-primary);
    background: #fff;
    outline: none;
    transition: all .2s ease;
    font-family: inherit;
}
.fm-form-input:focus,
.fm-form-select:focus,
.fm-form-textarea:focus {
    border-color: var(--chat-blue);
    box-shadow: 0 0 0 3px rgba(124,58,237,.1);
}
.fm-form-input::placeholder,
.fm-form-textarea::placeholder {
    color: var(--chat-text-muted);
}
.fm-form-textarea {
    resize: vertical;
    min-height: 100px;
    line-height: 1.5;
}
.fm-modal-footer {
    padding: 16px 24px;
    background: var(--chat-bg);
    border-top: 1px solid var(--chat-border);
    display: flex;
    justify-content: flex-end;
    gap: 12px;
}
.fm-btn {
    padding: 10px 20px;
    border-radius: 24px;
    font-size: .9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s ease;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}
.fm-btn-secondary {
    background: #fff;
    color: var(--chat-text-secondary);
    border: 1px solid var(--chat-border);
}
.fm-btn-secondary:hover {
    background: var(--chat-bg);
}
.fm-btn-primary {
    background: var(--chat-bubble-out);
    color: #fff;
}
.fm-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(124,58,237,.3);
}

/* ═══════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════ */
@media (max-width: 992px) {
    .fm-app {
        flex-direction: column;
        height: auto;
        min-height: calc(100vh - 80px);
    }
    .fm-sidebar {
        width: 100%;
        min-width: 100%;
        max-height: 350px;
        border-right: none;
        border-bottom: 1px solid var(--chat-border);
    }
    .fm-conv-list {
        max-height: 200px;
    }
    .fm-chat-body {
        min-height: 400px;
    }
    .fm-message {
        max-width: 85%;
    }
}
@media (max-width: 576px) {
    .fm-chat-header {
        padding: 12px 16px;
    }
    .fm-chat-delete-btn {
        width: 36px;
        height: 36px;
        padding: 0;
        justify-content: center;
    }
    .fm-chat-body {
        padding: 16px;
    }
    .fm-compose {
        padding: 12px 16px;
    }
    .fm-message {
        max-width: 90%;
    }
}

/* Animations */
.fm-conv-item {
    animation: fm-slide-in .2s ease;
}
@keyframes fm-slide-in {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
}
.fm-message {
    animation: fm-fade-up .2s ease;
}
@keyframes fm-fade-up {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>
{% endblock %}

{% block body %}
<div class="fm-app">
    {# ═══════════════════════════════════════
       SIDEBAR - Clean Contact List
       ═══════════════════════════════════════ #}
    <aside class="fm-sidebar">
        <div class="fm-search-section">
            <div class="fm-search-wrap">
                <i class="bi bi-search fm-search-icon"></i>
                <input type="text" class="fm-search-input" id="searchInput" placeholder="Search..." oninput="searchMessages()">
            </div>
        </div>

        <div class="fm-conv-list" id="convList">
            {% for msg in messages %}
            {% set lastMessage = msg.message %}
            {% if repliesMap[msg.id] is defined and repliesMap[msg.id]|length > 0 %}
                {% set lastReply = repliesMap[msg.id]|last %}
                {% set lastMessage = lastReply.message %}
            {% elseif msg.adminReply %}
                {% set lastMessage = msg.adminReply %}
            {% endif %}
            {% set latestActivityAt = msg.createdAt %}
            {% if repliesMap[msg.id] is defined and repliesMap[msg.id]|length > 0 %}
                {% set latestActivityAt = (repliesMap[msg.id]|last).createdAt %}
            {% endif %}
            <div class="fm-conv-item{% if loop.first %} active{% endif %}"
                 data-msg-id="{{ msg.id }}"
                 data-search="{{ msg.subject|lower }} {{ msg.message|lower }}"
                 onclick="selectConversation(this, {{ msg.id }})">
                <div class="fm-avatar">
                    <img src="{{ asset('images/quamc-logo.png') }}" alt="QUAMC">
                </div>
                <div class="fm-conv-info">
                    <div class="fm-conv-header">
                        <span class="fm-conv-name">Administration</span>
                        <span class="fm-conv-time">{{ latestActivityAt|date('M d') }}</span>
                    </div>
                    <div class="fm-conv-preview">{{ lastMessage|slice(0, 40) }}{% if lastMessage|length > 40 %}...{% endif %}</div>
                </div>
            </div>
            {% else %}
            <div class="fm-empty-state" style="padding:40px 20px;">
                <div class="fm-empty-icon" style="width:60px;height:60px;font-size:1.5rem;margin-bottom:14px;">
                    <i class="bi bi-chat-dots"></i>
                </div>
                <h5 class="fm-empty-title" style="font-size:.95rem;">No messages</h5>
                <p class="fm-empty-text" style="font-size:.8rem;margin-bottom:0;">Start a conversation</p>
            </div>
            {% endfor %}
        </div>

        {% if messages|length == 0 %}
        <div class="fm-new-msg-wrap">
            <button class="fm-new-msg-btn" data-bs-toggle="modal" data-bs-target="#newMessageModal">
                <i class="bi bi-plus-lg"></i> New Message
            </button>
        </div>
        {% endif %}
    </aside>

    {# ═══════════════════════════════════════
       CHAT PANEL - Clean Style
       ═══════════════════════════════════════ #}
    <main class="fm-chat">
        {% if messages|length > 0 %}
        {% set firstMsg = messages|first %}

        <header class="fm-chat-header" id="chatHeader">
            <div class="fm-chat-user">
                <div class="fm-chat-avatar" id="chatAvatar">
                    <img src="{{ asset('images/quamc-logo.png') }}" alt="QUAMC">
                </div>
                <div class="fm-chat-details">
                    <h5 id="chatTitle">Administration</h5>
                    <div class="fm-chat-status" id="chatStatus">{{ firstMsg.subject }}</div>
                </div>
            </div>
            <div class="fm-chat-actions">
                <button type="button" class="fm-chat-delete-btn" title="Delete chat" data-bs-toggle="modal" data-bs-target="#deleteChatModal">
                    <i class="bi bi-trash3"></i>
                    <span class="d-none d-sm-inline">Delete chat</span>
                </button>
            </div>
        </header>

        <div class="fm-chat-body" id="chatBody">
            {% for msg in messages %}
            <div class="fm-thread" id="thread-{{ msg.id }}"{% if not loop.first %} style="display:none"{% endif %}>
                <div class="fm-date-sep">
                    <span>{{ msg.createdAt|date('M d, Y') }}</span>
                </div>

                {# Faculty's message (sent - purple) #}
                <div class="fm-message outgoing">
                    <div class="fm-bubble">{{- msg.message|trim -}}</div>
                    <div class="fm-message-time">
                        {{ msg.createdAt|date('h:i A') }}
                        <i class="bi bi-check2-all read-icon"></i>
                    </div>
                </div>

                {# Old Admin's reply (backward compatibility) #}
                {% if msg.adminReply %}
                <div class="fm-message incoming">
                    <div class="fm-message-sender">
                        <i class="bi bi-circle-fill"></i> {% if msg.repliedBy and msg.repliedBy.isAdmin %}Admin{% else %}Staff{% endif %}
                    </div>
                    <div class="fm-bubble">{{- msg.adminReply|trim -}}</div>
                    <div class="fm-message-time">
                        {% if msg.repliedAt %}{{ msg.repliedAt|date('h:i A') }}{% endif %}
                    </div>
                </div>
                {% endif %}

                {# Conversation thread replies #}
                {% if repliesMap[msg.id] is defined and repliesMap[msg.id]|length > 0 %}
                {% for reply in repliesMap[msg.id] %}
                {% if reply.senderType == 'faculty' %}
                {# Faculty's reply (outgoing - purple) #}
                <div class="fm-message outgoing">
                    <div class="fm-bubble">{{- reply.message|trim -}}</div>
                    <div class="fm-message-time">
                        {{ reply.createdAt|date('h:i A') }}
                        <i class="bi bi-check2-all read-icon"></i>
                    </div>
                </div>
                {% else %}
                {# Admin/Staff reply (incoming - white) #}
                <div class="fm-message incoming">
                    <div class="fm-message-sender">
                        <i class="bi bi-circle-fill"></i> {% if reply.sender.isAdmin %}Admin{% else %}Staff{% endif %}
                    </div>
                    <div class="fm-bubble">{{- reply.message|trim -}}</div>
                    {%- if reply.attachment %}
                    <div class="fm-attachment">
                        <div class="fm-attachment-icon">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <div class="fm-attachment-info">
                            <div class="fm-attachment-name">{{ reply.attachmentOriginalName }}</div>
                            <div class="fm-attachment-size">Click to download</div>
                        </div>
                        <a href="{{ asset('uploads/attachments/' ~ reply.attachment) }}" download="{{ reply.attachmentOriginalName }}" class="fm-attachment-download" title="Download">
                            <i class="bi bi-download"></i>
                        </a>
                    </div>
                    {%- endif %}
                    <div class="fm-message-time">
                        {{ reply.createdAt|date('h:i A') }}
                    </div>
                </div>
                {% endif %}
                {% endfor %}
                {% endif %}
            </div>
            {% endfor %}
        </div>

        {% for msg in messages %}
        <div class="fm-compose" id="compose-{{ msg.id }}"{% if not loop.first %} style="display:none"{% endif %}>
            <form method="post" action="{{ path('faculty_eval_request') }}">
                <input type="hidden" name="_action" value="reply_message">
                <input type="hidden" name="parent_message_id" value="{{ msg.id }}">
                <div class="fm-compose-inner">
                    <textarea name="msg_body" class="fm-textarea" placeholder="Type a message..." required></textarea>
                    <button type="submit" class="fm-send-btn">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </form>
        </div>
        {% endfor %}

        {% else %}
        <div class="fm-empty-state">
            <div class="fm-empty-icon">
                <i class="bi bi-chat-dots"></i>
            </div>
            <h5 class="fm-empty-title">No messages yet</h5>
            <p class="fm-empty-text">Start a conversation with the administration.</p>
            <button class="fm-empty-btn" data-bs-toggle="modal" data-bs-target="#newMessageModal">
                <i class="bi bi-plus-lg"></i> New Message
            </button>
        </div>
        {% endif %}
    </main>
</div>

{% if messages|length > 0 %}
<div class="modal fade" id="deleteChatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">
            <form method="post" action="{{ path('faculty_eval_request') }}">
                <input type="hidden" name="_action" value="delete_message">
                <input type="hidden" name="msg_id" id="deleteMsgId" value="{{ firstMsg.id }}">
                <input type="hidden" name="_token" id="deleteMsgToken" value="{{ csrf_token('delete_msg' ~ firstMsg.id) }}">

                <div class="fm-modal-header" style="background:linear-gradient(135deg,#1e3a8a 0%,#2563eb 55%,#06b6d4 100%);">
                    <div class="fm-modal-icon">
                        <i class="bi bi-trash3-fill"></i>
                    </div>
                    <h5 class="fm-modal-title">Delete Chat</h5>
                    <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                </div>

                <div class="fm-modal-body">
                    <p class="mb-2" style="font-size:.9rem;color:var(--chat-text-secondary);">
                        Delete this conversation with Administration?
                    </p>
                    <div class="p-3 rounded" style="background:var(--chat-bg);border:1px solid var(--chat-border);">
                        <strong id="deleteChatSubject" style="font-size:.82rem;color:var(--chat-text-primary);">{{ firstMsg.subject }}</strong>
                    </div>
                </div>

                <div class="fm-modal-footer">
                    <button type="button" class="fm-btn fm-btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="fm-btn fm-btn-primary" style="min-width:120px;justify-content:center;">
                        <i class="bi bi-trash3 me-1"></i> Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}

{# ═══════════════════════════════════════
   NEW MESSAGE MODAL - Clean Style
   ═══════════════════════════════════════ #}
{% if messages|length == 0 %}
<div class="modal fade" id="newMessageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">
            <form method="post" action="{{ path('faculty_eval_request') }}">
                <input type="hidden" name="_action" value="send_message">

                <div class="fm-modal-header">
                    <div class="fm-modal-icon">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <h5 class="fm-modal-title">New Message</h5>
                    <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                </div>

                <div class="fm-modal-body">
                    <div class="fm-form-group">
                        <label class="fm-form-label">Message <span class="text-danger">*</span></label>
                        <textarea name="msg_body" class="fm-form-textarea" placeholder="Type your message..." required></textarea>
                    </div>
                </div>

                <div class="fm-modal-footer">
                    <button type="button" class="fm-btn fm-btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="fm-btn fm-btn-primary">
                        <i class="bi bi-send-fill"></i> Send
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}

{# Flash Messages #}
{% for label, msgs in app.flashes %}
<div class="position-fixed top-0 end-0 p-3" style="z-index:9999;">
    <div class="toast show align-items-center text-white bg-{{ label == 'error' ? 'danger' : label }}" role="alert" style="border-radius:12px;">
        <div class="d-flex">
            <div class="toast-body fw-semibold">{% for m in msgs %}{{ m }}{% endfor %}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>
{% endfor %}

<script>
const messagesData = {
    {% for msg in messages %}
    {{ msg.id }}: {
        id: {{ msg.id }},
        subject: "{{ msg.subject|e('js') }}",
        message: "{{ msg.message|e('js')|replace({"\n": "\\n", "\r": ""}) }}",
        status: "{{ msg.status }}",
        createdAt: "{{ msg.createdAt|date('M d, Y') }}",
        deleteToken: "{{ csrf_token('delete_msg' ~ msg.id) }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
};

let currentMsgId = {{ messages|length > 0 ? messages|first.id : 'null' }};

function selectConversation(el, msgId) {
    currentMsgId = msgId;

    document.querySelectorAll('.fm-conv-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');

    document.querySelectorAll('.fm-thread').forEach(t => t.style.display = 'none');
    document.querySelectorAll('.fm-compose').forEach(c => c.style.display = 'none');
    const thread = document.getElementById('thread-' + msgId);
    const compose = document.getElementById('compose-' + msgId);
    if (thread) thread.style.display = 'flex';
    if (compose) compose.style.display = 'block';

    const msg = messagesData[msgId];
    if (msg) {
        document.getElementById('chatTitle').textContent = 'Administration';
        document.getElementById('chatStatus').textContent = msg.subject;
        updateDeleteModal(msg);
    }

    const chatBody = document.getElementById('chatBody');
    chatBody.scrollTop = chatBody.scrollHeight;
}

function updateDeleteModal(msg) {
    if (!msg) {
        return;
    }

    const idEl = document.getElementById('deleteMsgId');
    const tokenEl = document.getElementById('deleteMsgToken');
    const subjectEl = document.getElementById('deleteChatSubject');

    if (idEl) {
        idEl.value = msg.id;
    }
    if (tokenEl) {
        tokenEl.value = msg.deleteToken || '';
    }
    if (subjectEl) {
        subjectEl.textContent = msg.subject;
    }
}

function searchMessages() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.fm-conv-item').forEach(item => {
        const searchText = item.dataset.search || '';
        item.style.display = searchText.includes(query) ? '' : 'none';
    });
}

function initFacultyEvalRequestPage() {
    const chatBody = document.getElementById('chatBody');
    if (chatBody) chatBody.scrollTop = chatBody.scrollHeight;

    if (currentMsgId && messagesData[currentMsgId]) {
        updateDeleteModal(messagesData[currentMsgId]);
    }

    document.querySelectorAll('.fm-textarea').forEach(textarea => {
        textarea.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });
    });

    document.querySelectorAll('.toast').forEach(toast => {
        if (toast.dataset.flashInit === '1') {
            return;
        }
        toast.dataset.flashInit = '1';

        toast.style.opacity = '0';
        toast.style.transform = 'translateY(-8px)';
        toast.style.transition = 'opacity .35s ease, transform .35s ease';

        requestAnimationFrame(() => {
            toast.style.opacity = '1';
            toast.style.transform = 'translateY(0)';
        });

        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-10px)';
            setTimeout(() => toast.remove(), 350);
        }, 3000);
    });
}

document.addEventListener('DOMContentLoaded', initFacultyEvalRequestPage);
document.addEventListener('turbo:load', initFacultyEvalRequestPage);
</script>
{% endblock %}
