{% block body %}
{# ═══════════════════════════════════════════════════
   REGISTRATION PAGE — Professional Split Layout
   ═══════════════════════════════════════════════════ #}

<div class="rg-page">
    {# ── LEFT PANEL: Decorative branding ── #}
    <div class="rg-brand-panel">
        <div class="rg-brand-bg"></div>
        <div class="rg-brand-content">
            <div class="rg-brand-logo-wrap">
                <img src="{{ asset('images/quamc-logo.png') }}" alt="QUAMC" class="rg-brand-logo">
            </div>
            <h1 class="rg-brand-title">SET-SEF Evaluation System</h1>
            <p class="rg-brand-sub">Join the Negros Oriental State University evaluation community</p>

            <div class="rg-brand-features">
                <div class="rg-feature-item">
                    <div class="rg-feature-icon"><i class="bi bi-shield-check"></i></div>
                    <div>
                        <strong>Secure Platform</strong>
                        <span>Enterprise-grade data protection</span>
                    </div>
                </div>
                <div class="rg-feature-item">
                    <div class="rg-feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <div>
                        <strong>Smart Analytics</strong>
                        <span>Data-driven evaluation insights</span>
                    </div>
                </div>
                <div class="rg-feature-item">
                    <div class="rg-feature-icon"><i class="bi bi-people"></i></div>
                    <div>
                        <strong>Collaborative</strong>
                        <span>University-wide assessment tools</span>
                    </div>
                </div>
            </div>

            <div class="rg-brand-footer">
                <p>&copy; {{ 'now'|date('Y') }} Negros Oriental State University</p>
            </div>
        </div>
    </div>

    {# ── RIGHT PANEL: Registration form ── #}
    <div class="rg-form-panel">
        <div class="rg-form-scroll">
            <div class="rg-form-inner">

                {# Step progress indicator #}
                <div class="rg-steps" id="rgSteps">
                    <div class="rg-step active" data-step="1">
                        <div class="rg-step-num">1</div>
                        <span>Select Role</span>
                    </div>
                    <div class="rg-step-line"></div>
                    <div class="rg-step" data-step="2">
                        <div class="rg-step-num">2</div>
                        <span>Your Details</span>
                    </div>
                </div>

                <h2 class="rg-title" id="rgTitle">Choose your role</h2>
                <p class="rg-subtitle" id="rgSubtitle">Select how you'll use the evaluation system</p>

                {# ═══ STEP 1: Role Selection ═══ #}
                <div id="roleStep" class="rg-step-content">
                    <div class="rg-role-grid">
                        <button type="button" class="rg-role-card" data-role="student" onclick="selectRole('student')">
                            <div class="rg-role-icon-wrap rg-role-student">
                                <i class="bi bi-mortarboard"></i>
                            </div>
                            <div class="rg-role-info">
                                <h4>Student</h4>
                                <p>Evaluate faculty performance and participate in academic assessments</p>
                            </div>
                            <div class="rg-role-arrow"><i class="bi bi-arrow-right"></i></div>
                        </button>

                        <button type="button" class="rg-role-card" data-role="faculty" onclick="selectRole('faculty')">
                            <div class="rg-role-icon-wrap rg-role-faculty">
                                <i class="bi bi-person"></i>
                            </div>
                            <div class="rg-role-info">
                                <h4>Faculty</h4>
                                <p>Access evaluation results, analytics and faculty development tools</p>
                            </div>
                            <div class="rg-role-arrow"><i class="bi bi-arrow-right"></i></div>
                        </button>

                        <button type="button" class="rg-role-card" data-role="staff" onclick="selectRole('staff')">
                            <div class="rg-role-icon-wrap rg-role-staff">
                                <i class="bi bi-clipboard2-check"></i>
                            </div>
                            <div class="rg-role-info">
                                <h4>Staff</h4>
                                <p>Manage evaluations, generate reports and oversee processes</p>
                            </div>
                            <div class="rg-role-arrow"><i class="bi bi-arrow-right"></i></div>
                        </button>

                        <button type="button" class="rg-role-card" data-role="superior" onclick="selectRole('superior')">
                            <div class="rg-role-icon-wrap rg-role-superior">
                                <i class="bi bi-star"></i>
                            </div>
                            <div class="rg-role-info">
                                <h4>Superior</h4>
                                <p>Evaluate Superior Performane , review institutional performace</p>
                            </div>
                            <div class="rg-role-arrow"><i class="bi bi-arrow-right"></i></div>
                        </button>
                    </div>

                    <div class="rg-login-link mt-4">
                        Already have an account? <a href="{{ path('app_login') }}">Sign in here</a>
                    </div>
                </div>

                {# ═══ GOOGLE GATE STEP (All roles) ═══ #}
                <div id="googleGateStep" class="rg-step-content d-none">
                    <div class="rg-google-gate">
                        {# ── Sign-in card ── #}
                        <div class="rg-google-gate-card">
                            <div class="rg-google-gate-icon"><i class="bi bi-shield-lock"></i></div>
                            <div class="rg-google-gate-title" id="gateRoleTitle">Google Verification Required</div>
                            <p class="rg-google-gate-desc" id="gateRoleDesc">
                                Sign in with your Google account to receive a verification code in your Gmail inbox.
                            </p>

                            {% if googleAuthEnabled|default(false) %}
                            <div class="rg-google-btn-wrap" id="googleSignInBtnWrap">
                                {# Custom styled button (visible) #}
                                <button type="button" class="rg-google-custom-btn" tabindex="-1" aria-hidden="true">
                                    <svg width="20" height="20" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                    </svg>
                                    Sign in with Google
                                </button>
                                {# Real GIS button — transparent overlay, captures the click #}
                                <div class="rg-google-btn-overlay" id="google-signin-btn"></div>
                            </div>
                            <div id="gateMsg" class="rg-gate-msg info d-none"></div>
                            {% else %}
                            <div class="rg-gate-msg error">
                                <strong>Google Sign-In not configured.</strong><br>
                                Set <code>GOOGLE_AUTH_CLIENT_ID</code> in <code>.env.local</code>.
                            </div>
                            {% endif %}
                        </div>

                        {# ── Code entry card (shown after sign-in) ── #}
                        <div class="rg-code-box d-none" id="gateCodeBox">
                            <label class="rg-code-label">
                                <i class="bi bi-envelope-check me-1"></i>Enter the 6-digit code sent to your Gmail
                            </label>
                            <div class="rg-code-input-row">
                                <input type="text"
                                       id="gateCodeInput"
                                       class="rg-code-input"
                                       maxlength="6"
                                       inputmode="numeric"
                                       pattern="[0-9]{6}"
                                       placeholder="000000"
                                       autocomplete="one-time-code">
                                <button type="button" class="rg-code-verify-btn" id="gateVerifyBtn">
                                    Verify
                                </button>
                            </div>
                            <div id="gateCodeMsg" class="rg-gate-msg info mt-2 d-none"></div>
                        </div>

                        <div class="text-center">
                            <button type="button" class="rg-gate-back-btn" id="gateBackBtn">
                                <i class="bi bi-arrow-left-short"></i> Back to role selection
                            </button>
                        </div>
                    </div>
                </div>

                {# ═══ STEP 2: Registration Form ═══ #}
                <div id="formStep" class="rg-step-content d-none">
                    <div class="rg-selected-role" id="selectedRoleBadge">
                        <span class="rg-role-pill" id="rolePill"></span>
                        <button type="button" class="rg-change-role" id="changeRoleBtn">
                            <i class="bi bi-arrow-left-short"></i>Change
                        </button>
                    </div>

                    {{ form_start(registrationForm, {'attr': {'id': 'regForm', 'class': 'rg-form', 'novalidate': 'novalidate', 'data-turbo': 'false'}}) }}

                        {# Hidden role select + unused Symfony widgets #}
                        <div class="d-none">
                            {{ form_widget(registrationForm.role) }}
                            {{ form_widget(registrationForm.course) }}
                            {{ form_widget(registrationForm.department) }}
                        </div>

                        {# ── Honeypot: hidden from humans, bots auto-fill it ── #}
                        <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;height:0;width:0;overflow:hidden;">
                            <label for="reg_website">Leave this empty</label>
                            {{ form_widget(registrationForm.website, {'attr': {'id': 'reg_website', 'tabindex': '-1', 'autocomplete': 'off'}}) }}
                        </div>

                        {# ── Timestamp for timing-based bot detection ── #}
                        {{ form_widget(registrationForm._ts) }}

                        {# ── Form validation feedback (server-side) ── #}
                        {% if registrationForm.vars.submitted and not registrationForm.vars.valid %}
                        <div class="rg-security-alert">
                            <i class="bi bi-exclamation-triangle"></i>
                            <div>
                                <strong>Registration could not be submitted</strong>
                                <p>Please review the highlighted fields and try again.</p>
                            </div>
                        </div>
                        {% endif %}

                        {# ── Security error alert ── #}
                        {% if securityError|default(null) %}
                        <div class="rg-security-alert">
                            <i class="bi bi-shield-exclamation"></i>
                            <div>
                                <strong>Security Notice</strong>
                                <p>{{ securityError }}</p>
                            </div>
                        </div>
                        {% endif %}

                        {# ── Section: Personal Information ── #}
                        <div class="rg-section">
                            <div class="rg-section-label">
                                <i class="bi bi-person-circle"></i>
                                <span>Personal Information</span>
                            </div>
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="rg-label">First Name <span class="text-danger">*</span></label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-person"></i>
                                        {{ form_widget(registrationForm.firstName, {'attr': {'placeholder': 'First name', 'class': 'form-control rg-input', 'required': 'required'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.firstName) }}
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Last Name <span class="text-danger">*</span></label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-person"></i>
                                        {{ form_widget(registrationForm.lastName, {'attr': {'placeholder': 'Last name', 'class': 'form-control rg-input', 'required': 'required'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.lastName) }}
                                </div>
                            </div>
                        </div>

                        {# ── Section: Student Details ── #}
                        <div class="rg-section role-field" data-for="student" style="display:none">
                            <div class="rg-section-label">
                                <i class="bi bi-mortarboard"></i>
                                <span>Academic Information</span>
                            </div>
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="rg-label">Student ID</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-person-badge"></i>
                                        {{ form_widget(registrationForm.schoolId, {'attr': {'placeholder': 'e.g. 2024-00123', 'class': 'form-control rg-input', 'required': 'required'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.schoolId) }}
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Year Level</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-layers"></i>
                                        {{ form_widget(registrationForm.yearLevel, {'attr': {'class': 'form-select rg-select', 'required': 'required'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.yearLevel) }}
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Campus</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-geo-alt"></i>
                                        <select id="studentCampus" class="form-select rg-select" name="{{ registrationForm.campus.vars.full_name }}" required>
                                            <option value="">Select campus</option>
                                            {% for choice in registrationForm.campus.vars.choices %}
                                                <option value="{{ choice.value }}" {{ registrationForm.campus.vars.value == choice.value ? 'selected' : '' }}>{{ choice.label }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    {{ form_errors(registrationForm.campus) }}
                                </div>
                            </div>
                            <div class="row g-3 mt-0">
                                <div class="col-sm-6">
                                    <label class="rg-label">College</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-bank2"></i>
                                        <select id="studentCollege" class="form-select rg-select" onchange="filterStudentDepts()" required>
                                            <option value="">Select college</option>
                                            {% for college in colleges %}
                                                <option value="{{ college }}">{{ college }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Department</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-building"></i>
                                        <select id="studentDepartment" class="form-select rg-select" name="{{ registrationForm.department.vars.full_name }}" disabled required>
                                            <option value="">Select college first</option>
                                        </select>
                                    </div>
                                    {{ form_errors(registrationForm.department) }}
                                </div>
                            </div>
                        </div>

                        {# ── Section: Faculty Details ── #}
                        <div class="rg-section role-field" data-for="faculty" style="display:none">
                            <div class="rg-section-label">
                                <i class="bi bi-person-workspace"></i>
                                <span>Faculty Information</span>
                            </div>
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="rg-label">Campus</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-geo-alt"></i>
                                        {{ form_widget(registrationForm.campus, {'attr': {'class': 'form-select rg-select', 'required': 'required'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.campus) }}
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">College</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-bank2"></i>
                                        <select id="facultyCollege" class="form-select rg-select" onchange="filterFacultyDepts()" required>
                                            <option value="">Select college</option>
                                            {% for college in colleges %}
                                                <option value="{{ college }}">{{ college }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row g-3 mt-0">
                                <div class="col-sm-6">
                                    <label class="rg-label">Department</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-building"></i>
                                        <select id="facultyDepartment" class="form-select rg-select" name="{{ registrationForm.department.vars.full_name }}" disabled required>
                                            <option value="">Select college first</option>
                                        </select>
                                    </div>
                                    {{ form_errors(registrationForm.department) }}
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Employment Status</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-briefcase"></i>
                                        {{ form_widget(registrationForm.employmentStatus, {'attr': {'class': 'form-select rg-select', 'required': 'required'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.employmentStatus) }}
                                </div>
                            </div>
                            <div class="row g-3 mt-0">
                                <div class="col-sm-6">
                                    <label class="rg-label">Employee ID</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-person-vcard"></i>
                                        <input type="text" class="form-control rg-input{{ registrationForm.schoolId.vars.errors|length > 0 ? ' is-invalid' : '' }}" name="_employee_id" placeholder="e.g. EMP-0001" value="{{ app.request.request.get('_employee_id') }}" required>
                                    </div>
                                    {{ form_errors(registrationForm.schoolId) }}
                                </div>
                            </div>
                        </div>

                        {# ── Section: Staff Details ── #}
                        <div class="rg-section role-field" data-for="staff" style="display:none">
                            <div class="rg-section-label">
                                <i class="bi bi-clipboard2-check"></i>
                                <span>Staff Information</span>
                            </div>
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="rg-label">Employment Status</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-briefcase"></i>
                                        <select class="form-select rg-select" name="{{ registrationForm.employmentStatus.vars.full_name }}" required>
                                            <option value="">Select employment status</option>
                                            {% for choice in registrationForm.employmentStatus.vars.choices %}
                                                <option value="{{ choice.value }}" {{ registrationForm.employmentStatus.vars.value == choice.value ? 'selected' : '' }}>{{ choice.label }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Office / Unit</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-building"></i>
                                        <input type="text" class="form-control rg-input" name="_office" value="QUAMC Office" readonly required>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Staff ID</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-person-vcard"></i>
                                        <input type="text" class="form-control rg-input{{ registrationForm.schoolId.vars.errors|length > 0 ? ' is-invalid' : '' }}" name="_staff_id" placeholder="e.g. STF-0001" value="{{ app.request.request.get('_staff_id') }}" required>
                                    </div>
                                    {{ form_errors(registrationForm.schoolId) }}
                                </div>
                            </div>
                        </div>

                        {# ── Section: Superior Information ── #}
                        <div class="rg-section role-field" data-for="superior" style="display:none">
                            <div class="rg-section-label">
                                <i class="bi bi-star"></i>
                                <span>Superior Information</span>
                            </div>
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="rg-label">Campus</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-geo-alt"></i>
                                        <select class="form-select rg-select" name="{{ registrationForm.campus.vars.full_name }}" required>
                                            <option value="">Select campus</option>
                                            {% for choice in registrationForm.campus.vars.choices %}
                                                <option value="{{ choice.value }}" {{ registrationForm.campus.vars.value == choice.value ? 'selected' : '' }}>{{ choice.label }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Position / Designation</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-briefcase"></i>
                                        <select class="form-select rg-select" name="_position" required>
                                            <option value="">Select position</option>
                                            <option value="President">President</option>
                                            <option value="Vice President">Vice President</option>
                                            <option value="Campus Director">Campus Director</option>
                                            <option value="Dean">Dean</option>
                                            <option value="Department Head">Department Head</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Employee ID</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-person-vcard"></i>
                                        <input type="text" class="form-control rg-input{{ registrationForm.schoolId.vars.errors|length > 0 ? ' is-invalid' : '' }}" name="_employee_id" placeholder="e.g. EMP-0001" value="{{ app.request.request.get('_employee_id') }}" required>
                                    </div>
                                    {{ form_errors(registrationForm.schoolId) }}
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Academic Rank</label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-award"></i>
                                        <select class="form-select rg-select" name="_academic_rank" required>
                                            <option value="">Select academic rank</option>
                                            <option value="Instructor">Instructor</option>
                                            <option value="Assistant Professor">Assistant Professor</option>
                                            <option value="Associate Professor">Associate Professor</option>
                                            <option value="Professor">Professor</option>
                                            <option value="University Professor">University Professor</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# ── Section: Security ── #}
                        <div class="rg-section">
                            <div class="rg-section-label">
                                <i class="bi bi-shield-lock"></i>
                                <span>Create Password</span>
                            </div>
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="rg-label">Password <span class="text-danger">*</span></label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-lock"></i>
                                        {{ form_widget(registrationForm.plainPassword.first, {'attr': {'placeholder': 'Create a password', 'class': 'form-control rg-input', 'id': 'regPwd', 'autocomplete': 'off', 'required': 'required'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.plainPassword.first) }}
                                    <div class="rg-pwd-strength" id="pwdStrength">
                                        <div class="rg-pwd-bar"><span id="pwdBar"></span></div>
                                        <small id="pwdText">Enter a password</small>
                                    </div>
                                    {# Password requirements checklist #}
                                    <div class="rg-pwd-requirements" id="pwdRequirements">
                                        <div class="rg-pwd-req" id="reqLength">
                                            <i class="bi bi-circle"></i>
                                            <span>At least 8 characters</span>
                                        </div>
                                        <div class="rg-pwd-req" id="reqUpper">
                                            <i class="bi bi-circle"></i>
                                            <span>One uppercase letter (A–Z)</span>
                                        </div>
                                        <div class="rg-pwd-req" id="reqLower">
                                            <i class="bi bi-circle"></i>
                                            <span>One lowercase letter (a–z)</span>
                                        </div>
                                        <div class="rg-pwd-req" id="reqNumber">
                                            <i class="bi bi-circle"></i>
                                            <span>One number (0–9)</span>
                                        </div>
                                        <div class="rg-pwd-req" id="reqSpecial">
                                            <i class="bi bi-circle"></i>
                                            <span>One special character (!@#$...)</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <label class="rg-label">Confirm Password <span class="text-danger">*</span></label>
                                    <div class="rg-input-wrap">
                                        <i class="bi bi-shield-lock-fill"></i>
                                        {{ form_widget(registrationForm.plainPassword.second, {'attr': {'placeholder': 'Confirm password', 'class': 'form-control rg-input', 'id': 'regPwdConfirm', 'autocomplete': 'off', 'required': 'required'}}) }}
                                    </div>
                                    {{ form_errors(registrationForm.plainPassword) }}
                                    {# Password match indicator #}
                                    <div class="rg-pwd-match d-none" id="pwdMatchIndicator">
                                        <i class="bi bi-circle"></i>
                                        <span>Passwords match</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# ── Section: Terms & Data Privacy ── #}
                        <div class="rg-section rg-terms-section">
                            <div class="rg-section-label">
                                <i class="bi bi-file-earmark-lock2"></i>
                                <span>Terms & Data Privacy</span>
                            </div>
                            <div class="rg-terms-box">
                                <div class="rg-terms-scroll">
                                    <h6>Data Privacy Notice</h6>
                                    <p>In compliance with the <strong>Data Privacy Act of 2012 (RA 10173)</strong>, the information you provide will be used solely for the purpose of faculty evaluation and academic quality assurance within NORSU.</p>
                                    <h6>Terms of Use</h6>
                                    <ul>
                                        <li>Your evaluation responses will be kept <strong>confidential</strong> and used only for institutional improvement.</li>
                                        <li>You agree not to share your account credentials with others.</li>
                                        <li>Any misuse of the system may result in account suspension.</li>
                                        <li>Anonymous evaluation data may be used in aggregate reports.</li>
                                    </ul>
                                    <h6>Data Collection</h6>
                                    <p>We collect: name, email, school/employee ID, department, and evaluation responses. This data is stored securely and access is restricted to authorized personnel only.</p>
                                </div>
                            </div>
                            <div class="rg-terms-check">
                                <label class="rg-checkbox-wrap" id="termsCheckboxWrap">
                                    <input type="checkbox" name="{{ registrationForm.agreeTerms.vars.full_name }}" id="agreeTermsCheck" value="1" style="position:absolute;opacity:0;width:0;height:0;pointer-events:none;">
                                    <span class="rg-checkbox-box" id="termsCheckboxBox">
                                        <i class="bi bi-check-lg"></i>
                                    </span>
                                    <span class="rg-checkbox-label">
                                        I have read and agree to the <strong>Terms of Use</strong> and <strong>Data Privacy Policy</strong> in accordance with RA 10173.
                                    </span>
                                </label>
                                {{ form_errors(registrationForm.agreeTerms) }}
                            </div>
                        </div>

                        {# Approval notice #}
                        <div class="rg-notice role-field" data-for="faculty staff superior" style="display:none">
                            <i class="bi bi-info-circle-fill"></i>
                            <div>
                                <strong>Admin Approval Required</strong>
                                <p>Faculty, Staff, and Superior accounts require a registered ID and administrator approval before access is granted.</p>
                            </div>
                        </div>

                        {# Submit button #}
                        <button type="submit" class="rg-submit-btn" id="regSubmitBtn">
                            <span class="rg-submit-text">
                                <i class="bi bi-person-plus-fill me-2"></i>Create Account
                            </span>
                            <span class="rg-submit-loading d-none">
                                <span class="rg-loading-spinner"></span>
                                <span>Creating Account</span>
                                <span class="rg-loading-dots"><span>.</span><span>.</span><span>.</span></span>
                            </span>
                            <span class="rg-btn-progress"></span>
                        </button>

                        <div class="rg-login-link mt-3">
                            Already have an account? <a href="{{ path('app_login') }}">Sign in here</a>
                        </div>
                    {% do registrationForm.agreeTerms.setRendered %}
                    {{ form_end(registrationForm) }}
                </div>

            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   DUPLICATE ACCOUNT MODAL
   ═══════════════════════════════════════════════════ #}
<div class="modal fade" id="duplicateAccountModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="true" data-bs-keyboard="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content" style="border:none;border-radius:1.25rem;overflow:hidden;box-shadow:0 25px 60px rgba(0,0,0,0.18);">
            <div class="modal-body text-center px-4 py-4 position-relative">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>

                <div class="mb-3" style="width:60px;height:60px;border-radius:50%;background:#FEF2F2;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                    <i class="bi bi-person-exclamation" style="font-size:1.6rem;color:#DC2626;"></i>
                </div>

                <h5 class="fw-bold mb-2" style="color:#1E293B;font-size:1.1rem;">Account Already Exists</h5>
                <p style="font-size:0.875rem;color:#64748B;line-height:1.55;margin-bottom:1.25rem;">
                    This Google email is already registered on QUAMC Evaluation.<br>
                    Please sign in with your existing account.
                </p>

                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-light flex-fill fw-medium" data-bs-dismiss="modal" style="border-radius:0.625rem;font-size:0.875rem;">
                        Cancel
                    </button>
                    <a href="{{ path('app_login') }}" class="btn flex-fill fw-semibold text-white" style="border-radius:0.625rem;font-size:0.875rem;background:#1E3A8A;">
                        Sign In Instead
                    </a>
                </div>
            </div>
        </div>
