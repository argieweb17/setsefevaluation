{% extends 'base.html.twig' %}

{% block title %}System Announcement | SET-SEF Evaluation{% endblock %}

{% block body %}
<div class="container-fluid px-3 px-md-4 py-3">
    <div class="card border-0 shadow-sm" style="border-radius:14px;">
        <div class="card-header bg-white border-0 py-3" style="border-bottom:1px solid #e5e7eb !important;">
            <h5 class="mb-1 fw-bold text-dark"><i class="bi bi-megaphone me-2 text-primary"></i>System Announcement</h5>
            <small class="text-muted">Staff can write, edit, and update announcement content shown on the Welcome page.</small>
            {% if metaUpdatedAt or metaUpdatedBy %}
            <div class="mt-2 text-muted" style="font-size:.82rem;">
                <i class="bi bi-clock-history me-1"></i>
                Last updated:
                {% if metaUpdatedAt %}<strong>{{ metaUpdatedAt|date('M d, Y h:i A') }}</strong>{% else %}<strong>—</strong>{% endif %}
                {% if metaUpdatedBy %} by <strong>{{ metaUpdatedBy }}</strong>{% endif %}
            </div>
            {% endif %}
        </div>
        <div class="card-body p-3 p-md-4">
            <form method="post" action="{{ path('staff_announcements_save') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('save_system_announcement') }}">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Announcement Title</label>
                    <input type="text" name="title" class="form-control" value="{{ title|default('') }}" maxlength="180" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Announcement Content</label>
                    <textarea name="body" class="form-control" rows="8" required>{{ body|default('') }}</textarea>
                    <div class="form-text">Use **double asterisks** for bold text. Line breaks are preserved.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check2-circle me-1"></i>Save Announcement
                    </button>
                    <a href="{{ path('staff_evaluations') }}" class="btn btn-outline-secondary">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
