{# ═══════════════════════════════════════
   JAVASCRIPT — VIEW SWITCHING
   ═══════════════════════════════════════ #}
<script>
function viewSubjectDetail(subjectId) {
    var card = document.querySelector('.cm-subj-card[data-view-id="' + subjectId + '"]');
    if (!card) return;
    document.getElementById('viewSubjAvatar').textContent = card.getAttribute('data-view-code').slice(0,2).toUpperCase();
    document.getElementById('viewSubjCode').textContent = card.getAttribute('data-view-code');
    document.getElementById('viewSubjName').textContent = card.getAttribute('data-view-name');
    document.getElementById('viewSubjUnits').textContent = card.getAttribute('data-view-units');
    document.getElementById('viewSubjYearLevel').textContent = card.getAttribute('data-view-yearlevel');
    document.getElementById('viewSubjSemester').textContent = card.getAttribute('data-view-semester');
    document.getElementById('viewSubjSchoolYear').textContent = card.getAttribute('data-view-schoolyear');
    document.getElementById('viewSubjTerm').textContent = card.getAttribute('data-view-term');
    document.getElementById('viewSubjDept').textContent = card.getAttribute('data-view-department');
    document.getElementById('viewSubjFaculty').textContent = card.getAttribute('data-view-faculty');
    new bootstrap.Modal(document.getElementById('viewSubjectModal')).show();
}

function hideAllViews() {
    document.getElementById('view-main').style.display = 'none';
    document.querySelectorAll('.cm-view').forEach(function(el) { el.style.display = 'none'; });
}

function showMain() {
    hideAllViews();
    document.getElementById('view-main').style.display = '';
    window.scrollTo({top: 0, behavior: 'smooth'});
}

/* ── College/Dept Table Search ── */
function filterCdTable() {
    var q = document.getElementById('cmCdSearch').value.toLowerCase().trim();
    // Filter dept rows
    document.querySelectorAll('#cmCdTable tbody .cm-cd-dept-row').forEach(function(row) {
        row.style.display = (!q || row.dataset.search.indexOf(q) !== -1) ? '' : 'none';
        if (row.style.display === '') row.classList.remove('cm-cd-hidden');
        else row.classList.add('cm-cd-hidden');
    });
    // Show/hide college headers based on visible dept rows
    document.querySelectorAll('#cmCdTable tbody .cm-cd-college-row').forEach(function(cRow) {
        var collegeName = cRow.dataset.college;
        var hasVisible = false;
        document.querySelectorAll('#cmCdTable tbody .cm-cd-dept-row[data-college="' + collegeName + '"]').forEach(function(dRow) {
            if (!dRow.classList.contains('cm-cd-hidden')) hasVisible = true;
        });
        cRow.style.display = hasVisible ? '' : 'none';
    });
    // Renumber visible dept rows
    var idx = 0;
    document.querySelectorAll('#cmCdTable tbody .cm-cd-dept-row').forEach(function(row) {
        if (!row.classList.contains('cm-cd-hidden') && row.style.display !== 'none') {
            idx++;
            row.querySelector('td').textContent = idx;
        }
    });
}

/* ── Toggle college expand/collapse ── */
function toggleCollegeDepts(collegeRow) {
    var collegeName = collegeRow.dataset.college;
    var isCollapsed = collegeRow.classList.toggle('collapsed');
    document.querySelectorAll('#cmCdTable tbody .cm-cd-dept-row[data-college="' + collegeName + '"]').forEach(function(row) {
        if (isCollapsed) row.classList.add('cm-cd-hidden');
        else row.classList.remove('cm-cd-hidden');
    });
}

function showDepartment(deptId) {
    hideAllViews();
    var el = document.getElementById('view-dept-' + deptId);
    if (el) { el.style.display = ''; }
    window.scrollTo({top: 0, behavior: 'smooth'});
}

function showCurriculum(curId, deptId) {
    hideAllViews();
    var el = document.getElementById('view-cur-' + curId);
    if (el) { el.style.display = ''; }
    window.scrollTo({top: 0, behavior: 'smooth'});
}

function switchYearLevel(btn) {
    var curId = btn.getAttribute('data-cur');
    var yl = btn.getAttribute('data-yl');
    document.querySelectorAll('.cm-tab[data-cur="' + curId + '"]').forEach(function(t) {
        t.classList.remove('active');
    });
    btn.classList.add('active');
    document.querySelectorAll('.cm-yl-panel[data-cur="' + curId + '"]').forEach(function(p) {
        p.style.display = 'none';
        p.classList.remove('active');
    });
    var panel = document.querySelector('.cm-yl-panel[data-cur="' + curId + '"][data-yl="' + yl + '"]');
    if (panel) {
        panel.style.display = '';
        panel.classList.add('active');
    }
}

function filterSubjects(input, curId) {
    var query = input.value.toLowerCase();
    var container = document.getElementById('subjects-container-' + curId);
    var noResults = document.getElementById('no-results-' + curId);
    if (!container) return;

    if (query.length > 0) {
        container.querySelectorAll('.cm-yl-panel').forEach(function(p) { p.style.display = ''; });
    } else {
        container.querySelectorAll('.cm-yl-panel').forEach(function(p) {
            p.style.display = p.classList.contains('active') ? '' : 'none';
        });
    }

    var rows = container.querySelectorAll('.cm-subject-row');
    var totalVisible = 0;
    rows.forEach(function(row) {
        var name = row.getAttribute('data-name') || '';
        var show = name.indexOf(query) !== -1;
        row.style.display = show ? '' : 'none';
        if (show) totalVisible++;
    });
    container.querySelectorAll('.cm-sem-card').forEach(function(card) {
        var visibleRows = card.querySelectorAll('.cm-subject-row:not([style*="display: none"])');
        card.style.display = visibleRows.length > 0 ? '' : 'none';
    });
    container.querySelectorAll('.cm-yl-panel').forEach(function(panel) {
        var visibleCards = panel.querySelectorAll('.cm-sem-card:not([style*="display: none"])');
        if (query.length > 0) {
            panel.style.display = visibleCards.length > 0 ? '' : 'none';
        }
    });
    if (noResults) noResults.style.display = totalVisible === 0 ? '' : 'none';
}

function filterCurricula(input, deptId) {
    var query = input.value.toLowerCase();
    var container = document.getElementById('curricula-list-' + deptId);
    if (!container) return;
    var items = container.querySelectorAll('.cm-curriculum-item');
    items.forEach(function(item) {
        var name = item.getAttribute('data-name') || '';
        item.style.display = name.indexOf(query) !== -1 ? '' : 'none';
    });
}

function submitEditDept(e, form, deptId) {
    e.preventDefault();
    var formData = new FormData(form);
    fetch(form.action, { method: 'POST', body: formData, headers: {'X-Requested-With': 'XMLHttpRequest'} })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                document.querySelectorAll('[data-dept-name-' + deptId + ']').forEach(function(el) {
                    el.textContent = data.name;
                });
                var modal = bootstrap.Modal.getInstance(document.getElementById('editDeptModal' + deptId));
                if (modal) modal.hide();
                location.reload();
            }
        })
        .catch(function() { form.submit(); });
    return false;
}
</script>
{% endblock %}
