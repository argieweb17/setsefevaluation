{% endfor %}

<div class="modal fade" id="disclaimerModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content qq-modal-content">
            <form method="post" action="{{ path(prefix ~ '_question_disclaimer') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('question_disclaimer') }}">
                <input type="hidden" name="evaluationType" value="{{ selectedType }}">
                <div class="qq-modal-header qq-modal-header-blue">
                    <div class="d-flex align-items-center gap-3">
                        <div class="qq-modal-icon"><i class="bi bi-shield-lock"></i></div>
                        <div>
                            <h6 class="fw-bold mb-0 text-white">Edit Data Privacy Disclaimer</h6>
