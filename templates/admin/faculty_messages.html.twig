{% extends 'base.html.twig' %}
{% set prefix = staffMode|default(false) ? 'staff' : 'admin' %}

{% block title %}Faculty Messages | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ═══════════════════════════════════════
   CSS VARIABLES
   ═══════════════════════════════════════ */
:root {
    --msg-primary: #1e40af;
    --msg-primary-dark: #1e3a8a;
    --msg-success: #059669;
    --msg-success-light: #ecfdf5;
    --msg-warning: #d97706;
    --msg-warning-light: #fffbeb;
    --msg-danger: #dc2626;
    --msg-sidebar-bg: #f8fafc;
    --msg-border: #e2e8f0;
    --msg-text-primary: #0f172a;
    --msg-text-secondary: #64748b;
    --msg-text-muted: #94a3b8;
    --msg-shadow-sm: 0 1px 2px rgba(0,0,0,.05);
    --msg-shadow-md: 0 4px 12px rgba(0,0,0,.08);
    --msg-shadow-lg: 0 8px 30px rgba(0,0,0,.12);
    --msg-radius-sm: 8px;
    --msg-radius-md: 12px;
    --msg-radius-lg: 16px;
    --msg-radius-xl: 20px;
}

/* ═══════════════════════════════════════
   MAIN CONTAINER
   ═══════════════════════════════════════ */
.fm-app {
    display: flex;
    height: calc(100vh - 100px);
    min-height: 600px;
    background: #fff;
    border-radius: var(--msg-radius-xl);
    overflow: hidden;
    box-shadow: var(--msg-shadow-lg);
    border: 1px solid var(--msg-border);
}

/* ═══════════════════════════════════════
   SIDEBAR
   ═══════════════════════════════════════ */
.fm-sidebar {
    width: 380px;
    min-width: 340px;
    background: var(--msg-sidebar-bg);
    border-right: 1px solid var(--msg-border);
    display: flex;
    flex-direction: column;
}

/* Sidebar Header */
.fm-sidebar-header {
    padding: 24px;
    background: linear-gradient(135deg, var(--msg-primary-dark) 0%, var(--msg-primary) 50%, var(--msg-success) 100%);
    position: relative;
    overflow: hidden;
}
.fm-sidebar-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,.1) 0%, transparent 60%);
    pointer-events: none;
}
.fm-sidebar-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    position: relative;
    z-index: 1;
}
.fm-sidebar-logo {
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,.15);
    border-radius: var(--msg-radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: #fff;
    backdrop-filter: blur(8px);
}
.fm-sidebar-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 2px;
    letter-spacing: -0.3px;
}
.fm-sidebar-subtitle {
    font-size: .78rem;
    color: rgba(255,255,255,.75);
    margin: 0;
}
.fm-sidebar-stats {
    display: flex;
    gap: 8px;
    margin-top: 16px;
    position: relative;
    z-index: 1;
}
.fm-stat-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: rgba(255,255,255,.15);
    border-radius: 20px;
    font-size: .72rem;
    font-weight: 600;
    color: #fff;
    backdrop-filter: blur(4px);
}
.fm-stat-chip.urgent {
    background: rgba(239,68,68,.9);
    animation: fm-pulse 2s ease-in-out infinite;
}
@keyframes fm-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,.4); }
    50% { box-shadow: 0 0 0 8px rgba(239,68,68,0); }
}

/* Filter Tabs */
.fm-filter-section {
    padding: 16px 20px;
    background: #fff;
    border-bottom: 1px solid var(--msg-border);
}
.fm-filter-tabs {
    display: flex;
    gap: 6px;
    background: #f1f5f9;
    padding: 4px;
    border-radius: var(--msg-radius-md);
}
.fm-filter-tab {
    flex: 1;
    padding: 10px 8px;
    border: none;
    background: transparent;
    border-radius: var(--msg-radius-sm);
    font-size: .75rem;
    font-weight: 600;
    color: var(--msg-text-secondary);
    cursor: pointer;
    transition: all .2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}
.fm-filter-tab:hover {
    background: rgba(255,255,255,.6);
    color: var(--msg-text-primary);
}
.fm-filter-tab.active {
    background: #fff;
    color: var(--msg-primary);
    box-shadow: var(--msg-shadow-sm);
}
.fm-filter-count {
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 10px;
    background: rgba(0,0,0,.06);
    font-size: .65rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
.fm-filter-tab.active .fm-filter-count {
    background: #dbeafe;
    color: var(--msg-primary);
}
.fm-filter-tab.has-pending .fm-filter-count {
    background: #fef2f2;
    color: var(--msg-danger);
}

/* Search */
.fm-search-section {
    padding: 12px 20px 16px;
    background: #fff;
}
.fm-search-wrap {
    position: relative;
}
.fm-search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--msg-text-muted);
    font-size: .9rem;
    pointer-events: none;
}
.fm-search-input {
    width: 100%;
    padding: 12px 16px 12px 42px;
    border: 2px solid var(--msg-border);
    border-radius: var(--msg-radius-md);
    font-size: .84rem;
    color: var(--msg-text-primary);
    background: var(--msg-sidebar-bg);
    outline: none;
    transition: all .2s ease;
}
.fm-search-input:focus {
    border-color: var(--msg-primary);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(30,64,175,.08);
}
.fm-search-input::placeholder {
    color: var(--msg-text-muted);
}

/* Conversation List */
.fm-conv-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px 12px;
}
.fm-conv-list::-webkit-scrollbar {
    width: 6px;
}
.fm-conv-list::-webkit-scrollbar-track {
    background: transparent;
}
.fm-conv-list::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 3px;
}
.fm-conv-list::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
}

.fm-conv-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px;
    border-radius: var(--msg-radius-md);
    cursor: pointer;
    transition: all .15s ease;
    margin-bottom: 4px;
    position: relative;
    border: 2px solid transparent;
}
.fm-conv-item:hover {
    background: #fff;
    border-color: var(--msg-border);
    box-shadow: var(--msg-shadow-sm);
}
.fm-conv-item.active {
    background: #fff;
    border-color: var(--msg-primary);
    box-shadow: 0 0 0 4px rgba(30,64,175,.08);
}
.fm-conv-item.unread {
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border-color: #fde68a;
}
.fm-conv-item.unread::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 60%;
    background: var(--msg-warning);
    border-radius: 0 4px 4px 0;
}

/* Avatar */
.fm-avatar {
    width: 50px;
    height: 50px;
    border-radius: var(--msg-radius-md);
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: .85rem;
    flex-shrink: 0;
    overflow: hidden;
    box-shadow: var(--msg-shadow-sm);
}
.fm-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Conversation Info */
.fm-conv-info {
    flex: 1;
    min-width: 0;
}
.fm-conv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 4px;
}
.fm-conv-name {
    font-size: .9rem;
    font-weight: 700;
    color: var(--msg-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-conv-time {
    font-size: .7rem;
    color: var(--msg-text-muted);
    flex-shrink: 0;
    font-weight: 500;
}
.fm-conv-dept {
    font-size: .75rem;
    color: var(--msg-text-secondary);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 5px;
}
.fm-conv-dept i {
    font-size: .7rem;
    color: var(--msg-text-muted);
}
.fm-conv-subject {
    font-size: .78rem;
    color: var(--msg-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 500;
}
.fm-conv-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
}
.fm-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: .68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .3px;
}
.fm-status-pending {
    background: var(--msg-warning-light);
    color: var(--msg-warning);
}
.fm-status-reviewed {
    background: #dbeafe;
    color: var(--msg-primary);
}
.fm-status-resolved {
    background: var(--msg-success-light);
    color: var(--msg-success);
}

/* ═══════════════════════════════════════
   CHAT PANEL
   ═══════════════════════════════════════ */
.fm-chat {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: #fff;
}

/* Chat Header */
.fm-chat-header {
    padding: 20px 28px;
    background: #fff;
    border-bottom: 1px solid var(--msg-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.fm-chat-user {
    display: flex;
    align-items: center;
    gap: 16px;
}
.fm-chat-avatar {
    width: 52px;
    height: 52px;
    border-radius: var(--msg-radius-md);
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: .9rem;
    overflow: hidden;
    box-shadow: var(--msg-shadow-md);
}
.fm-chat-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.fm-chat-details h5 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--msg-text-primary);
    margin: 0 0 4px;
}
.fm-chat-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
}
.fm-chat-meta-item {
    font-size: .78rem;
    color: var(--msg-text-secondary);
    display: flex;
    align-items: center;
    gap: 5px;
}
.fm-chat-meta-item i {
    color: var(--msg-text-muted);
    font-size: .75rem;
}
.fm-chat-actions {
    display: flex;
    align-items: center;
    gap: 10px;
}
.fm-header-badge {
    padding: 8px 16px;
    border-radius: 20px;
    font-size: .75rem;
    font-weight: 700;
}
.fm-action-btn {
    width: 42px;
    height: 42px;
    border-radius: var(--msg-radius-md);
    border: 2px solid var(--msg-border);
    background: #fff;
    color: var(--msg-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .95rem;
    transition: all .2s ease;
}
.fm-action-btn:hover {
    border-color: var(--msg-primary);
    color: var(--msg-primary);
    background: #eff6ff;
}
.fm-action-btn.danger:hover {
    border-color: var(--msg-danger);
    color: var(--msg-danger);
    background: #fef2f2;
}

/* Chat Body */
.fm-chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 22px;
    background: #f8fafd;
    display: flex;
    flex-direction: column;
    gap: 20px;
}
.fm-thread {
    display: flex;
    flex-direction: column;
    gap: 10px;
}
.fm-chat-body::-webkit-scrollbar {
    width: 6px;
}
.fm-chat-body::-webkit-scrollbar-track {
    background: transparent;
}
.fm-chat-body::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 3px;
}

/* Date Separator */
.fm-date-sep {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 8px 0;
}
.fm-date-sep::before,
.fm-date-sep::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--msg-border), transparent);
}
.fm-date-sep span {
    font-size: .72rem;
    font-weight: 600;
    color: var(--msg-text-muted);
    padding: 6px 16px;
    background: #fff;
    border-radius: 20px;
    border: 1px solid var(--msg-border);
    white-space: nowrap;
}

/* Message Bubbles */
.fm-message {
    display: flex;
    flex-direction: column;
    max-width: 72%;
}
.fm-message.incoming {
    align-self: flex-start;
    align-items: flex-start;
}
.fm-message.outgoing {
    align-self: flex-end;
    align-items: flex-end;
}
.fm-message-sender {
    font-size: .72rem;
    font-weight: 600;
    color: var(--msg-text-secondary);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
}
.fm-message-sender i {
    color: #6366f1;
}
.fm-bubble {
    padding: 9px 13px;
    border-radius: 12px;
    font-size: .82rem;
    line-height: 1.45;
    white-space: pre-wrap;
    word-break: break-word;
    display: inline-flex;
    width: max-content;
    max-width: 100%;
    align-self: flex-start;
    box-shadow: var(--msg-shadow-sm);
}
.fm-message.incoming .fm-bubble {
    background: #fff;
    color: var(--msg-text-primary);
    border: 1px solid var(--msg-border);
    border-bottom-left-radius: 4px;
}
.fm-message.outgoing .fm-bubble {
    background: linear-gradient(135deg, var(--msg-success) 0%, #10b981 100%);
    color: #fff;
    border-bottom-right-radius: 4px;
    align-self: flex-end;
}
.fm-bubble-subject {
    font-weight: 700;
    margin-bottom: 8px;
    padding: 4px 10px;
    border: none;
    border-radius: 999px;
    font-size: .74rem;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--msg-success-light);
}
.fm-message.outgoing .fm-bubble-subject {
    background: rgba(255,255,255,.18);
}
.fm-bubble-subject i {
    font-size: .78rem;
}
.fm-message-time {
    font-size: .68rem;
    color: var(--msg-text-muted);
    margin-top: 5px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.fm-message.outgoing .fm-message-time {
    justify-content: flex-end;
}
.fm-message-time .read-icon {
    color: var(--msg-success);
}

/* Attachment */
.fm-attachment {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid rgba(0,0,0,.08);
}
.fm-message.outgoing .fm-attachment {
    border-color: rgba(255,255,255,.2);
}
.fm-attachment-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-radius: var(--msg-radius-sm);
    font-size: .8rem;
    font-weight: 600;
    text-decoration: none;
    transition: all .15s ease;
}
.fm-message.incoming .fm-attachment-link {
    background: #f1f5f9;
    color: var(--msg-text-secondary);
}
.fm-message.incoming .fm-attachment-link:hover {
    background: #e2e8f0;
}
.fm-message.outgoing .fm-attachment-link {
    background: rgba(255,255,255,.2);
    color: #fff;
}
.fm-message.outgoing .fm-attachment-link:hover {
    background: rgba(255,255,255,.3);
}

/* Empty State */
.fm-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    text-align: center;
}
.fm-empty-icon {
    width: 100px;
    height: 100px;
    border-radius: 28px;
    background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: var(--msg-text-muted);
    margin-bottom: 24px;
}
.fm-empty-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--msg-text-secondary);
    margin: 0 0 8px;
}
.fm-empty-text {
    font-size: .9rem;
    color: var(--msg-text-muted);
    max-width: 320px;
    line-height: 1.6;
    margin: 0;
}

/* ═══════════════════════════════════════
   COMPOSE AREA
   ═══════════════════════════════════════ */
.fm-compose {
    padding: 12px 20px;
    background: #fff;
    border-top: 1px solid var(--msg-border);
}
.fm-compose-inner {
    background: var(--msg-sidebar-bg);
    border-radius: var(--msg-radius-md);
    border: 2px solid var(--msg-border);
    overflow: hidden;
    transition: all .2s ease;
}
.fm-compose-inner:focus-within {
    border-color: var(--msg-success);
    box-shadow: 0 0 0 4px rgba(15,118,110,.1);
}
.fm-compose-header {
    padding: 10px 14px;
    background: #fff;
    border-bottom: 1px solid var(--msg-border);
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .78rem;
    font-weight: 600;
    color: var(--msg-text-secondary);
}
.fm-compose-header i {
    color: var(--msg-success);
}
.fm-compose-body {
    padding: 0;
}
.fm-textarea {
    width: 100%;
    padding: 12px 14px;
    border: none;
    font-size: .88rem;
    color: var(--msg-text-primary);
    background: transparent;
    outline: none;
    resize: none;
    min-height: 56px;
    max-height: 120px;
    font-family: inherit;
    line-height: 1.6;
}
.fm-textarea::placeholder {
    color: var(--msg-text-muted);
}
.fm-compose-footer {
    padding: 10px 14px;
    background: #fff;
    border-top: 1px solid var(--msg-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}
.fm-compose-tools {
    display: flex;
    align-items: center;
    gap: 10px;
}
.fm-tool-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--msg-radius-sm);
    border: 2px dashed var(--msg-border);
    background: #fff;
    color: var(--msg-text-muted);
    cursor: pointer;
    transition: all .15s ease;
    font-size: 1rem;
}
.fm-tool-btn:hover {
    border-color: var(--msg-success);
    color: var(--msg-success);
    background: var(--msg-success-light);
    border-style: solid;
}
.fm-status-select {
    padding: 9px 14px;
    border: 2px solid var(--msg-border);
    border-radius: var(--msg-radius-sm);
    font-size: .82rem;
    font-weight: 600;
    color: var(--msg-text-secondary);
    background: #fff;
    cursor: pointer;
    outline: none;
    transition: all .15s ease;
    min-width: 150px;
}
.fm-status-select:focus {
    border-color: var(--msg-success);
}
.fm-send-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    border-radius: var(--msg-radius-md);
    border: none;
    background: linear-gradient(135deg, var(--msg-success) 0%, #10b981 100%);
    color: #fff;
    font-size: .84rem;
    font-weight: 700;
    cursor: pointer;
    transition: all .2s ease;
    box-shadow: 0 4px 12px rgba(15,118,110,.22);
}
.fm-send-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(15,118,110,.3);
}
.fm-send-btn:active {
    transform: translateY(0);
}
.fm-file-name {
    font-size: .75rem;
    color: var(--msg-text-secondary);
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
}

/* ═══════════════════════════════════════
   DELETE MODAL
   ═══════════════════════════════════════ */
.fm-modal-danger-header {
    background: linear-gradient(135deg, #991b1b 0%, #dc2626 50%, #f87171 100%);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
}
.fm-modal-icon {
    width: 44px;
    height: 44px;
    background: rgba(255,255,255,.15);
    border-radius: var(--msg-radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.2rem;
    backdrop-filter: blur(4px);
}

/* ═══════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════ */
@media (max-width: 1200px) {
    .fm-sidebar {
        width: 320px;
        min-width: 280px;
    }
    .fm-message {
        max-width: 75%;
    }
}
@media (max-width: 992px) {
    .fm-app {
        flex-direction: column;
        height: auto;
        min-height: calc(100vh - 80px);
    }
    .fm-sidebar {
        width: 100%;
        min-width: 100%;
        max-height: 400px;
        border-right: none;
        border-bottom: 1px solid var(--msg-border);
    }
    .fm-conv-list {
        max-height: 250px;
    }
    .fm-chat-body {
        min-height: 400px;
    }
    .fm-message {
        max-width: 85%;
    }
}
@media (max-width: 576px) {
    .fm-sidebar-header {
        padding: 18px;
    }
    .fm-chat-header {
        padding: 16px;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
    .fm-chat-actions {
        width: 100%;
        justify-content: flex-end;
    }
    .fm-compose {
        padding: 10px;
    }
    .fm-compose-footer {
        flex-direction: column;
        align-items: stretch;
    }
    .fm-compose-tools {
        justify-content: space-between;
    }
    .fm-send-btn {
        width: 100%;
        justify-content: center;
    }
}

/* Animations */
.fm-conv-item {
    animation: fm-slide-in .25s ease;
}
@keyframes fm-slide-in {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
}
.fm-message {
    animation: fm-fade-up .3s ease;
}
@keyframes fm-fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>
{% endblock %}

{% block body %}
{% set pendingMessages = messages|filter(m => m.status == 'pending')|length %}
{% set reviewedMessages = messages|filter(m => m.status == 'reviewed')|length %}
{% set resolvedMessages = messages|filter(m => m.status == 'resolved')|length %}

<div class="fm-app">
    {# ═══════════════════════════════════════
       SIDEBAR
       ═══════════════════════════════════════ #}
    <aside class="fm-sidebar">
        <div class="fm-sidebar-header">
            <div class="fm-sidebar-brand">
                <div class="fm-sidebar-logo">
                    <i class="bi bi-envelope-paper-fill"></i>
                </div>
                <div>
                    <h4 class="fm-sidebar-title">Faculty Messages</h4>
                    <p class="fm-sidebar-subtitle">Manage inquiries & requests</p>
                </div>
            </div>
            <div class="fm-sidebar-stats">
                <span class="fm-stat-chip">
                    <i class="bi bi-inbox-fill"></i> {{ messages|length }} Total
                </span>
                {% if pendingMessages > 0 %}
                <span class="fm-stat-chip urgent">
                    <i class="bi bi-exclamation-circle-fill"></i> {{ pendingMessages }} Pending
                </span>
                {% endif %}
            </div>
        </div>

        <div class="fm-filter-section">
            <div class="fm-filter-tabs">
                <button class="fm-filter-tab active" data-filter="all" onclick="filterMessages('all', this)">
                    All <span class="fm-filter-count">{{ messages|length }}</span>
                </button>
                <button class="fm-filter-tab{% if pendingMessages > 0 %} has-pending{% endif %}" data-filter="pending" onclick="filterMessages('pending', this)">
                    Pending <span class="fm-filter-count">{{ pendingMessages }}</span>
                </button>
                <button class="fm-filter-tab" data-filter="reviewed" onclick="filterMessages('reviewed', this)">
                    Reviewed <span class="fm-filter-count">{{ reviewedMessages }}</span>
                </button>
                <button class="fm-filter-tab" data-filter="resolved" onclick="filterMessages('resolved', this)">
                    Resolved <span class="fm-filter-count">{{ resolvedMessages }}</span>
                </button>
            </div>
        </div>

        <div class="fm-search-section">
            <div class="fm-search-wrap">
                <i class="bi bi-search fm-search-icon"></i>
                <input type="text" class="fm-search-input" id="searchInput" placeholder="Search by name, department, subject..." oninput="searchMessages()">
            </div>
        </div>

        <div class="fm-conv-list" id="convList">
            {% for msg in messages %}
            <div class="fm-conv-item{% if loop.first %} active{% endif %}{% if msg.status == 'pending' %} unread{% endif %}"
                 data-msg-id="{{ msg.id }}"
                 data-status="{{ msg.status }}"
                 data-search="{{ msg.sender.fullName|lower }} {{ msg.sender.department ? msg.sender.department.departmentName|lower : '' }} {{ msg.subject|lower }}"
                 onclick="selectConversation(this, {{ msg.id }})">
                <div class="fm-avatar">
                    {% if msg.sender.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ msg.sender.profilePicture) }}" alt="">
                    {% else %}
                        {{ msg.sender.firstName|first }}{{ msg.sender.lastName|first }}
                    {% endif %}
                </div>
                <div class="fm-conv-info">
                    <div class="fm-conv-header">
                        <span class="fm-conv-name">{{ msg.sender.fullName }}</span>
                        <span class="fm-conv-time">{{ msg.createdAt|date('M d') }}</span>
                    </div>
                    {% if msg.sender.department %}
                    <div class="fm-conv-dept">
                        <i class="bi bi-building"></i> {{ msg.sender.department.departmentName }}
                    </div>
                    {% endif %}
                    <div class="fm-conv-subject">{{ msg.subject }}</div>
                    <div class="fm-conv-footer">
                        <span class="fm-status-badge fm-status-{{ msg.status }}">
                            {% if msg.status == 'pending' %}<i class="bi bi-clock"></i> Pending
                            {% elseif msg.status == 'reviewed' %}<i class="bi bi-eye"></i> Reviewed
                            {% else %}<i class="bi bi-check-circle"></i> Resolved{% endif %}
                        </span>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="fm-empty-state" style="padding:50px 24px;">
                <div class="fm-empty-icon" style="width:70px;height:70px;font-size:1.8rem;margin-bottom:16px;">
                    <i class="bi bi-inbox"></i>
                </div>
                <h5 class="fm-empty-title" style="font-size:1rem;">No messages</h5>
                <p class="fm-empty-text" style="font-size:.82rem;">Faculty messages will appear here</p>
            </div>
            {% endfor %}
        </div>
    </aside>

    {# ═══════════════════════════════════════
       CHAT PANEL
       ═══════════════════════════════════════ #}
    <main class="fm-chat">
        {% if messages|length > 0 %}
        {% set firstMsg = messages|first %}

        <header class="fm-chat-header" id="chatHeader">
            <div class="fm-chat-user">
                <div class="fm-chat-avatar" id="chatAvatar">
                    {% if firstMsg.sender.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ firstMsg.sender.profilePicture) }}" alt="">
                    {% else %}
                        {{ firstMsg.sender.firstName|first }}{{ firstMsg.sender.lastName|first }}
                    {% endif %}
                </div>
                <div class="fm-chat-details">
                    <h5 id="chatName">{{ firstMsg.sender.fullName }}</h5>
                    <div class="fm-chat-meta">
                        {% if firstMsg.sender.department %}
                        <span class="fm-chat-meta-item" id="chatDept">
                            <i class="bi bi-building"></i> {{ firstMsg.sender.department.departmentName }}
                        </span>
                        {% endif %}
                        {% if firstMsg.evaluationPeriod %}
                        <span class="fm-chat-meta-item" id="chatEval">
                            <i class="bi bi-clipboard2-check"></i> {{ firstMsg.evaluationPeriod.evaluationType }} - {{ firstMsg.evaluationPeriod.semester ?? '' }} {{ firstMsg.evaluationPeriod.schoolYear ?? '' }}
                        </span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="fm-chat-actions">
                <span class="fm-header-badge fm-status-{{ firstMsg.status }}" id="chatStatusBadge">
                    {% if firstMsg.status == 'pending' %}<i class="bi bi-clock"></i> Pending
                    {% elseif firstMsg.status == 'reviewed' %}<i class="bi bi-eye"></i> Reviewed
                    {% else %}<i class="bi bi-check-circle"></i> Resolved{% endif %}
                </span>
                <button type="button" class="fm-action-btn danger" title="Delete conversation" data-bs-toggle="modal" data-bs-target="#deleteCurrentMsg">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>
        </header>

        <div class="fm-chat-body" id="chatBody">
            {% for msg in messages %}
            <div class="fm-thread" id="thread-{{ msg.id }}"{% if not loop.first %} style="display:none"{% endif %} data-msg-id="{{ msg.id }}">
                <div class="fm-date-sep">
                    <span>{{ msg.createdAt|date('l, F d, Y') }}</span>
                </div>

                {# Faculty's message #}
                <div class="fm-message incoming">
                    <div class="fm-message-sender">
                        <i class="bi bi-person-fill"></i> {{ msg.sender.fullName }}
                    </div>
                    <div class="fm-bubble">
                        {{- msg.message|trim -}}
                        {%- if msg.attachment %}
                        <div class="fm-attachment">
                            <a href="{{ asset('uploads/attachments/' ~ msg.attachment) }}" target="_blank" class="fm-attachment-link">
                                <i class="bi bi-file-earmark-pdf-fill"></i>
                                {{ msg.attachmentOriginalName }}
                                <i class="bi bi-download"></i>
                            </a>
                        </div>
                        {%- endif %}
                    </div>
                    <div class="fm-message-time">
                        <i class="bi bi-clock"></i> {{ msg.createdAt|date('h:i A') }}
                    </div>
                </div>

                {# Old admin reply (for backward compatibility) #}
                {% if msg.adminReply %}
                <div class="fm-message outgoing">
                    <div class="fm-bubble">{{ msg.adminReply|trim }}</div>
                    <div class="fm-message-time">
                        {% if msg.repliedBy %}<i class="bi bi-person-check"></i> {{ msg.repliedBy.fullName }} &bull; {% endif %}
                        {{ msg.repliedAt|date('h:i A') }}
                        <i class="bi bi-check2-all read-icon"></i>
                    </div>
                </div>
                {% endif %}

                {# Conversation thread replies #}
                {% if repliesMap[msg.id] is defined %}
                {% for reply in repliesMap[msg.id] %}
                <div class="fm-message outgoing">
                    <div class="fm-bubble">
                        {{- reply.message|trim -}}
                        {%- if reply.attachment %}
                        <div class="fm-attachment">
                            <a href="{{ asset('uploads/attachments/' ~ reply.attachment) }}" target="_blank" class="fm-attachment-link">
                                <i class="bi bi-file-earmark-pdf-fill"></i>
                                {{ reply.attachmentOriginalName }}
                                <i class="bi bi-download"></i>
                            </a>
                        </div>
                        {%- endif %}
                    </div>
                    <div class="fm-message-time">
                        <i class="bi bi-clock"></i> {{ reply.createdAt|date('h:i A') }}
                        <i class="bi bi-check2-all read-icon"></i>
                    </div>
                </div>
                {% endfor %}
                {% endif %}
            </div>
            {% endfor %}
        </div>

        {# Compose areas #}
        {% for msg in messages %}
        <div class="fm-compose" id="compose-{{ msg.id }}"{% if not loop.first %} style="display:none"{% endif %}>
            <form method="post" action="{{ path(prefix ~ '_faculty_message_reply', {id: msg.id}) }}" enctype="multipart/form-data">
                <div class="fm-compose-inner">
                    <div class="fm-compose-header">
                        <i class="bi bi-reply-fill"></i>
                        Write a reply
                    </div>
                    <div class="fm-compose-body">
                        <textarea name="reply" class="fm-textarea" placeholder="Type your response here..." required></textarea>
                    </div>
                    <div class="fm-compose-footer">
                        <div class="fm-compose-tools">
                            <label class="fm-tool-btn" title="Attach file">
                                <i class="bi bi-paperclip"></i>
                                <input type="file" name="attachment" accept=".pdf" class="d-none" onchange="updateFileName(this, {{ msg.id }})">
                            </label>
                            <select name="status" class="fm-status-select">
                                <option value="reviewed" {% if msg.status == 'reviewed' %}selected{% endif %}>Mark as Reviewed</option>
                                <option value="resolved" {% if msg.status == 'resolved' %}selected{% endif %}>Mark as Resolved</option>
                            </select>
                        </div>
                        <button type="submit" class="fm-send-btn">
                            <i class="bi bi-send-fill"></i> Send Reply
                        </button>
                    </div>
                </div>
                <div class="fm-file-name" id="fileName-{{ msg.id }}"></div>
            </form>
        </div>
        {% endfor %}

        {% else %}
        <div class="fm-empty-state">
            <div class="fm-empty-icon">
                <i class="bi bi-envelope-open"></i>
            </div>
            <h5 class="fm-empty-title">No messages yet</h5>
            <p class="fm-empty-text">Faculty messages and evaluation requests will appear here when they reach out.</p>
        </div>
        {% endif %}
    </main>
</div>

{# Delete Modal #}
<div class="modal fade" id="deleteCurrentMsg" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:var(--msg-radius-lg);overflow:hidden;">
            <form method="post" id="deleteCurrentForm" action="{% if messages|length > 0 %}{{ path(prefix ~ '_faculty_message_delete', {id: messages|first.id}) }}{% endif %}">
                <input type="hidden" name="_token" id="deleteCurrentToken" value="{% if messages|length > 0 %}{{ csrf_token('admin_delete_msg' ~ messages|first.id) }}{% endif %}">
                <div class="fm-modal-danger-header">
                    <div class="fm-modal-icon">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div>
                        <h6 class="text-white fw-bold mb-0">Delete Message</h6>
                        <small class="text-white-50">This action cannot be undone</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-3" style="font-size:.88rem;color:var(--msg-text-secondary);">
                        Delete this conversation with <strong id="deleteCurrentName" style="color:var(--msg-text-primary);">{% if messages|length > 0 %}{{ messages|first.sender.fullName }}{% endif %}</strong>?
                    </p>
                    <div class="p-3 rounded" style="background:var(--msg-sidebar-bg);border:1px solid var(--msg-border);">
                        <strong class="d-block mb-1" style="font-size:.85rem;color:var(--msg-text-primary);" id="deleteCurrentSubject">{% if messages|length > 0 %}{{ messages|first.subject }}{% endif %}</strong>
                        <small style="color:var(--msg-text-muted);" id="deleteCurrentDate">{% if messages|length > 0 %}{{ messages|first.createdAt|date('M d, Y h:i A') }}{% endif %}</small>
                    </div>
                </div>
                <div class="modal-footer" style="background:var(--msg-sidebar-bg);border-top:1px solid var(--msg-border);padding:16px 20px;">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal" style="font-weight:600;border-radius:var(--msg-radius-sm);">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4" style="font-weight:600;border-radius:var(--msg-radius-sm);">
                        <i class="bi bi-trash3 me-1"></i> Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{# Flash Messages #}
{% for label, msgs in app.flashes %}
<div class="position-fixed top-0 end-0 p-3" style="z-index:9999;">
    <div class="toast show align-items-center text-white bg-{{ label == 'error' ? 'danger' : label }}" role="alert" style="border-radius:var(--msg-radius-md);">
        <div class="d-flex">
            <div class="toast-body fw-semibold">{% for m in msgs %}{{ m }}{% endfor %}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>
{% endfor %}

<script>
const messagesData = {
    {% for msg in messages %}
    {{ msg.id }}: {
        id: {{ msg.id }},
        senderName: "{{ msg.sender.fullName|e('js') }}",
        senderInitials: "{{ msg.sender.firstName|first }}{{ msg.sender.lastName|first }}",
        senderPhoto: {% if msg.sender.profilePicture %}"{{ asset('images/profiles/' ~ msg.sender.profilePicture) }}"{% else %}null{% endif %},
        department: {% if msg.sender.department %}"{{ msg.sender.department.departmentName|e('js') }}"{% else %}null{% endif %},
        subject: "{{ msg.subject|e('js') }}",
        status: "{{ msg.status }}",
        createdAt: "{{ msg.createdAt|date('M d, Y h:i A') }}",
        evalLabel: {% if msg.evaluationPeriod %}"{{ msg.evaluationPeriod.evaluationType }} - {{ msg.evaluationPeriod.semester ?? '' }} {{ msg.evaluationPeriod.schoolYear ?? '' }}"{% else %}null{% endif %},
        deleteUrl: "{{ path(prefix ~ '_faculty_message_delete', {id: msg.id}) }}",
        deleteToken: "{{ csrf_token('admin_delete_msg' ~ msg.id) }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
};

let currentMsgId = {{ messages|length > 0 ? messages|first.id : 'null' }};

function selectConversation(el, msgId) {
    currentMsgId = msgId;

    document.querySelectorAll('.fm-conv-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');

    document.querySelectorAll('.fm-thread').forEach(t => t.style.display = 'none');
    document.querySelectorAll('.fm-compose').forEach(c => c.style.display = 'none');

    const thread = document.getElementById('thread-' + msgId);
    const compose = document.getElementById('compose-' + msgId);
    if (thread) thread.style.display = 'block';
    if (compose) compose.style.display = 'block';

    const msg = messagesData[msgId];
    if (msg) {
        const avatarEl = document.getElementById('chatAvatar');
        avatarEl.innerHTML = msg.senderPhoto
            ? '<img src="' + msg.senderPhoto + '" alt="">'
            : msg.senderInitials;

        document.getElementById('chatName').textContent = msg.senderName;

        const deptEl = document.getElementById('chatDept');
        if (deptEl) {
            if (msg.department) {
                deptEl.innerHTML = '<i class="bi bi-building"></i> ' + msg.department;
                deptEl.style.display = '';
            } else {
                deptEl.style.display = 'none';
            }
        }

        const evalEl = document.getElementById('chatEval');
        if (evalEl) {
            if (msg.evalLabel) {
                evalEl.innerHTML = '<i class="bi bi-clipboard2-check"></i> ' + msg.evalLabel;
                evalEl.style.display = '';
            } else {
                evalEl.style.display = 'none';
            }
        }

        const statusBadge = document.getElementById('chatStatusBadge');
        statusBadge.className = 'fm-header-badge fm-status-' + msg.status;
        const statusLabels = {
            pending: '<i class="bi bi-clock"></i> Pending',
            reviewed: '<i class="bi bi-eye"></i> Reviewed',
            resolved: '<i class="bi bi-check-circle"></i> Resolved'
        };
        statusBadge.innerHTML = statusLabels[msg.status] || statusLabels.pending;

        document.getElementById('deleteCurrentForm').action = msg.deleteUrl;
        document.getElementById('deleteCurrentToken').value = msg.deleteToken;
        document.getElementById('deleteCurrentName').textContent = msg.senderName;
        document.getElementById('deleteCurrentSubject').textContent = msg.subject;
        document.getElementById('deleteCurrentDate').textContent = msg.createdAt;
    }

    const chatBody = document.getElementById('chatBody');
    chatBody.scrollTop = chatBody.scrollHeight;
}

function filterMessages(status, btn) {
    document.querySelectorAll('.fm-filter-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');

    document.querySelectorAll('.fm-conv-item').forEach(item => {
        const show = status === 'all' || item.dataset.status === status;
        item.style.display = show ? '' : 'none';
    });
}

function searchMessages() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.fm-conv-item').forEach(item => {
        const searchText = item.dataset.search || '';
        item.style.display = searchText.includes(query) ? '' : 'none';
    });
}

function updateFileName(input, msgId) {
    const nameEl = document.getElementById('fileName-' + msgId);
    if (input.files[0]) {
        nameEl.innerHTML = '<i class="bi bi-paperclip"></i> ' + input.files[0].name;
    } else {
        nameEl.innerHTML = '';
    }
}

document.querySelectorAll('.fm-textarea').forEach(textarea => {
    textarea.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 160) + 'px';
    });
});

document.addEventListener('DOMContentLoaded', function() {
    const chatBody = document.getElementById('chatBody');
    if (chatBody) chatBody.scrollTop = chatBody.scrollHeight;

    document.querySelectorAll('.toast').forEach(toast => {
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transition = 'opacity .3s';
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    });
});
</script>
{% endblock %}
