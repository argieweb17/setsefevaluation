{# Footer partial for FES pages #}
<footer class="fes-footer">
    {% set footerQuickLinks = [
        { label: 'NORSU Logo', href: 'https://' },
    ] %}
    {% set footerUsefulLinks = [
        { label: 'Organizational Structure', href: 'https:///' }
    ] %}
    {% set footerContactLinks = [
        { label: 'Local Lines', href: 'https:///' },
        { label: 'E-mail Addresses', href: 'https:///' }
    ] %}

    <div class="fes-footer-main">
        <div class="container">
            <div class="fes-footer-grid">
                <div class="fes-footer-brand">
                    <div class="fes-footer-brand-head">
                        <img src="{{ asset('images/homeHeader/logonor.png') }}" alt="Negros Oriental State University seal" class="fes-footer-seal" loading="lazy" decoding="async">
                        <div class="fes-footer-brand-copy">
                            <h2 class="fes-footer-brand-title">NORSU</h2>
                            <p class="fes-footer-brand-tagline">Our <strong>Pride</strong>. Our <strong>Hope</strong>. Our <strong>Future</strong>.</p>
                        </div>
                    </div>
                </div>

                <div class="fes-footer-col">
                    <h3 class="fes-footer-heading">Quick Links</h3>
                    <ul class="fes-footer-links">
                        {% for item in footerQuickLinks %}
                        <li>
                            <a href="{{ item.href }}" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                <span>{{ item.label }}</span>
                            </a>
                        </li>
                        {% endfor %}
                    </ul>
                </div>

                <div class="fes-footer-col">
                    <h3 class="fes-footer-heading">Useful Links</h3>
                    <ul class="fes-footer-links">
                        {% for item in footerUsefulLinks %}
                        <li>
                            <a href="{{ item.href }}" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                <span>{{ item.label }}</span>
                            </a>
                        </li>
                        {% endfor %}
                    </ul>
                </div>

                <div class="fes-footer-col">
                    <h3 class="fes-footer-heading">Contact Us</h3>
                    <ul class="fes-footer-links">
                        {% for item in footerContactLinks %}
                        <li>
                            <a href="{{ item.href }}" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                <span>{{ item.label }}</span>
                            </a>
                        </li>
                        {% endfor %}
                    </ul>
                </div>

                <div class="fes-footer-col">
                    <h3 class="fes-footer-heading">NORSU Channels</h3>
                    <ul class="fes-footer-links fes-footer-channel-links">
                        <li>
                            <a href="https://www.facebook.com/norsupio" target="_blank" rel="noopener noreferrer" class="is-facebook">
                                <i class="bi bi-facebook" aria-hidden="true"></i>
                                <span>NORSU Public Information Office</span>
                            </a>
                        </li>
                        <li>
                            <a href="https://www.youtube.com/results?search_query=NORSU+YouTube+Channel" target="_blank" rel="noopener noreferrer" class="is-youtube">
                                <i class="bi bi-youtube" aria-hidden="true"></i>
                                <span>NORSU YouTube Channel</span>
                            </a>
                        </li>
                    </ul>

                    <div class="fes-footer-address">
                        <h4>Address</h4>
                        <p>
                            Kagawasan Avenue, Capitol Area,<br>
                            Dumaguete City, Negros Oriental,<br>
                            Philippines 6200
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="fes-footer-bottom">
        <div class="container">
            <div class="fes-footer-bottom-wrap">
                <p class="fes-footer-copyright">&copy; {{ 'now'|date('Y') }} <strong>Negros Oriental State University</strong></p>
                <div class="fes-footer-legal">
                    <a href="https:///" target="_blank" rel="noopener noreferrer">Terms and Conditions</a>
                    <span aria-hidden="true">&bull;</span>
                    <a href="https:///" target="_blank" rel="noopener noreferrer">Data Privacy Notice</a>
                </div>
            </div>
        </div>
    </div>
</footer>
