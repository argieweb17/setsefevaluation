{% extends 'base.html.twig' %}
{% set isStaffMode = staffMode|default(false) %}
{% set prefix = isStaffMode ? 'staff' : 'admin' %}
{% set printAllSetupUrl = isStaffMode
    ? app.request.basePath ~ '/reports/results/print-all/setup?faculty=' ~ faculty.id
    : path('admin_results_print_all_setup', {faculty: faculty.id}) %}

{% block title %}{{ faculty.fullName }} | Evaluations{% endblock %}

{% block stylesheets %}
<style>
/* ΓöÇΓöÇ Header ΓöÇΓöÇ */
.fe-header {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    background: #1e3a5f;
}
.fe-header-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 35%, #1e40af 60%, #059669 100%);
    opacity: 0.95;
}
.fe-header-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(59,130,246,.15) 0%, transparent 50%),
                radial-gradient(circle at 20% 80%, rgba(16,185,129,.15) 0%, transparent 50%);
}
.fe-header-inner {
    position: relative;
    z-index: 1;
    padding: 1.5rem 2rem;
}
.fe-avatar {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(255,255,255,.12);
    border: 2px solid rgba(255,255,255,.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
    overflow: hidden;
}
.fe-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.fe-name {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
}
.fe-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}
.fe-meta-tag {
    font-size: .72rem;
    color: rgba(255,255,255,.75);
    background: rgba(255,255,255,.08);
    padding: 2px 10px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
}
.fe-btn-back {
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.2);
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: .78rem;
    padding: 6px 14px;
    transition: all .2s;
}
.fe-btn-back:hover {
    background: rgba(255,255,255,.2);
    color: #fff;
}
.fe-btn-print {
    background: #fff;
    color: #1e3a5f;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: .78rem;
    padding: 6px 14px;
    transition: all .2s;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
}
.fe-btn-print:hover {
    background: #f0f4ff;
    color: #1e3a5f;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
}

/* ΓöÇΓöÇ Stats ΓöÇΓöÇ */
.fe-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: .75rem;
    margin-bottom: 1.25rem;
}
.fe-page-set .fe-stats {
    grid-template-columns: repeat(4, minmax(0, 1fr));
}
.fe-stat-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all .2s;
    box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.fe-stat-card:hover {
    border-color: #c7d2fe;
    box-shadow: 0 4px 12px rgba(0,0,0,.06);
}
.fe-stat-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
}
.stat-blue { background: #eff6ff; color: #2563eb; }
.stat-green { background: #f0fdf4; color: #16a34a; }
.stat-purple { background: #faf5ff; color: #7c3aed; }
.stat-amber { background: #fffbeb; color: #d97706; }
.fe-stat-num {
    font-size: 1.35rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.2;
}
.fe-stat-label {
    font-size: .7rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: .04em;
    font-weight: 500;
}
.fe-page-set .fe-stat-card {
    min-width: 0;
}

/* ΓöÇΓöÇ Toolbar ΓöÇΓöÇ */
.fe-toolbar{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:.75rem 1rem;margin-bottom:1rem;overflow-x:auto;}
.fe-toolbar-row{min-width:0;}
.ev-filter-group{display:inline-flex;background:#f1f5f9;border-radius:8px;padding:2px;gap:2px;}
.ev-filter-btn{border:none;background:transparent;color:#64748b;font-size:.78rem;font-weight:600;padding:5px 12px;border-radius:6px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.ev-filter-btn:hover{background:rgba(59,130,246,.08);color:#1e40af;}
.ev-filter-btn.active{background:#1a56db;color:#fff;box-shadow:0 1px 3px rgba(26,86,219,.3);}
.ev-filter-count{background:rgba(0,0,0,.08);padding:1px 6px;border-radius:10px;font-size:.7rem;margin-left:3px;}
.ev-filter-btn.active .ev-filter-count{background:rgba(255,255,255,.25);color:#fff;}
.ev-search-box{position:relative;width:280px;max-width:100%;flex:0 0 280px;margin-left:auto;}
.ev-search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.8rem;}
.ev-search-input{width:100%;padding:6px 12px 6px 32px;border:1px solid #e2e8f0;border-radius:8px;font-size:.8rem;background:#f8fafc;transition:all .2s;}
.ev-search-input:focus{outline:none;border-color:#3b82f6;background:#fff;box-shadow:0 0 0 3px rgba(59,130,246,.1);}

/* ΓöÇΓöÇ Evaluation Table ΓöÇΓöÇ */
.fe-table-wrap {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.fe-table {
    margin: 0;
    font-size: .82rem;
}
.fe-table thead th {
    background: #f8fafc;
    border-bottom: 2px solid #e5e7eb;
    font-size: .7rem;
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: .04em;
    padding: .65rem .75rem;
    white-space: nowrap;
}
.fe-table tbody td {
    padding: .7rem .75rem;
    vertical-align: middle;
    border-bottom: 1px solid #f1f5f9;
}
.fe-table tbody tr:last-child td { border-bottom: none; }
.fe-table tbody tr:hover { background: #f8fafc; }
.fe-type-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: .68rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 6px;
    letter-spacing: .03em;
}
.fe-type-set { background: #eff6ff; color: #1e40af; }
.fe-type-sef { background: #f0fdf4; color: #059669; }
.fe-info-badge {
    display: inline-flex;
    align-items: center;
    font-size: .75rem;
    color: #475569;
    background: #f1f5f9;
    padding: 3px 10px;
    border-radius: 6px;
}
.fe-rating-num {
    font-size: .95rem;
    font-weight: 800;
    color: #0f172a;
}
.fe-rating-of {
    font-size: .65rem;
    color: #94a3b8;
}
.fe-bar {
    width: 80px;
    height: 6px;
    background: #f1f5f9;
    border-radius: 3px;
    overflow: hidden;
}
.fe-bar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width .4s ease;
}
.bar-green { background: linear-gradient(90deg, #16a34a, #4ade80); }
.bar-blue { background: linear-gradient(90deg, #2563eb, #60a5fa); }
.bar-yellow { background: linear-gradient(90deg, #d97706, #fbbf24); }
.bar-red { background: linear-gradient(90deg, #dc2626, #f87171); }
.fe-perf-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: .68rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    white-space: nowrap;
}
.perf-excellent { background: #dcfce7; color: #15803d; }
.perf-verygood  { background: #dbeafe; color: #1d4ed8; }
.perf-good      { background: #ccfbf1; color: #0f766e; }
.perf-fair      { background: #fef3c7; color: #b45309; }
.perf-poor      { background: #fee2e2; color: #dc2626; }
.fe-action-btn {
    width: 30px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: .8rem;
    color: #3b82f6;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    text-decoration: none;
    transition: all .2s;
}
.fe-action-btn:hover {
    background: #dbeafe;
    color: #1d4ed8;
    border-color: #93c5fd;
    transform: translateY(-1px);
}
.fe-row.selected {
    background: #eff6ff !important;
}
.fe-row.selectable {
    cursor: pointer;
}

/* ΓöÇΓöÇ Empty ΓöÇΓöÇ */
.fe-empty {
    text-align: center;
    padding: 3rem 1rem;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.fe-empty-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: #f1f5f9;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: #94a3b8;
    margin-bottom: .75rem;
}

/* ΓöÇΓöÇ Animation ΓöÇΓöÇ */
@keyframes feSlideIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}
.fe-stat-card, .fe-empty, .fe-table-wrap {
    animation: feSlideIn .3s ease forwards;
    opacity: 0;
}
.fe-stat-card:nth-child(1) { animation-delay: .05s; }
.fe-stat-card:nth-child(2) { animation-delay: .1s; }
.fe-stat-card:nth-child(3) { animation-delay: .15s; }
.fe-stat-card:nth-child(4) { animation-delay: .2s; }
.fe-table-wrap { animation-delay: .15s; }

/* ΓöÇΓöÇ Select Mode Button ΓöÇΓöÇ */
.fe-btn-select {
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.2);
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: .78rem;
    padding: 6px 14px;
    transition: all .2s;
}
.fe-btn-select:hover {
    background: rgba(255,255,255,.2);
    color: #fff;
}
.fe-btn-select.active {
    background: #fbbf24;
    border-color: #f59e0b;
    color: #78350f;
}

/* ΓöÇΓöÇ Select All ΓöÇΓöÇ */
.fe-select-all {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: .78rem;
    font-weight: 600;
    color: #475569;
    cursor: pointer;
    user-select: none;
}
.fe-select-all .form-check-input {
    margin: 0;
    cursor: pointer;
}

/* ΓöÇΓöÇ Checkbox in Table ΓöÇΓöÇ */
.fe-th-check, .fe-td-check {
    text-align: center;
    width: 40px;
}
.fe-td-check .form-check-input,
.fe-th-check .form-check-input {
    width: 18px;
    height: 18px;
    margin: 0;
    cursor: pointer;
    border-radius: 4px;
}

/* ΓöÇΓöÇ Floating Action Bar ΓöÇΓöÇ */
.fe-action-bar {
    position: fixed;
    bottom: -80px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1050;
    transition: bottom .3s ease;
}
.fe-action-bar.show {
    bottom: 24px;
}
.fe-action-inner {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #0f172a;
    color: #fff;
    padding: 10px 20px;
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0,0,0,.25);
    white-space: nowrap;
}
.fe-action-count {
    font-size: .82rem;
    font-weight: 600;
    color: rgba(255,255,255,.8);
}
#feSelCount {
    color: #fbbf24;
    font-weight: 700;
}
.fe-action-print {
    background: #3b82f6;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: .78rem;
    padding: 6px 16px;
    text-decoration: none;
    transition: all .2s;
}
.fe-action-print:hover {
    background: #2563eb;
    color: #fff;
}
.fe-action-cancel {
    background: rgba(255,255,255,.1);
    color: rgba(255,255,255,.8);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 8px;
    font-weight: 600;
    font-size: .78rem;
    padding: 6px 14px;
    transition: all .2s;
}
.fe-action-cancel:hover {
    background: rgba(255,255,255,.2);
    color: #fff;
}

/* ΓöÇΓöÇ Responsive ΓöÇΓöÇ */
@media (max-width: 768px) {
    .fe-page-set .fe-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .fe-toolbar-row{flex-wrap:wrap;}
    .ev-search-box{width:100%;flex:1 1 100%;}
    .fe-table-wrap { overflow-x: auto; }
    .fe-action-inner { padding: 8px 14px; gap: 8px; }
}
</style>
{% endblock %}

{% block body %}
<div class="fe-page-set">

{# ΓöÇΓöÇ Header Section ΓöÇΓöÇ #}
<div class="fe-header">
    <div class="fe-header-bg"></div>
    <div class="fe-header-inner">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="fe-avatar">
                    {% if faculty.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ faculty.profilePicture) }}" alt="Profile" class="fe-avatar-img">
                    {% else %}
                        {{ faculty.firstName|first|upper }}{{ faculty.lastName|first|upper }}
                    {% endif %}
                </div>
                <div>
                    <h4 class="fe-name">{{ faculty.fullName }}</h4>
                    <div class="fe-meta">
                        {% if faculty.department %}
                        <span class="fe-meta-tag"><i class="bi bi-building"></i> {{ faculty.department.departmentName }}</span>
                        {% endif %}
                        {% if faculty.employmentStatus %}
                        <span class="fe-meta-tag"><i class="bi bi-briefcase"></i> {{ faculty.employmentStatus }}</span>
                        {% endif %}
                        {% if faculty.campus %}
                        <span class="fe-meta-tag"><i class="bi bi-geo-alt"></i> {{ faculty.campus }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path(prefix ~ '_results') }}" class="btn btn-sm fe-btn-back">
                    <i class="bi bi-arrow-left me-1"></i>Back to Results
                </a>
                {% if evaluations|length > 0 %}
                <a href="{{ printAllSetupUrl }}" target="_blank" class="btn btn-sm fe-btn-print">
                    <i class="bi bi-printer me-1"></i>Print All
                </a>
                {% if not staffMode %}
                <button type="button" id="feToggleSelect" class="btn btn-sm fe-btn-select">
                    <i class="bi bi-check2-square me-1"></i>Choose the subject to print
                </button>
                {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# ΓöÇΓöÇ Stats Row ΓöÇΓöÇ #}
{% if evaluations|length > 0 %}
<div class="fe-stats">
    <div class="fe-stat-card">
        <div class="fe-stat-icon stat-blue"><i class="bi bi-clipboard-data"></i></div>
        <div>
            <div class="fe-stat-num">{{ evaluations|length }}</div>
            <div class="fe-stat-label">Evaluations</div>
        </div>
    </div>
    <div class="fe-stat-card">
        <div class="fe-stat-icon stat-green"><i class="bi bi-graph-up"></i></div>
        <div>
            <div class="fe-stat-num">{{ overallAvg|number_format(2) }}</div>
            <div class="fe-stat-label">Overall Average</div>
        </div>
    </div>
    <div class="fe-stat-card">
        <div class="fe-stat-icon stat-purple"><i class="bi bi-people"></i></div>
        <div>
            <div class="fe-stat-num">{{ totalEvaluators }}</div>
            <div class="fe-stat-label">Total Evaluators</div>
        </div>
    </div>
    <div class="fe-stat-card">
        <div class="fe-stat-icon stat-amber"><i class="bi bi-trophy"></i></div>
        <div>
            {% set overallLevel = overallAvg >= 4.5 ? 'Always manifested' : (overallAvg >= 3.5 ? 'Often manifested' : (overallAvg >= 2.5 ? 'Sometimes manifested' : (overallAvg >= 1.5 ? 'Seldom manifested' : 'Never manifested'))) %}
            <div class="fe-stat-num" style="font-size:1rem;">{{ overallLevel }}</div>
            <div class="fe-stat-label">Performance</div>
        </div>
    </div>
</div>
{% endif %}

{# ΓöÇΓöÇ Filter Toolbar ΓöÇΓöÇ #}
<div class="fe-toolbar">
    <div class="d-flex align-items-center flex-nowrap gap-2 w-100 fe-toolbar-row {% if staffMode %}justify-content-end{% endif %}">
        {% if not staffMode %}
        <div class="ev-filter-group" id="feTypeFilter">
            <button class="ev-filter-btn active" data-type="all" onclick="feFilterType('all', this)">All <span class="ev-filter-count">{{ evaluations|length }}</span></button>
            <button class="ev-filter-btn" data-type="SET" onclick="feFilterType('SET', this)">SET <span class="ev-filter-count">{{ evaluations|filter(e => e.evaluation.evaluationType == 'SET')|length }}</span></button>
            <button class="ev-filter-btn" data-type="SEF" onclick="feFilterType('SEF', this)">SEF <span class="ev-filter-count">{{ evaluations|filter(e => e.evaluation.evaluationType == 'SEF' or e.evaluation.evaluationType == 'SUPERIOR')|length }}</span></button>
        </div>
        {% endif %}
        <label class="fe-select-all" id="feSelectAllWrap" style="display:none;">
            <input type="checkbox" id="feSelectAll" class="form-check-input">
            <span>Select All</span>
        </label>
        <div class="ev-search-box">
            <i class="bi bi-search ev-search-icon"></i>
            <input type="text" class="ev-search-input" id="feSearchInput" placeholder="Search..." oninput="feApplyFilters()">
        </div>
    </div>
</div>

{# ΓöÇΓöÇ Evaluation Table ΓöÇΓöÇ #}
{% if evaluations|length > 0 %}
<div class="fe-table-wrap">
    <table class="table table-hover align-middle mb-0 fe-table">
        <thead>
            <tr>
                <th style="width:50px">Type</th>
                <th>Period</th>
                <th>Subject</th>
                <th>Section</th>
                <th>Schedule</th>
                <th class="text-center">Rating</th>
                <th class="text-center" style="width:100px">Progress</th>
                <th class="text-center">Evaluators</th>
                <th class="text-center">Performance</th>
                <th class="text-center" style="width:80px">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for item in evaluations %}
            {% set ev = item.evaluation %}
            {% set pct = (item.average / 5 * 100)|round(0) %}
            {% if not item.subjectDetails or item.subjectDetails|length == 0 %}
            <tr class="fe-row" data-eval-id="{{ ev.id }}" data-type="{{ ev.evaluationType }}" data-search="{{ ev.evaluationType }} {{ ev.semester ?? '' }} {{ ev.schoolYear ?? '' }} {{ ev.subject ?? '' }} {{ ev.section ?? '' }}">
                <td class="fe-td-check" style="display:none;"><input type="checkbox" class="form-check-input fe-check" value="{{ ev.id }}"></td>
                <td><span class="fe-type-badge {{ ev.evaluationType == 'SET' ? 'fe-type-set' : 'fe-type-sef' }}">{{ ev.evaluationType == 'SUPERIOR' ? 'SEF' : ev.evaluationType }}</span></td>
                <td>
                    <div class="fw-semibold" style="font-size:.85rem;">{{ ev.semester ?? '' }} {{ ev.schoolYear ?? '' }}</div>
                </td>
                <td>
                    {% if ev.subject %}<span class="fe-info-badge"><i class="bi bi-book me-1"></i>{{ ev.subject }}</span>{% else %}ΓÇö{% endif %}
                </td>
                <td>
                    {% if ev.section %}<span class="fe-info-badge"><i class="bi bi-people me-1"></i>{{ ev.section }}</span>{% else %}ΓÇö{% endif %}
                </td>
                <td></td>
                <td class="text-center">
                    <span class="fe-rating-num">{{ item.average|number_format(2) }}</span>
                    <span class="fe-rating-of">/ 5</span>
                </td>
                <td class="text-center">
                    <div class="fe-bar mx-auto">
                        <div class="fe-bar-fill {% if item.average >= 4.5 %}bar-green{% elseif item.average >= 3.5 %}bar-blue{% elseif item.average >= 2.5 %}bar-yellow{% else %}bar-red{% endif %}" style="width:{{ pct }}%"></div>
                    </div>
                </td>
                <td class="text-center"><span class="fw-semibold">{{ item.evaluators }}</span></td>
                <td class="text-center">
                    {% if item.level == 'Always manifested' %}
                        <span class="fe-perf-badge perf-excellent"><i class="bi bi-star-fill"></i> {{ item.level }}</span>
                    {% elseif item.level == 'Often manifested' %}
                        <span class="fe-perf-badge perf-verygood"><i class="bi bi-hand-thumbs-up-fill"></i> {{ item.level }}</span>
                    {% elseif item.level == 'Sometimes manifested' %}
                        <span class="fe-perf-badge perf-good"><i class="bi bi-check-circle-fill"></i> {{ item.level }}</span>
                    {% elseif item.level == 'Seldom manifested' %}
                        <span class="fe-perf-badge perf-fair"><i class="bi bi-exclamation-circle-fill"></i> {{ item.level }}</span>
                    {% else %}
                        <span class="fe-perf-badge perf-poor"><i class="bi bi-x-circle-fill"></i> {{ item.level }}</span>
                    {% endif %}
                </td>
                <td class="text-center">
                    <div class="d-flex justify-content-center gap-1">
                        <a href="{{ path(prefix ~ '_results_print_setup', {faculty: faculty.id, evaluation: ev.id}) }}" target="_blank" class="fe-action-btn" title="Print Results"><i class="bi bi-printer"></i></a>
                    </div>
                </td>
            </tr>
            {% endif %}
            {% if item.subjectDetails %}
                {% for subj in item.subjectDetails %}
                <tr class="subject-details-row fe-row" data-eval-id="{{ ev.id }}" data-type="{{ ev.evaluationType }}" data-search="{{ ev.evaluationType }} {{ ev.semester ?? '' }} {{ ev.schoolYear ?? '' }} {{ subj.subjectCode ?? '' }} {{ subj.subjectName ?? '' }} {{ subj.section ?? '' }} {{ subj.schedule ?? '' }}">
                    <td class="fe-td-check" style="display:none;"><input type="checkbox" class="form-check-input fe-check" value="{{ ev.id }}"></td>
                    <td><span class="fe-type-badge {{ ev.evaluationType == 'SET' ? 'fe-type-set' : 'fe-type-sef' }}">{{ ev.evaluationType == 'SUPERIOR' ? 'SEF' : ev.evaluationType }}</span></td>
                    <td>
                        <div class="fw-semibold" style="font-size:.85rem;">{{ ev.semester ?? '' }} {{ ev.schoolYear ?? '' }}</div>
                    </td>
                    <td>
                        <span><strong>{{ subj.subjectCode }}</strong></span>
                    </td>
                    <td>
                        <span>{{ subj.section ?: '—' }}</span>
                    </td>
                    <td>{{ subj.schedule ?: '—' }}</td>
                    <td class="text-center">
                        <span class="fe-rating-num">{{ subj.average|number_format(2) }}</span>
                        <span class="fe-rating-of">/ 5</span>
                    </td>
                    <td class="text-center">
                        {% set pct_subj = (subj.average / 5 * 100)|round(0) %}
                        <div class="fe-bar mx-auto">
                            <div class="fe-bar-fill {% if subj.average >= 4.5 %}bar-green{% elseif subj.average >= 3.5 %}bar-blue{% elseif subj.average >= 2.5 %}bar-yellow{% else %}bar-red{% endif %}" style="width:{{ pct_subj }}%"></div>
                        </div>
                    </td>
                    <td class="text-center"><span class="fw-semibold">{{ subj.evaluators }}</span></td>
                    <td class="text-center">
                        {% if subj.average >= 4.5 %}
                            <span class="fe-perf-badge perf-excellent"><i class="bi bi-star-fill"></i> Always manifested</span>
                        {% elseif subj.average >= 3.5 %}
                            <span class="fe-perf-badge perf-verygood"><i class="bi bi-hand-thumbs-up-fill"></i> Often manifested</span>
                        {% elseif subj.average >= 2.5 %}
                            <span class="fe-perf-badge perf-good"><i class="bi bi-check-circle-fill"></i> Sometimes manifested</span>
                        {% else %}
                            <span class="fe-perf-badge perf-fair"><i class="bi bi-exclamation-circle-fill"></i> Seldom manifested</span>
                        {% endif %}
                    </td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-1">
                            <a href="{{ path(prefix ~ '_results_print_setup', {faculty: faculty.id, evaluation: ev.id, subject: subj.subjectId, section: subj.section}) }}" target="_blank" class="fe-action-btn" title="Print Results"><i class="bi bi-printer"></i></a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            {% endif %}
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<div class="fe-empty">
    <div class="fe-empty-icon"><i class="bi bi-clipboard-x"></i></div>
    <h6 class="fw-bold text-dark mb-1">No Evaluations Found</h6>
    <p class="text-muted small mb-0">This faculty has not been evaluated in any period yet.</p>
</div>
{% endif %}

{# ΓöÇΓöÇ Floating Action Bar ΓöÇΓöÇ #}
<div class="fe-action-bar" id="feActionBar">
    <div class="fe-action-inner">
        <span class="fe-action-count"><span id="feSelCount">0</span> evaluation(s) selected</span>
        <a href="#" id="fePrintSelected" target="_blank" class="btn btn-sm fe-action-print">
            <i class="bi bi-printer me-1"></i>Print Selected
        </a>
        <button type="button" id="feCancelSelect" class="btn btn-sm fe-action-cancel">
            <i class="bi bi-x-lg me-1"></i>Cancel
        </button>
    </div>
</div>




<script>
/* ΓöÇΓöÇ Type Filter & Search ΓöÇΓöÇ */
var feCurrentType = 'all';

function feFilterType(type, btn) {
    feCurrentType = type;
    document.querySelectorAll('#feTypeFilter .ev-filter-btn').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');
    feApplyFilters();
}

function feApplyFilters() {
    var q = document.getElementById('feSearchInput').value.toLowerCase().trim();
    document.querySelectorAll('.fe-row').forEach(function(row) {
        var rowType = row.dataset.type;
        var tMatch = feCurrentType === 'all' || (feCurrentType === 'SEF' ? (rowType === 'SEF' || rowType === 'SUPERIOR') : rowType === feCurrentType);
        var qMatch = !q || row.dataset.search.toLowerCase().indexOf(q) !== -1;
        row.style.display = (tMatch && qMatch) ? '' : 'none';
    });
}

document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('feToggleSelect');
    const selectAllWrap = document.getElementById('feSelectAllWrap');
    const selectAllCb = document.getElementById('feSelectAll');
    const actionBar = document.getElementById('feActionBar');
    const selCountEl = document.getElementById('feSelCount');
    const printSelBtn = document.getElementById('fePrintSelected');
    const cancelBtn = document.getElementById('feCancelSelect');
    const rows = document.querySelectorAll('.fe-row');
    const checks = document.querySelectorAll('.fe-check');
    const thChecks = document.querySelectorAll('.fe-th-check');
    const tdChecks = document.querySelectorAll('.fe-td-check');
    const facultyId = {{ faculty.id }};
    const basePrintUrl = '{{ printAllSetupUrl|e('js') }}';
    let selectMode = false;

    if (!toggleBtn) return;

    function enterSelectMode() {
        selectMode = true;
        toggleBtn.classList.add('active');
        toggleBtn.innerHTML = '<i class="bi bi-x-lg me-1"></i>Cancel Selection';
        selectAllWrap.style.display = 'flex';
        thChecks.forEach(th => th.style.display = 'table-cell');
        tdChecks.forEach(td => td.style.display = 'table-cell');
        rows.forEach(r => r.classList.add('selectable'));
        updateCount();
    }

    function exitSelectMode() {
        selectMode = false;
        toggleBtn.classList.remove('active');
        toggleBtn.innerHTML = '<i class="bi bi-check2-square me-1"></i>Choose the subject to print';
        selectAllWrap.style.display = 'none';
        thChecks.forEach(th => th.style.display = 'none');
        tdChecks.forEach(td => td.style.display = 'none');
        rows.forEach(r => { r.classList.remove('selectable', 'selected'); });
        checks.forEach(cb => cb.checked = false);
        selectAllCb.checked = false;
        actionBar.classList.remove('show');
    }

    function updateCount() {
        const selected = document.querySelectorAll('.fe-check:checked');
        const count = selected.length;
        selCountEl.textContent = count;

        if (count > 0) {
            actionBar.classList.add('show');
            const ids = Array.from(selected).map(cb => cb.value);
            const params = new URLSearchParams();
            ids.forEach(id => params.append('evals[]', id));
            const separator = basePrintUrl.includes('?') ? '&' : '?';
            printSelBtn.href = basePrintUrl + separator + params.toString();
        } else {
            actionBar.classList.remove('show');
        }

        selectAllCb.checked = checks.length > 0 && count === checks.length;
        selectAllCb.indeterminate = count > 0 && count < checks.length;

        rows.forEach(row => {
            const cb = row.querySelector('.fe-check');
            if (cb && cb.checked) {
                row.classList.add('selected');
            } else {
                row.classList.remove('selected');
            }
        });
    }

    toggleBtn.addEventListener('click', function() {
        selectMode ? exitSelectMode() : enterSelectMode();
    });

    cancelBtn.addEventListener('click', exitSelectMode);

    selectAllCb.addEventListener('change', function() {
        checks.forEach(cb => cb.checked = selectAllCb.checked);
        updateCount();
    });

    checks.forEach(cb => {
        cb.addEventListener('change', updateCount);
    });

    rows.forEach(row => {
        row.addEventListener('click', function(e) {
            if (!selectMode) return;
            if (e.target.closest('a, button, input')) return;
            const cb = row.querySelector('.fe-check');
            if (cb) {
                cb.checked = !cb.checked;
                updateCount();
            }
        });
    });
});
</script>

</div>

{% endblock %}
