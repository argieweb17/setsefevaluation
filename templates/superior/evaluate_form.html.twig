{% extends 'base.html.twig' %}

{% block title %}Evaluate {{ evaluatee.fullName }} | Superior Evaluation{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.sup-evidence-list {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: .42rem;
    width: 100%;
}
.sup-evidence-item {
    display: grid;
    grid-template-columns: 16px 1fr;
    column-gap: .55rem;
    align-items: start;
    width: 100%;
}
.sup-evidence-check {
    width: 16px;
    height: 16px;
    margin: .12rem 0 0;
    cursor: pointer;
    accent-color: #1e40af;
    pointer-events: auto !important;
}
.sup-evidence-text {
    margin: 0;
    font-size: .76rem;
    line-height: 1.35;
    color: #334155;
    cursor: pointer;
    white-space: normal;
    word-break: break-word;
}
.sup-privacy-card { border: 1px solid #dbe3ef; border-radius: 0; overflow: hidden; margin: 14px 18px; }
.sup-privacy-head { background: linear-gradient(135deg,#1e3a8a,#2563eb); color: #fff; padding: 12px 16px; }
.sup-privacy-body { background: #fff; color: #1f2937; padding: 16px; font-size: .9rem; line-height: 1.65; }
.sup-privacy-choice { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; }
.sup-instruction-bar {
    background: #fffbeb;
    border-bottom: 1px solid #fde68a;
    padding: 14px 24px;
}
.sup-instruction-title {
    font-size: .82rem;
    font-weight: 700;
    color: #78350f;
    margin-bottom: .55rem;
}
.sup-instruction-scale {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: .45rem 1rem;
}
.sup-instruction-item {
    display: flex;
    align-items: flex-start;
    gap: .4rem;
    font-size: .8rem;
    line-height: 1.45;
    color: #92400e;
}
.sup-instruction-score {
    min-width: 1rem;
    font-weight: 700;
    color: #b45309;
}
@media (max-width: 768px) {
    .sup-instruction-bar {
        padding: 12px 16px;
    }

    .sup-instruction-scale {
        grid-template-columns: 1fr;
        gap: .3rem;
    }

    .sup-instruction-item {
        font-size: .76rem;
    }
}
</style>
{% endblock %}

{% block body %}
{% set backRouteName = backRouteName|default('superior_evaluate_index') %}
{% set backRouteParams = backRouteParams|default({}) %}
{% set backLinkLabel = backLinkLabel|default('Back to Evaluations') %}
{% set backButtonLabel = backButtonLabel|default('Back to Personnel List') %}
{% set showPrivacyDisclaimerFirst = not (readOnly|default(false)) and not privacyConsentCaptured|default(false) %}
<div class="mb-3">
    <a href="{{ path(backRouteName, backRouteParams) }}" class="text-decoration-none small">
        <i  class="bi bi-arrow-left me-1"></i>{{ backLinkLabel }}
    </a>
</div>

{% set isReadOnly = readOnly|default(false) %}
{% if error is defined and error %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}
{% if isReadOnly %}
<div class="alert alert-success border-0 shadow-sm mb-3" style="background:#ecfdf3;color:#14532d;">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <span><i  class="bi bi-check-circle-fill me-2"></i>This evaluation has been submitted and is now in view-only mode.</span>
        {% if submittedAt is defined and submittedAt %}
            <small class="fw-semibold">Submitted: {{ submittedAt|date('M d, Y h:i A') }}</small>
        {% endif %}
    </div>
</div>
{% else %}
<form method="post" id="evalForm">
{% endif %}
<div class="eval-form-paper">
    <div style="text-align:center;padding:14px 24px 12px;background:#f8fafc;">
        <span style="display:inline-block;background:linear-gradient(135deg,#fef3c7,#fde68a);color:#92400e;border-radius:0;padding:6px 20px;font-size:.85rem;font-weight:600;">
            Superior Evaluation of {{ evaluateeRoleLabel }}
        </span>
    </div>

    {% if isReadOnly or showPrivacyDisclaimerFirst %}
    <div class="sup-privacy-card">
        <div class="sup-privacy-head">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-shield-lock-fill"></i>
                <div>
                    <div class="fw-bold">Data Privacy Disclaimer</div>
                    <small class="opacity-75">Please read before proceeding</small>
                </div>
            </div>
        </div>
        <div class="sup-privacy-body">
            <div>{{ privacyDisclaimerHtml|default('')|raw }}</div>
            {% if showPrivacyDisclaimerFirst %}
            <hr class="my-3">
            <div class="mb-2 fw-semibold">Do you agree to the Data Privacy Disclaimer? <span class="text-danger">*</span></div>
            <div class="sup-privacy-choice">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="radio" name="privacy_consent" id="supPrivacyAgree" value="agree" {{ formValues.privacy_consent|default('') == 'agree' ? 'checked' : '' }}>
                    <label class="form-check-label" for="supPrivacyAgree">Agree</label>
                </div>
                <div class="form-check mb-0">
                    <input class="form-check-input" type="radio" name="privacy_consent" id="supPrivacyDisagree" value="disagree" {{ formValues.privacy_consent|default('') == 'disagree' ? 'checked' : '' }}>
                    <label class="form-check-label" for="supPrivacyDisagree">Disagree</label>
                </div>
            </div>
            <div class="d-flex flex-wrap gap-2 align-items-center mt-4">
                <button type="submit" name="_action" value="privacy_gate" class="btn btn-norsu">
                    <i class="bi bi-arrow-right-circle me-1"></i>Continue
                </button>
                <a href="{{ path('superior_evaluate_index') }}" class="btn btn-light">Cancel</a>
            </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if not showPrivacyDisclaimerFirst %}
    {# Evaluatee Info #}
    <div style="padding:12px 24px;background:#fefce8;border-bottom:1px solid #e5e7eb;">
        <div class="row">
            <div class="col-md-4">
                <small class="text-muted fw-semibold">Evaluatee</small><br>
                <span class="fw-bold">{{ evaluatee.fullName }}</span>
            </div>
            <div class="col-md-4">
                <small class="text-muted fw-semibold">Position</small><br>
                <span>{{ evaluateeRoleLabel }}</span>
            </div>
            <div class="col-md-4">
                <small class="text-muted fw-semibold">Department</small><br>
                <span>{{ evaluatee.department ? evaluatee.department.departmentName : '—' }}</span>
            </div>
        </div>
    </div>

    {# Evaluatee Subjects #}
    <div style="padding:12px 24px;background:#fff;border-bottom:1px solid #e2e8f0;">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <small class="text-muted fw-semibold">Faculty Subjects</small>
            <small class="text-muted">{{ evaluateeSubjects|length }} subject{{ evaluateeSubjects|length != 1 ? 's' : '' }}</small>
        </div>
        {% if evaluateeSubjects|length > 0 %}
            <div class="table-responsive">
                <table class="table table-sm mb-0" style="font-size:.74rem;">
                    <thead class="table-light">
                        <tr>
                            <th>Code</th>
                            <th>Subject</th>
                            <th>Semester</th>
                            <th>Section</th>
                            <th>Schedule</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for s in evaluateeSubjects %}
                        <tr>
                            <td class="fw-semibold">{{ s.code }}</td>
                            <td>{{ s.name }}</td>
                            <td>{{ s.semester ?: '—' }}</td>
                            <td>{{ s.section ?: '—' }}</td>
                            <td>{{ s.schedule ?: '—' }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-muted" style="font-size:.74rem;">No loaded subjects found for this faculty.</div>
        {% endif %}
    </div>

    <div class="sup-instruction-bar">
        <div class="sup-instruction-title">Instructions: Rate each item using the scale below.</div>
        <div class="sup-instruction-scale">
            <div class="sup-instruction-item"><span class="sup-instruction-score">5</span><span>Always manifested</span></div>
            <div class="sup-instruction-item"><span class="sup-instruction-score">4</span><span>Often manifested</span></div>
            <div class="sup-instruction-item"><span class="sup-instruction-score">3</span><span>Sometimes manifested</span></div>
            <div class="sup-instruction-item"><span class="sup-instruction-score">2</span><span>Seldom manifested</span></div>
            <div class="sup-instruction-item"><span class="sup-instruction-score">1</span><span>Never/Rarely manifested</span></div>
        </div>
    </div>

    {% set counter = 1 %}

    {% for category, questions in groupedQuestions %}
    <div class="eval-form-section">
        <div class="eval-form-category">
            <span class="eval-form-category-label">{{ category }}</span>
        </div>
        <table class="eval-form-table">
            <thead>
                <tr>
                    <th class="eval-form-num"></th>
                    <th class="eval-form-question">Question</th>
                    <th class="eval-form-evidence">Means of Verification</th>
                    <th class="eval-form-rating">1<br><small>Never/Rarely manifested</small></th>
                    <th class="eval-form-rating">2<br><small>Seldom manifested</small></th>
                    <th class="eval-form-rating">3<br><small>Sometimes manifested</small></th>
                    <th class="eval-form-rating">4<br><small>Often manifested</small></th>
                    <th class="eval-form-rating">5<br><small>Always manifested</small></th>
                </tr>
            </thead>
            <tbody>
                {% for q in questions %}
                {% set draftRating = draftMap[q.id] is defined ? draftMap[q.id].rating : 0 %}
                <tr>
                    <td class="eval-form-num">{{ counter }}.</td>
                    <td class="eval-form-question">
                        {{ q.questionText }}
                        {% if q.isRequired %}<span class="text-danger">*</span>{% endif %}
                    </td>
                    <td class="eval-form-evidence">
                        {% set evidenceItems = q.evidenceItems ?? [] %}
                        {% set selectedVerificationItems = draftMap[q.id] is defined and draftMap[q.id].verification is defined ? draftMap[q.id].verification : [] %}
                        {% if evidenceItems|length > 0 %}
                        <div class="sup-evidence-list" role="group" aria-label="Means of verification">
                            {% for evidence in evidenceItems %}
                            {% set evidenceInputId = 'sup-evidence-' ~ q.id ~ '-' ~ loop.index %}
                            <div class="sup-evidence-item">
                                <input id="{{ evidenceInputId }}" class="sup-evidence-check" type="checkbox" name="verification[{{ q.id }}][]" value="{{ evidence }}" {{ evidence in selectedVerificationItems ? 'checked' }} {{ isReadOnly ? 'disabled' }}>
                                <label for="{{ evidenceInputId }}" class="sup-evidence-text">{{ evidence }}</label>
                            </div>
                            {% endfor %}
                        </div>
                        {% else %}
                        <span class="eval-evidence-empty">No checklist items</span>
                        {% endif %}
                    </td>
                    {% for r in 1..5 %}
                    <td class="eval-form-rating">
                        <label class="eval-radio-label">
                            <input type="radio" name="ratings[{{ q.id }}]" value="{{ r }}"
                                   {{ draftRating == r ? 'checked' }}
                                   {{ (not isReadOnly and q.isRequired) ? 'required' }}
                                   {{ isReadOnly ? 'disabled' }}>
                            <span class="eval-radio-circle {{ draftRating == r ? 'selected' }}"></span>
                        </label>
                    </td>
                    {% endfor %}
                </tr>
                {% set counter = counter + 1 %}
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endfor %}

    {# Comment #}
    <div class="eval-form-section">
        <div class="eval-form-category">
            <span class="eval-form-category-label">Feedback/Comments <span class="text-danger">*</span></span>
        </div>
        <div class="p-3">
            <textarea name="comments[0]" class="form-control eval-form-textarea" rows="3" {{ not isReadOnly ? 'required' }} {{ isReadOnly ? 'readonly' }}
                      placeholder="Share any additional feedback for this {{ evaluateeRoleLabel }}...">{{ generalComment|default('') }}</textarea>
        </div>
    </div>
    {% endif %}
</div>

{# Buttons outside paper #}
{% if isReadOnly or not showPrivacyDisclaimerFirst %}
<div class="eval-form-actions-bar">
    {% if isReadOnly %}
    <a href="{{ path(backRouteName, backRouteParams) }}" class="btn btn-norsu">
        <i  class="bi bi-arrow-left me-1"></i>{{ backButtonLabel }}
    </a>
    {% else %}
    <button type="submit" name="_action" value="submit" class="btn btn-norsu"
            onclick="return confirm('Once submitted, you cannot edit this evaluation. Continue?')">
        <i  class="bi bi-send me-1"></i>Submit Evaluation
    </button>
    <button type="submit" name="_action" value="save_draft" class="btn btn-outline-secondary">
        <i  class="bi bi-save me-1"></i>Save as Draft
    </button>
    <a href="{{ path('superior_evaluate_index') }}" class="btn btn-light">Cancel</a>
    {% endif %}
</div>
{% endif %}
{% if not isReadOnly %}
</form>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
    function initSuperiorPrivacyGate() {
        var form = document.getElementById('evalForm');
        if (!form || form.dataset.superiorPrivacyGateBound === '1') {
            return;
        }

        form.dataset.superiorPrivacyGateBound = '1';

        var privacyAgree = document.getElementById('supPrivacyAgree');
        var privacyDisagree = document.getElementById('supPrivacyDisagree');
        var privacyGateButton = form.querySelector('button[name="_action"][value="privacy_gate"]');
        if (!privacyGateButton) {
            return;
        }

        var submitPrivacyGate = function () {
            if (typeof form.requestSubmit === 'function') {
                form.requestSubmit(privacyGateButton);
                return;
            }

            privacyGateButton.click();
        };

        [privacyAgree, privacyDisagree].forEach(function (input) {
            if (!input) {
                return;
            }

            input.addEventListener('change', function () {
                if (input.checked) {
                    submitPrivacyGate();
                }
            });
        });

        form.addEventListener('submit', function (event) {
            var action = (event.submitter && event.submitter.value) ? event.submitter.value : '';
            if (action !== 'privacy_gate') {
                return;
            }

            var consentSelected = form.querySelector('input[name="privacy_consent"]:checked');
            if (!consentSelected) {
                event.preventDefault();
                alert('Please select Agree or Disagree for the Data Privacy Disclaimer before continuing.');
                if (privacyAgree) {
                    privacyAgree.focus();
                }
            }
        });
    }

    document.addEventListener('DOMContentLoaded', initSuperiorPrivacyGate);
    document.addEventListener('turbo:load', initSuperiorPrivacyGate);
})();
</script>
{% endblock %}
