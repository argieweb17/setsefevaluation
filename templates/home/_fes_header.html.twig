{# Header partial for FES pages #}
<header class="fes-header">
    <div class="container">
        <a href="{{ path('app_home') }}" class="fes-logo">
            <img src="{{ asset('images/norsu1logo.png') }}" alt="NORSU Logo" class="fes-logo-img">
            <div class="fes-logo-text">
                <span class="fes-logo-title">SET - SEF Evaluation System</span>
            </div>
        </a>
        <nav class="fes-nav">
            <a href="{{ path('app_home') }}" class="fes-nav-link{{ active|default('') == 'home' ? ' active' : '' }}">Home</a>
            <a href="{{ path('app_home', {view: 'about'}) }}" class="fes-nav-link{{ active|default('') == 'about' ? ' active' : '' }}">About</a>
            <a href="{{ path('app_home', {view: 'faq'}) }}" class="fes-nav-link{{ active|default('') == 'faq' ? ' active' : '' }}">FAQ</a>
            <a href="{{ path('app_home', {view: 'contact'}) }}" class="fes-nav-link{{ active|default('') == 'contact' ? ' active' : '' }}">Contact Us</a>
            <details class="fes-account-dropdown">
                <summary class="fes-nav-btn fes-account-summary">My Account</summary>
                <div class="fes-account-menu">
                    <a href="{{ path('app_login') }}" class="fes-account-item">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Sign In</span>
                    </a>
                    <a href="{{ path('app_register') }}" class="fes-account-item">
                        <i class="bi bi-person-fill"></i>
                        <span>Register</span>
                    </a>
                </div>
            </details>
        </nav>
        <button type="button" class="fes-hamburger" id="fesHamburger" aria-label="Open navigation" aria-expanded="false">
            <i class="bi bi-list" id="fesHamburgerIcon"></i>
        </button>
    </div>
    <nav class="fes-mobile-drawer" id="fesMobileDrawer" aria-label="Mobile navigation">
        <div class="fes-mobile-drawer-inner">
            <div class="fes-mobile-drawer-links">
                <a href="{{ path('app_home') }}" class="fes-mobile-drawer-link{{ active|default('') == 'home' ? ' is-active' : '' }}">Home</a>
                <a href="{{ path('app_home', {view: 'about'}) }}" class="fes-mobile-drawer-link{{ active|default('') == 'about' ? ' is-active' : '' }}">About</a>
                <a href="{{ path('app_home', {view: 'faq'}) }}" class="fes-mobile-drawer-link{{ active|default('') == 'faq' ? ' is-active' : '' }}">FAQ</a>
                <a href="{{ path('app_home', {view: 'contact'}) }}" class="fes-mobile-drawer-link{{ active|default('') == 'contact' ? ' is-active' : '' }}">Contact Us</a>
            </div>
            <div class="fes-mobile-drawer-divider"></div>
            <div class="fes-mobile-drawer-cta">
                <a href="{{ path('app_login') }}" class="fes-mobile-cta-btn is-primary">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </a>
                <a href="{{ path('app_register') }}" class="fes-mobile-cta-btn is-secondary">
                    <i class="bi bi-person-fill"></i> Register
                </a>
            </div>
        </div>
    </nav>
    <script>
    (function() {
        var btn = document.getElementById('fesHamburger');
        var drawer = document.getElementById('fesMobileDrawer');
        var icon = document.getElementById('fesHamburgerIcon');
        if (!btn || !drawer) return;
        function closeDrawer() {
            drawer.classList.remove('is-open');
            btn.setAttribute('aria-expanded', 'false');
            if (icon) icon.className = 'bi bi-list';
        }
        btn.addEventListener('click', function() {
            var isOpen = drawer.classList.toggle('is-open');
            btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            if (icon) icon.className = isOpen ? 'bi bi-x-lg' : 'bi bi-list';
        });
        document.addEventListener('click', function(e) {
            if (!drawer.contains(e.target) && !btn.contains(e.target)) closeDrawer();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeDrawer();
        });
    })();
    </script>
</header>
