{% extends 'base.html.twig' %}
{% set prefix = staffMode|default(false) ? 'staff' : 'admin' %}

{% block title %}Curriculum Management | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* Header Card (system blue-green gradient) */
.cm-header{border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);box-shadow:0 4px 24px rgba(26,86,219,.15);margin-bottom:16px;}
.cm-header-inner{padding:22px 26px 18px;}
.cm-header-icon{width:auto;height:auto;border-radius:0;background:transparent;backdrop-filter:none;display:inline-flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;flex-shrink:0;}
.cm-meta-pill{display:inline-flex;align-items:center;background:transparent;color:rgba(255,255,255,.85);padding:0;border-radius:0;font-weight:500;backdrop-filter:none;}
.cm-stats-row{display:flex;gap:0;margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,255,255,.12);}
.cm-stat{flex:1;text-align:center;}
.cm-stat-val{display:block;font-size:1.15rem;font-weight:700;color:#fff;line-height:1.2;}
.cm-stat-lbl{display:block;font-size:.62rem;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.8px;margin-top:2px;}
.cm-stat-divider{width:1px;background:rgba(255,255,255,.12);margin:0 4px;}

/* Toolbar */
.cm-toolbar{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;background:#fff;border:1px solid #e8ecf1;border-radius:12px;padding:10px 14px;box-shadow:0 1px 3px rgba(0,0,0,.04);margin-bottom:16px;}
.cm-toolbar-btn{font-size:.78rem;font-weight:600;}

/* Modal Header */
.cm-modal-header{display:flex;align-items:center;justify-content:space-between;padding:18px 24px;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);}
.cm-modal-icon{width:42px;height:42px;border-radius:12px;background:rgba(255,255,255,.12);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:#fff;flex-shrink:0;}

/* College & Department Table */
.cm-cd-toolbar{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin:1rem 0 .75rem;}
.cm-cd-toolbar-left{display:flex;flex-direction:column;gap:2px;}
.cm-cd-toolbar-right{display:flex;align-items:center;gap:8px;}
.cm-cd-search-box{position:relative;min-width:260px;}
.cm-cd-search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.8rem;}
.cm-cd-search-input{width:100%;padding:7px 12px 7px 32px;border:1px solid #e2e8f0;border-radius:8px;font-size:.8rem;background:#f8fafc;transition:all .2s;}
.cm-cd-search-input:focus{outline:none;border-color:#3b82f6;background:#fff;box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.cm-cd-table-wrap{background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04);}
.cm-cd-table{width:100%;border-collapse:collapse;font-size:.82rem;}
.cm-cd-th{padding:10px 14px;background:#f8fafc;color:#64748b;font-weight:700;font-size:.72rem;text-transform:uppercase;letter-spacing:.5px;border-bottom:2px solid #e2e8f0;white-space:nowrap;user-select:none;}
.cm-cd-td{padding:12px 14px;border-bottom:1px solid #f1f5f9;vertical-align:middle;}
.cm-cd-college-row{background:linear-gradient(135deg,#f8fafc,#f0f4ff);cursor:pointer;transition:background .15s;border-bottom:1px solid #e2e8f0;}
.cm-cd-college-row:hover{background:linear-gradient(135deg,#eef2ff,#e0e7ff);}
.cm-cd-toggle-icon{font-size:.75rem;color:#64748b;transition:transform .2s;}
.cm-cd-college-row.collapsed .cm-cd-toggle-icon{transform:rotate(-90deg);}
.cm-cd-dept-count{font-size:.7rem;color:#94a3b8;margin-left:8px;font-weight:500;}
.cm-cd-dept-row{transition:background .15s;}
.cm-cd-dept-row:hover{background:#f0f4ff;}
.cm-cd-dept-row.cm-cd-hidden{display:none;}
.cm-cd-college-icon{width:auto;height:auto;min-width:0;border-radius:0;background:transparent;color:#1a56db;display:inline-flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0;}
.cm-cd-dept-icon{width:auto;height:auto;min-width:0;border-radius:0;background:transparent;color:#059669;display:inline-flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0;}
.cm-cd-count-badge{display:inline-flex;align-items:center;justify-content:center;min-width:28px;padding:2px 8px;border-radius:20px;font-size:.75rem;font-weight:700;}
.cm-cd-count-primary{background:#eff6ff;color:#1a56db;}
.cm-cd-count-secondary{background:#f1f5f9;color:#475569;}
.cm-cd-action-btn{width:30px;height:30px;padding:0;display:inline-flex;align-items:center;justify-content:center;border-radius:0;border:none;font-size:.78rem;cursor:pointer;transition:all .15s;background:transparent;box-shadow:none;}
.cm-cd-action-view{background:transparent;color:#1a56db;border-color:transparent;}
.cm-cd-action-view:hover{background:transparent;color:#1e40af;}
.cm-cd-action-edit{background:transparent;color:#64748b;border-color:transparent;}
.cm-cd-action-edit:hover{background:transparent;color:#475569;}
.cm-cd-action-delete{background:transparent;color:#dc2626;border-color:transparent;}
.cm-cd-action-delete:hover{background:transparent;color:#b91c1c;}

/* Curriculum list items */
.cm-cur-icon{width:auto;height:auto;border-radius:0;display:inline-flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;color:#2563eb;background:transparent;}
.cm-status-active{display:inline-flex;align-items:center;gap:4px;font-size:.75rem;font-weight:600;color:#16a34a;background:transparent;padding:0;border-radius:0;}
.cm-curriculum-item{border-radius:10px;transition:box-shadow .2s ease;}
.cm-curriculum-item:hover{box-shadow:0 4px 16px rgba(0,0,0,.06)!important;}
.cm-action-btn{width:32px;height:32px;padding:0;display:inline-flex;align-items:center;justify-content:center;border-radius:0;font-size:.85rem;border:none!important;background:transparent!important;box-shadow:none!important;}
.cm-action-btn.btn-outline-primary{color:#2563eb!important;}
.cm-action-btn.btn-outline-secondary{color:#64748b!important;}
.cm-action-btn.btn-outline-danger{color:#ef4444!important;}
.cm-action-btn:hover{background:transparent!important;transform:translateY(-1px);}
.cm-action-btn.btn-outline-primary:hover{color:#1d4ed8!important;}
.cm-action-btn.btn-outline-secondary:hover{color:#475569!important;}
.cm-action-btn.btn-outline-danger:hover{color:#dc2626!important;}

/* Navigation Bar (Year Level Tabs) */
.cm-nav{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;background:#fff;border:1px solid #e8ecf1;border-radius:12px;padding:6px 8px;box-shadow:0 1px 3px rgba(0,0,0,.04);}
.cm-nav-tabs{display:flex;flex-wrap:wrap;gap:4px;}
.cm-tab{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border:none;background:transparent;color:#6b7280;font-size:.8rem;font-weight:600;border-radius:8px;cursor:pointer;transition:all .15s ease;}
.cm-tab:hover{background:#f3f4f6;color:#374151;}
.cm-tab.active{background:var(--norsu-blue,#1a56db);color:#fff;box-shadow:0 2px 8px rgba(26,86,219,.25);}
.cm-tab i{font-size:.9rem;}
.cm-tab-label{white-space:nowrap;}
.cm-tab-badge{display:inline-flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 5px;border-radius:9px;font-size:.65rem;font-weight:700;background:rgba(0,0,0,.06);color:#6b7280;}
.cm-tab.active .cm-tab-badge{background:rgba(255,255,255,.25);color:#fff;}

/* Search */
.cm-search-wrap{position:relative;min-width:200px;}
.cm-search-wrap>i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:.78rem;pointer-events:none;}
.cm-search{width:100%;border:1px solid #e5e7eb;border-radius:8px;padding:6px 12px 6px 30px;font-size:.8rem;outline:none;transition:border-color .15s,box-shadow .15s;}
.cm-search:focus{border-color:var(--norsu-blue,#1a56db);box-shadow:0 0 0 3px rgba(26,86,219,.08);}

/* Year Level Bar */
.cm-yl-bar{display:flex;align-items:center;padding:10px 14px;background:#f8fafc;border:1px solid #e8ecf1;border-radius:8px;}
.cm-yl-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}

/* Semester Block */
.cm-sem-block{border:1px solid #e8ecf1;border-radius:12px;overflow:hidden;background:#fff;transition:box-shadow .2s ease;}
.cm-sem-block:hover{box-shadow:0 4px 16px rgba(0,0,0,.05);}
.cm-sem-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;padding:10px 16px;background:#f8fafc;border-bottom:1px solid #e8ecf1;}
.cm-sem-indicator{width:4px;height:20px;border-radius:2px;flex-shrink:0;}
.cm-sem-table{padding:12px;max-height:520px;overflow-y:auto;}
.cm-sem-table::-webkit-scrollbar{width:5px;}
.cm-sem-table::-webkit-scrollbar-track{background:#f8fafc;border-radius:3px;}
.cm-sem-table::-webkit-scrollbar-thumb{background:#d1d5db;border-radius:3px;}
.cm-sem-table::-webkit-scrollbar-thumb:hover{background:#9ca3af;}

/* Year Level Panel transition */
.cm-yl-panel{animation:cmFadeIn .2s ease;}

/* View transitions */
.cm-view{animation:cmFadeIn .2s ease;}
.cm-header,.cm-toolbar,.cm-nav{animation:cmFadeIn .25s ease;}
@keyframes cmFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
</style>
{% endblock %}

{% block body %}
{# ═══════════════════════════════════════════════
   CURRICULA MANAGEMENT — DEPARTMENT DRILL-DOWN
   ═══════════════════════════════════════════════ #}

{# ═══════════════════════════════════════
   VIEW 1 — DEPARTMENTS OVERVIEW
   ═══════════════════════════════════════ #}
<div id="view-main">
    {# ── Professional Header Card ── #}
    <div class="cm-header">
        <div class="cm-header-inner">
            <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="cm-header-icon">
                        <i  class="bi bi-journal-text"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">Curricula Management</h4>
                        <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                            <span class="cm-meta-pill"><i  class="bi bi-layers me-1"></i>{{ curricula|length }} Curricula</span>
                            <span class="cm-meta-pill"><i  class="bi bi-building me-1"></i>{{ departments|length }} Departments</span>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-1">
                    <button type="button" class="btn btn-sm btn-light fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#addDeptModal">
                        <i  class="bi bi-plus me-1"></i>Add Department
                    </button>
                </div>
            </div>
            <div class="cm-stats-row">
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ curricula|length }}</span>
                    <span class="cm-stat-lbl">Total Curricula</span>
                </div>
                <div class="cm-stat-divider"></div>
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ curricula|length }}</span>
                    <span class="cm-stat-lbl">Active</span>
                </div>
                <div class="cm-stat-divider"></div>
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ subjects|length }}</span>
                    <span class="cm-stat-lbl">Total Subjects</span>
                </div>
                <div class="cm-stat-divider"></div>
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ departments|length }}</span>
                    <span class="cm-stat-lbl">Departments</span>
                </div>
                <div class="cm-stat-divider"></div>
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ colleges|length }}</span>
                    <span class="cm-stat-lbl">Colleges</span>
                </div>
            </div>
        </div>
    </div>

    {# ── Colleges & Departments Table ── #}
    <div class="cm-cd-toolbar">
        <div class="cm-cd-toolbar-left">
            <h5 class="fw-bold mb-0" style="font-size:1rem;">Colleges & Departments</h5>
            <span class="text-muted" style="font-size:.75rem;">Select a department to view and manage its curricula</span>
        </div>
        <div class="cm-cd-toolbar-right">
            <div class="cm-cd-search-box">
                <i  class="bi bi-search cm-cd-search-icon"></i>
                <input type="text" class="cm-cd-search-input" id="cmCdSearch" placeholder="Search colleges or departments..." oninput="filterCdTable()">
            </div>
        </div>
    </div>

    {# ── Group departments by college ── #}
    {% set collegeGroups = {} %}
    {% for dept in departments %}
        {% set cKey = dept.collegeName ? dept.collegeName : 'Unassigned' %}
        {% if cKey not in collegeGroups|keys %}
            {% set collegeGroups = collegeGroups|merge({(cKey): []}) %}
        {% endif %}
        {% set collegeGroups = collegeGroups|merge({(cKey): collegeGroups[cKey]|merge([dept])}) %}
    {% endfor %}

    <div class="cm-cd-table-wrap">
        <table class="cm-cd-table" id="cmCdTable">
            <thead>
                <tr>
                    <th class="cm-cd-th" style="width:36px;">#</th>
                    <th class="cm-cd-th" style="min-width:250px;">Department</th>
                    <th class="cm-cd-th text-center" style="width:100px;">Curricula</th>
                    <th class="cm-cd-th text-center" style="width:100px;">Subjects</th>
                    <th class="cm-cd-th text-center" style="width:130px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% set globalIdx = 0 %}
                {% for collegeName, collegeDepts in collegeGroups %}
                    {# ── College group header row ── #}
                    {% set totalCollegeCurr = 0 %}
                    {% set totalCollegeSubj = 0 %}
                    {% for dept in collegeDepts %}
                        {% for c in curricula %}
                            {% if c.department and c.department.id == dept.id %}
                                {% set totalCollegeCurr = totalCollegeCurr + 1 %}
                            {% endif %}
                        {% endfor %}
                        {% set totalCollegeSubj = totalCollegeSubj + dept.subjects|length %}
                    {% endfor %}
                    <tr class="cm-cd-college-row collapsed" data-college="{{ collegeName|lower }}" onclick="toggleCollegeDepts(this)">
                        <td class="cm-cd-td" colspan="1">
                            <i  class="bi bi-chevron-down cm-cd-toggle-icon"></i>
                        </td>
                        <td class="cm-cd-td" colspan="1">
                            <div class="d-flex align-items-center gap-2">
                                <div class="cm-cd-college-icon"><i  class="bi bi-mortarboard"></i></div>
                                <div>
                                    <span class="fw-bold" style="font-size:.85rem;">{{ collegeName }}</span>
                                    <span class="cm-cd-dept-count">{{ collegeDepts|length }} dept{{ collegeDepts|length != 1 ? 's' : '' }}</span>
                                </div>
                            </div>
                        </td>
                        <td class="cm-cd-td text-center">
                            <span class="cm-cd-count-badge cm-cd-count-primary">{{ totalCollegeCurr }}</span>
                        </td>
                        <td class="cm-cd-td text-center">
                            <span class="cm-cd-count-badge cm-cd-count-secondary">{{ totalCollegeSubj }}</span>
                        </td>
                        <td class="cm-cd-td"></td>
                    </tr>
                    {# ── Department rows inside this college ── #}
                    {% for dept in collegeDepts %}
                        {% set deptCurrCount = 0 %}
                        {% for c in curricula %}
                            {% if c.department and c.department.id == dept.id %}
                                {% set deptCurrCount = deptCurrCount + 1 %}
                            {% endif %}
                        {% endfor %}
                        {% set globalIdx = globalIdx + 1 %}
                        <tr class="cm-cd-row cm-cd-dept-row cm-cd-hidden" data-search="{{ collegeName|lower }} {{ dept.departmentName|lower }}" data-college="{{ collegeName|lower }}">
                            <td class="cm-cd-td text-muted" style="font-size:.75rem;">{{ globalIdx }}</td>
                            <td class="cm-cd-td">
                                <div class="d-flex align-items-center gap-2" style="padding-left:18px;">
                                    <div class="cm-cd-dept-icon"><i  class="bi bi-bank"></i></div>
                                    <span style="font-size:.82rem;">{{ dept.departmentName }}</span>
                                </div>
                            </td>
                            <td class="cm-cd-td text-center">
                                <span class="cm-cd-count-badge cm-cd-count-primary">{{ deptCurrCount }}</span>
                            </td>
                            <td class="cm-cd-td text-center">
                                <span class="cm-cd-count-badge cm-cd-count-secondary">{{ dept.subjects|length }}</span>
                            </td>
                            <td class="cm-cd-td text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <button type="button" class="cm-cd-action-btn cm-cd-action-view" title="View Curricula" onclick="event.stopPropagation(); showDepartment({{ dept.id }})">
                                        <i  class="bi bi-eye"></i>
                                    </button>
                                    <button type="button" class="cm-cd-action-btn cm-cd-action-edit" data-bs-toggle="modal" data-bs-target="#editDeptModal{{ dept.id }}" title="Edit" onclick="event.stopPropagation()">
                                        <i  class="bi bi-pencil"></i>
                                    </button>
                                    <form method="post" action="{{ path(prefix ~ '_department_delete', {id: dept.id}) }}" class="d-inline" onsubmit="return confirm('Delete this department?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_dept' ~ dept.id) }}">
                                        <button type="submit" class="cm-cd-action-btn cm-cd-action-delete" title="Delete" onclick="event.stopPropagation()">
                                            <i  class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <i  class="bi bi-building fs-1 d-block mb-2 opacity-25"></i>
                            No departments found. Add departments first to manage curricula.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>


{# ═══════════════════════════════════════
   VIEW 2 — DEPARTMENT DETAIL (per dept)
   ═══════════════════════════════════════ #}
{% for dept in departments %}
    {% set deptCurricula = [] %}
    {% for c in curricula %}
        {% if c.department and c.department.id == dept.id %}
            {% set deptCurricula = deptCurricula|merge([c]) %}
        {% endif %}
    {% endfor %}

<div id="view-dept-{{ dept.id }}" class="cm-view" style="display:none;">
    <div class="cm-header">
        <div class="cm-header-inner">
            <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="cm-header-icon">
                        <i  class="bi bi-bank"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">{{ dept.departmentName }}</h4>
                        <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                            {% if dept.collegeName %}<span class="cm-meta-pill"><i  class="bi bi-mortarboard me-1"></i>{{ dept.collegeName }}</span>{% endif %}
                            <span class="cm-meta-pill"><i  class="bi bi-layers me-1"></i>{{ deptCurricula|length }} Curricula</span>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-1">
                    <button class="btn btn-sm btn-light fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#addProgramModal" onclick="document.getElementById('createDept').value='{{ dept.id }}'; document.getElementById('createDeptSelect').value='{{ dept.id }}'">
                        <i  class="bi bi-plus me-1"></i>Add Curriculum
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-light" onclick="showMain()">
                        <i  class="bi bi-arrow-left me-1"></i>Back
                    </button>
                </div>
            </div>
            <div class="cm-stats-row">
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ deptCurricula|length }}</span>
                    <span class="cm-stat-lbl">Total Curricula</span>
                </div>
                <div class="cm-stat-divider"></div>
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ deptCurricula|length }}</span>
                    <span class="cm-stat-lbl">Active</span>
                </div>
                <div class="cm-stat-divider"></div>
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ dept.subjects|length }}</span>
                    <span class="cm-stat-lbl">Subjects</span>
                </div>
            </div>
        </div>
    </div>

    <div class="cm-toolbar">
        <div class="cm-search-wrap">
            <i  class="bi bi-search"></i>
            <input type="text" class="cm-search" placeholder="Search curricula..." data-dept="{{ dept.id }}" onkeyup="filterCurricula(this, {{ dept.id }})">
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm cm-toolbar-btn">
                <i  class="bi bi-send me-1"></i>Publish
            </button>
            <button class="btn btn-warning btn-sm text-white cm-toolbar-btn">
                <i  class="bi bi-download me-1"></i>Import
            </button>
            <button class="btn btn-secondary btn-sm cm-toolbar-btn" onclick="window.print()">
                <i  class="bi bi-printer me-1"></i>Print
            </button>
        </div>
    </div>

    <div id="curricula-list-{{ dept.id }}">
        {% for c in deptCurricula %}
        <div class="card border-0 shadow-sm mb-3 cm-curriculum-item" data-name="{{ c.curriculumName|lower }}">
            <div class="card-body py-3">
                <div class="d-flex align-items-center">
                    <div class="cm-cur-icon text-primary me-3">
                        <i  class="bi bi-bookmark-check"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center flex-wrap gap-2 mb-1">
                            <h6 class="fw-bold mb-0">{{ c.curriculumName }}</h6>
                            <span class="cm-status-active"><i class="bi bi-check-circle-fill"></i>Active</span>
                        </div>
                        <div class="text-muted small">
                            {% if c.curriculumYear %}Version: {{ c.curriculumYear }}{% endif %}
                            {% if c.course %} &bull; {{ c.course.courseName }}{% endif %}
                            {% if c.department %} &bull; {{ c.department.departmentName }}{% endif %}
                            &bull; {{ c.subjects|length }} subject{{ c.subjects|length != 1 ? 's' : '' }}
                        </div>
                    </div>
                    <div class="d-flex gap-1 ms-3">
                        <button type="button" class="btn btn-sm btn-outline-primary cm-action-btn" title="View Subjects" onclick="showCurriculum({{ c.id }}, {{ dept.id }})">
                            <i  class="bi bi-eye"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary cm-action-btn" title="Edit" data-bs-toggle="modal" data-bs-target="#editProgramModal{{ c.id }}">
                            <i  class="bi bi-pencil"></i>
                        </button>
                        <form method="post" action="{{ path(prefix ~ '_curriculum_delete', {id: c.id}) }}" class="d-inline" onsubmit="return confirm('Delete this curriculum?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_curriculum' ~ c.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger cm-action-btn" title="Delete">
                                <i  class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="text-center text-muted py-5">
            <i  class="bi bi-bookmark-check fs-1 d-block mb-2 opacity-25"></i>
            No curricula in this department yet. Click "Add Curriculum" to create one.
        </div>
        {% endfor %}
    </div>
</div>
{% endfor %}


{# ═══════════════════════════════════════
   VIEW 3 — CURRICULUM SUBJECTS (per curriculum)
   ═══════════════════════════════════════ #}
{% for c in curricula %}
    {% set yearLevelOrder = {'First Year': 1, 'Second Year': 2, 'Third Year': 3, 'Fourth Year': 4, 'Unassigned': 5} %}
    {% set yearSemGroups = {} %}
    {% for s in c.subjects %}
        {% set yl = s.yearLevel ?? 'Unassigned' %}
        {% set sem = s.semester ?? 'Unassigned' %}
        {% if yl not in yearSemGroups|keys %}
            {% set yearSemGroups = yearSemGroups|merge({(yl): {}}) %}
        {% endif %}
        {% if sem not in yearSemGroups[yl]|keys %}
            {% set yearSemGroups = yearSemGroups|merge({(yl): yearSemGroups[yl]|merge({(sem): []})}) %}
        {% endif %}
        {% set yearSemGroups = yearSemGroups|merge({(yl): yearSemGroups[yl]|merge({(sem): yearSemGroups[yl][sem]|merge([s])})}) %}
    {% endfor %}
    {% set sortedYears = [] %}
    {% for yl in ['First Year', 'Second Year', 'Third Year', 'Fourth Year', 'Unassigned'] %}
        {% if yl in yearSemGroups|keys %}
            {% set sortedYears = sortedYears|merge([yl]) %}
        {% endif %}
    {% endfor %}
    {% for yl, sems in yearSemGroups %}
        {% if yl not in sortedYears %}
            {% set sortedYears = sortedYears|merge([yl]) %}
        {% endif %}
    {% endfor %}

<div id="view-cur-{{ c.id }}" class="cm-view" style="display:none;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small mb-0" style="font-size:.78rem;">
            <li class="breadcrumb-item"><a href="#" onclick="showMain(); return false;" class="text-decoration-none text-muted">Departments</a></li>
            <li class="breadcrumb-item"><a href="#" onclick="showDepartment({{ c.department ? c.department.id : 0 }}); return false;" class="text-decoration-none text-muted">{{ c.department ? c.department.departmentName : 'Unknown' }}</a></li>
            <li class="breadcrumb-item active text-dark" aria-current="page">{{ c.curriculumName }}</li>
        </ol>
    </nav>

    <div class="cm-header mb-4">
        <div class="cm-header-inner">
            <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="cm-header-icon">
                        <i  class="bi bi-bookmark-check"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-1 text-white">{{ c.curriculumName }}</h4>
                        <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.8rem;">
                            {% if c.curriculumYear %}<span class="cm-meta-pill"><i  class="bi bi-calendar3 me-1"></i>{{ c.curriculumYear }}</span>{% endif %}
                            {% if c.course %}<span class="cm-meta-pill"><i  class="bi bi-mortarboard me-1"></i>{{ c.course.courseName }}</span>{% endif %}
                            {% if c.department %}<span class="cm-meta-pill"><i  class="bi bi-bank me-1"></i>{{ c.department.departmentName }}</span>{% endif %}
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-1">
                    <button type="button" class="btn btn-sm btn-light fw-semibold" data-bs-toggle="modal" data-bs-target="#addSubjectModal{{ c.id }}">
                        <i  class="bi bi-plus me-1"></i>Add Subject
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-light" data-bs-toggle="modal" data-bs-target="#editProgramModal{{ c.id }}">
                        <i  class="bi bi-pencil me-1"></i>Edit
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-light" onclick="showDepartment({{ c.department ? c.department.id : 0 }})">
                        <i  class="bi bi-arrow-left me-1"></i>Back
                    </button>
                </div>
            </div>
            <div class="cm-stats-row">
                {% set totalUnitsAll = 0 %}
                {% for s in c.subjects %}{% set totalUnitsAll = totalUnitsAll + (s.units ?? 0) %}{% endfor %}
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ c.subjects|length }}</span>
                    <span class="cm-stat-lbl">Subjects</span>
                </div>
                <div class="cm-stat-divider"></div>
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ totalUnitsAll }}</span>
                    <span class="cm-stat-lbl">Total Units</span>
                </div>
                <div class="cm-stat-divider"></div>
                <div class="cm-stat">
                    <span class="cm-stat-val">{{ sortedYears|length }}</span>
                    <span class="cm-stat-lbl">Year Levels</span>
                </div>
                <div class="cm-stat-divider"></div>
                <div class="cm-stat">
                    {% set totalSems = 0 %}
                    {% for yl in sortedYears %}{% for sem in yearSemGroups[yl]|keys %}{% set totalSems = totalSems + 1 %}{% endfor %}{% endfor %}
                    <span class="cm-stat-val">{{ totalSems }}</span>
                    <span class="cm-stat-lbl">Semesters</span>
                </div>
            </div>
        </div>
    </div>

    {% set ylColors = {'First Year': 'primary', 'Second Year': 'success', 'Third Year': 'warning', 'Fourth Year': 'info', 'Unassigned': 'secondary'} %}
    {% set ylIcons  = {'First Year': 'bi-1-circle-fill', 'Second Year': 'bi-2-circle-fill', 'Third Year': 'bi-3-circle-fill', 'Fourth Year': 'bi-4-circle-fill', 'Unassigned': 'bi-question-circle-fill'} %}

    {% if c.subjects|length > 0 %}
        <div id="subjects-container-{{ c.id }}">
        <div class="cm-nav mb-4">
            <div class="cm-nav-tabs">
                {% for yearLevel in sortedYears %}
                    {% set ylColor = ylColors[yearLevel] ?? 'secondary' %}
                    {% set ylIcon  = ylIcons[yearLevel]  ?? 'bi-circle' %}
                    {% set ylCount = 0 %}
                    {% for sem, sList in yearSemGroups[yearLevel] %}{% set ylCount = ylCount + sList|length %}{% endfor %}
                    <button type="button"
                        class="cm-tab{% if loop.first %} active{% endif %}"
                        data-cur="{{ c.id }}" data-yl="{{ yearLevel|lower|replace({' ': '-'}) }}"
                        onclick="switchYearLevel(this)">
                        <i class="bi {{ ylIcon }}"></i>
                        <span class="cm-tab-label">{{ yearLevel }}</span>
                        <span class="cm-tab-badge">{{ ylCount }}</span>
                    </button>
                {% endfor %}
            </div>
            <div class="cm-search-wrap">
                <i  class="bi bi-search"></i>
                <input type="text" class="cm-search" placeholder="Search subjects..." oninput="filterSubjects(this, {{ c.id }})">
            </div>
        </div>

        {% for yearLevel in sortedYears %}
        {% set ylColor = ylColors[yearLevel] ?? 'secondary' %}
        {% set ylIcon  = ylIcons[yearLevel]  ?? 'bi-circle' %}
        {% set ylTotalSubjects = 0 %}
        {% set ylTotalUnits = 0 %}
        {% set ylSemCount = 0 %}
        {% for sem, sList in yearSemGroups[yearLevel] %}
            {% set ylSemCount = ylSemCount + 1 %}
            {% set ylTotalSubjects = ylTotalSubjects + sList|length %}
            {% for s in sList %}{% set ylTotalUnits = ylTotalUnits + (s.units ?? 0) %}{% endfor %}
        {% endfor %}

        <div class="cm-yl-panel cm-semester-group{% if loop.first %} active{% endif %}"
             data-cur="{{ c.id }}" data-yl="{{ yearLevel|lower|replace({' ': '-'}) }}"
             {% if not loop.first %}style="display:none;"{% endif %}>

            <div class="cm-yl-bar mb-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="cm-yl-dot bg-{{ ylColor }}"></span>
                    <h6 class="fw-bold mb-0" style="font-size:.95rem;">{{ yearLevel }}</h6>
                    <span class="text-muted" style="font-size:.78rem;">—</span>
                    <span class="text-muted" style="font-size:.78rem;">{{ ylTotalSubjects }} subject{{ ylTotalSubjects != 1 ? 's' : '' }}, {{ ylTotalUnits }} unit{{ ylTotalUnits != 1 ? 's' : '' }}, {{ ylSemCount }} semester{{ ylSemCount != 1 ? 's' : '' }}</span>
                </div>
            </div>

            {% for semester, subjectList in yearSemGroups[yearLevel] %}
            {% set semUnits = 0 %}{% for s in subjectList %}{% set semUnits = semUnits + (s.units ?? 0) %}{% endfor %}
            <div class="cm-sem-block mb-4 cm-sem-card">
                <div class="cm-sem-header">
                    <div class="d-flex align-items-center gap-2">
                        <span class="cm-sem-indicator bg-{{ ylColor }}"></span>
                        <span class="fw-semibold" style="font-size:.85rem;">{{ yearLevel }}</span>
                        <span class="text-muted" style="font-size:.75rem;">|</span>
                        <span class="fw-semibold" style="font-size:.85rem;">{{ semester }}</span>
                    </div>
                    <div class="d-flex align-items-center gap-3" style="font-size:.75rem;">
                        <span class="text-muted"><i  class="bi bi-journal-text me-1"></i>{{ subjectList|length }} subject{{ subjectList|length != 1 ? 's' : '' }}</span>
                        <span class="text-muted"><i  class="bi bi-layers me-1"></i>{{ semUnits }} unit{{ semUnits != 1 ? 's' : '' }}</span>
                    </div>
                </div>
                <div class="cm-sem-table">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm align-middle mb-0" style="font-size:.82rem;">
                            <thead>
                                <tr class="bg-light">
                                    <th style="width:3%;" class="text-center text-muted">#</th>
                                    <th style="width:12%;" class="text-muted">Subject</th>
                                    <th class="text-muted">Descriptive Title</th>
                                    <th style="width:8%;" class="text-center text-muted">Units</th>
                                    <th style="width:14%;" class="text-end text-muted">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for s in subjectList %}
                                <tr class="cm-subject-row" data-name="{{ s.subjectCode|lower }} {{ s.subjectName|lower }}">
                                    <td class="text-center text-muted">{{ loop.index }}</td>
                                    <td><code class="fw-semibold text-{{ ylColor }}">{{ s.subjectCode }}</code></td>
                                    <td>{{ s.subjectName }}</td>
                                    <td class="text-center fw-semibold">{{ s.units ?? '—' }}</td>
                                    <td class="text-end">
                                        <div class="d-flex gap-1 justify-content-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary py-0 px-1 cm-action-btn" style="font-size:.72rem;" title="View" onclick="viewSubjectDetail({{ s.id }})">
                                                <i  class="bi bi-eye"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1 cm-action-btn" style="font-size:.72rem;" title="Edit" data-bs-toggle="modal" data-bs-target="#editSubjectModal{{ s.id }}">
                                                <i  class="bi bi-pencil"></i>
                                            </button>
                                            <form method="post" action="{{ path(prefix ~ '_curriculum_remove_subject', {id: c.id, subjectId: s.id}) }}" class="d-inline" onsubmit="return confirm('Remove this subject from the curriculum?')">
                                                <input type="hidden" name="_token" value="{{ csrf_token('remove_subject_curriculum' ~ c.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1 cm-action-btn" style="font-size:.72rem;" title="Remove">
                                                    <i  class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endfor %}
        </div>
        <div id="no-results-{{ c.id }}" class="text-center text-muted py-4" style="display:none;">
            <i  class="bi bi-search fs-3 d-block mb-2 opacity-25"></i>
            No subjects match your search.
        </div>
    {% else %}
        <div class="text-center py-5">
            <div class="mb-3">
                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center" style="width:72px;height:72px;">
                    <i  class="bi bi-journal-plus text-primary" style="font-size:1.8rem;"></i>
                </div>
            </div>
            <h6 class="fw-bold text-dark mb-1">No Subjects Yet</h6>
            <p class="text-muted small mb-3">Start building this curriculum by adding your first subject.</p>
            <button type="button" class="btn btn-norsu btn-sm" data-bs-toggle="modal" data-bs-target="#addSubjectModal{{ c.id }}">
                <i  class="bi bi-plus-circle-fill me-1"></i>Add First Subject
            </button>
        </div>
    {% endif %}
</div>
{% endfor %}


{# ═══════════════════════════════════════
   MODALS — CREATE & EDIT PROGRAMS
   ═══════════════════════════════════════ #}

<div class="modal fade" id="addProgramModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">
            <form method="post" action="{{ path(prefix ~ '_curriculum_create') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('create_curriculum') }}">
                <div class="cm-modal-header">
                    <div class="d-flex align-items-center gap-3">
                        <div class="cm-modal-icon"><i  class="bi bi-bookmark-check"></i></div>
                        <div>
                            <h5 class="modal-title fw-bold text-white mb-0">New Curriculum</h5>
                            <small class="text-white-50">Create a new curriculum program</small>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" name="department" id="createDept" value="">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Curriculum Name <span class="text-danger">*</span></label>
                            <input type="text" name="curriculumName" class="form-control" placeholder="e.g. BSIT Curriculum 2024" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Year / Version</label>
                            <input type="text" name="curriculumYear" class="form-control" placeholder="e.g. 2024">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Department <span class="text-danger">*</span></label>
                            <select name="department" id="createDeptSelect" class="form-select" required>
                                <option value="">— Select Department —</option>
                                {% for dept in departments %}
                                    <option value="{{ dept.id }}">{{ dept.departmentName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Course</label>
                            <select name="course" class="form-select">
                                <option value="">— Select Course —</option>
                                {% for course in courses %}
                                    <option value="{{ course.id }}">{{ course.courseName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea name="description" class="form-control" rows="2" placeholder="Brief description..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-norsu btn-sm"><i  class="bi bi-check-circle-fill me-1"></i>Create Curriculum</button>
                </div>
            </form>
        </div>
    </div>
</div>

{% for c in curricula %}
<div class="modal fade" id="editProgramModal{{ c.id }}" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">
            <form method="post" action="{{ path(prefix ~ '_curriculum_edit', {id: c.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('edit_curriculum' ~ c.id) }}">
                <div class="cm-modal-header">
                    <div class="d-flex align-items-center gap-3">
                        <div class="cm-modal-icon"><i  class="bi bi-pencil"></i></div>
                        <div>
                            <h5 class="modal-title fw-bold text-white mb-0">Edit Curriculum</h5>
                            <small class="text-white-50">{{ c.curriculumName }}</small>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Curriculum Name <span class="text-danger">*</span></label>
                            <input type="text" name="curriculumName" class="form-control" value="{{ c.curriculumName }}" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Year / Version</label>
                            <input type="text" name="curriculumYear" class="form-control" value="{{ c.curriculumYear }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Department <span class="text-danger">*</span></label>
                            <select name="department" class="form-select" required>
                                <option value="">— Select Department —</option>
                                {% for dept in departments %}
                                    <option value="{{ dept.id }}" {{ c.department and c.department.id == dept.id ? 'selected' : '' }}>{{ dept.departmentName }}</option>
                                {% endfor %}
