{# ═══════════════════════════════════════
   JAVASCRIPT
   ═══════════════════════════════════════ #}
<script>
/* ── Section Switching ── */
var currentSection = 'active';
var currentTypeFilter = 'SET';

function switchSection(section, btn) {
    currentSection = section;
    document.querySelectorAll('#evSectionTabs .ev-filter-btn').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');
    document.getElementById('activeSection').style.display = section === 'active' ? '' : 'none';
    document.getElementById('previousSection').style.display = section === 'previous' ? '' : 'none';
    applyAllFilters();
}

function filterType(type, btn) {
    currentTypeFilter = type;
    document.querySelectorAll('#evTypeFilter .ev-filter-btn').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');

    // Hide Subject, Year, Schedule columns when filtering by SEF/Superior
    var hideCols = (type === 'SEF');
    document.querySelectorAll('.ev-table').forEach(function(table){
        if (hideCols) {
            table.classList.add('hide-set-cols');
        } else {
            table.classList.remove('hide-set-cols');
        }
    });

    applyAllFilters();
}

function applyAllFilters() {
    var q = document.getElementById('evSearchInput').value.toLowerCase().trim();
    var college = document.getElementById('evFilterCollege').value;
    var dept = document.getElementById('evFilterDept').value;
    var faculty = document.getElementById('evFilterFaculty').value;
    var tableId = currentSection === 'active' ? 'activeTable' : 'previousTable';

    document.querySelectorAll('#' + tableId + ' tbody .ev-row').forEach(function(row){
        var tMatch = currentTypeFilter === 'all' || (currentTypeFilter === 'SEF' ? (row.dataset.type === 'SEF' || row.dataset.type === 'SUPERIOR') : row.dataset.type === currentTypeFilter);
        var cMatch = !college || row.dataset.college === college;
        var dMatch = !dept || row.dataset.dept === dept;
        var fMatch = !faculty || row.dataset.faculty === faculty;
        var qMatch = !q || row.dataset.search.toLowerCase().indexOf(q) !== -1;

        // For previous section, also apply AY and semester filters
        var ayMatch = true, semMatch = true;
        if (currentSection === 'previous') {
            var ayVal = document.getElementById('evPrevAYFilter').value;
            var semVal = document.getElementById('evPrevSemFilter').value;
            ayMatch = !ayVal || row.dataset.schoolYear === ayVal;
            semMatch = !semVal || row.dataset.semester === semVal;
        }

        row.style.display = (tMatch && cMatch && dMatch && fMatch && qMatch && ayMatch && semMatch) ? '' : 'none';
    });
}

function filterPreviousByAY() {
    applyAllFilters();
}

/* ── Table Sorting ── */
var sortDirections = {};
function sortTable(tableId, colIdx) {
    var table = document.getElementById(tableId);
    var tbody = table.querySelector('tbody');
    var rows = Array.from(tbody.querySelectorAll('tr.ev-row'));
    var key = tableId + '_' + colIdx;
    sortDirections[key] = !sortDirections[key];
    var asc = sortDirections[key];

    rows.sort(function(a, b) {
        var aText = a.cells[colIdx] ? a.cells[colIdx].textContent.trim().toLowerCase() : '';
        var bText = b.cells[colIdx] ? b.cells[colIdx].textContent.trim().toLowerCase() : '';
        if (colIdx === 9 || colIdx === 10) { // Evaluators column - numeric sort
            return asc ? (parseInt(aText)||0) - (parseInt(bText)||0) : (parseInt(bText)||0) - (parseInt(aText)||0);
        }
        return asc ? aText.localeCompare(bText) : bText.localeCompare(aText);
    });

    rows.forEach(function(row){ tbody.appendChild(row); });
}

/* ── Fetch subjects from API based on selected faculty ── */
function filterSubjectsByFaculty(facultySelect, keepValue) {
    var facultyOpt = facultySelect.options[facultySelect.selectedIndex];
    var facultyId = facultyOpt ? facultyOpt.getAttribute('data-faculty-id') : '';
    var subjectSel = document.querySelector(facultySelect.getAttribute('data-target-subject'));
    if (!subjectSel) return;

    var currentVal = keepValue || '';
    var timeField = document.querySelector(subjectSel.getAttribute('data-target-time'));
    var sectionField = document.querySelector(subjectSel.getAttribute('data-target-section'));
    if (!keepValue) {
        if (timeField) timeField.value = '';
        if (sectionField) sectionField.value = '';
    }

    subjectSel.innerHTML = '';
    var defaultOpt = document.createElement('option');
    defaultOpt.value = '';
    defaultOpt.setAttribute('data-schedule', '');
    defaultOpt.setAttribute('data-section', '');
    defaultOpt.textContent = facultyId ? 'Loading...' : '— Select Faculty first —';
    subjectSel.appendChild(defaultOpt);

    if (facultyId) {
        fetch('/admin/api/faculty/' + facultyId + '/subjects')
            .then(function(r) { return r.json(); })
            .then(function(subjects) {
                subjectSel.innerHTML = '';
                var defOpt = document.createElement('option');
                defOpt.value = '';
                defOpt.setAttribute('data-schedule', '');
                defOpt.setAttribute('data-section', '');
                defOpt.textContent = '— Select Subject —';
                subjectSel.appendChild(defOpt);

                subjects.forEach(function(s) {
                    var opt = document.createElement('option');
                    opt.value = s.value;
                    opt.setAttribute('data-schedule', s.schedule);
                    opt.setAttribute('data-section', s.section);
                    opt.textContent = s.value;
                    if (s.value === currentVal) opt.selected = true;
                    subjectSel.appendChild(opt);
                });

                /* Auto-fill time/section if a value was pre-selected */
                if (currentVal) {
                    var selOpt = subjectSel.options[subjectSel.selectedIndex];
                    if (selOpt && selOpt.value) {
                        if (timeField) timeField.value = selOpt.getAttribute('data-schedule') || '';
                        if (sectionField) sectionField.value = selOpt.getAttribute('data-section') || '';
                    }
                }
            });
    }
}

/* ── Auto-fill time & section when subject is selected ── */
document.querySelectorAll('.subject-select').forEach(function(sel) {
    sel.addEventListener('change', function() {
        var opt = this.options[this.selectedIndex];
        var timeField = document.querySelector(this.dataset.targetTime);
        var sectionField = document.querySelector(this.dataset.targetSection);
        if (timeField) timeField.value = opt.getAttribute('data-schedule') || '';
        if (sectionField) sectionField.value = opt.getAttribute('data-section') || '';
    });
});

document.querySelectorAll('.faculty-select').forEach(function(sel) {
    sel.addEventListener('change', function() { filterSubjectsByFaculty(this, ''); });
    var subjectSel = document.querySelector(sel.getAttribute('data-target-subject'));
    var currentSubjectVal = subjectSel ? subjectSel.getAttribute('data-current-value') : '';
    if (sel.value) {
        filterSubjectsByFaculty(sel, currentSubjectVal);
    }
});

/* ── Filter faculty options by selected department ── */
document.querySelectorAll('.dept-select').forEach(function(deptSel) {
    var modal = deptSel.closest('.modal');
    var facultySel = modal ? modal.querySelector('.faculty-select') : null;
    if (!facultySel) return;

    var allFacultyOpts = [];
    Array.from(facultySel.options).forEach(function(opt) {
        allFacultyOpts.push({ value: opt.value, text: opt.textContent, facultyId: opt.getAttribute('data-faculty-id') || '', department: opt.getAttribute('data-department') || '', selected: opt.selected });
    });

    deptSel.addEventListener('change', function() {
        var selDept = this.value;
        var currentFacultyVal = facultySel.value;
        facultySel.innerHTML = '';

        allFacultyOpts.forEach(function(o) {
            if (!selDept || o.value === '' || o.department === selDept) {
                var opt = document.createElement('option');
                opt.value = o.value;
                opt.textContent = o.text;
                opt.setAttribute('data-faculty-id', o.facultyId);
                opt.setAttribute('data-department', o.department);
                if (o.value === currentFacultyVal) opt.selected = true;
                facultySel.appendChild(opt);
            }
        });

        /* Reset subject dropdown when department changes */
        var subjectSel = modal ? modal.querySelector('.subject-select') : null;
        if (subjectSel) {
            subjectSel.innerHTML = '<option value="" data-schedule="" data-section="">— Select Faculty first —</option>';
        }
        var timeField = modal ? modal.querySelector('[name="time"]') : null;
        var sectionField = modal ? modal.querySelector('[name="section"]') : null;
        if (timeField) timeField.value = '';
        if (sectionField) sectionField.value = '';
    });
});

/* ── Superior modal: Filter faculty by department ── */
(function() {
    var deptSel = document.querySelector('.sup-dept-select');
    var facultySel = document.querySelector('.sup-faculty-select');
    if (!deptSel || !facultySel) return;

    var allFacultyOpts = [];
    Array.from(facultySel.options).forEach(function(opt) {
        allFacultyOpts.push({ value: opt.value, text: opt.textContent, position: opt.getAttribute('data-position') || '', department: opt.getAttribute('data-department') || '' });
    });

    deptSel.addEventListener('change', function() {
        var selDept = this.value;
        facultySel.innerHTML = '';
        allFacultyOpts.forEach(function(o) {
            if (!selDept || o.value === '' || o.department === selDept) {
                var opt = document.createElement('option');
                opt.value = o.value;
                opt.textContent = o.text;
                opt.setAttribute('data-position', o.position);
                opt.setAttribute('data-department', o.department);
                facultySel.appendChild(opt);
            }
        });
        /* Clear position field */
        var posInput = document.querySelector('.sup-position-input');
        if (posInput) posInput.value = '';
    });
})();

/* ── Filter department options by selected college ── */
document.querySelectorAll('.college-select').forEach(function(collegeSel) {
    var modal = collegeSel.closest('.modal');
    var deptSel = modal ? modal.querySelector('.dept-select') : null;
    if (!deptSel) return;

    var allDeptOpts = [];
    Array.from(deptSel.options).forEach(function(opt) {
        allDeptOpts.push({ value: opt.value, text: opt.textContent, college: opt.getAttribute('data-college') || '', selected: opt.selected });
    });

    collegeSel.addEventListener('change', function() {
        var selCollege = this.value;
        var currentDeptVal = deptSel.value;
        deptSel.innerHTML = '';

        allDeptOpts.forEach(function(o) {
            if (!selCollege || o.value === '' || o.college === selCollege) {
                var opt = document.createElement('option');
                opt.value = o.value;
                opt.textContent = o.text;
                opt.setAttribute('data-college', o.college);
                if (o.value === currentDeptVal) opt.selected = true;
                deptSel.appendChild(opt);
            }
        });
    });
});

/* ── Superior modal: Filter departments by college ── */
(function() {
    var collegeSel = document.querySelector('.sup-college-select');
    var deptSel = document.querySelector('.sup-dept-select');
    if (!collegeSel || !deptSel) return;

    var allDeptOpts = [];
    Array.from(deptSel.options).forEach(function(opt) {
        allDeptOpts.push({ value: opt.value, text: opt.textContent, college: opt.getAttribute('data-college') || '' });
    });

    collegeSel.addEventListener('change', function() {
        var selCollege = this.value;
        deptSel.innerHTML = '';
        allDeptOpts.forEach(function(o) {
            if (!selCollege || o.value === '' || o.college === selCollege) {
                var opt = document.createElement('option');
                opt.value = o.value;
                opt.textContent = o.text;
                opt.setAttribute('data-college', o.college);
                deptSel.appendChild(opt);
            }
        });
    });
})();

/* ── Superior modal: Auto-fill position from faculty ── */
(function() {
    var facultySel = document.querySelector('.sup-faculty-select');
    var positionInput = document.querySelector('.sup-position-input');
    if (!facultySel || !positionInput) return;

    facultySel.addEventListener('change', function() {
        var selected = this.options[this.selectedIndex];
        positionInput.value = selected ? (selected.getAttribute('data-position') || '') : '';
    });
})();

/* ── QR Code Generation ── */
(function() {
    var qrModal = document.getElementById('qrCodeModal');
    if (!qrModal) return;
    var currentQrUrl = '';

    qrModal.addEventListener('show.bs.modal', function(e) {
        var btn = e.relatedTarget;
        if (!btn) return;

        var evalId = btn.getAttribute('data-eval-id');
        var evalType = btn.getAttribute('data-eval-type');
        var faculty = btn.getAttribute('data-eval-faculty');
        var subject = btn.getAttribute('data-eval-subject');
        var section = btn.getAttribute('data-eval-section');
        var schoolYear = btn.getAttribute('data-eval-school-year');

        // Build the evaluation URL
        var baseUrl = window.location.origin;
        currentQrUrl = baseUrl + '/evaluation/qr/' + evalId;

        // Update modal info
        var typeBadge = document.getElementById('qrEvalType');
        typeBadge.textContent = evalType;
        typeBadge.className = 'ev-type-badge ' + (evalType === 'SET' ? 'ev-type-set' : (evalType === 'SEF' ? 'ev-type-sef' : 'ev-type-superior'));

        document.getElementById('qrModalSubtitle').textContent = schoolYear || 'Scan to evaluate';
        document.getElementById('qrEvalFaculty').textContent = faculty || '';
        document.getElementById('qrEvalSubject').textContent = subject || '';

        var details = [];
        if (section) details.push('Section: ' + section);
        document.getElementById('qrEvalDetails').textContent = details.join(' · ');
        document.getElementById('qrUrl').textContent = currentQrUrl;

        // Generate QR code via API
        var qrImg = document.getElementById('qrImage');
        qrImg.src = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(currentQrUrl);
    });

    window.downloadQR = function() {
        var img = document.getElementById('qrImage');
        var link = document.createElement('a');
        link.download = 'evaluation-qr-code.png';
        link.href = img.src;
        link.click();
    };

    window.copyQRLink = function() {
        navigator.clipboard.writeText(currentQrUrl).then(function() {
            var btn = document.querySelector('#qrCodeModal .qr-btn-copy');
            var orig = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Copied!';
            setTimeout(function() { btn.innerHTML = orig; }, 1500);
        });
    };
})();

