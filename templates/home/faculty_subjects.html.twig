<script>
/* ── Global active evaluations map ── */
const activeEvaluations = {{ activeEvalMap|json_encode }};
window.hasActiveEval = Object.keys(activeEvaluations).length > 0;
window.firstActiveEvalId = Object.keys(activeEvaluations).length > 0 ? Object.keys(activeEvaluations)[0] : null;

// Faculty and evaluation data for QR modals
window.facultyName = '{{ app.user.firstName|e("js") }} {{ app.user.lastName|e("js") }}';
if (window.firstActiveEvalId && activeEvaluations[window.firstActiveEvalId]) {
    window.firstEvalName = activeEvaluations[window.firstActiveEvalId].name;
} else {
    window.firstEvalName = '';
}

// Debug log
console.log('Active Evaluations on page load:', activeEvaluations);
console.log('hasActiveEval:', window.hasActiveEval);
console.log('firstActiveEvalId:', window.firstActiveEvalId);
console.log('Total active evaluations:', Object.keys(activeEvaluations).length);

/* ── Checked count ── */
function updateCheckedCount() {
    var count = document.querySelectorAll('.subject-check:checked').length;
    document.getElementById('checkedCount').textContent = count;
}

/* ── Toggle department sections ── */
function toggleDept(deptId) {
    var body = document.getElementById('deptBody' + deptId);
    var section = document.getElementById('deptSection' + deptId);
    if (!body || !section) return;
    var chevron = section.querySelector('.sb-dept-chevron');
    body.classList.toggle('open');
    if (chevron) chevron.classList.toggle('open');
}

/* ── Combined filter: search + year level + department ── */
function applyFilters() {
    var q = (document.getElementById('subjectSearchInput').value || '').toLowerCase().trim();
    var yl = (document.getElementById('yearLevelFilter').value || '').toLowerCase();
    var deptId = (document.getElementById('departmentFilter').value || '').trim();
    var visibleAny = false;

    document.querySelectorAll('.sb-row').forEach(function(row) {
        var text = (row.getAttribute('data-search') || '').toLowerCase();
        var rowYl = (row.getAttribute('data-yearlevel') || '').toLowerCase();
        var matchSearch = q === '' || text.indexOf(q) !== -1;
        var matchYl = yl === '' || rowYl === yl;

        // Get the parent department section ID
        var deptSection = row.closest('.sb-dept-section');
        var rowDeptId = deptSection ? deptSection.id.replace('deptSection', '') : '';
        var matchDept = deptId === '' || rowDeptId === deptId;

        var show = matchSearch && matchYl && matchDept;
        row.style.display = show ? '' : 'none';
        if (show) visibleAny = true;
    });

    // Update department metadata and hide empty sections
    var hasFilter = q || yl || deptId;
    document.querySelectorAll('.sb-dept-section').forEach(function(section) {
        var sectionDeptId = section.id.replace('deptSection', '');
        var deptVisible = deptId === '' || sectionDeptId === deptId;

        var total = section.querySelectorAll('.sb-row').length;
        var visible = 0;
        section.querySelectorAll('.sb-row').forEach(function(r) {
            if (r.style.display !== 'none') visible++;
        });
        // Hide entire department section when not selected or no matches
        section.style.display = (!deptVisible || (hasFilter && visible === 0)) ? 'none' : '';
        var meta = section.querySelector('.sb-dept-meta');
        if (meta) {
            meta.textContent = hasFilter ? visible + ' of ' + total + ' shown' : total + ' subject' + (total !== 1 ? 's' : '') + ' available';
        }
    });
    var noResults = document.getElementById('sbNoResults');
    if (noResults) noResults.style.display = (!visibleAny && hasFilter) ? '' : 'none';
}

function searchSubjects(query) {
    applyFilters();
}

function filterByYearLevel(val) {
    applyFilters();
}

/* ── Department filter ── */
function filterByDepartment(deptId) {
    // Reset department body visibility, then apply all filters
    document.querySelectorAll('.sb-dept-section').forEach(function(section) {
        section.style.display = '';
    });
    // Apply all filters together
    applyFilters();
}

/* ── Semester filter ── */
function filterBySemester(val) {
    /* Fade out content then navigate for smooth transition */
    var mc = document.querySelector('.main-content');
    if (mc) {
        mc.style.transition = 'opacity .12s ease';
        mc.style.opacity = '0';
    }
    var url = val
        ? '{{ path('faculty_subjects') }}?semester=' + encodeURIComponent(val)
        : '{{ path('faculty_subjects') }}';
    setTimeout(function() {
        /* Use a temporary Turbo-driven link for smooth navigation */
        var a = document.createElement('a');
        a.href = url;
        a.style.display = 'none';
        document.body.appendChild(a);
        a.click();
        a.remove();
    }, 120);
}

/* ── Unload ── */
var unloadTargetId = null;
var loadedSubjectIds = [{% for id in loadedSubjectIds %}{{ id }}{% if not loop.last %},{% endif %}{% endfor %}];

function unloadSubject(subjectId, subjectCode) {
    unloadTargetId = subjectId;
    document.getElementById('unloadSubjectName').textContent = subjectCode;
    new bootstrap.Modal(document.getElementById('unloadModal')).show();
}

function quickLoadSubject(subjectId) {
    /* Validate section is filled before quick-loading */
    var sectionInput = document.querySelector('.sb-section-input[data-subject-id="' + subjectId + '"]');
    if (sectionInput && !sectionInput.value.trim()) {
        sectionInput.style.borderColor = '#ef4444';
        sectionInput.style.boxShadow = '0 0 0 3px rgba(239,68,68,.15)';
        sectionInput.focus();
        alert('Please fill in the Section before picking this subject.');
        return;
    }
    var cb = document.getElementById('subj_' + subjectId);
    if (cb) {
        cb.checked = true;
        cb.dispatchEvent(new Event('change', { bubbles: true }));
        updateCheckedCount();
    }
    document.getElementById('loadForm').submit();
}

/* ── Pick Again Modal ── */
function openPickAgainModal(subjectId, subjectCode, subjectName) {
    document.getElementById('pickAgainSubjectId').value = subjectId;
    document.getElementById('pickAgainSubjectLabel').textContent = subjectCode + ' — ' + subjectName;
    new bootstrap.Modal(document.getElementById('pickAgainModal')).show();
}

/* ── Remove additional FSL entry ── */
function removeFslEntry(fslId, token) {
    if (!confirm('Remove this section?')) return;
    var form = document.getElementById('removeFslForm');
    form.action = '{{ path('faculty_subject_unload_fsl', {id: '__ID__'}) }}'.replace('__ID__', fslId);
    document.getElementById('removeFslToken').value = token;
    form.submit();
}

/* ── Update row visuals when checkbox changes ── */
function updateRowVisual(cb) {
    var row = cb.closest('.sb-row');
    if (!row) return;
    var statusCell = row.querySelector('.sb-td-status');
    var actionCell = row.querySelector('.sb-action-btns');
    var qrCell = row.querySelector('td:nth-child(9)');  // QR column is 9th
    var sid = cb.dataset.subjectId;
    var code = row.querySelector('.sb-code-text') ? row.querySelector('.sb-code-text').textContent : '';
    var section = row.querySelector('.sb-section-input') ? row.querySelector('.sb-section-input').value : '';

    if (cb.checked) {
        row.classList.add('is-loaded');
        if (statusCell) statusCell.innerHTML = '<span class="sb-status-badge loaded"><i class="bi bi-check-circle-fill"></i> Loaded</span>';

        // Check for active evaluations immediately (bypass debounce)
        // Use setTimeout to allow the fetch to complete before rendering buttons
        window.pollActiveEvaluations(true);

        // Small delay to let polling update the state
        setTimeout(function() {
            console.log('Loading subject:', code, '| hasActiveEval:', window.hasActiveEval, '| firstActiveEvalId:', window.firstActiveEvalId);
            var actionsHtml = '';

            // Update QR column
            if (qrCell) {
                if (window.hasActiveEval && window.firstActiveEvalId) {
                    console.log('Adding QR button for subject:', code);
                    var qrHtml = '<button type="button" class="sb-btn-qr sb-qr-btn-column" data-subject-id="' + sid + '" data-subject-code="' + code.replace(/"/g, '&quot;') + '" data-subject-name="' + code.replace(/"/g, '&quot;') + '" data-section="' + section.replace(/"/g, '&quot;') + '" data-eval-id="' + window.firstActiveEvalId + '" data-eval-type="SET" data-faculty="' + window.facultyName.replace(/"/g, '&quot;') + '" data-school-year="' + (window.firstEvalName || '').replace(/"/g, '&quot;') + '" title="Evaluation QR Code" style="width: 32px; height: 32px; border-radius: 6px; background: #e0f2fe; border: 1px solid #bae6fd; color: #0369a1; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: all .2s; font-size: .85rem;"><i class="bi bi-qr-code-scan"></i></button>';
                    qrCell.innerHTML = qrHtml;
                } else {
                    qrCell.innerHTML = '<span class="text-muted small">No Evaluation</span>';
                }
            }

            // Add QR button if there's an active evaluation
            if (window.hasActiveEval && window.firstActiveEvalId) {
                console.log('Adding QR button for subject:', code);
                actionsHtml += '<button type="button" class="sb-btn-qr sb-qr-btn" data-subject-id="' + sid + '" data-subject-code="' + code.replace(/"/g, '&quot;') + '" data-subject-name="' + code.replace(/"/g, '&quot;') + '" data-section="' + section.replace(/"/g, '&quot;') + '" data-eval-id="' + window.firstActiveEvalId + '" data-eval-type="SET" data-faculty="' + window.facultyName.replace(/"/g, '&quot;') + '" data-school-year="' + (window.firstEvalName || '').replace(/"/g, '&quot;') + '" title="Evaluation QR Code" style="width: 32px; height: 32px; border-radius: 6px; background: #e0f2fe; border: 1px solid #bae6fd; color: #0369a1; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: all .2s; font-size: .85rem;"><i class="bi bi-qr-code-scan"></i></button>';
            } else {
                console.log('NOT adding QR button - hasActiveEval:', window.hasActiveEval, 'firstActiveEvalId:', window.firstActiveEvalId);
            }

            // Add Pick and Unload buttons
            actionsHtml += '<button type="button" class="sb-btn-pick" onclick="openPickAgainModal(' + sid + ', \'' + code.replace(/'/g,"\\'") + '\', \'Subject\')" title="Pick again with different section"><i class="bi bi-plus-circle"></i> Pick</button>';
            actionsHtml += '<button type="button" class="sb-btn-unload" onclick="unloadSubject(' + sid + ', \'' + code.replace(/'/g,"\\'") + '\')"><i class="bi bi-x-circle"></i> Unload</button>';

            if (actionCell) actionCell.innerHTML = actionsHtml;
        }, 200);  // 200ms delay for network fetch to complete
    } else {
        row.classList.remove('is-loaded');
        if (statusCell) statusCell.innerHTML = '<span class="sb-status-badge available"><i class="bi bi-circle"></i> Available</span>';

        // Clear QR column
        if (qrCell) qrCell.innerHTML = '<span class="text-muted small">No Evaluation</span>';

        if (actionCell) actionCell.innerHTML = '<button type="button" class="sb-btn-pick" onclick="quickLoadSubject(' + sid + ')"><i class="bi bi-plus-circle"></i> Pick</button>';
    }
}

/* ── Stagger row animations */
function initializeEventListeners() {
    document.querySelectorAll('.sb-row').forEach(function(r, i) {
        r.style.animationDelay = (i * 0.02) + 's';
    });

    /* Attach checkbox change events */
    document.querySelectorAll('.subject-check').forEach(function(cb) {
        cb.addEventListener('change', function() {
            updateRowVisual(this);
            updateCheckedCount();
        });
    });

    /* Attach select-all per department */
    document.querySelectorAll('.sb-check-all').forEach(function(allCb) {
        allCb.addEventListener('change', function() {
            var deptId = this.dataset.dept;
            var body = document.getElementById('deptBody' + deptId);
            if (!body) return;
            body.querySelectorAll('.subject-check').forEach(function(cb) {
                cb.checked = allCb.checked;
                // Trigger change event to update row visuals
                cb.dispatchEvent(new Event('change', { bubbles: true }));
            });
            updateCheckedCount();
        });
    });

    /* Unload confirmation button */
    var confirmUnloadBtn = document.getElementById('confirmUnloadBtn');
    if (confirmUnloadBtn) {
        confirmUnloadBtn.addEventListener('click', function() {
            if (!unloadTargetId) return;
            var container = document.getElementById('unloadFormSubjects');
            container.innerHTML = '';
            loadedSubjectIds.forEach(function(id) {
                if (id !== unloadTargetId) {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'subject_ids[]';
                    input.value = id;
                    container.appendChild(input);
                }
            });
            document.getElementById('unloadForm').submit();
        });
    }

    /* Department header toggle */
    document.querySelectorAll('.sb-dept-header').forEach(function(header) {
        header.addEventListener('click', function(e) {
            // Don't toggle if clicking on the detail link
            if (e.target.closest('.sb-dept-link')) return;

            var deptId = this.dataset.dept;
            if (deptId) {
                toggleDept(deptId);
            }
        });
    });

    /* Validate: require section for checked subjects only */
    var loadForm = document.getElementById('loadForm');
    if (loadForm) {
        loadForm.addEventListener('submit', function(e) {
            var missing = [];
            document.querySelectorAll('.subject-check:checked').forEach(function(cb) {
                var sid = cb.value;
                var sectionInput = document.querySelector('.sb-section-input[data-subject-id="' + sid + '"]');
                if (sectionInput && !sectionInput.value.trim()) {
                    missing.push(sectionInput);
                    sectionInput.style.borderColor = '#ef4444';
                    sectionInput.style.boxShadow = '0 0 0 3px rgba(239,68,68,.15)';
                }
            });
            if (missing.length > 0) {
                e.preventDefault();
                missing[0].focus();
                alert('Please fill in the Section for all selected subjects.');
                return false;
            }
        });
    }

    /* Clear error styling on input */
    document.querySelectorAll('.sb-section-input').forEach(function(inp) {
        inp.addEventListener('input', function() {
            this.style.borderColor = '';
            this.style.boxShadow = '';
        });
    });

    /* QR Code Modal */
    window.showQRModal = function(subjectId, subjectCode, subjectName, section, evalId, evalType, faculty, schoolYear) {
        const qrUrl = '{{ path('evaluation_qr_redirect_with_section', {'id': '__EVAL_ID__', 'subjectId': '__SUBJECT_ID__', 'section': '__SECTION__'}) }}'
            .replace('__EVAL_ID__', evalId)
            .replace('__SUBJECT_ID__', subjectId)
            .replace('__SECTION__', encodeURIComponent(section || ''));

        const fullUrl = window.location.origin + qrUrl;
        window.currentQrUrl = fullUrl;

        // Populate modal fields
        const typeBadge = document.getElementById('qrEvalType');
        typeBadge.textContent = evalType || 'SET';

        document.getElementById('qrEvalFaculty').textContent = faculty || '';
        document.getElementById('qrEvalSubject').textContent = `${subjectCode}${subjectName ? ' — ' + subjectName : ''}`;
        document.getElementById('qrEvalDetails').textContent = section || '';

        const detailsRow = document.getElementById('qrEvalDetailsRow');
        if (detailsRow) detailsRow.style.display = section ? '' : 'none';

        document.getElementById('qrUrl').textContent = fullUrl;

        // Generate QR code
        const qrContainer = document.getElementById('qrContainer');
        qrContainer.innerHTML = '';

        // Using QRCode.js library
        if (typeof QRCode !== 'undefined') {
            new QRCode(qrContainer, {
                text: fullUrl,
                width: 180,
                height: 180,
                colorDark: '#000000',
                colorLight: '#ffffff'
            });
        } else {
            // Fallback to QR server
            qrContainer.innerHTML = '<img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=' + encodeURIComponent(fullUrl) + '" alt="QR Code" style="max-width:180px;height:auto;">';
        }

        const modal = new bootstrap.Modal(document.getElementById('qrCodeModal'));
        modal.show();
    };

    window.copyQRLink = function(btn) {
        if (!btn) btn = event.target;
        navigator.clipboard.writeText(window.currentQrUrl).then(function() {
            var orig = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Copied!';
            setTimeout(function() { btn.innerHTML = orig; }, 1500);
        });
    };

    window.downloadQRCode = function() {
        const canvas = document.querySelector('#qrContainer canvas');
        const img = document.querySelector('#qrContainer img');

        if (canvas) {
            const link = document.createElement('a');
            link.href = canvas.toDataURL('image/png');
            link.download = 'evaluation-qr-' + new Date().getTime() + '.png';
            link.click();
        } else if (img) {
            const link = document.createElement('a');
            link.href = img.src;
            link.download = 'evaluation-qr-' + new Date().getTime() + '.png';
            link.click();
        }
    };
}

/* Initialize on page load */
document.addEventListener('DOMContentLoaded', initializeEventListeners);

/* Re-initialize after Turbo navigation (for semester filter) */
document.addEventListener('turbo:load', initializeEventListeners);

/* ─── Real-time QR Evaluation Updates ─── */
let lastCheckTime = 0;
let currentActiveEvals = activeEvaluations;

/**
 * Poll for active evaluations and update QR buttons if new ones appear
 * @param {boolean} forceImmediate - If true, bypass debounce check (e.g., when user loads a subject)
 */
window.pollActiveEvaluations = function(forceImmediate) {
    // Debounce: don't poll more frequently than every 5 seconds (unless forceImmediate)
    const now = Date.now();
    if (!forceImmediate && now - lastCheckTime < 5000) return;
    lastCheckTime = now;

    fetch('{{ path("api_active_evaluations") }}')
        .then(response => {
            if (!response.ok) throw new Error('Failed to fetch evaluations');
            return response.json();
        })
        .then(data => {
            const newEvals = data.evaluations || [];
            console.log('API response - Active evaluations:', newEvals, 'Count:', newEvals.length);

            // Check if evaluations have changed
            const newEvalMap = {};
            newEvals.forEach(e => {
                newEvalMap[e.id] = e;
            });

            const oldKeys = Object.keys(currentActiveEvals || {}).sort();
            const newKeys = Object.keys(newEvalMap).sort();

            // Debug log
            if (newKeys.length > 0 || oldKeys.length > 0) {
                console.log('Poll update - Old evaluations:', oldKeys, 'New evaluations:', newKeys);
            }

            // Only update if evaluation list actually changed
            if (JSON.stringify(oldKeys) !== JSON.stringify(newKeys)) {
                console.log('Evaluation list changed! Updating UI...');
                currentActiveEvals = newEvalMap;
                window.firstActiveEvalId = newKeys.length > 0 ? newKeys[0] : null;
                window.hasActiveEval = newKeys.length > 0;
                console.log('Updated hasActiveEval:', window.hasActiveEval, 'firstActiveEvalId:', window.firstActiveEvalId);

                // Update QR buttons for all loaded subjects
                updateQRButtonsForLoadedSubjects();
            }
        })
        .catch(error => {
            console.error('Evaluation poll error:', error);
        });
};

/**
 * Update QR buttons for all loaded subjects based on current active evaluations
 */
window.updateQRButtonsForLoadedSubjects = function() {
    // Get all rows with a loaded subject
    const loadedRows = document.querySelectorAll('tbody tr[data-subject-id]');

    loadedRows.forEach(row => {
        const checkbox = row.querySelector('.subject-check');
        if (!checkbox || !checkbox.checked) return; // Skip unloaded subjects

        const subjectId = parseInt(row.getAttribute('data-subject-id'));
        const codeCell = row.querySelector('.sb-code-text');
        const subjectCode = codeCell ? codeCell.textContent.trim() : '';

        // Find section from the section input field
        const sectionInput = row.querySelector('.sb-section-input');
        const section = sectionInput ? sectionInput.value.trim() : '';

        // Update QR column (9th column)
        const qrCell = row.querySelector('td:nth-child(9)');
        if (qrCell) {
            if (window.hasActiveEval && window.firstActiveEvalId) {
                qrCell.innerHTML = '<button type="button" class="sb-btn-qr sb-qr-btn-column" data-subject-id="' + subjectId + '" data-subject-code="' + subjectCode.replace(/"/g, '&quot;') + '" data-subject-name="' + subjectCode.replace(/"/g, '&quot;') + '" data-section="' + section.replace(/"/g, '&quot;') + '" data-eval-id="' + window.firstActiveEvalId + '" data-eval-type="SET" data-faculty="' + window.facultyName.replace(/"/g, '&quot;') + '" data-school-year="' + (window.firstEvalName || '').replace(/"/g, '&quot;') + '" title="Evaluation QR Code" style="width: 32px; height: 32px; border-radius: 6px; background: #e0f2fe; border: 1px solid #bae6fd; color: #0369a1; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: all .2s; font-size: .85rem;"><i class="bi bi-qr-code-scan"></i></button>';
            } else {
                qrCell.innerHTML = '<span class="text-muted small">No Evaluation</span>';
            }
        }

        // Update action buttons (with QR button if evaluation exists)
        const actionCell = row.querySelector('.sb-action-btns');
        if (!actionCell) return;

        let actionsHtml = '';

        // Add QR button if there's an active evaluation
        if (window.hasActiveEval && window.firstActiveEvalId) {
            actionsHtml += '<button type="button" class="sb-btn-qr sb-qr-btn" data-subject-id="' + subjectId + '" data-subject-code="' + subjectCode.replace(/"/g, '&quot;') + '" data-subject-name="' + subjectCode.replace(/"/g, '&quot;') + '" data-section="' + section.replace(/"/g, '&quot;') + '" data-eval-id="' + window.firstActiveEvalId + '" data-eval-type="SET" data-faculty="' + window.facultyName.replace(/"/g, '&quot;') + '" data-school-year="' + (window.firstEvalName || '').replace(/"/g, '&quot;') + '" title="Evaluation QR Code" style="width: 32px; height: 32px; border-radius: 6px; background: #e0f2fe; border: 1px solid #bae6fd; color: #0369a1; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: all .2s; font-size: .85rem;"><i class="bi bi-qr-code-scan"></i></button>';
        }

        // Add other action buttons
        actionsHtml += '<button type="button" class="sb-btn-pick" onclick="openPickAgainModal(' + subjectId + ', \'' + subjectCode.replace(/'/g,"\\'") + '\', \'Subject\')" title="Pick again with different section"><i class="bi bi-plus-circle"></i> Pick</button>';
        actionsHtml += '<button type="button" class="sb-btn-unload" onclick="unloadSubject(' + subjectId + ', \'' + subjectCode.replace(/'/g,"\\'") + '\')"><i class="bi bi-x-circle"></i> Unload</button>';

        actionCell.innerHTML = actionsHtml;
    });
};

/* ── Event delegation for QR button clicks (both column and action buttons) ── */
document.addEventListener('click', function(event) {
    const qrBtn = event.target.closest('.sb-qr-btn, .sb-qr-btn-column');
    if (qrBtn) {
        const subjectId = qrBtn.getAttribute('data-subject-id');
        const subjectCode = qrBtn.getAttribute('data-subject-code');
        const subjectName = qrBtn.getAttribute('data-subject-name');
        const section = qrBtn.getAttribute('data-section');
        const evalId = qrBtn.getAttribute('data-eval-id');
        const evalType = qrBtn.getAttribute('data-eval-type');
        const faculty = qrBtn.getAttribute('data-faculty');
        const schoolYear = qrBtn.getAttribute('data-school-year');

        if (subjectId && subjectCode && evalId) {
            window.showQRModal(parseInt(subjectId), subjectCode, subjectName, section || '', parseInt(evalId), evalType, faculty, schoolYear);
        }
    }
});

// Start polling for new evaluations immediately on load, then every 30 seconds
window.pollActiveEvaluations(true);  // Initial poll with forceImmediate to get fresh data
setInterval(pollActiveEvaluations, 30000);  // Then every 30 seconds with debounce
</script>

