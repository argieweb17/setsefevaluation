{# ═══════════════════════════════════════════════════
   JAVASCRIPT
   ═══════════════════════════════════════════════════ #}
<script>
(function() {
    'use strict';

    /* ── DOM references ── */
    var roleStep      = document.getElementById('roleStep');
    var googleGateStep= document.getElementById('googleGateStep');
    var formStep      = document.getElementById('formStep');
    var rgTitle       = document.getElementById('rgTitle');
    var rgSubtitle    = document.getElementById('rgSubtitle');
    var rolePill      = document.getElementById('rolePill');
    var changeRoleBtn = document.getElementById('changeRoleBtn');
    var roleSelect    = document.getElementById('{{ registrationForm.role.vars.id }}');
    var regForm       = document.getElementById('regForm');
    var emailInput       = document.getElementById('regEmail');
    var emailHiddenInput = document.getElementById('regEmailHidden');
    var submitBtn        = document.getElementById('regSubmitBtn');
    var stepsEl       = document.getElementById('rgSteps');

    /* Google gate DOM */
    var gateRoleTitle  = document.getElementById('gateRoleTitle');
    var gateRoleDesc   = document.getElementById('gateRoleDesc');
    var gateMsg        = document.getElementById('gateMsg');
    var gateCodeBox    = document.getElementById('gateCodeBox');
    var gateCodeInput  = document.getElementById('gateCodeInput');
    var gateCodeMsg    = document.getElementById('gateCodeMsg');
    var gateVerifyBtn  = document.getElementById('gateVerifyBtn');
    var gateBackBtn    = document.getElementById('gateBackBtn');

    /* Google gate state */
    var googleGateVerified  = false;
    var googleGateEmail     = '';
    var googleGateRole      = '';
    var googleSignInRendered= false;
    var googleAuthEnabled   = {{ googleAuthEnabled|default(false) ? 'true' : 'false' }};
    var googleGateHydration = {{ googleAuthState|default(null)|json_encode|raw }};
    var initialRoleValue    = '{{ registrationForm.role.vars.value|default('')|e('js') }}';
    var hasServerValidationErrors = {{ (registrationForm.vars.submitted and not registrationForm.vars.valid) ? 'true' : 'false' }};
    var hasServerSecurityError    = {{ (securityError|default(null)) ? 'true' : 'false' }};
    var googleScriptPromise = null;

    var roleConfig = {
        student: { label: 'Student', icon: 'bi-mortarboard', color: '#1E40AF', bg: '#1E3A8A' },
        faculty: { label: 'Faculty', icon: 'bi-person', color: '#059669', bg: '#1E3A8A' },
        staff:    { label: 'Staff',    icon: 'bi-clipboard2-check', color: '#D97706', bg: '#1E3A8A' },
        superior: { label: 'Superior', icon: 'bi-star',             color: '#7C3AED', bg: '#1E3A8A' }
    };

    /* ── Step progress helpers ── */
    function setStep(num) {
        var steps = stepsEl.querySelectorAll('.rg-step');
        var line  = stepsEl.querySelector('.rg-step-line');
        steps.forEach(function(s) {
            var n = parseInt(s.getAttribute('data-step'));
            s.classList.remove('active', 'completed');
            if (n === num)   s.classList.add('active');
            if (n < num)     s.classList.add('completed');
        });
        if (line) {
            if (num > 1) line.classList.add('active');
            else         line.classList.remove('active');
        }
    }

    /* ── Gate helpers ── */
    function setGateMsg(el, text, type) {
        if (!el) return;
        el.className = 'rg-gate-msg ' + type;
        el.textContent = text;
        el.classList.remove('d-none');
    }

    function showPanel(panel) {
        [roleStep, googleGateStep, formStep].forEach(function(p) {
            if (p) p.classList.add('d-none');
        });
        if (panel) {
            panel.classList.remove('d-none');
            panel.style.animation = 'none';
            void panel.offsetHeight;
            panel.style.animation = 'rgFadeIn 0.35s ease forwards';
        }
    }

    function ensureGoogleIdentityScript() {
        if (window.google && window.google.accounts && window.google.accounts.id) {
            return Promise.resolve(window.google);
        }
        if (googleScriptPromise) {
            return googleScriptPromise;
        }

        googleScriptPromise = new Promise(function(resolve, reject) {
            var existing = document.querySelector('script[data-google-gsi="1"]');
            if (existing) {
                var existingStatus = existing.getAttribute('data-google-gsi-status');
                if (existingStatus === 'loaded' && window.google && window.google.accounts && window.google.accounts.id) {
                    resolve(window.google);
                    return;
                }
                if (existingStatus === 'loading') {
                    existing.addEventListener('load', function() {
                        if (window.google && window.google.accounts && window.google.accounts.id) {
                            resolve(window.google);
                            return;
                        }
                        googleScriptPromise = null;
                        reject(new Error('Google Identity script loaded without API.'));
                    }, { once: true });
                    existing.addEventListener('error', function() {
                        googleScriptPromise = null;
                        reject(new Error('Failed to load Google Identity script.'));
                    }, { once: true });
                    return;
                }

                existing.remove();
            }

            var script = document.createElement('script');
            script.src = 'https://accounts.google.com/gsi/client';
            script.async = true;
            script.defer = true;
            script.setAttribute('data-google-gsi', '1');
            script.setAttribute('data-google-gsi-status', 'loading');
            script.onload = function() {
                script.setAttribute('data-google-gsi-status', 'loaded');
                if (window.google && window.google.accounts && window.google.accounts.id) {
                    resolve(window.google);
                    return;
                }
                googleScriptPromise = null;
                reject(new Error('Google Identity script loaded without API.'));
            };
            script.onerror = function() {
                script.setAttribute('data-google-gsi-status', 'error');
                googleScriptPromise = null;
                reject(new Error('Failed to load Google Identity script.'));
            };
            document.head.appendChild(script);
        });

        return googleScriptPromise;
    }

    function applyRoleFieldState(role, resetDependentFields) {
        /* Show/hide role-specific fields and toggle required markers */
        document.querySelectorAll('.role-field').forEach(function(el) {
            var forRoles = (el.getAttribute('data-for') || '').split(' ');
            var visible = forRoles.indexOf(role) !== -1;
            el.style.display = visible ? '' : 'none';
            el.querySelectorAll('input, select, textarea').forEach(function(inp) {
                if (!visible) {
                    if (inp.hasAttribute('required')) {
                        inp.removeAttribute('required');
                        inp.setAttribute('data-was-required', '1');
                    }
                    inp.disabled = true;
                } else {
                    inp.disabled = false;
                    if (inp.getAttribute('data-was-required') === '1') {
                        inp.setAttribute('required', 'required');
                        inp.removeAttribute('data-was-required');
                    }
                }
            });
        });

        /* Prevent duplicate department field submission */
        if (hiddenDeptSelect) hiddenDeptSelect.disabled = true;
        if (role === 'student') {
            if (studentDeptSel) studentDeptSel.disabled = false;
            if (facultyDeptSel) facultyDeptSel.disabled = true;
        } else if (role === 'faculty') {
            if (studentDeptSel) studentDeptSel.disabled = true;
            if (facultyDeptSel) facultyDeptSel.disabled = false;
        } else {
            if (studentDeptSel) studentDeptSel.disabled = true;
            if (facultyDeptSel) facultyDeptSel.disabled = true;
        }

        if (!resetDependentFields) {
            return;
        }

        /* Reset college-dependent selectors for roles that are not active */
        if (role !== 'faculty' && facultyCollegeSel) {
            facultyCollegeSel.value = '';
            if (facultyDeptSel) {
                facultyDeptSel.innerHTML = '<option value="">Select college first</option>';
                facultyDeptSel.disabled = true;
            }
        }
        if (role !== 'student' && studentCollegeSel) {
            studentCollegeSel.value = '';
            if (studentDeptSel) {
                studentDeptSel.innerHTML = '<option value="">Select college first</option>';
                studentDeptSel.disabled = true;
            }
        }
    }

    /* ── Select role ── */
    window.selectRole = function(role) {
        var cfg = roleConfig[role];
        if (!cfg) return;
        if (roleSelect) roleSelect.value = role;

        rolePill.innerHTML = '<i class="bi ' + cfg.icon + ' me-1"></i>' + cfg.label;
        rolePill.style.background = cfg.bg;
        applyRoleFieldState(role, true);

        /* Email input: all roles use hidden input pre-filled from Google gate */
        if (emailInput) {
            emailInput.disabled = true;
            emailInput.removeAttribute('required');
            emailInput.value = '';
        }
        if (emailHiddenInput) {
            emailHiddenInput.value = '';
        }

        /* Transition steps — all roles go through Google gate */
        googleGateRole = role;
        googleGateVerified = false;
        setStep(1);
        if (gateRoleTitle) {
            if (role === 'student') {
                gateRoleTitle.textContent = 'Student Registration — Verify with Google';
            } else {
                gateRoleTitle.textContent = cfg.label + ' Registration — Verify with Google';
            }
        }
        if (gateRoleDesc) {
            if (role === 'student') {
                gateRoleDesc.textContent = 'Sign in with your Google account to verify your email. A 6-digit code will be sent to your Gmail inbox.';
            } else {
                gateRoleDesc.textContent = 'Sign in with your Google account. A 6-digit code will be sent to your Gmail inbox.';
            }
        }
        if (gateMsg)       { gateMsg.classList.add('d-none'); gateMsg.textContent = ''; }
        if (gateCodeBox)   gateCodeBox.classList.add('d-none');
        if (gateCodeInput) gateCodeInput.value = '';
        if (gateCodeMsg)   gateCodeMsg.classList.add('d-none');
        showPanel(googleGateStep);
        renderGoogleButton(role);
    };

    /* ── Render (or re-render) the Google Sign-In button ── */
    window._rgRenderGoogleButton = function(role) {
        if (role) googleGateRole = role;
        var btnContainer = document.getElementById('google-signin-btn');
        if (!btnContainer || !googleAuthEnabled) return;

        ensureGoogleIdentityScript()
            .then(function() {
                if (typeof window.google === 'undefined' || !window.google.accounts) {
                    throw new Error('Google Identity API unavailable.');
                }

                if (!googleSignInRendered) {
                    window.google.accounts.id.initialize({
                        client_id: '{{ googleClientId|default("")|e("js") }}',
                        callback:  window.handleGoogleGateCredential,
                        ux_mode:   'popup',
                        auto_select: false,
                    });
                    googleSignInRendered = true;
                }

                /* Render the real GIS button inside the transparent overlay div */
                btnContainer.innerHTML = '';
                window.google.accounts.id.renderButton(btnContainer, {
                    type:  'standard',
                    theme: 'outline',
                    size:  'large',
                    text:  'signin_with',
                    shape: 'rectangular',
                    logo_alignment: 'left',
                    width: 260,
                });
                /* Stretch GIS button iframe to fill overlay so clicks register anywhere */
                var iframe = btnContainer.querySelector('iframe, div[role="button"]');
                if (iframe) { iframe.style.cssText += ';width:100%!important;height:100%!important;'; }
            })
            .catch(function() {
                showGateErrorModal('Google sign-in is unavailable right now. Please check your internet connection and try again.');
            });
    };
    function renderGoogleButton(role) { window._rgRenderGoogleButton(role); }

    function showGateErrorModal(msg) {
        var msgEl = document.getElementById('googleGateErrorMsg');
        if (msgEl) msgEl.textContent = msg;
        var m = new bootstrap.Modal(document.getElementById('googleGateErrorModal'));
        m.show();
    }

    /* ── Called by Google GIS when the user completes sign-in ── */
    window.handleGoogleGateCredential = function(googleResponse) {
        var idToken = googleResponse.credential;
        if (!idToken) {
            showGateErrorModal('Google sign-in failed. Please try again.');
            return;
        }
        setGateMsg(gateMsg, 'Signed in! Sending verification code…', 'info');

        fetch('{{ path("app_register_google_start") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ idToken: idToken, role: googleGateRole }),
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success) {
                if (data.duplicate) {
                    var dupModal = new bootstrap.Modal(document.getElementById('duplicateAccountModal'));
                    dupModal.show();
                } else {
                    showGateErrorModal(data.message || 'Failed to send verification code. Please try again.');
                }
                return;
            }
            googleGateEmail = data.email || '';
            var msgType = data.debugCode ? 'info' : 'success';
            var msg = data.message || 'Code sent! Check your Gmail inbox.';
            setGateMsg(gateMsg, msg, msgType);
            if (gateCodeBox) gateCodeBox.classList.remove('d-none');
            if (gateCodeInput) {
                /* In dev mode, auto-fill the code */
                gateCodeInput.value = data.debugCode ? String(data.debugCode) : '';
                gateCodeInput.focus();
            }
        })
        .catch(function() {
            showGateErrorModal('Network error. Please check your connection and try again.');
        });
    };

    /* ── Verify the code entered by user ── */
    function verifyGateCode() {
        var code = gateCodeInput ? gateCodeInput.value.trim() : '';
        if (code.length !== 6 || !/^\d{6}$/.test(code)) {
            setGateMsg(gateCodeMsg, 'Please enter the 6-digit code from your email.', 'error');
            return;
        }
        if (gateVerifyBtn) { gateVerifyBtn.disabled = true; gateVerifyBtn.textContent = 'Verifying…'; }

        fetch('{{ path("app_register_google_verify") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ code: code }),
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (gateVerifyBtn) { gateVerifyBtn.disabled = false; gateVerifyBtn.textContent = 'Verify'; }
            if (!data.success) {
                setGateMsg(gateCodeMsg, data.message || 'Incorrect code.', 'error');
                return;
            }
            /* ✓ Verified — proceed to registration form */
            googleGateVerified = true;
            googleGateEmail    = data.email || googleGateEmail;

            var cfg = roleConfig[googleGateRole] || {};
            rgTitle.textContent    = 'Create your account';
            rgSubtitle.textContent = 'Fill in your details to register as ' + (cfg.label || googleGateRole);

            /* Pre-fill email from Google verification into the hidden input */
            if (emailHiddenInput && googleGateEmail) {
                emailHiddenInput.value = googleGateEmail;
            }
            /* Keep any legacy visible field disabled (if present) */
            if (emailInput) {
                emailInput.value = '';
                emailInput.removeAttribute('required');
                emailInput.disabled = true;
            }

            setStep(2);
            showPanel(formStep);
        })
        .catch(function() {
            if (gateVerifyBtn) { gateVerifyBtn.disabled = false; gateVerifyBtn.textContent = 'Verify'; }
            setGateMsg(gateCodeMsg, 'Network error. Please try again.', 'error');
        });
    }

    if (gateVerifyBtn) gateVerifyBtn.addEventListener('click', verifyGateCode);
    if (gateCodeInput) {
        gateCodeInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') verifyGateCode();
        });
    }

    /* Back to role selection from gate */
    if (gateBackBtn) {
        gateBackBtn.addEventListener('click', function() {
            googleGateVerified = false;
            googleGateRole = '';
            showPanel(roleStep);
            setStep(1);
            rgTitle.textContent    = 'Choose your role';
            rgSubtitle.textContent = 'Select how you\'ll use the evaluation system';
        });
    }

    /* ── Change role (back from form) ── */
    if (changeRoleBtn) {
        changeRoleBtn.addEventListener('click', function() {
            if (emailHiddenInput) emailHiddenInput.value = '';
            if (emailInput) { emailInput.disabled = false; emailInput.value = ''; emailInput.setAttribute('required', 'required'); }
            showPanel(roleStep);
            setStep(1);
            rgTitle.textContent    = 'Choose your role';
            rgSubtitle.textContent = 'Select how you\'ll use the evaluation system';
        });
    }

    /* ── Submit with approval confirmation for non-student roles ── */
    var approvalModal = null;
    var approvalModalEl = document.getElementById('approvalConfirmModal');
    if (approvalModalEl && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
        approvalModal = new bootstrap.Modal(approvalModalEl);
    }
    var confirmProceedBtn = document.getElementById('confirmProceedBtn');
    var formConfirmed = false;

    if (regForm) {
        regForm.addEventListener('submit', function(e) {
            var selectedRole = roleSelect ? roleSelect.value : '';
            var needsApproval = (selectedRole === 'faculty' || selectedRole === 'staff' || selectedRole === 'superior');
            applyRoleFieldState(selectedRole, false);

            /* Always validate the form first — if invalid, let the browser show errors */
            if (!regForm.checkValidity()) {
                e.preventDefault();
                regForm.reportValidity();
                return;
            }

            /* Google gate check: all roles must be verified when Google auth is enabled */
            var hasVerifiedEmail = !!(emailHiddenInput && String(emailHiddenInput.value || '').trim() !== '');
            if (googleAuthEnabled && selectedRole && !googleGateVerified && !hasVerifiedEmail) {
                e.preventDefault();
                alert('Please complete Google sign-in and code verification before submitting.');
                showPanel(googleGateStep);
                setStep(1);
                renderGoogleButton(selectedRole);
                return;
            }

            /* If non-student and not yet confirmed, show the approval modal */
            if (needsApproval && !formConfirmed && approvalModal) {
                e.preventDefault();
                approvalModal.show();
                return;
            }

            /* Show loading state on actual submit */
            var load = submitBtn.querySelector('.rg-submit-loading');
            if (load) load.classList.remove('d-none');
            submitBtn.classList.add('rg-btn-loading');
            submitBtn.disabled = true;
        });
    }

    /* When user confirms in the modal, submit the form */
    if (confirmProceedBtn) {
        confirmProceedBtn.addEventListener('click', function() {
            formConfirmed = true;
            approvalModal.hide();
            regForm.requestSubmit();
        });
    }

    /* Reset confirmation flag if modal is dismissed */
    if (approvalModalEl) {
        approvalModalEl.addEventListener('hidden.bs.modal', function() {
            formConfirmed = false;
        });
    }

    /* ── Terms checkbox toggle ── */
    var termsWrap = document.getElementById('termsCheckboxWrap');
    var termsCheckbox = document.getElementById('agreeTermsCheck');
    var termsBox = document.getElementById('termsCheckboxBox');
    if (termsWrap && termsCheckbox && termsBox) {
        termsWrap.addEventListener('click', function(e) {
            e.preventDefault();
            termsCheckbox.checked = !termsCheckbox.checked;
            termsBox.classList.toggle('checked', termsCheckbox.checked);
        });
    }

    /* ── Password strength meter + requirements checklist ── */
    var pwdInput = document.getElementById('regPwd') || document.getElementById('{{ registrationForm.plainPassword.first.vars.id }}');
    var pwdBar   = document.getElementById('pwdBar');
    var pwdText  = document.getElementById('pwdText');
    var pwdConfirmInput = document.getElementById('regPwdConfirm') || document.getElementById('{{ registrationForm.plainPassword.second.vars.id }}');
    var pwdMatchIndicator = document.getElementById('pwdMatchIndicator');

    /* Requirements elements */
    var reqLength  = document.getElementById('reqLength');
    var reqUpper   = document.getElementById('reqUpper');
    var reqLower   = document.getElementById('reqLower');
    var reqNumber  = document.getElementById('reqNumber');
    var reqSpecial = document.getElementById('reqSpecial');

    function setReq(el, met) {
        if (!el) return;
        var icon = el.querySelector('i');
        if (met) {
            el.classList.add('met');
            el.classList.remove('unmet');
            if (icon) { icon.className = 'bi bi-check-circle-fill'; }
        } else {
            el.classList.remove('met');
            el.classList.add('unmet');
            if (icon) { icon.className = 'bi bi-circle'; }
        }
    }

    function checkPasswordMatch() {
        if (!pwdConfirmInput || !pwdMatchIndicator) return;
        var pwd = pwdInput ? pwdInput.value : '';
        var confirm = pwdConfirmInput.value;
        var icon = pwdMatchIndicator.querySelector('i');
        if (!confirm) {
            pwdMatchIndicator.classList.add('d-none');
            return;
        }
        pwdMatchIndicator.classList.remove('d-none');
        if (pwd === confirm) {
            pwdMatchIndicator.classList.add('matched');
            pwdMatchIndicator.classList.remove('unmatched');
            pwdMatchIndicator.querySelector('span').textContent = 'Passwords match';
            if (icon) icon.className = 'bi bi-check-circle-fill';
        } else {
            pwdMatchIndicator.classList.add('unmatched');
            pwdMatchIndicator.classList.remove('matched');
            pwdMatchIndicator.querySelector('span').textContent = 'Passwords do not match';
            if (icon) icon.className = 'bi bi-x-circle-fill';
        }
    }

    if (pwdInput && pwdBar && pwdText) {
        pwdInput.addEventListener('input', function() {
            var v = this.value;
            var hasLength  = v.length >= 8;
            var hasUpper   = /[A-Z]/.test(v);
            var hasLower   = /[a-z]/.test(v);
            var hasNumber  = /\d/.test(v);
            var hasSpecial = /[^A-Za-z0-9]/.test(v);

            /* Update requirements checklist */
            setReq(reqLength, hasLength);
            setReq(reqUpper, hasUpper);
            setReq(reqLower, hasLower);
            setReq(reqNumber, hasNumber);
            setReq(reqSpecial, hasSpecial);

            /* Calculate score for strength bar */
            var score = 0;
            if (hasLength) score++;
            if (v.length >= 12) score++;
            if (hasUpper && hasLower) score++;
            if (hasNumber) score++;
            if (hasSpecial) score++;

            var levels = [
                { w: '0%',   c: '#E5E7EB', t: 'Enter a password' },
                { w: '20%',  c: '#EF4444', t: 'Weak' },
                { w: '40%',  c: '#F59E0B', t: 'Fair' },
                { w: '60%',  c: '#F59E0B', t: 'Good' },
                { w: '80%',  c: '#10B981', t: 'Strong' },
                { w: '100%', c: '#059669', t: 'Very Strong' }
            ];
            var lv = levels[score] || levels[0];
            if (!v) lv = levels[0];
            pwdBar.style.width = lv.w;
            pwdBar.style.background = lv.c;
            pwdText.textContent = lv.t;
            pwdText.style.color = lv.c;

            /* Re-check match */
            checkPasswordMatch();
        });
    }

    /* Confirm password match check */
    if (pwdConfirmInput) {
        pwdConfirmInput.addEventListener('input', checkPasswordMatch);
    }

    /* ── Success modal ── */
    {% if registrationSuccess|default(false) %}
    if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
        if (typeof window.playSuccessModalSound === 'function') {
            window.playSuccessModalSound();
        }
        var successModal = new bootstrap.Modal(document.getElementById('registrationSuccessModal'));
        successModal.show();
    }
    {% endif %}

    /* ═══ College → Department filter (shared) ═══ */
    var deptCollegeMap = {{ deptCollegeMap|json_encode|raw }};
    var hiddenDeptSelect = document.getElementById('{{ registrationForm.department.vars.id }}');
    var studentCollegeSel = document.getElementById('studentCollege');
    var studentDeptSel    = document.getElementById('studentDepartment');
    var facultyCollegeSel = document.getElementById('facultyCollege');
    var facultyDeptSel    = document.getElementById('facultyDepartment');

    /* Harvest all department options from the hidden Symfony select */
    var allDeptOptions = [];
    if (hiddenDeptSelect) {
        Array.prototype.slice.call(hiddenDeptSelect.options).forEach(function(opt) {
            if (opt.value) {
                allDeptOptions.push({
                    value: String(opt.value),
                    text: opt.text,
                    college: (deptCollegeMap && deptCollegeMap[String(opt.value)] !== undefined)
                        ? String(deptCollegeMap[String(opt.value)])
                        : ''
                });
            }
        });
        hiddenDeptSelect.disabled = true;
    }

    function normalizeText(value) {
        return String(value || '').trim().toLowerCase();
    }

    function filterDeptsByCollege(collegeSel, deptSel) {
        if (!collegeSel || !deptSel) return;

        var college = collegeSel.value;
        deptSel.innerHTML = '';

        if (!college) {
            deptSel.innerHTML = '<option value="">Select college first</option>';
            deptSel.disabled = true;
            return;
        }

        var normalizedCollege = normalizeText(college);

        var placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.textContent = 'Select department';
        deptSel.appendChild(placeholder);

        var count = 0;
        allDeptOptions.forEach(function(opt) {
            if (normalizeText(opt.college) === normalizedCollege) {
                var o = document.createElement('option');
                o.value = opt.value;
                o.textContent = opt.text;
                deptSel.appendChild(o);
                count++;
            }
        });

        deptSel.disabled = (count === 0);
        if (count === 0) {
            deptSel.innerHTML = '<option value="">No departments found</option>';
        }
    }

    window.filterStudentDepts = function() {
        filterDeptsByCollege(studentCollegeSel, studentDeptSel);
    };

    window.filterFacultyDepts = function() {
        filterDeptsByCollege(facultyCollegeSel, facultyDeptSel);
    };

    if (studentCollegeSel) {
        studentCollegeSel.addEventListener('change', window.filterStudentDepts);
    }
    if (facultyCollegeSel) {
        facultyCollegeSel.addEventListener('change', window.filterFacultyDepts);
    }

    /* Restore server-side state when a submit returns with validation/security errors */
    if (googleGateHydration && googleGateHydration.verified) {
        googleGateVerified = true;
        googleGateEmail = String(googleGateHydration.email || '');
        googleGateRole = String(googleGateHydration.role || '');
        if (emailHiddenInput && !emailHiddenInput.value && googleGateEmail) {
            emailHiddenInput.value = googleGateEmail;
        }
    }

    if ((hasServerValidationErrors || hasServerSecurityError) && initialRoleValue && roleConfig[initialRoleValue]) {
        var initialCfg = roleConfig[initialRoleValue];
        if (roleSelect) roleSelect.value = initialRoleValue;

        rolePill.innerHTML = '<i class="bi ' + initialCfg.icon + ' me-1"></i>' + initialCfg.label;
        rolePill.style.background = initialCfg.bg;
        applyRoleFieldState(initialRoleValue, false);

        rgTitle.textContent = 'Create your account';
        rgSubtitle.textContent = 'Fill in your details to register as ' + initialCfg.label;
        setStep(2);
        showPanel(formStep);
    }
})();
</script>
{% endblock %}
