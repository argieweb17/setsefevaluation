<script src="{{ asset('vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
<script>
    'use strict';

    /* ── Submit loading state ── */
    var form = document.getElementById('studentLoginForm');
    var btn = document.getElementById('slSubmitBtn');
    if (form && btn) {
        form.addEventListener('submit', function() {
            var load = btn.querySelector('.sl-submit-loading');
            if (load) load.classList.remove('d-none');
            btn.classList.add('sl-btn-loading');
            btn.disabled = true;
        });
    }

    /* ── Focus animation on inputs ── */
    document.querySelectorAll('.sl-input').forEach(function(input) {
        input.addEventListener('focus', function() {
            this.closest('.sl-input-wrap').classList.add('sl-focused');
        });
        input.addEventListener('blur', function() {
            this.closest('.sl-input-wrap').classList.remove('sl-focused');
        });
    });
})();
</script>
