{% extends 'base.html.twig' %}

{% block title %}{{ title }} | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
.cr-header{border:1px solid #e5e7eb;border-bottom:0;border-radius:12px 12px 0 0;overflow:hidden;background:linear-gradient(135deg,#eff6ff,#f8fafc);margin-bottom:0;}
.cr-header-inner{padding:14px 16px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;}
.cr-title{color:#1e3a8a;font-size:1rem;font-weight:700;margin:0;}
.cr-sub{font-size:.78rem;color:#64748b;}
.cr-badge{display:inline-flex;align-items:center;gap:6px;font-size:.72rem;font-weight:600;padding:0;border-radius:0;background:transparent;color:#1e3a8a;}
.cr-card{background:#fff;border:1px solid #e5e7eb;border-top:0;border-radius:0 0 12px 12px;box-shadow:0 1px 5px rgba(15,23,42,.05);overflow:hidden;}
.cr-toolbar{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;padding:12px 14px;border-bottom:1px solid #e5e7eb;background:#fbfdff;}
.cr-search-wrap{position:relative;min-width:170px;flex:0 1 280px;max-width:280px;}
.cr-search-wrap i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.82rem;pointer-events:none;}
.cr-search{width:100%;border:1px solid #dbe2ec;border-radius:10px;padding:7px 10px 7px 30px;font-size:.82rem;color:#0f172a;outline:none;background:#fff;transition:border-color .18s,box-shadow .18s;}
.cr-search:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.08);}
.cr-filter-select{border:1px solid #dbe2ec;border-radius:10px;padding:7px 10px;font-size:.8rem;color:#334155;background:#fff;min-width:170px;outline:none;}
.cr-meta{font-size:.75rem;color:#64748b;white-space:nowrap;}
.cr-table{width:100%;border-collapse:collapse;}
.cr-table thead{background:#f8fafc;border-bottom:1px solid #e5e7eb;}
.cr-table th{padding:11px 12px;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.35px;}
.cr-th-wrap{display:inline-flex;align-items:center;gap:4px;}
.cr-th-sort{font-size:.66rem;color:#cbd5e1;line-height:1;}
.cr-table td{padding:11px 12px;border-bottom:1px solid #f1f5f9;font-size:.84rem;color:#0f172a;vertical-align:middle;}
.cr-table tr:last-child td{border-bottom:0;}
.cr-table tbody tr:hover{background:#f8fbff;}
.cr-pill{display:inline-flex;align-items:center;border-radius:999px;padding:3px 10px;font-size:.7rem;font-weight:700;letter-spacing:.25px;}
.cr-pill-set{background:#dbeafe;color:#1e3a8a;}
.cr-pill-sef{background:#dcfce7;color:#166534;}
.cr-muted{color:#64748b;}
.cr-empty{padding:32px 20px;text-align:center;color:#64748b;}
.cr-empty i{font-size:1.5rem;color:#94a3b8;display:block;margin-bottom:8px;}
.cr-file-link{display:inline-flex;align-items:center;gap:5px;border:1px solid #cbd5e1;background:#fff;color:#1e3a8a;text-decoration:none;border-radius:8px;padding:4px 10px;font-size:.72rem;font-weight:700;}
.cr-file-link:hover{background:#eff6ff;color:#1e3a8a;border-color:#93c5fd;}
.cr-action-cell{white-space:nowrap;}
.cr-action-wrap{display:flex;align-items:center;gap:8px;}
.cr-action-wrap form{margin:0;}
.cr-icon-btn{width:34px;height:34px;display:inline-flex;align-items:center;justify-content:center;border-radius:10px;border:none;background:transparent;cursor:pointer;transition:all .18s ease;box-shadow:none;}
.cr-icon-btn i{font-size:.94rem;line-height:1;}
.cr-icon-btn-release{color:#166534;}
.cr-icon-btn-release:hover{background:transparent;color:#14532d;}
.cr-icon-btn-delete{color:#b91c1c;}
.cr-icon-btn-delete:hover{background:transparent;color:#991b1b;}
.cr-icon-state{width:34px;height:34px;display:inline-flex;align-items:center;justify-content:center;border-radius:10px;border:none;background:transparent;color:#166534;box-shadow:none;}
.cr-icon-state i{font-size:.94rem;line-height:1;}
.cr-no-match td{text-align:center;color:#64748b;font-style:italic;padding:16px 12px;}
@media(max-width:768px){
    .cr-toolbar{padding:10px;}
    .cr-search-wrap{max-width:220px;min-width:140px;flex:0 1 220px;}
    .cr-filter-select{min-width:140px;}
    .cr-meta{width:100%;}
    .cr-table{font-size:.78rem;}
    .cr-table th,.cr-table td{padding:9px 8px;}
}
</style>
{% endblock %}

{% block body %}
<div class="cr-header">
    <div class="cr-header-inner">
        <div>
            <h1 class="cr-title">{{ title }}</h1>
            <div class="cr-sub">Saved correspondence IDs from generated print files.</div>
        </div>
        <span class="cr-badge"><i  class="bi bi-archive"></i> {{ records|length }} record{{ records|length != 1 ? 's' : '' }}</span>
    </div>
</div>

<div class="cr-card">
    {% if records is empty %}
    <div class="cr-empty">
        <i  class="bi bi-inbox"></i>
        No correspondence IDs saved yet for {{ idType }}.
    </div>
    {% else %}
    {% set academicYears = [] %}
    {% for row in records %}
        {% if row.createdAt %}
            {% set startYear = row.createdAt|date('Y') %}
            {% set ay = startYear ~ '-' ~ (startYear + 1) %}
            {% if ay not in academicYears %}
                {% set academicYears = academicYears|merge([ay]) %}
            {% endif %}
        {% endif %}
    {% endfor %}
    {% set academicYears = academicYears|sort|reverse %}

    <div class="cr-toolbar">
        <div class="cr-search-wrap">
            <i  class="bi bi-search"></i>
            <input type="search" id="crSearchInput" class="cr-search" placeholder="Search correspondence ID, scope, saved by, or date...">
        </div>
        <select id="crYearFilter" class="cr-filter-select" aria-label="Filter by academic year">
            <option value="">All Academic Years</option>
            {% for ay in academicYears %}
                <option value="{{ ay }}">{{ ay }}</option>
            {% endfor %}
        </select>
        <div class="cr-meta" id="crFilterMeta">Showing {{ records|length }} of {{ records|length }}</div>
    </div>
    <div class="table-responsive">
        <table class="cr-table">
            <thead>
                <tr>
                    <th><span class="cr-th-wrap">Document ID <i  class="bi bi-arrow-down-up cr-th-sort"></i></span></th>
                    <th style="width:120px;"><span class="cr-th-wrap">Type <i  class="bi bi-arrow-down-up cr-th-sort"></i></span></th>
                    <th style="width:220px;"><span class="cr-th-wrap">Faculty Name <i  class="bi bi-arrow-down-up cr-th-sort"></i></span></th>
                    <th style="width:190px;"><span class="cr-th-wrap">Record By <i  class="bi bi-arrow-down-up cr-th-sort"></i></span></th>
                    <th style="width:180px;"><span class="cr-th-wrap">Record Date <i  class="bi bi-arrow-down-up cr-th-sort"></i></span></th>
                    <th style="width:120px;"><span class="cr-th-wrap">File <i  class="bi bi-arrow-down-up cr-th-sort"></i></span></th>
                    <th style="width:110px;"><span class="cr-th-wrap">Action <i  class="bi bi-arrow-down-up cr-th-sort"></i></span></th>
                </tr>
            </thead>
            <tbody>
                {% for row in records %}
                <tr class="cr-row"
                    data-academic-year="{{ row.createdAt ? (row.createdAt|date('Y') ~ '-' ~ ((row.createdAt|date('Y')) + 1)) : '' }}"
                    data-search="{{ row.correspondenceId }} {{ row.facultyName ?: 'N/A' }} {% if row.createdBy %}{{ row.createdBy.fullName }}{% else %}System{% endif %} {{ row.createdAt ? row.createdAt|date('M d, Y h:i A') : '' }} {{ row.evaluationType }}">
                    <td>{{ row.correspondenceId }}</td>
                    <td>
                        <span class="cr-pill {{ row.evaluationType == 'SEF' ? 'cr-pill-sef' : 'cr-pill-set' }}">{{ row.evaluationType }}</span>
                    </td>
                    <td>{{ row.facultyName ?: 'N/A' }}</td>
                    <td>
                        {% if row.createdBy %}
                            {{ row.createdBy.fullName }}
                        {% else %}
                            <span class="cr-muted">System</span>
                        {% endif %}
                    </td>
                    <td>{{ row.createdAt ? row.createdAt|date('M d, Y h:i A') : '' }}</td>
                    <td>
                        <a href="{{ path('staff_correspondence_file', {id: row.id}) }}" class="cr-file-link" target="_blank" rel="noopener noreferrer">
                            <i  class="bi bi-file-earmark-arrow-down"></i> PDF
                        </a>
                    </td>
                    <td class="cr-action-cell">
                        <div class="cr-action-wrap">
                            {% if not row.isReleased %}
                                <button type="button"
                                        class="cr-icon-btn cr-icon-btn-release"
                                        data-bs-toggle="modal"
                                        data-bs-target="#releaseModal{{ row.id }}"
                                        title="Release">
                                    <i  class="bi bi-check-circle-fill"></i>
                                    <span class="visually-hidden">Release</span>
                                </button>
                            {% else %}
                                <span class="cr-icon-state" title="Released">
                                    <i  class="bi bi-check-circle-fill"></i>
                                    <span class="visually-hidden">Released</span>
                                </span>
                            {% endif %}

                            <form method="post" action="{{ path('staff_correspondence_delete', {id: row.id}) }}" onsubmit="return confirm('Delete this correspondence record?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_correspondence' ~ row.id) }}">
                                <button type="submit" class="cr-icon-btn cr-icon-btn-delete" title="Delete">
                                    <i  class="bi bi-trash"></i>
                                    <span class="visually-hidden">Delete</span>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
                <tr id="crNoMatchRow" class="cr-no-match" style="display:none;">
                    <td colspan="7">No records match your filter.</td>
                </tr>
            </tbody>
        </table>
    </div>
    {% endif %}
</div>

{% if records is not empty %}
    {% for row in records %}
    {% if not row.isReleased %}
    <div class="modal fade" id="releaseModal{{ row.id }}" tabindex="-1" aria-labelledby="releaseModalLabel{{ row.id }}" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form method="post" action="{{ path('staff_correspondence_release', {id: row.id}) }}">
                    <div class="modal-header">
                        <h5 class="modal-title" id="releaseModalLabel{{ row.id }}">Release {{ row.correspondenceId }}</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="_token" value="{{ csrf_token('release_correspondence' ~ row.id) }}">

                        <div class="mb-2">
                            <label class="form-label form-label-sm">Name Received</label>
                            <input type="text" name="received_by_name" class="form-control form-control-sm" maxlength="120" required>
                        </div>

                        <div class="mb-2">
                            <label class="form-label form-label-sm">Release Date</label>
                            <input type="date" name="release_date" class="form-control form-control-sm" value="{{ 'now'|date('Y-m-d') }}" required>
                        </div>

                        <div>
                            <label class="form-label form-label-sm">Automatic Time</label>
                            <input type="text" class="form-control form-control-sm" value="{{ 'now'|date('h:i A') }}" readonly>
                            <div class="form-text">Current time is applied automatically when you submit release.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success btn-sm"><i  class="bi bi-check-circle-fill"></i> Confirm Release</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {% endif %}
    {% endfor %}
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(() => {
    const searchInput = document.getElementById('crSearchInput');
    const yearFilter = document.getElementById('crYearFilter');
    const rows = Array.from(document.querySelectorAll('.cr-row'));
    const noMatchRow = document.getElementById('crNoMatchRow');
    const meta = document.getElementById('crFilterMeta');

    const total = rows.length;

    const applyFilters = function () {
        const term = (searchInput.value || '').trim().toLowerCase();
        const selectedYear = (yearFilter.value || '').trim();
        let visible = 0;

        rows.forEach(function (row) {
            const haystack = (row.getAttribute('data-search') || '').toLowerCase();
            const rowYear = (row.getAttribute('data-academic-year') || '').trim();
            const passText = !term || haystack.includes(term);
            const passYear = !selectedYear || rowYear === selectedYear;
            const show = passText && passYear;

            row.style.display = show ? '' : 'none';
            if (show) {
                visible++;
            }
        });

        if (noMatchRow) {
            noMatchRow.style.display = visible === 0 ? '' : 'none';
        }

        if (meta) {
            meta.textContent = 'Showing ' + visible + ' of ' + total;
        }
    };

    if (searchInput && yearFilter && rows.length > 0) {
        searchInput.addEventListener('input', applyFilters);
        yearFilter.addEventListener('change', applyFilters);
    }

})();
</script>
{% endblock %}
