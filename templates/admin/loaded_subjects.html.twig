                        <input type="hidden" name="_token" value="{{ csrf_token('unload_subject_' ~ s.subject.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Unload subject" style="padding:2px 8px;font-size:.75rem;border-radius:6px">
                            <i class="bi bi-x-circle"></i>
                        </button>
