{% extends 'base.html.twig' %}

{% block title %}Welcome | SET - SEF Evaluation System{% endblock %}

{% block body_class %}no-navbar{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
{% include 'home/_fes_styles.html.twig' %}
</style>
{% endblock %}

{% block body %}
{% set currentHeroView = heroView|default('home') %}
<div class="fes-page">
    {% include 'home/_fes_header.html.twig' with {active: currentHeroView} %}

    <button type="button" class="fes-hero-announcement-wrap fes-hero-announcement-trigger" id="announcementTrigger" aria-label="Open announcement">
        <span class="fes-hero-announcement-tab"><i class="bi bi-megaphone-fill"></i><span>Announcement</span></span>
    </button>

    {# ── Hero Section ── #}
    <section class="fes-hero" id="hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <div class="fes-hero-content">
                        <div class="fes-hero-panel" data-hero-view="home" {{ currentHeroView == 'home' ? '' : 'hidden' }}>
                            <h1 class="fes-hero-title">SET - SEF Evaluation System <span class="fes-hero-version">Ver 1.0</span></h1>
                            <p class="fes-hero-subtitle">Students, Superior, and Faculty can now evaluate through this online tool.</p>

                            <ul class="fes-hero-features">
                                <li>Students can evaluate faculty of subjects enrolled in a semester</li>
                                <li>Superior can evaluate his/her subordinate</li>
                                <li>Faculty can evaluate his/her self and his/her peers</li>
                            </ul>

                            <div class="d-flex gap-4 flex-wrap fes-hero-cta-row">
                                <div class="fes-hero-buttons">
                                    <span class="fes-hero-label">* You can now login!</span>
                                    <a href="{{ path('app_login') }}" class="fes-btn-login">
                                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                                    </a>
                                </div>
                                <div class="fes-hero-buttons">
                                    <span class="fes-hero-label">* You can now register!</span>
                                    <a href="{{ path('app_register') }}" class="fes-btn-register">
                                        <i class="bi bi-person-fill"></i> Register
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="fes-hero-panel" data-hero-view="about" {{ currentHeroView == 'about' ? '' : 'hidden' }}>
                            <h1 class="fes-hero-title">About the System</h1>
                            <p class="fes-hero-subtitle">The Faculty Evaluation System is an online platform for transparent and meaningful academic assessment of faculty performance.</p>

                            <ul class="fes-hero-features">
                                <li><strong>Secure and Confidential</strong>: all evaluations are anonymous, ensuring honest and unbiased feedback.</li>
                                <li><strong>Real-Time Results</strong>: administrators and faculty can access data as soon as evaluation periods close.</li>
                                <li><strong>Role-Based Access</strong>: students, staff, faculty, and supervisors each get the right tools.</li>
                            </ul>

                            <div class="d-flex gap-4 flex-wrap fes-hero-cta-row">
                                <div class="fes-hero-buttons">
                                    <span class="fes-hero-label">* Ready to start?</span>
                                    <a href="{{ path('app_register') }}" class="fes-btn-register">
                                        <i class="bi bi-person-fill"></i> Register
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="fes-hero-panel" data-hero-view="faq" {{ currentHeroView == 'faq' ? '' : 'hidden' }}>
                            <h1 class="fes-hero-title">Frequently Asked Questions</h1>
                            <p class="fes-hero-subtitle">Quick answers to common questions about using the SET-SEF Evaluation System.</p>

                            <ul class="fes-hero-features">
                                <li><strong>Who can use this system?</strong> Students, faculty, supervisors, peers, and administrators with role-based access.</li>
                                <li><strong>Are evaluations anonymous?</strong> Yes, responses are confidential to encourage honest feedback.</li>
                                <li><strong>How do I register?</strong> Click Register, complete your information, and wait for account approval.</li>
                            </ul>

                            <div class="d-flex gap-4 flex-wrap fes-hero-cta-row">
                                <div class="fes-hero-buttons">
                                    <span class="fes-hero-label">* Need an account?</span>
                                    <a href="{{ path('app_register') }}" class="fes-btn-register">
                                        <i class="bi bi-person-fill"></i> Register
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="fes-hero-panel" data-hero-view="contact" {{ currentHeroView == 'contact' ? '' : 'hidden' }}>
                            <h1 class="fes-hero-title">Contact Us</h1>
                            <p class="fes-hero-subtitle">Reach our support team for assistance, account concerns, or system-related inquiries.</p>

                            <ul class="fes-hero-features">
                                <li><strong>Location</strong>: Main Campus, Negros Oriental State University</li>
                                <li><strong>Email</strong>: support@example.edu.ph</li>
                                <li><strong>Phone</strong>: (000) 000-0000 (Mon-Fri, 8 AM - 5 PM)</li>
                            </ul>

                            <div class="d-flex gap-4 flex-wrap fes-hero-cta-row">
                                <div class="fes-hero-buttons">
                                    <span class="fes-hero-label">* Prefer email?</span>
                                    <a href="mailto:support@example.edu.ph" class="fes-btn-login">
                                        <i class="bi bi-envelope"></i> Send Email
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="fes-hero-image fes-hero-logo-card">
                        <img src="{{ asset('images/quamc-logo.png') }}" alt="QUAMC Logo" class="fes-quamc-logo">
                        <h3 class="fes-quamc-title">NORSU</h3>
                        <p class="fes-quamc-subtitle">Quality Assured - Nationally Accredited</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ── Stats Section ── #}
    <section class="fes-stats" id="stats">
        <div class="container">
            <div class="fes-stats-grid">
                <div class="fes-stat-card">
                    <div class="fes-stat-icon">
                        <i class="bi bi-mortarboard"></i>
                    </div>
                    <div class="fes-stat-number" data-target="{{ studentCount|default(0) }}">0</div>
                    <div class="fes-stat-label">Students</div>
                </div>
                <div class="fes-stat-card">
                    <div class="fes-stat-icon">
                        <i class="bi bi-person-workspace"></i>
                    </div>
                    <div class="fes-stat-number" data-target="{{ facultyCount|default(0) }}">0</div>
                    <div class="fes-stat-label">Faculty</div>
                </div>
                <div class="fes-stat-card">
                    <div class="fes-stat-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <div class="fes-stat-number" data-target="{{ staffCount|default(0) }}">0</div>
                    <div class="fes-stat-label">Staff</div>
                </div>
                <div class="fes-stat-card">
                    <div class="fes-stat-icon">
                        <i class="bi bi-clipboard-check"></i>
                    </div>
                    <div class="fes-stat-number" data-target="{{ evaluationCount|default(0) }}">0</div>
                    <div class="fes-stat-label">Evaluations</div>
                </div>
            </div>
        </div>
    </section>

    {% include 'home/_fes_footer.html.twig' %}
</div>

<div class="fes-announcement-overlay" id="announcementOverlay" aria-hidden="true">
    <div class="fes-announcement-panel" role="dialog" aria-modal="true" aria-labelledby="announcementPanelTitle">
        <div class="fes-announcement-panel-header">
            <div>
                <h2 class="mb-0 fw-bold" id="announcementPanelTitle">Announcement</h2>
                <small>Latest updates for the SET-SEF Evaluation System</small>
            </div>
            <button type="button" class="btn-close btn-close-white" id="announcementClose" aria-label="Close announcement"></button>
        </div>
        <div class="fes-announcement-panel-body">
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="fes-hero-announcement-kicker"><i class="bi bi-megaphone-fill"></i>Announcement</span>
            </div>
            <h3 class="fes-hero-announcement-title">{{ systemAnnouncementTitle|default('New evaluation schedules and updates are now available.') }}</h3>
            <p class="fes-hero-announcement-text">{{ systemAnnouncementBodyHtml|default('Please check your evaluation period, assigned subjects, and reminders before submitting. All notices will be posted here for students, faculty, and staff.')|raw }}</p>
            {% if systemAnnouncementUpdatedAt or systemAnnouncementUpdatedBy %}
            <div class="text-muted mt-2" style="font-size:.8rem;">
                <i class="bi bi-clock-history me-1"></i>
                {% if systemAnnouncementUpdatedAt %}
                    Updated {{ systemAnnouncementUpdatedAt|date('M d, Y h:i A') }}
                {% else %}
                    Updated recently
                {% endif %}
                {% if systemAnnouncementUpdatedBy %} by {{ systemAnnouncementUpdatedBy }}{% endif %}
            </div>
            {% endif %}
            <div class="fes-hero-announcement-links">
                <a href="{{ path('app_login') }}" class="fes-hero-announcement-link">
                    <i class="bi bi-arrow-right-circle"></i>
                    View Details
                </a>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';

    function formatNumber(value) {
        return new Intl.NumberFormat().format(value);
    }

    function animateCounter(el) {
        var target = parseInt(el.getAttribute('data-target') || '0', 10);
        if (!Number.isFinite(target) || target < 0) {
            target = 0;
        }

        var duration = 1200;
        var startTime = null;

        function tick(timestamp) {
            if (!startTime) {
                startTime = timestamp;
            }

            var progress = Math.min((timestamp - startTime) / duration, 1);
            var current = Math.round(progress * target);
            el.textContent = formatNumber(current);

            if (progress < 1) {
                window.requestAnimationFrame(tick);
            }
        }

        window.requestAnimationFrame(tick);
    }

    function initCountUp() {
        var statsSection = document.getElementById('stats');
        if (!statsSection) {
            return;
        }

        var counters = statsSection.querySelectorAll('.fes-stat-number[data-target]');
        if (!counters.length) {
            return;
        }

        var hasStarted = false;
        function runCounters() {
            if (hasStarted) {
                return;
            }
            hasStarted = true;
            counters.forEach(function(counter, index) {
                window.setTimeout(function() {
                    animateCounter(counter);
                }, index * 120);
            });
        }

        if ('IntersectionObserver' in window) {
            var observer = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        runCounters();
                        observer.disconnect();
                    }
                });
            }, { threshold: 0.35 });

            observer.observe(statsSection);
            return;
        }

        runCounters();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCountUp);
    } else {
        initCountUp();
    }

    function initAnnouncementOverlay() {
        var trigger = document.getElementById('announcementTrigger');
        var overlay = document.getElementById('announcementOverlay');
        var closeBtn = document.getElementById('announcementClose');
        if (!trigger || !overlay || !closeBtn) return;

        function openOverlay() {
            overlay.classList.add('is-open');
            overlay.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeOverlay() {
            overlay.classList.remove('is-open');
            overlay.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        trigger.addEventListener('click', openOverlay);
        closeBtn.addEventListener('click', closeOverlay);
        overlay.addEventListener('click', function(e) {
            if (e.target === overlay) closeOverlay();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
                closeOverlay();
            }
        });
    }

    initAnnouncementOverlay();
})();
</script>
{% endblock %}
