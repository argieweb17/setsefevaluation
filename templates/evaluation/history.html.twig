{% extends 'base.html.twig' %}

{% block title %}Evaluation History | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
.eh-page { max-width: 1140px; margin: 0 auto; }
.eh-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; }
.eh-header-title { font-size: 1.5rem; font-weight: 800; color: #0f172a; letter-spacing: -.02em; margin: 0; line-height: 1.2; }
.eh-header-sub { font-size: .85rem; color: #64748b; margin-top: .25rem; }

.eh-chips { display: flex; gap: .75rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
.eh-chip { display: inline-flex; align-items: center; gap: .5rem; background: transparent; border: none; border-radius: 0; padding: 0; font-size: .82rem; color: #334155; font-weight: 500; }
.eh-chip-icon { width: auto; height: auto; border-radius: 0; display: flex; align-items: center; justify-content: center; font-size: .9rem; color: #2563eb; flex-shrink: 0; background: transparent; }
.eh-chip-val { font-weight: 700; }

.eh-panel { background: #fff; border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 1px 3px rgba(0,0,0,.04); overflow: hidden; margin-bottom: 1rem; }
.eh-panel-head { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .75rem; padding: .85rem 1.25rem; border-bottom: 1px solid #f1f5f9; background: #fafbfc; }
.eh-panel-title { font-size: .85rem; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: .45rem; }
.eh-panel-title i { color: #2563eb; font-size: .95rem; }
.eh-panel-badge { font-size: .7rem; font-weight: 600; background: transparent; color: #2563eb; padding: 0; border-radius: 0; }

/* Remove card-style background box for grouped history panels */
.eh-panel[data-period] { background: transparent; border: none; box-shadow: none; border-radius: 0; overflow: visible; }
.eh-panel[data-period] .eh-panel-head { background: transparent; border-bottom: none; padding: .3rem 0 .65rem; }

.eh-search-wrap { position: relative; }
.eh-search-wrap > i { position: absolute; left: .7rem; top: 50%; transform: translateY(-50%); font-size: .8rem; color: #94a3b8; pointer-events: none; }
.eh-search-wrap input { border: 1.5px solid #e2e8f0; border-radius: 10px; padding: .4rem .75rem .4rem 2rem; font-size: .8rem; width: 200px; transition: border-color .15s, box-shadow .15s; background: #f8fafc; }
.eh-search-wrap input:focus { border-color: #2563eb; outline: none; box-shadow: 0 0 0 3px rgba(37,99,235,.08); background: #fff; }

.eh-list { display: flex; flex-direction: column; }
.eh-item { display: flex; align-items: center; gap: .5rem; padding: .8rem 1.25rem; border-bottom: 1px solid #f1f5f9; transition: background .1s; }
.eh-item:last-child { border-bottom: none; }
.eh-item:hover { background: #f8fafc; }

.eh-item-body { flex: 1; min-width: 0; }
.eh-item-top { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
.eh-item-code { display: inline-flex; align-items: center; gap: .25rem; background: transparent; color: #1d4ed8; padding: 0; border-radius: 0; font-size: .72rem; font-weight: 700; letter-spacing: .3px; }
.eh-item-name { font-weight: 600; font-size: .85rem; color: #0f172a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.eh-item-meta { display: flex; gap: .6rem; flex-wrap: wrap; font-size: .7rem; color: #94a3b8; margin-top: .25rem; }
.eh-item-meta span { display: inline-flex; align-items: center; gap: .2rem; }

.eh-rating { display: inline-flex; align-items: center; gap: .35rem; padding: .3rem .65rem; border-radius: 50px; font-size: .78rem; font-weight: 700; flex-shrink: 0; }
.eh-rating-excellent { background: #dcfce7; color: #166534; }
.eh-rating-good { background: #dbeafe; color: #1e40af; }
.eh-rating-average { background: #fef9c3; color: #854d0e; }
.eh-rating-poor { background: #fee2e2; color: #991b1b; }
.eh-rating i { font-size: .7rem; }

.eh-submitted-badge { display: inline-flex; align-items: center; gap: .3rem; padding: 0; border-radius: 0; font-size: .68rem; font-weight: 600; background: transparent; color: #166534; flex-shrink: 0; }

/* Empty State */
.eh-empty { text-align: center; padding: 4rem 2rem 3.5rem; }
.eh-empty-illustration { width: 130px; height: 130px; margin: 0 auto 1.5rem; background: linear-gradient(135deg, #eff6ff 0%, #faf5ff 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; position: relative; }
.eh-empty-illustration::before { content: ''; position: absolute; inset: -8px; border-radius: 50%; border: 2px dashed #d1d5db; animation: eh-spin 20s linear infinite; }
@keyframes eh-spin { to { transform: rotate(360deg); } }
.eh-empty-illustration i { font-size: 3.2rem; color: #7c3aed; opacity: .5; }
.eh-empty-title { font-size: 1.05rem; font-weight: 700; color: #0f172a; margin-bottom: .35rem; }
.eh-empty-desc { font-size: .84rem; color: #64748b; max-width: 340px; margin: 0 auto; line-height: 1.5; }

@media (max-width: 768px) {
    .eh-header-title { font-size: 1.25rem; }
    .eh-item { padding: .7rem .85rem; }
    .eh-search-wrap input { width: 150px; }
}
</style>
{% endblock %}

{% block body %}

{% set totalAvg = 0 %}
{% set totalCount = 0 %}
{% for item in history %}
    {% set totalAvg = totalAvg + item.avgRating %}
    {% set totalCount = totalCount + 1 %}
{% endfor %}

<div class="eh-page">

<div class="eh-header">
    <div>
        <h1 class="eh-header-title">Evaluation History</h1>
        <div class="eh-header-sub">Review your previously submitted evaluations</div>
    </div>
    {% if history|length > 0 %}
    <div class="eh-search-wrap">
        <i  class="bi bi-search"></i>
        <input type="search" id="ehSearch" placeholder="Search history...">
    </div>
    {% endif %}
</div>

{% if history|length > 0 %}
<div class="eh-chips">
    <div class="eh-chip">
        <span class="eh-chip-icon"><i  class="bi bi-check2-all"></i></span>
        <span><span class="eh-chip-val">{{ history|length }}</span> Submitted</span>
    </div>

</div>

{# ── Group by semester/school year ── #}
{% set grouped = {} %}
{% for item in history %}
    {% set key = item.semester and item.schoolYear
        ? item.semester ~ ' — ' ~ item.schoolYear
        : (item.schoolYear ?: item.semester) %}
    {% set grouped = grouped|merge({ (key): (grouped[key] is defined ? grouped[key] : [])|merge([item]) }) %}
{% endfor %}

{% for period, items in grouped %}
<div class="eh-panel" data-period="{{ period|lower }}">
    <div class="eh-panel-head">
        <div class="eh-panel-title">
            <i  class="bi bi-calendar3"></i>
            {{ period }}
        </div>
        <span class="eh-panel-badge">{{ items|length }} evaluation{{ items|length > 1 ? 's' : '' }}</span>
    </div>
    <div class="eh-list">
        {% for item in items %}
            {% set avg = item.avgRating|round(2) %}
            <div class="eh-item" data-search="{{ item.subjectCode ?? '' }} {{ item.subjectName ?? '' }} {{ item.facultyName }}">
                <div class="eh-item-body">
                    <div class="eh-item-top">
                        {% if item.subjectCode %}
                            <span class="eh-item-code">{{ item.subjectCode }}</span>
                        {% endif %}
                        <span class="eh-item-name">{% if item.subjectName %}{{ item.subjectName }}{% else %}{{ item.facultyName }}{% endif %}</span>
                    </div>
                    <div class="eh-item-meta">
                        <span><i  class="bi bi-person"></i> {{ item.facultyName }}</span>
                        <span><i  class="bi bi-clock"></i> {{ item.submittedAt|date('M d, Y g:i A') }}</span>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:.5rem;flex-shrink:0;">
                    <span class="eh-submitted-badge"><i  class="bi bi-check-circle-fill"></i> Submitted</span>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endfor %}

{% else %}
<div class="eh-panel">
    <div class="eh-panel-head">
        <div class="eh-panel-title"><i  class="bi bi-clock-history"></i> History</div>
    </div>
    <div class="eh-empty">
        <div class="eh-empty-illustration">
            <i  class="bi bi-clock-history"></i>
        </div>
        <div class="eh-empty-title">No evaluation history yet</div>
        <div class="eh-empty-desc">Your submitted evaluations will appear here once you complete them during an active evaluation period.</div>
    </div>
</div>
{% endif %}

</div>

{% if history|length > 0 %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('ehSearch');
    if (!input) return;
    input.addEventListener('input', () => {
        const term = input.value.trim().toLowerCase();
        document.querySelectorAll('.eh-item').forEach(item => {
            item.style.display = !term || (item.dataset.search || '').toLowerCase().includes(term) ? '' : 'none';
        });
        // Hide period panels if all items are hidden
        document.querySelectorAll('.eh-panel[data-period]').forEach(panel => {
            const visible = panel.querySelectorAll('.eh-item:not([style*="display: none"])').length;
            panel.style.display = !term || visible > 0 ? '' : 'none';
        });
    });
});
</script>
{% endif %}
{% endblock %}
