<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Evaluate {{ faculty.fullName }} | SET</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
<style>
.eval-form-paper{background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;box-shadow:0 4px 15px rgba(0,0,0,.06);margin-bottom:16px;}
.eval-info-bar{display:flex;flex-wrap:wrap;gap:12px;padding:12px 20px;background:#f0f9ff;border-bottom:1px solid #e2e8f0;font-size:.82rem;}
.eval-form-instructions{background:#fffbeb;border-bottom:1px solid #fde68a;padding:12px 24px;font-size:.82rem;color:#92400e;line-height:1.6;}
.eval-form-section{border-bottom:1px solid #e2e8f0;}
.eval-form-section:last-child{border-bottom:0;}
.eval-form-category{background:#1e40af;padding:10px 24px;display:flex;align-items:center;gap:8px;}
.eval-form-category-label{color:#fff;font-weight:700;font-size:.85rem;}
.eval-form-cat-desc{background:#eff6ff;border-bottom:1px solid #bfdbfe;padding:12px 24px;font-size:.82rem;color:#475569;line-height:1.6;font-style:italic;}
.eval-form-table{width:100%;border-collapse:collapse;}
.eval-form-table thead{background:#f8fafc;}
.eval-form-table th{padding:10px 8px;font-size:.72rem;font-weight:600;color:#64748b;text-align:center;border-bottom:2px solid #e2e8f0;}
.eval-form-table th.eval-form-question{text-align:left;padding-left:16px;}
.eval-form-table th.eval-form-num{width:36px;text-align:center;}
.eval-form-table td{padding:10px 8px;border-bottom:1px solid #f1f5f9;vertical-align:middle;}
.eval-form-table td.eval-form-num{text-align:center;font-weight:600;color:#94a3b8;font-size:.82rem;}
.eval-form-table td.eval-form-question{padding-left:16px;font-size:.85rem;color:#1e293b;line-height:1.5;}
.eval-form-table td.eval-form-rating{text-align:center;width:60px;}
.eval-form-table tr:hover{background:#f8fafc;}
.eval-radio-label{display:inline-flex;align-items:center;justify-content:center;cursor:pointer;width:28px;height:28px;}
.eval-radio-label input{display:none;}
.eval-radio-circle{width:22px;height:22px;border:2px solid #cbd5e1;border-radius:50%;transition:all .15s;}
.eval-radio-label input:checked+.eval-radio-circle{border-color:#1e40af;background:#1e40af;box-shadow:inset 0 0 0 3px #fff;}
.eval-radio-label:hover .eval-radio-circle{border-color:#3b82f6;background:#eff6ff;}
.eval-form-textarea{border-radius:8px;border-color:#e2e8f0;font-size:.85rem;resize:vertical;}
.eval-form-textarea:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.eval-form-actions-bar{display:flex;gap:10px;padding:16px 0;justify-content:center;}
.btn-norsu{background:linear-gradient(135deg,#1e40af,#3b82f6);color:#fff;border:0;border-radius:8px;padding:10px 32px;font-weight:600;font-size:.9rem;transition:all .2s;}
.btn-norsu:hover{background:linear-gradient(135deg,#1e3a8a,#2563eb);color:#fff;transform:translateY(-1px);box-shadow:0 4px 12px rgba(30,64,175,.3);}
@media(max-width:576px){
    .container{padding-left:8px;padding-right:8px;}
    .eval-form-paper{border-radius:8px;}
    .eval-info-bar{flex-direction:column;gap:4px;padding:10px 14px;font-size:.75rem;}
    .eval-form-instructions{padding:10px 14px;font-size:.75rem;}
    .eval-form-category{padding:8px 14px;}
    .eval-form-category-label{font-size:.78rem;}
    .eval-form-cat-desc{padding:8px 14px;font-size:.75rem;}
    .eval-form-table th{padding:6px 3px;font-size:.62rem;}
    .eval-form-table th small{display:none;}
    .eval-form-table th.eval-form-question{padding-left:10px;}
    .eval-form-table th.eval-form-num{width:24px;}
    .eval-form-table td{padding:8px 3px;}
    .eval-form-table td.eval-form-num{font-size:.72rem;width:24px;padding-left:4px;}
    .eval-form-table td.eval-form-question{padding-left:10px;font-size:.78rem;}
    .eval-form-table td.eval-form-rating{width:32px;padding:4px 1px;}
    .eval-radio-label{width:24px;height:24px;}
    .eval-radio-circle{width:18px;height:18px;}
    .card-header{padding:12px 16px !important;}
    .card-header h6{font-size:.85rem;}
    .card-body{padding:16px !important;}
    .eval-form-actions-bar{padding:12px 0;}
    .btn-norsu{width:100%;padding:12px;font-size:.85rem;}
}
@media(max-width:400px){
    .eval-form-table td.eval-form-rating{width:26px;}
    .eval-radio-label{width:20px;height:20px;}
    .eval-radio-circle{width:16px;height:16px;}
    .eval-form-table td.eval-form-question{font-size:.72rem;}
}
</style>
</head>
<body style="background:#f1f5f9;min-height:100vh;">

<div class="container py-4" style="max-width:860px;">

{% if success %}
{# ── Success Screen ── #}
<div class="text-center py-5">
    <div style="width:80px;height:80px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:20px;">
        <i class="bi bi-check-circle-fill" style="font-size:2.5rem;color:#16a34a;"></i>
    </div>
    <h4 class="fw-bold text-success mb-2">Evaluation Submitted!</h4>
    <p class="text-muted">Thank you for your feedback. Your evaluation has been recorded.</p>
    <div class="mt-3 p-3 rounded-3 d-inline-block" style="background:#f0fdf4;border:1px solid #bbf7d0;">
        <small class="text-muted">Faculty: <strong>{{ faculty.fullName }}</strong></small><br>
        <small class="text-muted">Subject: <strong>{{ subject.subjectCode }} — {{ subject.subjectName }}</strong></small>
    </div>
    <div class="mt-4">
        <p class="text-muted" style="font-size:.85rem;">You may close this page now.</p>
    </div>
</div>
{% else %}
{# ── Student Verification + Evaluation Form ── #}

{% if error %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<form method="post" id="qrEvalForm">

{# ── Student Identification ── #}
<div class="card border-0 shadow-sm mb-3" style="border-radius:12px;overflow:hidden;">
    <div class="card-header py-3" style="background:linear-gradient(135deg,#0f172a,#1e40af);color:#fff;">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-person-badge-fill" style="font-size:1.2rem;"></i>
            <div>
                <h6 class="mb-0 fw-bold">Student Verification</h6>
                <small class="opacity-75">Enter your Student ID and Full Name</small>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold" style="font-size:.82rem;">Student ID <span class="text-danger">*</span></label>
                <input type="text" name="school_id" class="form-control" placeholder="e.g. 2023-1234" required>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold" style="font-size:.82rem;">Full Name <span class="text-danger">*</span></label>
                <input type="text" name="full_name" class="form-control" placeholder="First Name Last Name" required>
            </div>
        </div>
    </div>
</div>

{# ── Evaluation Form Paper ── #}
<div class="eval-form-paper">
    <div style="text-align:center;padding:16px 24px;border-bottom:3px solid #1e40af;background:#fff;">
        <img src="{{ asset('images/header.jpg') }}" alt="NORSU Letterhead" style="max-width:100%;height:auto;">
    </div>
    <div style="text-align:center;padding:14px 24px 12px;border-bottom:2px solid #1e40af;background:#f8fafc;">
        <span style="display:inline-block;background:linear-gradient(135deg,#dbeafe,#e0e7ff);color:#1e3a8a;border-radius:20px;padding:6px 20px;font-size:.85rem;font-weight:600;">Student Evaluation for Teacher (SET)</span>
    </div>
    <div style="text-align:center;padding:12px 32px 14px;background:#fff;border-bottom:1px solid #e2e8f0;">
        <div style="font-size:.82rem;font-weight:600;color:#475569;margin-bottom:6px;">(NBC 461 Evaluation Instrument for Teaching Effectiveness)</div>
        <p style="font-size:.78rem;color:#64748b;line-height:1.6;margin:0;">It's time to evaluate your teacher. Please answer honestly based on your experience. All responses are confidential, and your identity will not be shared with faculty members. Your feedback is valuable in improving the quality of teaching.</p>
    </div>

    {# ── Evaluation Info Bar ── #}
    <div class="eval-info-bar">
        <div><i class="bi bi-person-fill text-primary me-1"></i><strong>Faculty:</strong> {{ faculty.fullName }}</div>
        <div><i class="bi bi-journal-text text-success me-1"></i><strong>Subject:</strong> {{ subject.subjectCode }} — {{ subject.subjectName }}</div>
        {% if section %}<div><i class="bi bi-diagram-3 text-info me-1"></i><strong>Section:</strong> {{ section }}</div>{% endif %}
        {% if schedule %}<div><i class="bi bi-calendar-event text-warning me-1"></i><strong>Schedule:</strong> {{ schedule }}</div>{% endif %}
    </div>

    <div class="eval-form-instructions">
        <strong>Instructions:</strong> Rate each item using the scale:
        <strong>5</strong> – Always manifested &nbsp; <strong>4</strong> – Often manifested &nbsp; <strong>3</strong> – Sometimes manifested &nbsp; <strong>2</strong> – Seldom manifested &nbsp; <strong>1</strong> – Never/Rarely manifested
    </div>

    {% set currentCategory = '' %}
    {% set counter = 1 %}

    {% for q in questions %}
        {% if q.category != currentCategory %}
            {% if currentCategory != '' %}
                    </tbody>
                </table>
            </div>
            {% endif %}
            {% set currentCategory = q.category %}
        <div class="eval-form-section">
            <div class="eval-form-category">
                <span class="eval-form-category-label">{{ currentCategory ?? 'General' }}</span>
            </div>
            {% if categoryDescriptions[currentCategory] is defined and categoryDescriptions[currentCategory] %}
            <div class="eval-form-cat-desc">
                <em>{{ categoryDescriptions[currentCategory] }}</em>
            </div>
            {% endif %}
            <table class="eval-form-table">
                <thead>
                    <tr>
                        <th class="eval-form-num"></th>
                        <th class="eval-form-question">Question</th>
                        <th class="eval-form-rating">1<br><small>Never</small></th>
                        <th class="eval-form-rating">2<br><small>Seldom</small></th>
                        <th class="eval-form-rating">3<br><small>Sometimes</small></th>
                        <th class="eval-form-rating">4<br><small>Often</small></th>
                        <th class="eval-form-rating">5<br><small>Always</small></th>
                    </tr>
                </thead>
                <tbody>
        {% endif %}

        <tr>
            <td class="eval-form-num">{{ counter }}.</td>
            <td class="eval-form-question">
                {{ q.questionText }}
                {% if q.isRequired %}<span class="text-danger">*</span>{% endif %}
            </td>
            {% for r in 1..5 %}
            <td class="eval-form-rating">
                <label class="eval-radio-label">
                    <input type="radio" name="ratings[{{ q.id }}]" value="{{ r }}"
                           {{ q.isRequired ? 'required' }}>
                    <span class="eval-radio-circle"></span>
                </label>
            </td>
            {% endfor %}
        </tr>
        {% set counter = counter + 1 %}
    {% endfor %}

    {# Close last category #}
    {% if currentCategory != '' %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {# Comment #}
    <div class="eval-form-section">
        <div class="eval-form-category">
            <span class="eval-form-category-label">Additional Comments <span class="text-danger">*</span></span>
        </div>
        <div class="p-3">
            <textarea name="comments[0]" class="form-control eval-form-textarea" rows="3" required
                      placeholder="Share any additional feedback for this faculty member..."></textarea>
        </div>
    </div>
</div>

{# Buttons #}
<div class="eval-form-actions-bar">
    <button type="submit" name="_action" value="submit" class="btn btn-norsu"
            onclick="return confirm('Once submitted, you cannot edit this evaluation. Continue?')">
        <i class="bi bi-send me-1"></i>Submit Evaluation
    </button>
</div>
</form>
{% endif %}

</div>

</body>
</html>
