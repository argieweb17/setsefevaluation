{% extends 'base.html.twig' %}

{% block title %}Superior Evaluation Results | SET-SEF Evaluation{% endblock %}

{% block body %}
<div class="mb-3">
    <h4 class="fw-bold"><i  class="bi bi-graph-up-arrow me-2"></i>Superior Evaluation Results</h4>
    <p class="text-muted mb-0">Performance results of Deans and Department Heads.</p>
</div>

{% if allEvals|length > 0 %}
<div class="card shadow-sm mb-4">
    <div class="card-body p-0">
        {% if rankings|length > 0 %}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="thead-norsu">
                    <tr>
                        <th class="ps-3 text-center" style="width:60px">#</th>
                        <th>Name</th>
                        <th class="text-center">Avg. Rating</th>
                        <th class="text-center">Evaluators</th>
                        <th class="text-center">Performance</th>
                        <th class="text-end pe-3">Details</th>
                    </tr>
                </thead>
                <tbody>
                    {% for i, item in rankings %}
                    <tr>
                        <td class="ps-3 text-center fw-bold">{{ i + 1 }}</td>
                        <td class="fw-semibold">{{ item.evaluatee.fullName }}</td>
                        <td class="text-center">
                            <span class="fw-bold">{{ item.average }}</span>
                            <small class="text-muted">/ 5</small>
                        </td>
                        <td class="text-center">{{ item.evaluators }}</td>
                        <td class="text-center">
                            <span class="badge bg-{{ item.level == 'Excellent' ? 'success' : (item.level == 'Very Good' ? 'primary' : (item.level == 'Good' ? 'info' : (item.level == 'Fair' ? 'warning' : 'danger'))) }}">
                                {{ item.level }}
                            </span>
                        </td>
                        <td class="text-end pe-3">
                            <button class="btn btn-sm btn-outline-primary" type="button"
                                    onclick="loadDetail({{ selectedEvalId }}, {{ item.evaluatee.id }})">
                                <i  class="bi bi-eye me-1"></i>View
                            </button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="text-center text-muted py-5">
            <i  class="bi bi-clipboard-x display-4 d-block mb-3"></i>
            <p>No evaluation results yet for this period.</p>
        </div>
        {% endif %}
    </div>
</div>
{% else %}
<div class="alert alert-info">
    <i  class="bi bi-info-circle me-2"></i>No evaluation periods found.
</div>
{% endif %}

{# Detail Modal #}
<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailTitle">Evaluation Detail</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function loadDetail(evalId, evaluateeId) {
    const modal = new bootstrap.Modal(document.getElementById('detailModal'));
    document.getElementById('detailBody').innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>';
    modal.show();

    fetch('{{ path("superior_results_detail") }}?evalId=' + evalId + '&evaluateeId=' + evaluateeId)
        .then(r => r.json())
        .then(data => {
            document.getElementById('detailTitle').textContent = data.evaluatee + ' — ' + data.department;
            let html = '<div class="mb-3"><span class="fw-bold fs-4">' + data.overall + '</span> <small class="text-muted">/ 5 overall</small></div>';

            if (data.categories.length > 0) {
                html += '<table class="table table-sm"><thead><tr><th>Category</th><th class="text-center">Average</th><th class="text-center">Responses</th></tr></thead><tbody>';
                data.categories.forEach(function(c) {
                    html += '<tr><td>' + (c.category || 'General') + '</td><td class="text-center fw-bold">' + parseFloat(c.avgRating).toFixed(2) + '</td><td class="text-center">' + c.responseCount + '</td></tr>';
                });
                html += '</tbody></table>';
            }

            if (data.comments.length > 0) {
                html += '<h6 class="mt-3 fw-bold">Comments</h6><ul class="list-group list-group-flush">';
                data.comments.forEach(function(c) {
                    html += '<li class="list-group-item small">' + c + '</li>';
                });
                html += '</ul>';
            }

            document.getElementById('detailBody').innerHTML = html;
        });
}
</script>
{% endblock %}
