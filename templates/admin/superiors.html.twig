{% extends 'base.html.twig' %}

{% block title %}Manage Superiors | SET-SEF Evaluation{% endblock %}

{% block body %}
{% set totalSuperiors = users|length %}
{% set activeCount = 0 %}
{% set pendingCount = 0 %}
{% for u in users %}
    {% if u.accountStatus == 'active' %}{% set activeCount = activeCount + 1 %}{% endif %}
    {% if u.accountStatus == 'pending' %}{% set pendingCount = pendingCount + 1 %}{% endif %}
{% endfor %}

{# ── Header ── #}
<div class="rl-header">
    <div class="rl-header-inner">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="rl-header-icon"><i class="bi bi-star-fill"></i></div>
                <div>
                    <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">Manage Superiors</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                        <span class="rl-meta-pill"><i class="bi bi-person-check me-1"></i>{{ activeCount }} Active</span>
                        <span class="rl-meta-pill"><i class="bi bi-hourglass-split me-1"></i>{{ pendingCount }} Pending</span>
                        <span class="rl-meta-pill"><i class="bi bi-database me-1"></i>{{ totalSuperiors }} Total</span>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-1">
                <a href="{{ path('admin_users') }}" class="btn btn-sm btn-outline-light fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i>All Users
                </a>
                <a href="{{ path('admin_user_create') }}" class="btn btn-sm btn-light fw-semibold shadow-sm">
                    <i class="bi bi-person-plus-fill me-1"></i>Add Superior
                </a>
            </div>
        </div>
        <div class="rl-stats-row">
            <div class="rl-stat">
                <span class="rl-stat-val">{{ totalSuperiors }}</span>
                <span class="rl-stat-lbl">Total Superiors</span>
            </div>
            <div class="rl-stat-divider"></div>
            <div class="rl-stat">
                <span class="rl-stat-val">{{ activeCount }}</span>
                <span class="rl-stat-lbl">Active</span>
            </div>
            <div class="rl-stat-divider"></div>
            <div class="rl-stat">
                <span class="rl-stat-val">{{ pendingCount }}</span>
                <span class="rl-stat-lbl">Pending</span>
            </div>
        </div>
    </div>
</div>

{# ── Filter Toolbar ── #}
<div class="rl-toolbar">
    <div class="rl-search-wrap">
        <i class="bi bi-search"></i>
        <input type="text" class="rl-search" id="rlSearch" placeholder="Search by name or email..." autocomplete="off">
    </div>
    <div class="rl-filter-form">
        <div class="rl-filter-group">
            <i class="bi bi-bank rl-filter-icon"></i>
            <select class="rl-filter-select" id="rlCollege" style="min-width:160px;">
                <option value="">All Colleges</option>
                {% set colleges = [] %}
                {% for dept in departments %}
                    {% if dept.collegeName and dept.collegeName not in colleges %}
                        {% set colleges = colleges|merge([dept.collegeName]) %}
                        <option value="{{ dept.collegeName|lower }}">{{ dept.collegeName }}</option>
                    {% endif %}
                {% endfor %}
            </select>
        </div>
        <div class="rl-filter-group">
            <i class="bi bi-building rl-filter-icon"></i>
            <select class="rl-filter-select" id="rlDept" style="min-width:180px;">
                <option value="">All Departments</option>
                {% for dept in departments %}
                <option value="{{ dept.departmentName|lower }}" data-college="{{ dept.collegeName|lower }}">{{ dept.departmentName }}</option>
                {% endfor %}
            </select>
        </div>
    </div>
    <div class="rl-toolbar-info">
        <span class="rl-result-count" id="rlCount"></span>
    </div>
</div>

{# ── Superiors Table ── #}
<div class="rl-table-card">
    <div class="rl-table-header" style="background:linear-gradient(135deg,#1e3a8a,#1e40af 60%,#059669);">
        <span><i class="bi bi-star-fill me-2"></i>Superiors</span>
        <span class="rl-table-badge">{{ totalSuperiors }} member{{ totalSuperiors != 1 ? 's' : '' }}</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="rlTable">
            <thead>
                <tr class="small text-muted" style="font-size:.78rem;background:#f8fafc;border-bottom:2px solid #e2e8f0;">
                    <th class="ps-3 fw-semibold" style="width:50px">#</th>
                    <th class="fw-semibold">Name</th>
                    <th class="fw-semibold">Email</th>
                    <th class="fw-semibold">Department</th>
                    <th class="fw-semibold text-center">Status</th>
                    <th class="fw-semibold">Registered</th>
                    <th class="fw-semibold text-end pe-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr class="rl-row"
                    data-name="{{ user.fullName|lower }}"
                    data-email="{{ user.email|lower }}"
                    data-college="{{ user.department and user.department.collegeName ? user.department.collegeName|lower : '' }}"
                    data-dept="{{ user.department ? user.department.departmentName|lower : '' }}"
                    data-status="{% if user.accountStatus == 'active' %}Active{% elseif user.accountStatus == 'pending' %}Pending{% else %}Inactive{% endif %}"
                    data-date="{{ user.createdAt|date('Y-m-d') }}">
                    <td class="ps-3"><span class="fw-bold text-muted rl-num">{{ loop.index }}</span></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="rl-avatar" style="background:linear-gradient(135deg,rgba(124,58,237,.12),rgba(167,139,250,.12));color:#7c3aed;">{{ user.firstName|first|upper }}{{ user.lastName|first|upper }}</div>
                            <div class="fw-semibold small">{{ user.fullName }}</div>
                        </div>
                    </td>
                    <td><span class="small text-muted">{{ user.email }}</span></td>
                    <td><span class="small">{{ user.department ? user.department.departmentName : '—' }}</span></td>
                    <td class="text-center">
                        {% if user.accountStatus == 'active' %}
                            <span class="rl-status-badge status-active"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                        {% elseif user.accountStatus == 'pending' %}
                            <span class="rl-status-badge status-pending"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                        {% else %}
                            <span class="rl-status-badge status-inactive"><i class="bi bi-pause-circle-fill me-1"></i>Inactive</span>
                        {% endif %}
                    </td>
                    <td><span class="small text-muted">{{ user.createdAt|date('M d, Y') }}</span></td>
                    <td class="text-end pe-3">
                        <div class="d-flex gap-1 justify-content-end">
                            <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-sm btn-outline-primary rl-action-btn" title="Edit"><i class="bi bi-pencil-square"></i></a>
                            <form method="post" action="{{ path('admin_user_toggle_status', {id: user.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                <button class="btn btn-sm btn-outline-{{ user.accountStatus == 'active' ? 'secondary' : 'success' }} rl-action-btn" title="{{ user.accountStatus == 'active' ? 'Deactivate' : 'Activate' }}">
                                    <i class="bi {{ user.accountStatus == 'active' ? 'bi-pause-circle' : 'bi-play-circle' }}"></i>
                                </button>
                            </form>
                            <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" class="d-inline" onsubmit="return confirm('Delete this superior permanently?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                <button class="btn btn-sm btn-outline-danger rl-action-btn" title="Delete"><i class="bi bi-trash3"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="7" class="text-center py-5">
                    <i class="bi bi-star display-4 text-muted d-block mb-2"></i>
                    <span class="text-muted">No superiors found.</span>
                </td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% include 'admin/_role_list_styles.html.twig' %}

<script>
(function(){
    var search=document.getElementById('rlSearch'),college=document.getElementById('rlCollege'),dept=document.getElementById('rlDept'),countEl=document.getElementById('rlCount');
    if(!search)return;

    // Keep department options in sync with selected college.
    var deptSelect=dept,allDeptOpts=[];
    Array.from(deptSelect.options).forEach(function(o,i){if(i>0)allDeptOpts.push({value:o.value,text:o.text,college:o.getAttribute('data-college')});});

    function updateDeptOptions(){
        var cv=college.value;
        var current=deptSelect.value;
        while(deptSelect.options.length>1)deptSelect.remove(1);
        allDeptOpts.forEach(function(o){
            if(!cv||o.college===cv){
                var opt=document.createElement('option');
                opt.value=o.value;
                opt.text=o.text;
                opt.setAttribute('data-college',o.college);
                deptSelect.appendChild(opt);
            }
        });
        var found=false;
        Array.from(deptSelect.options).forEach(function(o){if(o.value===current)found=true;});
        deptSelect.value=found?current:'';
    }

    function applyFilters(){
        var q=search.value.trim().toLowerCase(),cv=college.value,dv=dept.value,rows=document.querySelectorAll('.rl-row'),vis=0;
        rows.forEach(function(r){var show=true;
            if(q){var n=r.getAttribute('data-name'),e=r.getAttribute('data-email');if(n.indexOf(q)===-1&&e.indexOf(q)===-1)show=false;}
            if(cv&&r.getAttribute('data-college')!==cv)show=false;
            if(dv&&r.getAttribute('data-dept')!==dv)show=false;
            r.style.display=show?'':'none';if(show)vis++;
        });
        if(countEl)countEl.textContent='Showing '+vis+' of '+rows.length+' superiors';
        var rows=Array.from(document.querySelectorAll('.rl-row'));
        var num=0;rows.forEach(function(r){if(r.style.display==='none')return;num++;var c=r.querySelector('.rl-num');if(c)c.textContent=num;});
    }
    search.addEventListener('input',applyFilters);
    college.addEventListener('change',function(){updateDeptOptions();applyFilters();});
    dept.addEventListener('change',applyFilters);
    applyFilters();
})();
</script>
{% endblock %}
