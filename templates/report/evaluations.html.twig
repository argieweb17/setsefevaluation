{# ═══════════════════════════════════════
   JAVASCRIPT
   ═══════════════════════════════════════ #}
<script>
/* ── Filter by status ── */
var currentStatusFilter = 'all';
var currentTypeFilter = 'all';

function filterEvals(status, btn) {
    currentStatusFilter = status;
    document.querySelectorAll('#evFilterTabs .ev-filter-btn').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');
    applyFilters();
}

function filterType(type, btn) {
    currentTypeFilter = type;
    document.querySelectorAll('#evTypeFilter .ev-filter-btn').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');
    applyFilters();
}

function searchEvals(query) {
    applyFilters(query);
}

function applyFilters(searchQuery) {
    var q = (searchQuery !== undefined ? searchQuery : document.getElementById('evSearchInput').value).toLowerCase().trim();
    document.querySelectorAll('.ev-card-wrap').forEach(function(card){
        var sMatch = currentStatusFilter === 'all' || card.dataset.status === currentStatusFilter;
        var tMatch = currentTypeFilter === 'all' || (currentTypeFilter === 'SEF' ? (card.dataset.type === 'SEF' || card.dataset.type === 'SUPERIOR') : card.dataset.type === currentTypeFilter);
        var qMatch = !q || card.dataset.search.toLowerCase().indexOf(q) !== -1;
        card.style.display = (sMatch && tMatch && qMatch) ? '' : 'none';
    });
}

/* ── Subject data for dynamic filtering ── */
var allSubjects = [
    {% for s in subjects %}
    { value: {{ (s.subjectCode ~ ' — ' ~ s.subjectName)|json_encode|raw }}, schedule: {{ (s.schedule ?? '')|json_encode|raw }}, section: {{ (s.section ?? '')|json_encode|raw }}, facultyId: '{{ s.faculty ? s.faculty.id : '' }}' }{{ not loop.last ? ',' : '' }}
    {% endfor %}
];

/* ── Auto-fill time & section when subject is selected ── */
document.querySelectorAll('.subject-select').forEach(function(sel) {
    sel.addEventListener('change', function() {
        var opt = this.options[this.selectedIndex];
        var timeField = document.querySelector(this.dataset.targetTime);
        var sectionField = document.querySelector(this.dataset.targetSection);
        if (timeField) timeField.value = opt.getAttribute('data-schedule') || '';
        if (sectionField) sectionField.value = opt.getAttribute('data-section') || '';
    });
});

/* ── Rebuild subject dropdown based on selected faculty ── */
function filterSubjectsByFaculty(facultySelect, keepValue) {
    var facultyOpt = facultySelect.options[facultySelect.selectedIndex];
    var facultyId = facultyOpt ? facultyOpt.getAttribute('data-faculty-id') : '';
    var subjectSel = document.querySelector(facultySelect.getAttribute('data-target-subject'));
    if (!subjectSel) return;

    var currentVal = keepValue || '';
    var timeField = document.querySelector(subjectSel.getAttribute('data-target-time'));
    var sectionField = document.querySelector(subjectSel.getAttribute('data-target-section'));
    if (!keepValue) {
        if (timeField) timeField.value = '';
        if (sectionField) sectionField.value = '';
    }

    subjectSel.innerHTML = '';
    var defaultOpt = document.createElement('option');
    defaultOpt.value = '';
    defaultOpt.setAttribute('data-schedule', '');
    defaultOpt.setAttribute('data-section', '');
    defaultOpt.textContent = facultyId ? '— Select Subject —' : '— Select Faculty first —';
    subjectSel.appendChild(defaultOpt);

    if (facultyId) {
        allSubjects.forEach(function(s) {
            if (s.facultyId === facultyId) {
                var opt = document.createElement('option');
                opt.value = s.value;
                opt.setAttribute('data-schedule', s.schedule);
                opt.setAttribute('data-section', s.section);
                opt.textContent = s.value;
                if (s.value === currentVal) opt.selected = true;
                subjectSel.appendChild(opt);
            }
        });
    }
}

document.querySelectorAll('.faculty-select').forEach(function(sel) {
    sel.addEventListener('change', function() { filterSubjectsByFaculty(this, ''); });
    var subjectSel = document.querySelector(sel.getAttribute('data-target-subject'));
    var currentSubjectVal = subjectSel ? subjectSel.getAttribute('data-current-value') : '';
    if (sel.value) {
        filterSubjectsByFaculty(sel, currentSubjectVal);
    }
});

/* ── QR Code Generation ── */
(function() {
    var qrModal = document.getElementById('qrCodeModal');
    if (!qrModal) return;
    var currentQrUrl = '';

    qrModal.addEventListener('show.bs.modal', function(e) {
        var btn = e.relatedTarget;
        if (!btn) return;

        var evalType = btn.getAttribute('data-eval-type');
        var faculty = btn.getAttribute('data-eval-faculty');
        var subject = btn.getAttribute('data-eval-subject');
        var section = btn.getAttribute('data-eval-section');
        var schedule = btn.getAttribute('data-eval-schedule');
        var schoolYear = btn.getAttribute('data-eval-school-year');

        var baseUrl = window.location.origin;
        currentQrUrl = baseUrl + '/evaluation/qr/' + btn.getAttribute('data-eval-id');

        var typeBadge = document.getElementById('qrEvalType');
        typeBadge.textContent = evalType;
        typeBadge.className = 'qr-eval-type-badge';

        document.getElementById('qrModalSubtitle').textContent = schoolYear || 'Scan to open the evaluation form';
        document.getElementById('qrEvalFaculty').textContent = faculty || '';
        document.getElementById('qrEvalSubject').textContent = subject || '';

        // Build details display with section and schedule if available
        var detailsDisplay = section || '';
        if (schedule) {
            detailsDisplay = (detailsDisplay ? detailsDisplay + ' | ' : '') + schedule;
        }
        document.getElementById('qrEvalDetails').textContent = detailsDisplay || '';
        var detailsRow = document.getElementById('qrEvalDetailsRow');
        if (detailsRow) detailsRow.style.display = detailsDisplay ? '' : 'none';
        document.getElementById('qrUrl').textContent = currentQrUrl;

        var qrImg = document.getElementById('qrImage');
        qrImg.src = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(currentQrUrl);
    });

    window.downloadQR = function() {
        var img = document.getElementById('qrImage');
        var link = document.createElement('a');
        link.download = 'evaluation-qr-code.png';
        link.href = img.src;
        link.click();
    };

    window.copyQRLink = function() {
        navigator.clipboard.writeText(currentQrUrl).then(function() {
            var btn = document.querySelector('#qrCodeModal .qr-btn-copy');
            var orig = btn.innerHTML;
            btn.innerHTML = '<i  class="bi bi-check me-1"></i>Copied!';
            setTimeout(function() { btn.innerHTML = orig; }, 1500);
        });
    };
})();
</script>
{% endblock %}
