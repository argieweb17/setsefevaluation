{% extends 'base.html.twig' %}

{% block title %}Evaluation Results | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ─── Toolbar ─── */
.er-toolbar{display:flex;align-items:center;gap:12px;flex-wrap:wrap;background:transparent;border:none;border-radius:0;padding:0;margin-bottom:16px;box-shadow:none;}
.er-search-wrap{position:relative;flex:1;min-width:180px;max-width:280px;}
.er-search-wrap>i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:.8rem;pointer-events:none;}
.er-search{width:100%;border:1px solid #e5e7eb;border-radius:8px;padding:7px 12px 7px 32px;font-size:.82rem;outline:none;transition:border-color .15s,box-shadow .15s;background:#fafbfc;}
.er-search:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.08);background:#fff;}
.er-toolbar-info{margin-left:auto;}
.er-result-count{font-size:.75rem;color:#9ca3af;font-weight:500;}

/* ─── Period Cards ─── */
.er-period-card{background:#fff;border:1px solid #e0e7ff;border-radius:12px;margin-bottom:16px;overflow:hidden;box-shadow:0 1px 4px rgba(99,102,241,.06);}
.er-period-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;padding:14px 20px;background:linear-gradient(135deg,#eef2ff,#e0e7ff);border-bottom:1px solid #e0e7ff;cursor:pointer;user-select:none;transition:background .15s;}
.er-period-header:hover{background:linear-gradient(135deg,#e0e7ff,#c7d2fe);}
.er-period-icon{width:auto;height:auto;border-radius:0;background:transparent;color:#4338ca;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.er-period-badge{display:inline-flex;align-items:center;justify-content:center;min-width:0;height:auto;border-radius:0;background:transparent;color:#4338ca;font-size:.72rem;font-weight:700;padding:0;}
.er-period-chevron{font-size:.9rem;color:#64748b;transition:transform .25s ease;}
.er-period-card.er-collapsed .er-period-chevron{transform:rotate(-90deg);}
.er-period-card.er-collapsed .er-period-body{display:none;}

/* ─── Table ─── */
.er-table{width:100%;border-collapse:collapse;font-size:.82rem;}
.er-table thead{background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-bottom:2px solid #e2e8f0;}
.er-table thead th{padding:10px 14px;font-size:.7rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.6px;white-space:nowrap;border:none;}
.er-table tbody tr{border-bottom:1px solid #f1f5f9;transition:background .12s ease;}
.er-table tbody tr:last-child{border-bottom:none;}
.er-table tbody tr:hover{background:#f8faff;}
.er-table tbody td{padding:10px 14px;vertical-align:middle;}
.er-td-num{color:#94a3b8;font-size:.72rem;font-weight:600;text-align:center;}

/* Code cell */
.er-code-cell{display:flex;align-items:center;gap:0;}
.er-code-text{font-family:'SF Mono','Cascadia Code','Consolas',monospace;font-size:.78rem;font-weight:700;color:#1e293b;background:transparent;padding:0;border-radius:0;letter-spacing:.3px;}

/* Name */
.er-subject-name{font-weight:600;color:#1e293b;font-size:.82rem;}

/* Pills */
.er-pill{display:inline-flex;align-items:center;padding:0;border-radius:0;font-size:.7rem;font-weight:600;white-space:nowrap;}
.er-pill-evaluator{background:transparent;color:#1e293b;}
.er-pill-status{background:transparent;color:#059669;}

/* ─── Empty ─── */
.er-table-wrap{background:#fff;border:1px solid #e8ecf1;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.03);}
.er-empty{text-align:center;padding:3rem 1rem;color:#94a3b8;font-size:.88rem;}
.er-empty-icon{width:64px;height:64px;border-radius:50%;background:#f1f5f9;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:1.6rem;color:#94a3b8;}
.er-no-results{text-align:center;padding:24px;color:#94a3b8;font-size:.85rem;display:flex;align-items:center;justify-content:center;gap:8px;background:#fff;border:1px solid #e8ecf1;border-radius:12px;}

/* ─── Responsive ─── */
@media(max-width:768px){
    .er-table{font-size:.75rem;}
    .er-table thead th{padding:8px 10px;font-size:.62rem;}
    .er-table tbody td{padding:8px 10px;}
    .er-period-header{padding:12px 14px;}
    .er-search-wrap{max-width:100%;}
}

/* ─── Animations ─── */
.er-toolbar,.er-period-card,.er-table-wrap{animation:erFadeIn .25s ease;}
@keyframes erFadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
</style>
{% endblock %}

{% block body %}

{% set totalSubjects = 0 %}
{% for p in periods %}
    {% set totalSubjects = totalSubjects + p.subjects|length %}
{% endfor %}

{% if periods|length > 0 %}
{# ── Toolbar ── #}
<div class="er-toolbar">
    <div class="er-search-wrap">
        <i  class="bi bi-search"></i>
        <input type="text" class="er-search" id="erSearch" placeholder="Search subjects..." oninput="erFilter()">
    </div>
    <div class="er-toolbar-info">
        <span class="er-result-count" id="erResultCount">{{ totalSubjects }} result{{ totalSubjects != 1 ? 's' : '' }}</span>
    </div>
</div>

{# ── Results by Period ── #}
{% for epId, period in periods %}
<div class="er-period-card">
    <div class="er-period-header" onclick="erToggle(this)">
        <div class="d-flex align-items-center gap-2">
            <div class="er-period-icon"><i  class="bi bi-calendar3"></i></div>
            <div>
                <h6 class="fw-bold mb-0" style="font-size:.92rem;color:#1e293b;">{{ period.evaluation.label|replace({' — ': ' ', ' – ': ' ', ' - ': ' '}) }}</h6>
                <span style="font-size:.72rem;color:#64748b;">{{ period.subjects|length }} subject{{ period.subjects|length != 1 ? 's' : '' }} evaluated</span>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="er-period-badge">{{ period.subjects|length }}</span>
            <i  class="bi bi-chevron-down er-period-chevron"></i>
        </div>
    </div>
    <div class="er-period-body">
        <table class="er-table">
            <thead>
                <tr>
                    <th style="width:40px">#</th>
                    <th>Subject Code</th>
                    <th>Subject Name</th>
                    <th class="text-center">Evaluators</th>
                    <th class="text-center">Status</th>
                </tr>
            </thead>
            <tbody>
                {% for subj in period.subjects %}
                <tr class="er-row" data-search="{{ subj.subjectCode|lower }} {{ subj.subjectName|lower }}">
                    <td class="er-td-num">{{ loop.index }}</td>
                    <td>
                        <div class="er-code-cell">
                            <span class="er-code-text">{{ subj.subjectCode }}</span>
                        </div>
                    </td>
                    <td class="er-subject-name">{{ subj.subjectName }}</td>
                    <td class="text-center">
                        <span class="er-pill er-pill-evaluator">
                            <i  class="bi bi-people me-1"></i>{{ subj.evaluatorCount }}
                        </span>
                    </td>
                    <td class="text-center">
                        <span class="er-pill er-pill-status">
                            <i  class="bi bi-check-circle-fill me-1"></i>Evaluated
                        </span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endfor %}

<div class="er-no-results" id="erNoResults" style="display:none;">
    <i  class="bi bi-search me-2"></i>No subjects match your search.
</div>

{% else %}
<div class="er-table-wrap">
    <div class="er-empty">
        <div class="er-empty-icon"><i  class="bi bi-card-checklist"></i></div>
        <p class="mb-0">No evaluation results available yet.</p>
    </div>
</div>
{% endif %}

{# ═══════════════════════════════════════
   SCOPED STYLES
   ═══════════════════════════════════════ #}

<script>
function erFilter(){
    var q=(document.getElementById('erSearch').value||'').toLowerCase();
    var visibleCount=0;
    document.querySelectorAll('.er-period-card').forEach(function(card){
        var rows=card.querySelectorAll('.er-row');
        var cardVisible=0;
        rows.forEach(function(r){
            var show=r.dataset.search.includes(q);
            r.style.display=show?'':'none';
            if(show)cardVisible++;
        });
        card.style.display=cardVisible>0?'':'none';
        visibleCount+=cardVisible;
    });
    var noRes=document.getElementById('erNoResults');
    if(noRes)noRes.style.display=visibleCount===0&&q?'flex':'none';
    var countEl=document.getElementById('erResultCount');
    if(countEl)countEl.textContent=visibleCount+' result'+(visibleCount!==1?'s':'');
}
function erToggle(el){
    var card=el.closest('.er-period-card');
    if(card)card.classList.toggle('er-collapsed');
}
</script>
{% endblock %}
