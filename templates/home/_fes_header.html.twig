{# Header partial for FES pages #}
<header class="fes-header">
    <a href="https://norsu.edu.ph" target="_blank" rel="noopener noreferrer" class="fes-topbar-link" aria-label="Visit official NORSU website">
        <div class="fes-topbar">
            <div class="fes-topbar-left">
                <img src="{{ asset('images/homeHeader/logonor.png') }}" alt="Negros Oriental State University seal" class="fes-topbar-seal">
                <h2 class="fes-topbar-title">
                    <span class="fes-topbar-highlight">N</span>EGROS
                    <span class="fes-topbar-highlight">OR</span>IENTAL
                    <span class="fes-topbar-highlight">S</span>TATE
                    <span class="fes-topbar-highlight">U</span>NIVERSITY
                </h2>
            </div>
            {% set topbarLogos = [
                { src: asset('images/homeHeader/SEAL2.png'), alt: 'Philippine Transparency Seal' },
                { src: asset('images/homeHeader/FREEDOM2.png'), alt: 'Freedom of Information Philippines' },
                { src: asset('images/homeHeader/CGI2.png'), alt: 'GCL UKAS ISO Certification', class: 'is-cgi2' },
                { src: asset('images/homeHeader/Bagong_Pilipinas_logo2.png'), alt: 'Bagong Pilipinas' }
            ] %}
            <div class="fes-topbar-right">
                {% for logo in topbarLogos %}
                <span class="fes-topbar-logo-item{{ logo.class is defined ? ' ' ~ logo.class : '' }}">
                    <img src="{{ logo.src }}" alt="{{ logo.alt }}" class="fes-topbar-logo{{ logo.class is defined ? ' ' ~ logo.class : '' }}" loading="eager" decoding="async">
                </span>
                {% endfor %}
            </div>
        </div>
    </a>
    <div class="container">
        <a href="{{ path('app_home') }}" class="fes-logo">
            <img src="{{ asset('images/norsu1logo.png') }}" alt="NORSU Logo" class="fes-logo-img">
            <div class="fes-logo-text">
                <span class="fes-logo-title">SET - SEF Evaluation System</span>
            </div>
        </a>
        <nav class="fes-nav">
            <a href="{{ path('app_home') }}" class="fes-nav-link{{ active|default('') == 'home' ? ' active' : '' }}">Home</a>
            <a href="{{ path('app_home', {view: 'about'}) }}" class="fes-nav-link{{ active|default('') == 'about' ? ' active' : '' }}">About</a>
            <a href="{{ path('app_home', {view: 'faq'}) }}" class="fes-nav-link{{ active|default('') == 'faq' ? ' active' : '' }}">FAQ</a>
            <a href="{{ path('app_home', {view: 'contact'}) }}" class="fes-nav-link{{ active|default('') == 'contact' ? ' active' : '' }}">Contact Us</a>
            <details class="fes-account-dropdown">
                <summary class="fes-nav-btn fes-account-summary">My Account</summary>
                <div class="fes-account-menu">
                    <a href="{{ path('app_login') }}" class="fes-account-item">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Sign In</span>
                    </a>
                    <a href="{{ path('app_register') }}" class="fes-account-item">
                        <i class="bi bi-person-fill"></i>
                        <span>Register</span>
                    </a>
                </div>
            </details>
        </nav>
    </div>
</header>
