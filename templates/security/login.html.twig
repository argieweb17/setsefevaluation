{% extends 'base.html.twig' %}

{% block title %}Sign In | QUAMC Evaluation{% endblock %}

{% block body_class %}no-navbar{% endblock %}

{% block stylesheets %}
<style>
/* ── Page layout ── */
.lg-page {
    display: flex;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: #F8FAFC;
}

/* ── Left brand panel ── */
.lg-brand-panel {
    position: relative;
    width: 420px;
    min-width: 420px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
}
.lg-brand-bg {
    position: absolute;
    inset: 0;
    background: #1E3A8A;
    z-index: 0;
}
.lg-brand-bg::before {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    top: -150px;
    right: -120px;
    animation: float 8s ease-in-out infinite;
}
.lg-brand-bg::after {
    content: '';
    position: absolute;
    width: 350px;
    height: 350px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    bottom: -80px;
    left: -60px;
    animation: float 10s ease-in-out infinite reverse;
}
.lg-brand-content {
    position: relative;
    z-index: 1;
    padding: 3rem 2.5rem;
    color: #fff;
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: center;
}
.lg-brand-logo-wrap {
    width: 60px;
    height: 60px;
    background: transparent;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: none;
    margin-bottom: 1.5rem;
    box-shadow: none;
    animation: scaleIn 0.6s ease 0.2s both;
}
.lg-brand-logo {
    width: 60px;
    height: 60px;
    object-fit: contain;
}
.lg-brand-title {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin-bottom: 0.5rem;
    line-height: 1.3;
    animation: slideUp 0.5s ease 0.35s both;
}
.lg-brand-sub {
    font-size: 0.95rem;
    opacity: 0.85;
    line-height: 1.5;
    margin-bottom: 2.5rem;
    animation: slideUp 0.5s ease 0.45s both;
}
.lg-brand-features {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
}
.lg-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    opacity: 0;
    animation: slideUp 0.4s ease both;
}
.lg-feature-item:nth-child(1) { animation-delay: 0.55s; }
.lg-feature-item:nth-child(2) { animation-delay: 0.65s; }
.lg-feature-item:nth-child(3) { animation-delay: 0.75s; }
.lg-feature-icon {
    width: 40px;
    height: 40px;
    border-radius: 0.625rem;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
}
.lg-feature-item strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.1rem;
}
.lg-feature-item span {
    font-size: 0.8rem;
    opacity: 0.75;
}
.lg-brand-footer {
    margin-top: auto;
    padding-top: 2rem;
    font-size: 0.78rem;
    opacity: 0.6;
}

/* ── Right form panel ── */
.lg-form-panel {
    flex: 1;
    display: flex;
    overflow: hidden;
    background: #fff;
}
.lg-form-scroll {
    flex: 1;
    overflow-y: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 2rem;
}
.lg-form-inner {
    width: 100%;
    max-width: 420px;
}

/* ── Mobile header ── */
.lg-mobile-header {
    text-align: center;
    margin-bottom: 1.25rem;
}
.lg-mobile-logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
}

/* ── Greeting pill ── */
.lg-greeting-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #F0FDF4;
    border: 1px solid #BBF7D0;
    color: #166534;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    margin-bottom: 0.85rem;
    animation: slideUp 0.4s ease 0.1s both;
}
.lg-wave-icon {
    display: inline-block;
    animation: waveHand 1.5s ease 0.8s both;
    transform-origin: 70% 70%;
    font-size: 0.85rem;
}
@keyframes waveHand {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(20deg); }
    50% { transform: rotate(-10deg); }
    75% { transform: rotate(15deg); }
}

/* ── Header ── */
.lg-header {
    margin-bottom: 1.75rem;
}
.lg-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: #0F172A;
    margin-bottom: 0.35rem;
    letter-spacing: -0.5px;
    line-height: 1.2;
    animation: slideUp 0.4s ease 0.2s both;
}
.lg-subtitle {
    font-size: 0.88rem;
    color: #64748B;
    margin: 0;
    animation: slideUp 0.35s ease 0.3s both;
}

/* ── Success alert ── */
.lg-success-alert {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: #F0FDF4;
    border: 1px solid #BBF7D0;
    margin-bottom: 1.5rem;
    animation: slideUp 0.4s ease;
}
.lg-success-icon-box {
    width: 32px;
    height: 32px;
    border-radius: 0.5rem;
    background: #DCFCE7;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #16A34A;
    font-size: 0.9rem;
    flex-shrink: 0;
}
.lg-success-title {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #166534;
    margin-bottom: 0.1rem;
}
.lg-success-msg {
    font-size: 0.8rem;
    color: #15803D;
}

/* ── Pending approval alert ── */
.lg-pending-alert {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: #FFFBEB;
    border: 1px solid #FDE68A;
    margin-bottom: 1.5rem;
    animation: slideUp 0.4s ease;
}
.lg-pending-icon-box {
    width: 32px;
    height: 32px;
    border-radius: 0.5rem;
    background: #FEF3C7;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #D97706;
    font-size: 0.9rem;
    flex-shrink: 0;
}
.lg-pending-title {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #92400E;
    margin-bottom: 0.1rem;
}
.lg-pending-msg {
    font-size: 0.8rem;
    color: #B45309;
}

/* ── Error alert ── */
.lg-error-alert {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: #FEF2F2;
    border: 1px solid #FECACA;
    margin-bottom: 1.5rem;
    animation: shakeX 0.5s ease;
}
.lg-error-icon-box {
    width: 32px;
    height: 32px;
    border-radius: 0.5rem;
    background: #FEE2E2;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #DC2626;
    font-size: 0.9rem;
    flex-shrink: 0;
}
.lg-error-title {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #991B1B;
    margin-bottom: 0.1rem;
}
.lg-error-msg {
    font-size: 0.8rem;
    color: #DC2626;
}
@keyframes shakeX {
    0%, 100% { transform: translateX(0); }
    15%, 45%, 75%  { transform: translateX(-6px); }
    30%, 60%, 90%  { transform: translateX(6px); }
}

/* ── Fields ── */
.lg-field {
    margin-bottom: 1.15rem;
    animation: slideUp 0.4s ease both;
}
.lg-field:nth-child(1) { animation-delay: 0.35s; }
.lg-field:nth-child(2) { animation-delay: 0.42s; }
.lg-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.4rem;
}
.lg-input-wrap {
    position: relative;
}
.lg-input-wrap > i:first-child {
    position: absolute;
    left: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94A3B8;
    font-size: 0.9rem;
    z-index: 2;
    pointer-events: none;
    transition: color 0.25s;
}
.lg-input-wrap.lg-focused > i:first-child {
    color: #1D4ED8;
}
.lg-input {
    padding-left: 2.6rem !important;
    border: 1.5px solid #E2E8F0;
    border-radius: 0.75rem;
    font-size: 0.88rem;
    height: 46px;
    transition: all 0.25s;
    background-color: #F8FAFC;
    color: #0F172A;
}
.lg-input::placeholder {
    color: #94A3B8;
    font-size: 0.85rem;
}
.lg-input:focus {
    border-color: #1D4ED8;
    box-shadow: 0 0 0 3px rgba(29,78,216,0.08), 0 1px 2px rgba(0,0,0,0.05);
    background-color: #fff;
}

/* ── Password toggle ── */
.lg-pwd-toggle {
    position: absolute;
    right: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #94A3B8;
    font-size: 1rem;
    cursor: pointer;
    padding: 0.3rem;
    border-radius: 0.375rem;
    transition: all 0.2s;
    z-index: 2;
}
.lg-pwd-toggle:hover {
    color: #334155;
    background: #F1F5F9;
}

/* ── Submit button ── */
.lg-submit-btn {
    width: 100%;
    padding: 0.85rem;
    border: none;
    border-radius: 0.75rem;
    background: #1E3A8A;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
    margin-top: 0.5rem;
    animation: slideUp 0.4s ease 0.5s both;
}
.lg-submit-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(255,255,255,0.1), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s;
}
.lg-submit-btn:hover {
    box-shadow: 0 8px 24px rgba(30,58,138,0.3), 0 2px 6px rgba(0,0,0,0.1);
    transform: translateY(-2px);
}
.lg-submit-btn:hover::before {
    transform: translateX(100%);
}
.lg-submit-btn:active {
    transform: translateY(0);
    box-shadow: 0 4px 12px rgba(30,58,138,0.25);
}
.lg-submit-btn.lg-btn-loading {
    pointer-events: none;
    background: #1E3A8A;
}
.lg-submit-btn.lg-btn-loading::before {
    animation: lgShimmerLoop 1.5s infinite;
}
.lg-submit-text,
.lg-submit-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s, transform 0.3s;
}
.lg-submit-text {
    opacity: 1;
    transform: translateY(0);
}
.lg-submit-btn.lg-btn-loading .lg-submit-text {
    opacity: 0;
    transform: translateY(8px);
    position: absolute;
}
.lg-submit-loading {
    opacity: 0;
    transform: translateY(-8px);
    gap: 0;
}
.lg-submit-btn.lg-btn-loading .lg-submit-loading {
    opacity: 1;
    transform: translateY(0);
}
.lg-loading-spinner {
    width: 18px;
    height: 18px;
    border: 2.5px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: lgSpin 0.7s linear infinite;
    margin-right: 8px;
    flex-shrink: 0;
}
.lg-loading-dots {
    display: inline-flex;
    margin-left: 1px;
}
.lg-loading-dots span {
    animation: lgDotBounce 1.2s ease-in-out infinite;
    font-weight: 700;
}
.lg-loading-dots span:nth-child(2) { animation-delay: 0.2s; }
.lg-loading-dots span:nth-child(3) { animation-delay: 0.4s; }
.lg-btn-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: linear-gradient(90deg, rgba(255,255,255,0.5), rgba(255,255,255,0.9), rgba(255,255,255,0.5));
    border-radius: 0 0 0.75rem 0.75rem;
}
.lg-submit-btn.lg-btn-loading .lg-btn-progress {
    animation: lgProgress 2s ease-in-out infinite;
}
@keyframes lgSpin {
    to { transform: rotate(360deg); }
}
@keyframes lgDotBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-4px); opacity: 1; }
}
@keyframes lgShimmerLoop {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}
@keyframes lgProgress {
    0% { width: 0; left: 0; }
    50% { width: 70%; left: 15%; }
    100% { width: 0; left: 100%; }
}

/* ── Divider ── */
.lg-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.5rem 0;
    color: #94A3B8;
    font-size: 0.75rem;
    animation: slideUp 0.35s ease 0.55s both;
}
.lg-divider::before, .lg-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #E2E8F0;
}

/* ── Google login button ── */
.lg-google-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid #E2E8F0;
    border-radius: 0.625rem;
    background: #fff;
    color: #1E293B;
    font-size: 0.925rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    margin-bottom: 0.75rem;
    animation: slideUp 0.35s ease 0.57s both;
}
.lg-google-btn:hover {
    border-color: #4285F4;
    background: #F8FAFF;
    box-shadow: 0 0 0 3px rgba(66,133,244,0.1);
}
.lg-google-btn:disabled {
    opacity: 0.6;
    cursor: wait;
}

/* ── Alt login button ── */
.lg-alt-btn {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1.5px solid #E2E8F0;
    border-radius: 0.75rem;
    background: #fff;
    text-decoration: none;
    transition: all 0.25s;
    animation: slideUp 0.35s ease 0.6s both;
    gap: 0.85rem;
}
.lg-alt-btn:hover {
    border-color: #1D4ED8;
    background: #EFF6FF;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(29,78,216,0.08);
}
.lg-alt-btn-icon {
    width: auto;
    height: auto;
    border-radius: 0;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1D4ED8;
    font-size: 1.1rem;
    flex-shrink: 0;
}
.lg-alt-btn-text {
    flex: 1;
}
.lg-alt-btn-text strong {
    display: block;
    font-size: 0.82rem;
    font-weight: 700;
    color: #0F172A;
}
.lg-alt-btn-text span {
    font-size: 0.72rem;
    color: #64748B;
}
.lg-alt-btn-arrow {
    color: #94A3B8;
    font-size: 0.85rem;
    transition: transform 0.2s, color 0.2s;
}
.lg-alt-btn:hover .lg-alt-btn-arrow {
    color: #1D4ED8;
    transform: translateX(3px);
}

/* ── Register link ── */
.lg-register-link {
    text-align: center;
    font-size: 0.82rem;
    color: #64748B;
    margin-top: 1.5rem;
    animation: slideUp 0.35s ease 0.65s both;
}
.lg-register-link a {
    color: #1D4ED8;
    font-weight: 700;
    text-decoration: none;
    transition: color 0.2s;
}
.lg-register-link a:hover {
    color: #1E3A8A;
    text-decoration: underline;
}

/* ═══ TABLET ═══ */
@media (max-width: 991.98px) {
    .lg-brand-panel {
        display: none;
    }
    .lg-page {
        background: #1E3A8A;
        justify-content: center;
        align-items: center;
        height: 100vh;
        height: 100dvh;
        overflow: hidden;
        padding: 1rem;
    }
    .lg-form-panel {
        max-width: 440px;
        width: 100%;
        margin: 0 auto;
        border-radius: 1.25rem;
        box-shadow: 0 25px 60px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.98);
        overflow: hidden;
        backdrop-filter: blur(20px);
    }
    .lg-form-scroll {
        padding: 1.75rem 1.5rem;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior: contain;
    }
    .lg-mobile-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }
    .lg-mobile-logo {
        filter: drop-shadow(0 4px 12px rgba(0,0,0,0.1));
    }
}

/* ═══ MOBILE ═══ */
@media (max-width: 575.98px) {
    .lg-page {
        align-items: center;
        padding: 0.5rem;
    }
    .lg-form-panel {
        margin: 0;
        border-radius: 1rem;
        max-width: 100%;
    }
    .lg-form-scroll {
        padding: 1.5rem 1.15rem;
    }
    .lg-header {
        margin-bottom: 1.25rem;
    }
    .lg-title {
        font-size: 1.4rem;
    }
    .lg-subtitle {
        font-size: 0.82rem;
    }
    .lg-input {
        height: 44px;
        font-size: 0.88rem;
    }
    .lg-label {
        font-size: 0.8rem;
    }
    .lg-submit-btn {
        padding: 0.85rem;
        font-size: 0.92rem;
        min-height: 48px;
    }
    .lg-pwd-toggle {
        padding: 0.4rem;
        font-size: 1.1rem;
    }
    .lg-error-alert {
        padding: 0.7rem 0.85rem;
    }
    .lg-divider {
        margin: 1.25rem 0;
    }
    .lg-register-link {
        font-size: 0.8rem;
        margin-top: 1.25rem;
    }
    .lg-alt-btn {
        padding: 0.75rem 0.85rem;
    }
}

/* ═══ SMALL MOBILE ═══ */
@media (max-width: 400px) {
    .lg-page {
        padding: 0.5rem;
    }
    .lg-form-panel {
        border-radius: 1rem;
    }
    .lg-form-scroll {
        padding: 1.25rem 0.9rem;
    }
    .lg-mobile-logo {
        width: 48px;
        height: 48px;
    }
    .lg-title {
        font-size: 1.25rem;
    }
    .lg-subtitle {
        font-size: 0.78rem;
    }
    .lg-input {
        height: 42px;
        font-size: 0.85rem;
    }
    .lg-greeting-pill {
        font-size: 0.72rem;
    }
}

@media (prefers-reduced-motion: reduce) {
    .lg-brand-logo-wrap,
    .lg-brand-title,
    .lg-brand-sub,
    .lg-feature-item,
    .lg-greeting-pill,
    .lg-wave-icon,
    .lg-title,
    .lg-subtitle,
    .lg-field,
    .lg-submit-btn,
    .lg-divider,
    .lg-alt-btn,
    .lg-register-link,
    .lg-error-alert,
    .lg-brand-bg::before,
    .lg-brand-bg::after {
        animation: none !important;
        opacity: 1 !important;
    }
}

/* ── Google error modal ── */
.lg-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15,23,42,0.55);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
}
.lg-modal-backdrop.lg-modal-open {
    opacity: 1;
    pointer-events: all;
}
.lg-modal {
    background: #fff;
    border-radius: 1rem;
    padding: 2rem 2rem 1.75rem;
    width: 100%;
    max-width: 380px;
    box-shadow: 0 20px 60px rgba(15,23,42,0.18);
    text-align: center;
    transform: translateY(20px) scale(0.97);
    transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1), opacity 0.22s ease;
    opacity: 0;
}
.lg-modal-backdrop.lg-modal-open .lg-modal {
    transform: translateY(0) scale(1);
    opacity: 1;
}
.lg-modal-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.1rem;
}
.lg-modal-icon--error {
    background: #FEF2F2;
    color: #DC2626;
}
.lg-modal-icon--warning {
    background: #FFFBEB;
    color: #D97706;
}
.lg-modal-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 0.5rem;
}
.lg-modal-body {
    font-size: 0.9rem;
    color: #475569;
    margin: 0 0 1.5rem;
    line-height: 1.55;
}
.lg-modal-actions {
    display: flex;
    gap: 0.65rem;
    justify-content: center;
}
.lg-modal-btn {
    flex: 1;
    padding: 0.6rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: background 0.15s, box-shadow 0.15s;
}
.lg-modal-btn--primary {
    background: #1E3A8A;
    color: #fff;
}
.lg-modal-btn--primary:hover {
    background: #1e40af;
    box-shadow: 0 4px 12px rgba(30,58,138,0.3);
}
.lg-modal-btn--secondary {
    background: #F1F5F9;
    color: #334155;
}
.lg-modal-btn--secondary:hover {
    background: #E2E8F0;
}
/* Password suggestion modal extras */
.lg-pwd-modal-note {
    font-size: 0.78rem;
    color: #64748B;
    margin: 0 0 1.25rem;
    line-height: 1.5;
    text-align: center;
}
#lgLoginCodeInput:focus {
    border-color: #1E3A8A;
    box-shadow: 0 0 0 3px rgba(30,58,138,.15);
}
</style>
{% endblock %}

{% block body %}
{# ═══════════════════════════════════════════════════
   LOGIN PAGE — Professional Split Layout
   ═══════════════════════════════════════════════════ #}

<div class="lg-page">
    {# ── LEFT PANEL: Decorative branding ── #}
    <div class="lg-brand-panel">
        <div class="lg-brand-bg"></div>
        <div class="lg-brand-content">
            <div class="lg-brand-logo-wrap">
                <img src="{{ asset('images/quamc-logo.png') }}" alt="QUAMC" class="lg-brand-logo">
            </div>
            <h1 class="lg-brand-title">SET-SEF Evaluation System</h1>
            <p class="lg-brand-sub">Welcome back to the Negros Oriental State University evaluation platform</p>

            <div class="lg-brand-features">
                <div class="lg-feature-item">
                    <div class="lg-feature-icon"><i  class="bi bi-shield-check"></i></div>
                    <div>
                        <strong>Secure Access</strong>
                        <span>Your data is protected with enterprise-grade security</span>
                    </div>
                </div>
                <div class="lg-feature-item">
                    <div class="lg-feature-icon"><i  class="bi bi-speedometer2"></i></div>
                    <div>
                        <strong>Real-time Dashboard</strong>
                        <span>Instant access to evaluations and analytics</span>
                    </div>
                </div>
                <div class="lg-feature-item">
                    <div class="lg-feature-icon"><i  class="bi bi-people"></i></div>
                    <div>
                        <strong>Multi-role Support</strong>
                        <span>Students, faculty, and staff — all in one system</span>
                    </div>
                </div>
            </div>

            <div class="lg-brand-footer">
                <p>&copy; {{ 'now'|date('Y') }} Negros Oriental State University</p>
            </div>
        </div>
    </div>

    {# ── RIGHT PANEL: Login form ── #}
    <div class="lg-form-panel">
        <div class="lg-form-scroll">
            <div class="lg-form-inner">

                {# Mobile logo (hidden on desktop) #}
                <div class="lg-mobile-header d-lg-none">
                    <img src="{{ asset('images/quamc-logo.png') }}" alt="QUAMC" class="lg-mobile-logo">
                </div>

                {# Welcome header #}
                <div class="lg-header">
                    <h2 class="lg-title">Sign in to your account</h2>
                    <p class="lg-subtitle">Access your dashboard, evaluations, and analytics</p>
                </div>

                {# Registration success alerts #}
                {% for message in app.flashes('registration_success') %}
                    <div class="lg-success-alert">
                        <div class="lg-success-icon-box">
                            <i  class="bi bi-check-circle-fill"></i>
                        </div>
                        <div>
                            <strong class="lg-success-title">Account Created!</strong>
                            <span class="lg-success-msg">{{ message }}</span>
                        </div>
                    </div>
                {% endfor %}

                {% for message in app.flashes('registration_pending') %}
                    <div class="lg-pending-alert">
                        <div class="lg-pending-icon-box">
                            <i  class="bi bi-hourglass-split"></i>
                        </div>
                        <div>
                            <strong class="lg-pending-title">Account Created — Pending Approval</strong>
                            <span class="lg-pending-msg">{{ message }}</span>
                        </div>
                    </div>
                {% endfor %}

                {# Error alert #}
                {% if error %}
                    <div class="lg-error-alert">
                        <div class="lg-error-icon-box">
                            <i  class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <div>
                            <strong class="lg-error-title">Authentication failed</strong>
                            <span class="lg-error-msg">{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                        </div>
                    </div>
                {% endif %}

                {# Login form #}
                <form method="post" class="lg-form" id="loginForm">
                    <div class="lg-field">
                        <label for="inputEmail" class="lg-label">
                            Email or Student ID
                        </label>
                        <div class="lg-input-wrap">
                            <i  class="bi bi-envelope"></i>
                            <input type="text" value="{{ last_username }}" name="_username" id="inputEmail"
                                   class="form-control lg-input" autocomplete="username" required autofocus
                                   placeholder="Enter your email or student ID">
                        </div>
                    </div>

                    <div class="lg-field">
                        <label for="inputPassword" class="lg-label">
                            Password
                        </label>
                        <div class="lg-input-wrap">
                            <i  class="bi bi-key"></i>
                            <input type="password" name="_password" id="inputPassword"
                                   class="form-control lg-input" autocomplete="current-password" required
                                   placeholder="Enter your password">
                            <button type="button" class="lg-pwd-toggle" id="pwdToggle" tabindex="-1"
                                    aria-label="Toggle password visibility">
                                <i  id="pwdToggleIcon" class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="lg-submit-btn" id="loginSubmitBtn">
                        <span class="lg-submit-text">
                            Sign In<i  class="bi bi-arrow-right ms-2"></i>
                        </span>
                        <span class="lg-submit-loading d-none">
                            <span class="lg-loading-spinner"></span>
                            <span>Signing In</span>
                            <span class="lg-loading-dots"><span>.</span><span>.</span><span>.</span></span>
                        </span>
                        <span class="lg-btn-progress"></span>
                    </button>

                    <div class="lg-divider">
                        <span>or continue with</span>
                    </div>

                    {% if googleAuthEnabled %}
                    <button type="button" class="lg-google-btn" id="lgGoogleBtn" onclick="lgTriggerGoogleSignIn()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" style="margin-right:10px;flex-shrink:0">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.96 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                            <path fill="none" d="M0 0h48v48H0z"/>
                        </svg>
                        <span>Continue with Google</span>
                    </button>
                    <div id="lgGoogleBtnOverlay" style="position:fixed;top:-9999px;left:-9999px;width:220px;height:50px;overflow:hidden;"></div>
                    {% endif %}

                    <div class="lg-register-link">
                        New to the platform? <a href="{{ path('app_register') }}">Create an account</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{% if googleAuthEnabled %}
{# ── Google sign-in error modal ── #}
<div id="lgGoogleModal" class="lg-modal-backdrop" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="lgGoogleModalTitle">
    <div class="lg-modal">
        <div class="lg-modal-icon lg-modal-icon--error" id="lgGoogleModalIcon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h3 class="lg-modal-title" id="lgGoogleModalTitle">Google Sign-In</h3>
        <p class="lg-modal-body" id="lgGoogleModalBody">An error occurred.</p>
        <div class="lg-modal-actions" id="lgGoogleModalActions">
            <button type="button" class="lg-modal-btn lg-modal-btn--secondary" onclick="lgCloseModal()">Close</button>
        </div>
    </div>
</div>
{% endif %}

{# ═══ Google login 6-digit code modal ═══ #}
{% if googleAuthEnabled %}
<div id="lgPwdModal" class="lg-modal-backdrop" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="lgPwdModalTitle" style="z-index:10001">
    <div class="lg-modal">
        <div class="lg-modal-icon" style="background:#EFF6FF;color:#1E40AF">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h3 class="lg-modal-title" id="lgPwdModalTitle">Check Your Gmail</h3>
        <p class="lg-modal-body" style="margin-bottom:0.4rem">A 6-digit login code was sent to:</p>
        <p id="lgPwdEmailAddr" style="font-weight:700;color:#1E40AF;font-size:0.88rem;text-align:center;margin:0 0 1rem;word-break:break-all"></p>
        <div style="margin-bottom:1rem">
            <input type="text" id="lgLoginCodeInput" inputmode="numeric" pattern="[0-9]{6}" maxlength="6"
                placeholder="Enter 6-digit code"
                style="width:100%;padding:0.65rem 1rem;font-size:1.3rem;font-weight:700;letter-spacing:.25em;text-align:center;border:2px solid #CBD5E1;border-radius:0.5rem;outline:none;font-family:monospace;box-sizing:border-box"
                autocomplete="one-time-code">
            <p id="lgLoginCodeMsg" style="margin:0.4rem 0 0;font-size:0.78rem;color:#DC2626;text-align:center;min-height:1.1em"></p>
        </div>
        <div class="lg-modal-actions">
            <button type="button" class="lg-modal-btn lg-modal-btn--secondary" id="lgPwdSkipBtn">Cancel</button>
            <button type="button" class="lg-modal-btn lg-modal-btn--primary" id="lgPwdContinueBtn">Verify &amp; Login</button>
        </div>
    </div>
</div>
{% endif %}
<script>
(function() {
    'use strict';

    /* ── Password visibility toggle ── */
    var pwdToggle = document.getElementById('pwdToggle');
    var pwdInput  = document.getElementById('inputPassword');
    var pwdIcon   = document.getElementById('pwdToggleIcon');
    if (pwdToggle && pwdInput) {
        pwdToggle.addEventListener('click', function() {
            var isPassword = pwdInput.type === 'password';
            pwdInput.type = isPassword ? 'text' : 'password';
            pwdIcon.classList.toggle('bi-eye', !isPassword);
            pwdIcon.classList.toggle('bi-eye-slash', isPassword);
        });
    }

    /* ── Submit loading state ── */
    var loginForm = document.getElementById('loginForm');
    var submitBtn = document.getElementById('loginSubmitBtn');
    if (loginForm && submitBtn) {
        loginForm.addEventListener('submit', function() {
            var load = submitBtn.querySelector('.lg-submit-loading');
            if (load) load.classList.remove('d-none');
            submitBtn.classList.add('lg-btn-loading');
            submitBtn.disabled = true;
        });
    }

    /* ── Focus animation on inputs ── */
    document.querySelectorAll('.lg-input').forEach(function(input) {
        input.addEventListener('focus', function() {
            this.closest('.lg-input-wrap').classList.add('lg-focused');
        });
        input.addEventListener('blur', function() {
            this.closest('.lg-input-wrap').classList.remove('lg-focused');
        });
    });
})();
</script>

{% if googleAuthEnabled %}
<script>
(function() {
    'use strict';

    var LG_CLIENT_ID  = {{ googleClientId | json_encode | raw }};
    var LG_LOGIN_URL   = '{{ path('app_google_login') }}';
    var LG_VERIFY_URL  = '{{ path('app_google_login_verify') }}';
    var _lgPendingRedirect = null;
    var _lgGoogleScriptPromise = null;

    function lgDefaultGoogleButtonHtml() {
        return '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" style="margin-right:10px;flex-shrink:0"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.96 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/><path fill="none" d="M0 0h48v48H0z"/></svg><span>Continue with Google</span>';
    }

    function lgResetGoogleButton(btn) {
        if (!btn) return;
        btn.disabled = false;
        btn.innerHTML = lgDefaultGoogleButtonHtml();
    }

    function lgEnsureGoogleScript() {
        if (window.google && window.google.accounts && window.google.accounts.id) {
            return Promise.resolve(window.google);
        }
        if (_lgGoogleScriptPromise) {
            return _lgGoogleScriptPromise;
        }

        _lgGoogleScriptPromise = new Promise(function(resolve, reject) {
            var existing = document.querySelector('script[data-google-gsi="1"]');
            if (existing) {
                var existingStatus = existing.getAttribute('data-google-gsi-status');
                if (existingStatus === 'loaded' && window.google && window.google.accounts && window.google.accounts.id) {
                    resolve(window.google);
                    return;
                }
                if (existingStatus === 'loading') {
                    existing.addEventListener('load', function() {
                        if (window.google && window.google.accounts && window.google.accounts.id) {
                            resolve(window.google);
                            return;
                        }
                        _lgGoogleScriptPromise = null;
                        reject(new Error('Google Identity script loaded without API.'));
                    }, { once: true });
                    existing.addEventListener('error', function() {
                        _lgGoogleScriptPromise = null;
                        reject(new Error('Failed to load Google Identity script.'));
                    }, { once: true });
                    return;
                }

                existing.remove();
            }

            var script = document.createElement('script');
            script.src = 'https://accounts.google.com/gsi/client';
            script.async = true;
            script.defer = true;
            script.setAttribute('data-google-gsi', '1');
            script.setAttribute('data-google-gsi-status', 'loading');
            script.onload = function() {
                script.setAttribute('data-google-gsi-status', 'loaded');
                if (window.google && window.google.accounts && window.google.accounts.id) {
                    resolve(window.google);
                    return;
                }
                _lgGoogleScriptPromise = null;
                reject(new Error('Google Identity script loaded without API.'));
            };
            script.onerror = function() {
                script.setAttribute('data-google-gsi-status', 'error');
                _lgGoogleScriptPromise = null;
                reject(new Error('Failed to load Google Identity script.'));
            };
            document.head.appendChild(script);
        });

        return _lgGoogleScriptPromise;
    }

    window.lgTriggerGoogleSignIn = function() {
        var overlay = document.getElementById('lgGoogleBtnOverlay');
        var btn = document.getElementById('lgGoogleBtn');
        if (!overlay) {
            return;
        }

        overlay.innerHTML = '';
        if (btn) {
            btn.disabled = true;
            btn.textContent = 'Loading Google...';
        }

        lgEnsureGoogleScript()
            .then(function() {
                if (window.google && window.google.accounts && window.google.accounts.id && typeof window.google.accounts.id.disableAutoSelect === 'function') {
                    // Always allow account switching instead of silently reusing a previous Google account.
                    window.google.accounts.id.disableAutoSelect();
                }

                window.google.accounts.id.initialize({
                    client_id: LG_CLIENT_ID,
                    callback: lgHandleGoogleCredential,
                    use_fedcm_for_prompt: false,
                    auto_select: false
                });

                window.google.accounts.id.renderButton(overlay, {
                    type: 'standard',
                    theme: 'outline',
                    size: 'large',
                    width: 220
                });

                setTimeout(function() {
                    var realBtn = overlay.querySelector('div[role="button"]') ||
                                  overlay.querySelector('button') ||
                                  overlay.firstElementChild;
                    if (realBtn) realBtn.click();
                }, 150);

                lgResetGoogleButton(btn);
            })
            .catch(function() {
                lgResetGoogleButton(btn);

                var bodyEl = document.getElementById('lgGoogleModalBody');
                var actionsEl = document.getElementById('lgGoogleModalActions');
                if (bodyEl) bodyEl.textContent = 'Google sign-in is unavailable right now. Please check your internet connection and try again.';
                if (actionsEl) actionsEl.innerHTML =
                    '<button type="button" class="lg-modal-btn lg-modal-btn--secondary" onclick="lgCloseModal()">Close</button>';
                lgOpenModal();
            });
    };

    window.lgUseAnotherGoogleAccount = function() {
        var btn = document.getElementById('lgGoogleBtn');
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" style="margin-right:10px;flex-shrink:0"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.96 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/><path fill="none" d="M0 0h48v48H0z"/></svg><span>Continue with Google</span>';
        }

        lgCloseModal();
        setTimeout(function() {
            window.lgTriggerGoogleSignIn();
        }, 120);
    };

    /* ── Google login 6-digit code modal ── */
    function lgShowCodeModal(email, debugCode) {
        var emailEl = document.getElementById('lgPwdEmailAddr');
        if (emailEl) emailEl.textContent = email || '';
        var codeInput = document.getElementById('lgLoginCodeInput');
        var codeMsg   = document.getElementById('lgLoginCodeMsg');
        if (codeInput) { codeInput.value = debugCode ? String(debugCode) : ''; }
        if (codeMsg)   { codeMsg.textContent = ''; }

        var modal = document.getElementById('lgPwdModal');
        if (!modal) return;
        modal.setAttribute('aria-hidden', 'false');
        modal.classList.add('lg-modal-open');
        document.body.style.overflow = 'hidden';
        if (codeInput) setTimeout(function() { codeInput.focus(); }, 100);

        function lgDoVerify() {
            var code = codeInput ? codeInput.value.trim() : '';
            if (!/^\d{6}$/.test(code)) {
                if (codeMsg) codeMsg.textContent = 'Enter the 6-digit code from your Gmail.';
                return;
            }
            var verifyBtn = document.getElementById('lgPwdContinueBtn');
            if (verifyBtn) { verifyBtn.disabled = true; verifyBtn.textContent = 'Verifying…'; }
            if (codeMsg) codeMsg.textContent = '';

            fetch(LG_VERIFY_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ code: code }),
            })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (verifyBtn) { verifyBtn.disabled = false; verifyBtn.textContent = 'Verify & Login'; }
                if (d.success && d.redirect) {
                    modal.setAttribute('aria-hidden', 'true');
                    modal.classList.remove('lg-modal-open');
                    document.body.style.overflow = '';
                    window.location.href = d.redirect;
                    return;
                }
                if (codeMsg) codeMsg.textContent = d.message || 'Incorrect code. Please try again.';
            })
            .catch(function() {
                if (verifyBtn) { verifyBtn.disabled = false; verifyBtn.textContent = 'Verify & Login'; }
                if (codeMsg) codeMsg.textContent = 'Network error. Please try again.';
            });
        }

        var continueBtn = document.getElementById('lgPwdContinueBtn');
        var cancelBtn   = document.getElementById('lgPwdSkipBtn');
        if (continueBtn) continueBtn.onclick = lgDoVerify;
        if (codeInput) {
            codeInput.onkeydown = function(e) { if (e.key === 'Enter') lgDoVerify(); };
        }
        if (cancelBtn) {
            cancelBtn.onclick = function() {
                modal.setAttribute('aria-hidden', 'true');
                modal.classList.remove('lg-modal-open');
                document.body.style.overflow = '';
                var btn = document.getElementById('lgGoogleBtn');
                if (btn) { btn.disabled = false; btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" style="margin-right:10px;flex-shrink:0"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.96 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/><path fill="none" d="M0 0h48v48H0z"/></svg><span>Continue with Google</span>'; }
            };
        }
    }

    function lgHandleGoogleCredential(response) {
        var btn = document.getElementById('lgGoogleBtn');
        if (btn) { btn.disabled = true; btn.textContent = 'Signing in…'; }

        fetch(LG_LOGIN_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ idToken: response.credential })
        })
        .then(function(r) { return r.json().then(function(d) { return { status: r.status, data: d }; }); })
        .then(function(res) {
            var d = res.data;
            if (d.success && d.redirect) {
                window.location.href = d.redirect;
                return;
            }
            if (d.needsCode) {
                lgShowCodeModal(d.email || '', d.debugCode || null);
                return;
            }
            if (btn) { btn.disabled = false; btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" style="margin-right:10px;flex-shrink:0"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.96 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/><path fill="none" d="M0 0h48v48H0z"/></svg><span>Continue with Google</span>'; }

            var iconEl    = document.getElementById('lgGoogleModalIcon');
            var bodyEl    = document.getElementById('lgGoogleModalBody');
            var actionsEl = document.getElementById('lgGoogleModalActions');

            if (d.noAccount) {
                if (iconEl) { iconEl.className = 'lg-modal-icon lg-modal-icon--error'; }
                if (bodyEl) bodyEl.textContent = 'No account is linked to this Google email. You can try another Google account or create a new account.';
                if (actionsEl) actionsEl.innerHTML =
                    '<button type="button" class="lg-modal-btn lg-modal-btn--secondary" onclick="lgUseAnotherGoogleAccount()">Use Another Google Account</button>' +
                    '<a href="{{ path('app_register') }}" class="lg-modal-btn lg-modal-btn--primary" style="display:flex;align-items:center;justify-content:center;text-decoration:none;">Create Account</a>';
            } else if (d.pending) {
                if (iconEl) { iconEl.className = 'lg-modal-icon lg-modal-icon--warning'; }
                if (bodyEl) bodyEl.textContent = 'Your account is pending administrator approval. Please check back later.';
                if (actionsEl) actionsEl.innerHTML =
                    '<button type="button" class="lg-modal-btn lg-modal-btn--secondary" onclick="lgCloseModal()">OK</button>';
            } else {
                if (iconEl) { iconEl.className = 'lg-modal-icon lg-modal-icon--error'; }
                if (bodyEl) bodyEl.textContent = d.message || 'Google sign-in failed. Please try again.';
                if (actionsEl) actionsEl.innerHTML =
                    '<button type="button" class="lg-modal-btn lg-modal-btn--secondary" onclick="lgCloseModal()">Close</button>';
            }

            lgOpenModal();
        })
        .catch(function() {
            if (btn) { btn.disabled = false; }
            var bodyEl = document.getElementById('lgGoogleModalBody');
            var actionsEl = document.getElementById('lgGoogleModalActions');
            if (bodyEl) bodyEl.textContent = 'A network error occurred. Please check your connection and try again.';
            if (actionsEl) actionsEl.innerHTML = '<button type="button" class="lg-modal-btn lg-modal-btn--secondary" onclick="lgCloseModal()">Close</button>';
            lgOpenModal();
        });
    }

    function lgOpenModal() {
        var modal = document.getElementById('lgGoogleModal');
        if (!modal) return;
        modal.setAttribute('aria-hidden', 'false');
        modal.classList.add('lg-modal-open');
        document.body.style.overflow = 'hidden';
        modal.addEventListener('click', function(e) {
            if (e.target === modal) lgCloseModal();
        }, { once: true });
    }

    window.lgCloseModal = function() {
        var modal = document.getElementById('lgGoogleModal');
        if (!modal) return;
        modal.classList.remove('lg-modal-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    };

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') lgCloseModal();
    });

    window.lgHandleGoogleCredential = lgHandleGoogleCredential;
})();
</script>
{% endif %}
{% endblock %}
