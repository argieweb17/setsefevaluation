                    {% elseif label == 'info' and message starts with 'Imported loadslip filter cleared.' %}
                        {% set loadslipClearedMessages = loadslipClearedMessages|merge([message]) %}
                    {% elseif label == 'warning' and (
                        message starts with 'No valid subject codes were found from the uploaded image.'
                        or message starts with 'Image is not readable for OCR'
                        or message starts with 'Image text is not readable enough for OCR.'
                        or message starts with 'Upload rejected: image color does not match the instruction sample'
                        or message starts with 'Upload rejected: image does not match the required loadslip format shown in the instruction'
                        or message starts with 'Upload rejected: loadslip semester mismatch.'
                        or message starts with 'Upload rejected: loadslip school year mismatch.'
                    ) %}
                        {% set loadslipNoCodesMessages = loadslipNoCodesMessages|merge([message]) %}
                    {% elseif label == 'warning' and message starts with 'Loadslip is not verified for this Student ID.' %}
                        {% set loadslipNotVerifiedMessages = loadslipNotVerifiedMessages|merge([message]) %}
                    {% elseif label == 'warning' and message starts with 'Loadslip is already verified.' %}
                        {% set loadslipAlreadyVerifiedMessages = loadslipAlreadyVerifiedMessages|merge([message]) %}
                    {% elseif label == 'danger' and message starts with 'Please select Agree or Disagree in the Data Privacy Disclaimer' %}
