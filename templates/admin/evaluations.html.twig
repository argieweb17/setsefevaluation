<div class="modal fade" id="createSuperiorEvalModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content ev-modal">
            <div class="ev-modal-header">
                <div class="d-flex align-items-center gap-2">
                    <div class="ev-modal-icon"><i class="bi bi-plus-circle-fill"></i></div>
                    <div>
                        <h5 class="mb-0 fw-bold text-white">New SEF Evaluation</h5>
                        <small class="text-white-50">Superior Evaluation for Faculty</small>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="{{ path(prefix ~ '_evaluation_create') }}" data-turbo="false">
                <input type="hidden" name="_token" value="{{ csrf_token('create_eval') }}">
                <input type="hidden" name="evaluationType" value="SUPERIOR">
                <div class="modal-body p-4">
                    <div class="mb-3 p-3 rounded-3" style="background:#f5f3ff;border:1px solid #ede9fe;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-info-circle-fill" style="color:#7c3aed;"></i>
                            <strong style="color:#5b21b6;font-size:.82rem;">About SEF Evaluation</strong>
                        </div>
                        <p class="mb-0" style="font-size:.78rem;color:#6b7280;">
                            <strong>Superior Evaluation for Faculty (SEF)</strong> allows Superiors to evaluate personnel
                            with employment status set to <strong>Dean</strong>, <strong>Department Head</strong>, or <strong>Chair</strong>.
                            Evaluation questions will use the SEF question set.
                        </p>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">School Year</label>
                            <select name="schoolYear" class="form-select ev-form-control">
                                <option value="">— Select —</option>
                                {% for ay in academicYears|default([]) %}
                                    <option value="{{ ay.yearLabel }}" {{ ay.isCurrent ? 'selected' : '' }}>{{ ay.yearLabel }}{% if ay.isCurrent %} (Current){% endif %}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">College</label>
                            <select name="college" class="form-select ev-form-control sup-college-select">
                                <option value="">All Colleges</option>
                                {% for col in colleges %}
                                    <option value="{{ col }}">{{ col }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Department</label>
                            <select name="department" class="form-select ev-form-control sup-dept-select">
                                <option value="">All Departments</option>
                                {% for dept in departments %}
                                    <option value="{{ dept.id }}" data-college="{{ dept.collegeName }}">{{ dept.departmentName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Faculty</label>
                            <select name="faculty" class="form-select ev-form-control sup-faculty-select">
                                <option value="" data-position="" data-department="">— Select Faculty —</option>
                                {% for f in facultyUsers %}
                                    <option value="{{ f.fullName }}" data-position="{{ f.employmentStatus }}" data-department="{{ f.department ? f.department.id : '' }}">{{ f.lastName }}, {{ f.firstName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Position</label>
                            <input type="text" name="position" class="form-control ev-form-control sup-position-input" placeholder="Auto-filled from faculty" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Start Date & Time</label>
                            <input type="datetime-local" name="startDate" class="form-control ev-form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">End Date & Time</label>
                            <input type="datetime-local" name="endDate" class="form-control ev-form-control" required>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="status" id="supEvalStatus" value="1" checked>
                                <label class="form-check-label ev-form-label" for="supEvalStatus">Open</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="anonymousMode" id="supAnonMode" value="1" checked>
                                <label class="form-check-label ev-form-label" for="supAnonMode">Anonymous</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 py-3" style="background:#f5f3ff;">
                    <button type="button" class="btn btn-sm btn-secondary px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm px-3 fw-semibold" style="background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(5,150,105,.85));color:#fff;border:none;">
                        <i class="bi bi-plus-lg me-1"></i>Create SEF Evaluation
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════
   STYLES
   ═══════════════════════════════════════ #}
<style>
/* ──── Header ──── */
.ev-header{border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);box-shadow:0 4px 24px rgba(26,86,219,.15);margin-bottom:16px;}
.ev-header-inner{padding:22px 26px 18px;}
.ev-header-icon{width:48px;height:48px;background:rgba(255,255,255,.15);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.35rem;color:#fff;backdrop-filter:blur(8px);}
.ev-meta-pill{background:rgba(255,255,255,.13);color:rgba(255,255,255,.85);padding:3px 10px;border-radius:20px;font-weight:600;backdrop-filter:blur(6px);}
.ev-meta-active{background:rgba(34,197,94,.25);color:#bbf7d0;}

/* ──── Stats Row ──── */
.ev-stats-row{display:flex;gap:0;margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,255,255,.1);flex-wrap:wrap;}
.ev-stat{text-align:center;flex:1;min-width:70px;padding:4px 0 8px;}
.ev-stat-val{display:block;font-size:1.35rem;font-weight:800;color:#fff;}
.ev-stat-lbl{font-size:.7rem;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.5px;font-weight:600;}
.ev-val-success{color:#86efac !important;}
.ev-val-warn{color:#fde68a !important;}
.ev-val-info{color:#93c5fd !important;}
.ev-stat-divider{width:1px;align-self:stretch;background:rgba(255,255,255,.10);margin:4px 0 8px;}

/* ──── Toolbar ──── */
.ev-toolbar{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:.75rem 1rem;margin:1.25rem 0;overflow-x:auto;}
.ev-filter-group{display:inline-flex;background:#f1f5f9;border-radius:8px;padding:2px;gap:2px;}
.ev-filter-btn{border:none;background:transparent;color:#64748b;font-size:.78rem;font-weight:600;padding:5px 12px;border-radius:6px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.ev-filter-btn:hover{background:rgba(59,130,246,.08);color:#1e40af;}
.ev-filter-btn.active{background:#1a56db;color:#fff;box-shadow:0 1px 3px rgba(26,86,219,.3);}
.ev-filter-count{background:rgba(0,0,0,.08);padding:1px 6px;border-radius:10px;font-size:.7rem;margin-left:3px;}
.ev-filter-btn.active .ev-filter-count{background:rgba(255,255,255,.25);color:#fff;}
.ev-filter-select{font-size:.78rem;padding:5px 10px;border:1px solid #e2e8f0;border-radius:8px;background:#f8fafc;color:#475569;cursor:pointer;min-width:110px;height:32px;}
.ev-filter-select:focus{outline:none;border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.ev-search-box{position:relative;min-width:150px;flex:1;}
.ev-search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.8rem;}
.ev-search-input{width:100%;padding:6px 12px 6px 32px;border:1px solid #e2e8f0;border-radius:8px;font-size:.8rem;background:#f8fafc;transition:all .2s;}
.ev-search-input:focus{outline:none;border-color:#3b82f6;background:#fff;box-shadow:0 0 0 3px rgba(59,130,246,.1);}

/* ──── Table Container ──── */
.ev-table-container{background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04);}
