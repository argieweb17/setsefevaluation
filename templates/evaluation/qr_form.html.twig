<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Evaluate {{ faculty.fullName }} | SET</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
<style>
.eval-form-paper{background:#fff;border:1px solid #e2e8f0;border-radius:0;overflow:hidden;box-shadow:0 4px 15px rgba(0,0,0,.06);margin-bottom:16px;}
.eval-info-bar{display:flex;flex-wrap:nowrap;align-items:center;justify-content:space-between;gap:4px 12px;padding:10px 14px;background:#f0f9ff;border-bottom:1px solid #e2e8f0;font-size:.76rem;}
.eval-info-bar>div{display:flex;align-items:center;gap:3px;white-space:nowrap;}
.eval-info-bar i{margin-right:0 !important;flex-shrink:0;}
.eval-form-instructions{background:#fffbeb;border-bottom:1px solid #fde68a;padding:12px 24px;font-size:.82rem;color:#92400e;display:flex;flex-direction:column;gap:.35rem;line-height:1.6;}
.eval-form-scale{display:flex;flex-wrap:wrap;align-items:center;gap:.2rem 1rem;}
.eval-form-section{border-bottom:1px solid #e2e8f0;}
.eval-form-section:last-child{border-bottom:0;}
.eval-form-category{background:#1e40af;padding:10px 24px;display:flex;align-items:center;gap:8px;}
.eval-form-category-label{color:#fff;font-weight:700;font-size:.85rem;}
.eval-form-cat-desc{background:#eff6ff;border-bottom:1px solid #bfdbfe;padding:12px 24px;font-size:.82rem;color:#475569;line-height:1.6;font-style:italic;}
.eval-form-table{width:100%;border-collapse:collapse;}
.eval-form-table thead{background:#f8fafc;}
.eval-form-table th{padding:10px 8px;font-size:.72rem;font-weight:600;color:#64748b;text-align:center;border-bottom:2px solid #e2e8f0;}
.eval-form-table th.eval-form-question{text-align:left;padding-left:16px;}
.eval-form-table th.eval-form-num{width:36px;text-align:center;}
.eval-form-table td{padding:10px 8px;border-bottom:1px solid #f1f5f9;vertical-align:middle;}
.eval-form-table td.eval-form-num{text-align:center;font-weight:600;color:#94a3b8;font-size:.82rem;}
.eval-form-table td.eval-form-question{padding-left:16px;font-size:.85rem;color:#1e293b;line-height:1.5;}
.eval-form-table td.eval-form-rating{text-align:center;width:60px;}
.eval-form-table tr:hover{background:#f8fafc;}
.eval-radio-label{display:inline-flex;align-items:center;justify-content:center;cursor:pointer;width:28px;height:28px;}
.eval-radio-label input{display:none;}
.eval-radio-circle{width:22px;height:22px;border:2px solid #cbd5e1;border-radius:50%;transition:all .15s;}
.eval-radio-label input:checked+.eval-radio-circle{border-color:#1e40af;background:#1e40af;box-shadow:inset 0 0 0 3px #fff;}
.eval-radio-label:hover .eval-radio-circle{border-color:#3b82f6;background:#eff6ff;}
.eval-form-textarea{border-radius:0;border-color:#e2e8f0;font-size:.85rem;resize:vertical;}
.eval-form-textarea:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.1);}
.eval-form-actions-bar{display:flex;gap:10px;padding:16px 0;justify-content:center;}
.btn-norsu{background:linear-gradient(135deg,#1e40af,#3b82f6);color:#fff;border:0;border-radius:0;padding:10px 32px;font-weight:600;font-size:.9rem;transition:all .2s;}
.btn-norsu:hover{background:linear-gradient(135deg,#1e3a8a,#2563eb);color:#fff;transform:translateY(-1px);box-shadow:0 4px 12px rgba(30,64,175,.3);}
.student-gate-card{background:#fff;border:1px solid #dbe3f0;border-radius:0;overflow:hidden;box-shadow:0 12px 30px rgba(30,64,175,.08);margin-bottom:16px;}
.student-gate-head{position:relative;padding:14px 18px;background:linear-gradient(135deg,#1e3a8a,#2563eb);color:#fff;}
.student-gate-head::after{display:none;}
.student-gate-body{padding:16px;background:linear-gradient(180deg,#ffffff 0%,#f8fbff 100%);}
.student-gate-grid{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(0,.95fr);gap:14px;align-items:start;}
.student-gate-grid.single{grid-template-columns:1fr;}
.student-verify-box,.student-guide-box{background:#fff;border:1px solid #dbeafe;border-radius:0;padding:14px;}
.student-verify-label{font-size:.82rem;font-weight:600;color:#334155;}
.student-id-input{height:44px;border-radius:0;border-color:#cbd5e1;font-size:1rem;font-weight:600;letter-spacing:.02em;}
.student-id-input:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.15);}
.student-verify-btn{height:44px;border-radius:0;}
.student-verified-chip{background:#ecfdf3;border:1px solid #86efac;border-radius:0;color:#166534;font-size:.84rem;font-weight:600;padding:10px 12px;display:flex;align-items:center;justify-content:center;gap:8px;}
.student-verified-name{max-width:100%;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.student-verified-icon{font-size:1rem;line-height:1;flex-shrink:0;}
.student-guide-box{background:#f8fafc;border-color:#dbe3ef;}
.student-guide-title{font-size:.96rem;font-weight:700;color:#1e40af;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.student-guide-list{list-style:none;padding:0;margin:0;counter-reset:verifyStep;}
.student-guide-list li{display:flex;gap:10px;align-items:flex-start;color:#475569;line-height:1.55;font-size:.9rem;}
.student-guide-list li+li{margin-top:9px;}
.student-guide-list li::before{counter-increment:verifyStep;content:counter(verifyStep) '.';min-width:auto;height:auto;border-radius:0;background:transparent;color:#1d4ed8;font-weight:700;font-size:.72rem;display:inline-flex;align-items:flex-start;justify-content:flex-start;margin-top:1px;flex-shrink:0;}
.student-state-card{margin-top:10px;padding:12px;border-radius:0;border:1px solid transparent;}
.student-state-title{font-size:.83rem;font-weight:700;margin-bottom:4px;}
.student-state-body{font-size:.82rem;line-height:1.52;}
.student-state-card.warn{background:#fff7ed;border-color:#fed7aa;color:#9a3412;}
.student-state-card.info{background:#eff6ff;border-color:#bfdbfe;color:#1e40af;}
.student-state-card.danger{background:#fef2f2;border-color:#fecaca;color:#991b1b;}
.student-loadslip-box{margin-top:10px;padding:12px;border-radius:0;background:#f8fafc;border:1px dashed #cbd5e1;}
.student-quick-card{margin-top:10px;padding:12px;border-radius:0;background:#eef2ff;border:1px solid #c7d2fe;}
.student-quick-title{font-size:.86rem;font-weight:700;color:#1e3a8a;margin-bottom:6px;display:flex;align-items:center;gap:6px;}
.student-quick-note{font-size:.8rem;color:#475569;line-height:1.45;margin-bottom:10px;}
@media(max-width:992px){
    .student-gate-grid{grid-template-columns:1fr;}
}
@media(max-width:576px){
    .container{padding-left:8px;padding-right:8px;}
    .eval-form-paper{border-radius:0;}
    .eval-info-bar{flex-direction:column;flex-wrap:nowrap;align-items:flex-start;justify-content:flex-start;gap:4px;padding:10px 14px;font-size:.75rem;}
    .eval-info-bar>div{white-space:normal;flex-wrap:wrap;}
    .eval-form-instructions{padding:10px 14px;font-size:.75rem;}
    .eval-form-scale{flex-direction:column;align-items:flex-start;gap:.15rem;}
    .eval-form-category{padding:8px 14px;}
    .eval-form-category-label{font-size:.78rem;}
    .eval-form-cat-desc{padding:8px 14px;font-size:.75rem;}
    .eval-form-table th{padding:6px 3px;font-size:.62rem;}
    .eval-form-table th small{display:none;}
    .eval-form-table th.eval-form-question{padding-left:10px;}
    .eval-form-table th.eval-form-num{width:24px;}
    .eval-form-table td{padding:8px 3px;}
    .eval-form-table td.eval-form-num{font-size:.72rem;width:24px;padding-left:4px;}
    .eval-form-table td.eval-form-question{padding-left:10px;font-size:.78rem;}
    .eval-form-table td.eval-form-rating{width:32px;padding:4px 1px;}
    .eval-radio-label{width:24px;height:24px;}
    .eval-radio-circle{width:18px;height:18px;}
    .card-header{padding:12px 16px !important;}
    .card-header h6{font-size:.85rem;}
    .card-body{padding:16px !important;}
    .student-gate-head{padding:12px 14px;}
    .student-gate-body{padding:12px;}
    .student-verify-box,.student-guide-box,.student-state-card{padding:12px;}
    .student-id-input,.student-verify-btn{height:42px;}
    .student-guide-list li{font-size:.86rem;}
    .eval-form-actions-bar{padding:12px 0;}
    .btn-norsu{width:100%;padding:12px;font-size:.85rem;}
}
@media(max-width:400px){
    .eval-form-table td.eval-form-rating{width:26px;}
    .eval-radio-label{width:20px;height:20px;}
    .eval-radio-circle{width:16px;height:16px;}
    .eval-form-table td.eval-form-question{font-size:.72rem;}
}
</style>
</head>
<body style="background:#f1f5f9;min-height:100vh;">

<div class="container py-4" style="max-width:860px;">

{% if success %}
{# ── Success Screen ── #}
<div class="text-center py-5">
    <div style="width:80px;height:80px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:20px;">
        <i class="bi bi-check-circle-fill" style="font-size:2.5rem;color:#16a34a;"></i>
    </div>
    <h4 class="fw-bold text-success mb-2">Evaluation Submitted!</h4>
    <p class="text-muted">Thank you for your feedback. Your evaluation has been recorded.</p>
    <div class="mt-3 p-3 rounded-3 d-inline-block" style="background:#f0fdf4;border:1px solid #bbf7d0;">
        <small class="text-muted">Faculty: <strong>{{ faculty.fullName }}</strong></small><br>
        <small class="text-muted">Subject: <strong>{{ subject.subjectCode }}</strong></small>
        <br><small class="text-muted">Description: <strong>{{ subject.subjectName }}</strong></small>
        <br><small class="text-muted">Section: <strong>{{ section|default('N/A') }}</strong></small>
        <br><small class="text-muted">Schedule: <strong>{{ schedule|default('N/A') }}</strong></small>
    </div>
    <div class="mt-4">
        <p class="text-muted" style="font-size:.85rem;">You may close this page now.</p>
    </div>
</div>
{% else %}
{# ── Student Verification + Evaluation Form ── #}

{% set showMismatchModal = error is defined and error and 'Loadslip details do not match this QR evaluation' in error %}
{% set showNoAccountHelp = error is defined and error and 'Student ID not found' in error %}
{% set showNoAccountModal = showNoAccountHelp %}
{% set showUnverifiedHelp = error is defined and error and ('Loadslip is not verified' in error or 'Loadslip verification expired or missing' in error) %}
{% set showUnverifiedModal = showUnverifiedHelp %}
{% set showPrivacyConsentModal = error is defined and error and ('You must agree to the Data Privacy Disclaimer to continue with the evaluation.' in error or 'You must agree to the Data Privacy Disclaimer before continuing.' in error or 'Please select Agree or Disagree for the Data Privacy Disclaimer.' in error) %}
{% set showInactiveHelp = error is defined and error and 'inactive' in error %}
{% set createAccountUrl = path('app_register', {'role': 'student'}) %}
{% set homeUrl = path('app_home') %}
{% set importLoadslipUrl = path('evaluation_set_index') %}
{% set showPrivacyDisclaimerFirst = qrVerified and not qrPrivacyConsentCaptured %}

{% if error and not showMismatchModal and not showNoAccountModal and not showUnverifiedModal and not showPrivacyConsentModal %}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ error }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<form method="post" id="qrEvalForm">

{# ── Student ID Gate ── #}
{% if not showPrivacyDisclaimerFirst %}
<div class="student-gate-card">
    <div class="student-gate-head">
        <div class="d-flex align-items-center gap-2 position-relative">
            <i class="bi bi-person-vcard-fill" style="font-size:1.18rem;"></i>
            <div>
                <h6 class="mb-0 fw-bold">Student ID Verification</h6>
                <small class="opacity-75">Enter your Student ID first to continue</small>
            </div>
        </div>
    </div>
    <div class="student-gate-body">
        <div class="student-gate-grid{{ qrVerified ? ' single' : '' }}">
            <div>
                <div class="student-verify-box">
                    <div class="small fw-semibold mb-2" style="color:#1e3a8a;">
                        <i class="bi bi-shield-check me-1"></i> {{ qrVerified ? 'Account verified' : 'Verify your account first' }}
                    </div>
                    <div class="row g-3 align-items-end">
                        <div class="col-md-8">
                            <label class="student-verify-label mb-1">Student ID <span class="text-danger">*</span></label>
                            <input type="text" name="school_id" class="form-control student-id-input" placeholder="e.g. 2023-1234"
                                   value="{{ qrVerified and verifiedStudent ? verifiedStudent.schoolId : formValues.school_id|default('') }}"
                                   {{ qrVerified ? 'readonly' : '' }} required>
                        </div>
                        <div class="col-md-4">
                            {% if not qrVerified %}
                            <button type="submit" name="_action" value="verify_student" class="btn btn-primary student-verify-btn w-100">
                                <i class="bi bi-check2-circle me-1"></i> Verify
                            </button>
                            {% else %}
                            <div class="student-verified-chip">
                                <span class="student-verified-name">{{ verifiedStudent.fullName }}</span>
                                <i class="bi bi-check-circle-fill student-verified-icon" title="Verified student" aria-label="Verified student"></i>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {% if qrVerified and (qrLoadslipRows|default([])) is not empty %}
                <div class="student-loadslip-box">
                    <div class="small fw-semibold text-primary mb-2">
                        <i class="bi bi-journal-check me-1"></i> Matched Loadslip Row
                    </div>
                    {% for row in qrLoadslipRows|slice(0, 3) %}
                        {% set displaySection = row.section|default('') %}
                        {% set displayDescription = row.description|default('') %}
                        {% set displaySchedule = row.schedule|default('') %}
                        {% set displayUnits = row.units|default('') %}
                        {% if displaySection == '' and section|default('') != '' %}
                            {% set displaySection = section %}
                        {% endif %}
                    <div class="small mb-2" style="color:#334155;">
                        <div><strong>Subject:</strong> {{ row.code|default('N/A') }}</div>
                        <div><strong>Section:</strong> {{ displaySection != '' ? displaySection : 'N/A' }}</div>
                        <div><strong>Description:</strong> {{ displayDescription != '' ? displayDescription : 'N/A' }}</div>
                        <div><strong>Schedule:</strong> {{ displaySchedule != '' ? displaySchedule : 'N/A' }}</div>
                        <div><strong>Unit:</strong> {{ displayUnits != '' ? displayUnits : 'N/A' }}</div>
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            </div>

            {% if not qrVerified %}
            <div>
                <div class="student-guide-box">
                    <div class="student-guide-title">
                        <i class="bi bi-info-circle-fill"></i> Student Verification Instructions
                    </div>
                    <ol class="student-guide-list">
                        <li>Enter your Student ID exactly as registered.</li>
                        <li>Click Verify to check account and loadslip status.</li>
                        <li>If no account is found, create an account.</li>
                        <li>If loadslip is not verified, import loadslip and verify it first.</li>
                    </ol>
                </div>

                <div class="student-quick-card">
                    <div class="student-quick-title">
                        <i class="bi bi-link-45deg"></i> Quick Access
                    </div>
                    <div class="student-quick-note">
                        Open the welcome page or create a student account before verification.
                    </div>
                    <div class="d-grid gap-2">
                        <a href="{{ createAccountUrl }}" class="btn btn-sm btn-primary">
                            <i class="bi bi-person-plus-fill me-1"></i>Student Register
                        </a>
                        <a href="{{ homeUrl }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-house-door-fill me-1"></i>Welcome / Home
                        </a>
                    </div>
                </div>

                {% if showNoAccountHelp %}
                <div class="student-state-card warn">
                    <div class="student-state-title">
                        <i class="bi bi-person-x-fill me-1"></i> No Student Account Found
                    </div>
                    <div class="student-state-body">
                        This Student ID does not exist in the system. Please create a student account to continue.
                    </div>
                </div>
                {% endif %}

                {% if showUnverifiedHelp %}
                <div class="student-state-card info">
                    <div class="student-state-title">
                        <i class="bi bi-journal-x me-1"></i> Loadslip Not Verified
                    </div>
                    <div class="student-state-body">
                        Import your loadslip in the student portal, complete verification, then return to this page and click Verify again.
                    </div>
                    <a href="{{ importLoadslipUrl }}" class="btn btn-sm btn-outline-primary mt-2">
                        <i class="bi bi-upload me-1"></i>Import Loadslip
                    </a>
                </div>
                {% endif %}

                {% if showInactiveHelp %}
                <div class="student-state-card danger">
                    <div class="student-state-title">
                        <i class="bi bi-person-lock me-1"></i> Account Inactive
                    </div>
                    <div class="student-state-body">
                        Your student account is inactive. Please contact your administrator to activate your account before verifying.
                    </div>
                </div>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}

{% if qrVerified %}

{# ── Data Privacy Disclaimer ── #}
{% if showPrivacyDisclaimerFirst %}
<div class="card border-0 shadow-sm mb-3" style="border-radius:0;overflow:hidden;">
    <div class="card-header py-3" style="background:linear-gradient(135deg,#1e3a8a,#2563eb);color:#fff;">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-shield-lock-fill" style="font-size:1.15rem;"></i>
            <div>
                <h6 class="mb-0 fw-bold">Data Privacy Disclaimer</h6>
                <small class="opacity-75">Please read before proceeding</small>
            </div>
        </div>
    </div>
    <div class="card-body p-4" style="font-size:.95rem;line-height:1.7;color:#1f2937;">
        <div class="mb-0">{{ privacyDisclaimerHtml|raw }}</div>

        <hr class="my-4">
        <div class="mb-2 fw-semibold" style="font-size:1rem;">
            Do you agree to the Data Privacy Disclaimer? <span class="text-danger">*</span>
        </div>
        <div class="d-flex flex-wrap gap-4 align-items-center">
            <div class="form-check mb-0">
                <input class="form-check-input" type="radio" name="privacy_consent" id="privacyAgree" value="agree" {{ formValues.privacy_consent|default('') == 'agree' ? 'checked' : '' }}>
                <label class="form-check-label" for="privacyAgree">Agree</label>
            </div>
            <div class="form-check mb-0">
                <input class="form-check-input" type="radio" name="privacy_consent" id="privacyDisagree" value="disagree" {{ formValues.privacy_consent|default('') == 'disagree' ? 'checked' : '' }}>
                <label class="form-check-label" for="privacyDisagree">Disagree</label>
            </div>
        </div>
        <button type="submit" name="_action" value="privacy_gate" class="d-none" tabindex="-1" aria-hidden="true"></button>
    </div>
</div>
{% endif %}

{# ── Evaluation Form Paper ── #}
{% if qrPrivacyConsentCaptured %}
<div class="eval-form-paper">
    {# ── Evaluation Info Bar ── #}
    <div class="eval-info-bar">
        <div><i class="bi bi-person-fill text-primary me-1"></i><strong>Faculty:</strong> {{ faculty.fullName }}</div>
        <div><i class="bi bi-journal-text text-success me-1"></i><strong>Subject:</strong> {{ subject.subjectCode }}</div>
        <div><i class="bi bi-card-text text-secondary me-1"></i><strong>Description:</strong> {{ subject.subjectName }}</div>
        {% if section %}<div><i class="bi bi-diagram-3 text-info me-1"></i><strong>Section:</strong> {{ section }}</div>{% endif %}
        {% if schedule %}<div><i class="bi bi-calendar-event text-warning me-1"></i><strong>Schedule:</strong> {{ schedule }}</div>{% endif %}
    </div>

    <div class="eval-form-instructions">
        <div><strong>Instructions:</strong> Rate each item using the scale:</div>
        <div class="eval-form-scale">
            <div><strong>5</strong> – Always manifested</div>
            <div><strong>4</strong> – Often manifested</div>
            <div><strong>3</strong> – Sometimes manifested</div>
            <div><strong>2</strong> – Seldom manifested</div>
            <div><strong>1</strong> – Never/Rarely manifested</div>
        </div>
    </div>

    {% set currentCategory = '' %}
    {% set counter = 1 %}

    {% for q in questions %}
        {% if q.category != currentCategory %}
            {% if currentCategory != '' %}
                    </tbody>
                </table>
            </div>
            {% endif %}
            {% set currentCategory = q.category %}
        <div class="eval-form-section">
            <div class="eval-form-category">
                <span class="eval-form-category-label">{{ currentCategory ?? 'General' }}</span>
            </div>
            {% if categoryDescriptions[currentCategory] is defined and categoryDescriptions[currentCategory] %}
            <div class="eval-form-cat-desc">
                <em>{{ categoryDescriptions[currentCategory]|replace({' (': "\n\n("})|replace({') and ': ")\n\nand "})|nl2br }}</em>
            </div>
            {% endif %}
            <table class="eval-form-table">
                <thead>
                    <tr>
                        <th class="eval-form-num"></th>
                        <th class="eval-form-question">Question</th>
                            <th class="eval-form-rating">1<br><small>Never/Rarely manifested</small></th>
                            <th class="eval-form-rating">2<br><small>Seldom manifested</small></th>
                            <th class="eval-form-rating">3<br><small>Sometimes manifested</small></th>
                            <th class="eval-form-rating">4<br><small>Often manifested</small></th>
                            <th class="eval-form-rating">5<br><small>Always manifested</small></th>
                    </tr>
                </thead>
                <tbody>
        {% endif %}

        <tr>
            <td class="eval-form-num">{{ counter }}.</td>
            <td class="eval-form-question">
                {{ q.questionText }}
                {% if q.isRequired %}<span class="text-danger">*</span>{% endif %}
            </td>
            {% for r in 1..5 %}
            <td class="eval-form-rating">
                <label class="eval-radio-label">
                    <input type="radio" name="ratings[{{ q.id }}]" value="{{ r }}"
                           {{ q.isRequired ? 'required' }}>
                    <span class="eval-radio-circle"></span>
                </label>
            </td>
            {% endfor %}
        </tr>
        {% set counter = counter + 1 %}
    {% endfor %}

    {# Close last category #}
    {% if currentCategory != '' %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {# Comment #}
    <div class="eval-form-section">
        <div class="eval-form-category">
            <span class="eval-form-category-label">Feedback/Comments <span class="text-danger">*</span></span>
        </div>
        <div class="p-3">
            <textarea name="comments[0]" class="form-control eval-form-textarea" rows="3" required
                      placeholder="Share any additional feedback for this faculty member..."></textarea>
        </div>
    </div>
</div>

{# Buttons #}
<div class="eval-form-actions-bar">
    <button type="submit" name="_action" value="submit" class="btn btn-norsu"
            onclick="return confirm('Once submitted, you cannot edit this evaluation. Continue?')">
        <i class="bi bi-send me-1"></i>Submit Evaluation
    </button>
</div>
{% endif %}
{% endif %}
</form>
