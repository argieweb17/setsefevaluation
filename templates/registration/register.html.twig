{% extends 'base.html.twig' %}

{% block title %}Create Account | QUAMC Evaluation{% endblock %}

{% block body_class %}no-navbar{% endblock %}

{% block stylesheets %}
<style>
/* ── Page layout ── */
.rg-page {
    display: flex;
    min-height: 100vh;
    background: #F8FAFC;
}

/* ── Left brand panel ── */
.rg-brand-panel {
    position: relative;
    width: 420px;
    min-width: 420px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
}
.rg-brand-bg {
    position: absolute;
    inset: 0;
    background: #1E3A8A;
    z-index: 0;
}
.rg-brand-bg::before {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    top: -150px;
    right: -120px;
    animation: float 8s ease-in-out infinite;
}
.rg-brand-bg::after {
    content: '';
    position: absolute;
    width: 350px;
    height: 350px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    bottom: -80px;
    left: -60px;
    animation: float 10s ease-in-out infinite reverse;
}
.rg-brand-content {
    position: relative;
    z-index: 1;
    padding: 3rem 2.5rem;
    color: #fff;
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: center;
}
.rg-brand-logo-wrap {
    width: 60px;
    height: 60px;
    background: transparent;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: none;
    margin-bottom: 1.5rem;
    box-shadow: none;
}
.rg-brand-logo {
    width: 60px;
    height: 60px;
    object-fit: contain;
}
.rg-brand-title {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin-bottom: 0.5rem;
    line-height: 1.3;
}
.rg-brand-sub {
    font-size: 0.95rem;
    opacity: 0.85;
    line-height: 1.5;
    margin-bottom: 2.5rem;
}
.rg-brand-features {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
}
.rg-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
}
.rg-feature-icon {
    width: 40px;
    height: 40px;
    border-radius: 0.625rem;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
}
.rg-feature-item strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.1rem;
}
.rg-feature-item span {
    font-size: 0.8rem;
    opacity: 0.75;
}
.rg-brand-footer {
    margin-top: auto;
    padding-top: 2rem;
    font-size: 0.78rem;
    opacity: 0.6;
}

/* ── Right form panel ── */
.rg-form-panel {
    flex: 1;
    display: flex;
    overflow: hidden;
}
.rg-form-scroll {
    flex: 1;
    overflow-y: auto;
    display: flex;
    justify-content: center;
    padding: 2rem 1.5rem;
}
.rg-form-inner {
    width: 100%;
    max-width: 580px;
    padding-top: 1rem;
    padding-bottom: 2rem;
}



/* ── Step progress ── */
.rg-steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 1.75rem;
}
.rg-step {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.4;
    transition: opacity 0.3s;
}
.rg-step.active {
    opacity: 1;
}
.rg-step.completed .rg-step-num {
    background: #1E3A8A;
    color: #fff;
}
.rg-step-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #E5E7EB;
    color: #6B7280;
    font-size: 0.8rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
}
.rg-step.active .rg-step-num {
    background: #1E3A8A;
    color: #fff;
    box-shadow: 0 2px 8px rgba(30, 58, 138, 0.35);
}
.rg-step span {
    font-size: 0.82rem;
    font-weight: 600;
    color: #374151;
}
.rg-step-line {
    width: 60px;
    height: 2px;
    background: #E5E7EB;
    margin: 0 0.75rem;
    border-radius: 1px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
}
.rg-step-line.active::after {
    content: '';
    position: absolute;
    inset: 0;
    background: #1E3A8A;
    animation: rgLineExpand 0.4s ease forwards;
}
@keyframes rgLineExpand {
    from { width: 0; }
    to   { width: 100%; }
}

/* ── Titles ── */
.rg-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: #1E293B;
    margin-bottom: 0.25rem;
    letter-spacing: -0.3px;
}
.rg-subtitle {
    font-size: 0.9rem;
    color: #6B7280;
    margin-bottom: 1.75rem;
}

/* ── Role cards ── */
.rg-role-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}
.rg-role-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 1.25rem;
    border: 2px solid #E5E7EB;
    border-radius: 0.875rem;
    background: #fff;
    cursor: pointer;
    transition: all 0.25s ease;
    text-align: left;
    width: 100%;
}
.rg-role-card:hover {
    border-color: #1E40AF;
    background: #F5F8FF;
    box-shadow: 0 4px 16px rgba(30,64,175,0.1);
    transform: translateX(4px);
}
.rg-role-card:hover .rg-role-arrow {
    opacity: 1;
    transform: translateX(0);
}
.rg-role-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 0.625rem;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: transform 0.2s;
}
.rg-role-card:hover .rg-role-icon-wrap {
    transform: scale(1.03);
}
.rg-role-student {
    background: transparent;
    color: #1E40AF;
}
.rg-role-faculty {
    background: transparent;
    color: #059669;
}
.rg-role-staff {
    background: transparent;
    color: #D97706;
}
.rg-role-superior {
    background: transparent;
    color: #7C3AED;
}
.rg-role-info {
    flex: 1;
    min-width: 0;
}
.rg-role-info h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: #1E293B;
    margin-bottom: 0.15rem;
}
.rg-role-info p {
    font-size: 0.78rem;
    color: #6B7280;
    margin: 0;
    line-height: 1.4;
}
.rg-role-arrow {
    font-size: 1.1rem;
    color: #1E40AF;
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.25s;
}

/* ── Selected role badge ── */
.rg-selected-role {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
}
.rg-role-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 1rem;
    border-radius: 2rem;
    font-size: 0.78rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.3px;
}
.rg-change-role {
    background: none;
    border: 1px solid #E5E7EB;
    border-radius: 0.5rem;
    padding: 0.3rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: #6B7280;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.15rem;
}
.rg-change-role:hover {
    background: #F3F4F6;
    color: #374151;
    border-color: #D1D5DB;
}

/* ── Form sections ── */
.rg-section {
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 0.875rem;
    padding: 1.25rem;
    margin-bottom: 1rem;
    transition: border-color 0.2s;
}
.rg-section:hover {
    border-color: #CBD5E1;
}
.rg-section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #1E40AF;
    margin-bottom: 1rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid #F1F5F9;
}
.rg-section-label i {
    font-size: 1rem;
    opacity: 0.8;
}

/* ── Input fields ── */
.rg-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 0.35rem;
}
.rg-input-wrap {
    position: relative;
}
.rg-input-wrap > i {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: #9CA3AF;
    font-size: 0.95rem;
    z-index: 2;
    pointer-events: none;
}
.rg-input, .rg-select {
    padding-left: 2.5rem !important;
    border: 1.5px solid #D1D5DB;
    border-radius: 0.625rem;
    font-size: 0.9rem;
    height: 42px;
    transition: border-color 0.2s, box-shadow 0.2s;
    background-color: #FAFBFC;
}
.rg-input:focus, .rg-select:focus {
    border-color: #1E40AF;
    box-shadow: 0 0 0 3px rgba(30,64,175,0.1);
    background-color: #fff;
}

/* ── Password strength meter ── */
.rg-pwd-strength {
    margin-top: 0.5rem;
}
.rg-pwd-bar {
    height: 4px;
    border-radius: 2px;
    background: #E5E7EB;
    overflow: hidden;
    margin-bottom: 0.25rem;
}
.rg-pwd-bar span {
    display: block;
    height: 100%;
    border-radius: 2px;
    transition: width 0.3s, background 0.3s;
    width: 0;
}
.rg-pwd-strength small {
    font-size: 0.72rem;
    color: #9CA3AF;
}

/* ── Security error alert ── */
.rg-security-alert {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: #1E3A8A;
    border: 1px solid #FECACA;
    margin-bottom: 1rem;
    font-size: 0.82rem;
    color: #991B1B;
    animation: rgShakeIn 0.4s ease;
}
.rg-security-alert i {
    font-size: 1.1rem;
    margin-top: 0.1rem;
    flex-shrink: 0;
    color: #DC2626;
}
.rg-security-alert strong {
    display: block;
    font-size: 0.82rem;
    margin-bottom: 0.1rem;
    color: #7F1D1D;
}
.rg-security-alert p {
    margin: 0;
    font-size: 0.78rem;
    color: #991B1B;
    line-height: 1.4;
}
@keyframes rgShakeIn {
    0% { transform: translateX(-8px); opacity: 0; }
    25% { transform: translateX(6px); }
    50% { transform: translateX(-4px); }
    75% { transform: translateX(2px); }
    100% { transform: translateX(0); opacity: 1; }
}

/* ── Password requirements checklist ── */
.rg-pwd-requirements {
    margin-top: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}
.rg-pwd-req {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: #9CA3AF;
    transition: color 0.2s;
}
.rg-pwd-req i {
    font-size: 0.6rem;
    transition: color 0.2s;
}
.rg-pwd-req.met {
    color: #059669;
}
.rg-pwd-req.met i::before {
    content: "\F26A"; /* bi-check-circle-fill */
    font-family: "bootstrap-icons" !important;
}
.rg-pwd-req.unmet {
    color: #9CA3AF;
}

/* ── Password match indicator ── */
.rg-pwd-match {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    margin-top: 0.5rem;
    transition: color 0.2s;
    color: #9CA3AF;
}
.rg-pwd-match i {
    font-size: 0.65rem;
}
.rg-pwd-match.matched {
    color: #059669;
}
.rg-pwd-match.matched i::before {
    content: "\F26A";
    font-family: "bootstrap-icons" !important;
}
.rg-pwd-match.unmatched {
    color: #DC2626;
}
.rg-pwd-match.unmatched i::before {
    content: "\F622"; /* bi-x-circle-fill */
    font-family: "bootstrap-icons" !important;
}

/* ── Terms & Data Privacy section ── */
.rg-terms-box {
    border: 1px solid #E5E7EB;
    border-radius: 0.5rem;
    background: #FAFBFC;
    margin-bottom: 0.85rem;
    overflow: hidden;
}
.rg-terms-scroll {
    max-height: 150px;
    overflow-y: auto;
    padding: 0.85rem 1rem;
    font-size: 0.76rem;
    color: #475569;
    line-height: 1.55;
}
.rg-terms-scroll::-webkit-scrollbar {
    width: 5px;
}
.rg-terms-scroll::-webkit-scrollbar-track {
    background: #F1F5F9;
}
.rg-terms-scroll::-webkit-scrollbar-thumb {
    background: #CBD5E1;
    border-radius: 3px;
}
.rg-terms-scroll h6 {
    font-size: 0.78rem;
    font-weight: 700;
    color: #1E293B;
    margin: 0.5rem 0 0.25rem;
}
.rg-terms-scroll h6:first-child {
    margin-top: 0;
}
.rg-terms-scroll ul {
    padding-left: 1rem;
    margin: 0.25rem 0 0.5rem;
}
.rg-terms-scroll ul li {
    margin-bottom: 0.2rem;
}
.rg-terms-check {
    padding: 0;
}
/* Custom checkbox */
.rg-checkbox-wrap {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    cursor: pointer;
    position: relative;
    user-select: none;
}
.rg-checkbox-box {
    width: 20px;
    height: 20px;
    min-width: 20px;
    border: 2px solid #CBD5E1;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    transition: all 0.2s ease;
    margin-top: 1px;
    font-size: 0;
    color: transparent;
}
.rg-checkbox-box.checked {
    background: #1E3A8A;
    border-color: #1E40AF;
    color: #fff;
    font-size: 0.75rem;
    box-shadow: 0 2px 6px rgba(30, 64, 175, 0.3);
}
.rg-checkbox-wrap:hover .rg-checkbox-box {
    border-color: #1E40AF;
}
.rg-checkbox-label {
    font-size: 0.78rem;
    color: #475569;
    line-height: 1.5;
}
.rg-checkbox-label strong {
    color: #1E40AF;
}
.rg-terms-section .form-error-message,
.rg-terms-check .invalid-feedback,
.rg-terms-check li.form-error-message {
    color: #DC2626;
    font-size: 0.75rem;
    margin-top: 0.4rem;
    list-style: none;
    padding: 0;
}

/* ── Notice ── */
.rg-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: #FFFFFF;
    border: 1px solid #CBD5E1;
    margin-bottom: 1.25rem;
    font-size: 0.82rem;
    color: #1E3A8A;
}
.rg-notice i {
    font-size: 1.1rem;
    margin-top: 0.1rem;
    flex-shrink: 0;
    color: #1E3A8A;
}
.rg-notice strong {
    display: block;
    font-size: 0.82rem;
    margin-bottom: 0.15rem;
    color: #1E3A8A;
}
.rg-notice p {
    margin: 0;
    font-size: 0.78rem;
    color: #334155;
    line-height: 1.4;
}

/* ── Submit button ── */
.rg-submit-btn {
    width: 100%;
    padding: 0.8rem;
    border: none;
    border-radius: 0.75rem;
    background: #1E3A8A;
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.3px;
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
}
.rg-submit-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #1E3A8A;
    transform: translateX(-100%);
    transition: transform 0.5s;
}
.rg-submit-btn:hover::before {
    transform: translateX(100%);
}
.rg-submit-btn:hover {
    box-shadow: 0 6px 20px rgba(30,64,175,0.3);
    transform: translateY(-1px);
}
.rg-submit-btn:active {
    transform: translateY(0);
}
.rg-submit-btn.rg-btn-loading {
    pointer-events: none;
    background: #1E3A8A;
    box-shadow: 0 4px 15px rgba(30,64,175,0.35);
}
.rg-submit-btn.rg-btn-loading::before {
    animation: rgShimmerLoop 1.5s infinite;
}
.rg-submit-text,
.rg-submit-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s, transform 0.3s;
}
.rg-submit-text {
    opacity: 1;
    transform: translateY(0);
}
.rg-submit-btn.rg-btn-loading .rg-submit-text {
    opacity: 0;
    transform: translateY(8px);
    position: absolute;
}
.rg-submit-loading {
    opacity: 0;
    transform: translateY(-8px);
    gap: 0;
}
.rg-submit-btn.rg-btn-loading .rg-submit-loading {
    opacity: 1;
    transform: translateY(0);
}
/* Custom spinner */
.rg-loading-spinner {
    width: 18px;
    height: 18px;
    border: 2.5px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: rgSpin 0.7s linear infinite;
    margin-right: 8px;
    flex-shrink: 0;
}
/* Bouncing dots */
.rg-loading-dots {
    display: inline-flex;
    margin-left: 1px;
}
.rg-loading-dots span {
    animation: rgDotBounce 1.2s ease-in-out infinite;
    font-weight: 700;
}
.rg-loading-dots span:nth-child(2) { animation-delay: 0.2s; }
.rg-loading-dots span:nth-child(3) { animation-delay: 0.4s; }
/* Progress bar at bottom of button */
.rg-btn-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: #1E3A8A;
    border-radius: 0 0 0.75rem 0.75rem;
    transition: width 0.3s;
}
.rg-submit-btn.rg-btn-loading .rg-btn-progress {
    animation: rgProgress 2s ease-in-out infinite;
}
@keyframes rgSpin {
    to { transform: rotate(360deg); }
}
@keyframes rgDotBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-4px); opacity: 1; }
}
@keyframes rgShimmerLoop {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}
@keyframes rgProgress {
    0% { width: 0; left: 0; }
    50% { width: 70%; left: 15%; }
    100% { width: 0; left: 100%; }
}

/* ── Login link ── */
.rg-login-link {
    text-align: center;
    font-size: 0.85rem;
    color: #6B7280;
}
.rg-login-link a {
    color: #1E40AF;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
}
.rg-login-link a:hover {
    color: #1E3A8A;
    text-decoration: underline;
}

/* ── Success modal ── */
.rg-success-modal {
    border: none;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 25px 60px rgba(0,0,0,0.2);
    background: #1E3A8A;
}
.rg-modal-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 2rem;
    border-radius: 0.625rem;
    background: #1E3A8A;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.2s;
}
.rg-modal-btn:hover {
    color: #fff;
    box-shadow: 0 4px 14px rgba(30,64,175,0.3);
    transform: translateY(-1px);
}
.rg-modal-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    text-align: left;
    padding: 0.75rem 1rem;
    border-radius: 0.625rem;
    background: #FEF3C7;
    margin: 1rem auto 1.25rem;
    max-width: 360px;
    font-size: 0.82rem;
}
.rg-modal-notice i {
    color: #D97706;
    font-size: 1.1rem;
    margin-top: 0.1rem;
}
.rg-modal-notice strong {
    display: block;
    color: #92400E;
    margin-bottom: 0.1rem;
}
.rg-modal-notice span {
    color: #78350F;
    font-size: 0.78rem;
    line-height: 1.3;
}

/* ── Approval confirmation modal ── */
.rg-confirm-icon-wrap {
    display: flex;
    justify-content: center;
}
.rg-confirm-icon {
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: linear-gradient(145deg, #1E40AF, #1E3A8A);
    border: 2px solid #DBEAFE;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: #F59E0B;
    box-shadow: 0 8px 20px rgba(30, 58, 138, 0.25);
}
.rg-confirm-info {
    text-align: left;
    background: #FFFBEB;
    border: 1px solid #FDE68A;
    border-radius: 0.75rem;
    padding: 0.85rem 1rem;
    margin: 0.75rem auto;
    max-width: 370px;
}
.rg-confirm-info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #92400E;
    line-height: 1.4;
    padding: 0.3rem 0;
}
.rg-confirm-info-item i {
    font-size: 0.9rem;
    margin-top: 0.1rem;
    flex-shrink: 0;
    color: #D97706;
}
.rg-confirm-contact {
    text-align: left;
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    margin: 0.5rem auto 0;
    max-width: 370px;
}
.rg-confirm-contact-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #1E40AF;
    font-size: 0.78rem;
    margin-bottom: 0.5rem;
}
.rg-confirm-contact-header i {
    font-size: 0.9rem;
}
.rg-confirm-contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
}
.rg-confirm-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.7rem;
    border-radius: 2rem;
    background: #EFF6FF;
    border: 1px solid #BFDBFE;
    font-size: 0.75rem;
    font-weight: 600;
    color: #1E40AF;
    text-decoration: none;
    transition: all 0.2s;
}
.rg-confirm-chip:hover {
    background: #DBEAFE;
    color: #1E3A8A;
    transform: translateY(-1px);
}
.rg-confirm-chip i {
    font-size: 0.7rem;
}
.rg-confirm-cancel-btn {
    padding: 0.55rem 1.5rem;
    border: 1.5px solid #E5E7EB;
    border-radius: 0.625rem;
    background: #fff;
    color: #6B7280;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}
.rg-confirm-cancel-btn:hover {
    background: #F3F4F6;
    border-color: #D1D5DB;
    color: #374151;
}
.rg-confirm-proceed-btn {
    padding: 0.55rem 1.5rem;
    border: none;
    border-radius: 0.625rem;
    background: #1E3A8A;
    color: #fff;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
}
.rg-confirm-proceed-btn:hover {
    box-shadow: 0 4px 14px rgba(30,64,175,0.3);
    transform: translateY(-1px);
}

/* ── Admin contact section in modal ── */
.rg-modal-contact {
    text-align: left;
    margin: 1rem auto 1.25rem;
    max-width: 360px;
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 0.75rem;
    padding: 1rem 1.1rem;
}
.rg-modal-contact-header {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: #1E40AF;
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
}
.rg-modal-contact-header i {
    font-size: 1rem;
}
.rg-modal-contact-header strong {
    font-weight: 700;
}
.rg-modal-contact-desc {
    font-size: 0.75rem;
    color: #64748B;
    margin: 0 0 0.75rem;
    line-height: 1.4;
}
.rg-modal-contact-items {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
}
.rg-contact-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.65rem;
    border-radius: 0.5rem;
    background: #fff;
    border: 1px solid #E5E7EB;
    text-decoration: none;
    transition: all 0.2s;
}
a.rg-contact-item:hover {
    border-color: #1E40AF;
    background: #EFF6FF;
    transform: translateX(3px);
}
.rg-contact-icon {
    width: 32px;
    height: 32px;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    flex-shrink: 0;
}
.rg-contact-email {
    background: #DBEAFE;
    color: #1E40AF;
}
.rg-contact-phone {
    background: #D1FAE5;
    color: #059669;
}
.rg-contact-office {
    background: #FEF3C7;
    color: #D97706;
}
.rg-contact-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    color: #9CA3AF;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1;
    margin-bottom: 0.15rem;
}
.rg-contact-value {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: #1E293B;
    line-height: 1.2;
}

/* ── Success modal checkmark & confetti animations ── */
.success-confetti {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    pointer-events: none;
    z-index: 1;
}
.confetti-piece {
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--c, #3B82F6);
    opacity: 0;
    animation: confettiBurst 0.8s ease-out var(--d, 0s) forwards;
}
.confetti-piece.confetti-rect {
    width: 12px;
    height: 6px;
    border-radius: 2px;
}
@keyframes confettiBurst {
    0% {
        opacity: 1;
        transform: translate(0, 0) rotate(0deg) scale(0);
    }
    50% {
        opacity: 1;
        transform: translate(var(--x, 0), var(--y, 0)) rotate(var(--r, 0deg)) scale(1.2);
    }
    100% {
        opacity: 0;
        transform: translate(calc(var(--x, 0) * 1.5), calc(var(--y, 0) * 1.5 + 30px)) rotate(calc(var(--r, 0deg) * 2)) scale(0.6);
    }
}
.success-check-wrap {
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 2;
}
.success-check-svg {
    width: 80px;
    height: 80px;
}
.success-circle {
    stroke-dasharray: 283;
    stroke-dashoffset: 283;
    animation: successCircleDraw 0.6s ease-out 0.15s forwards;
}
@keyframes successCircleDraw {
    to { stroke-dashoffset: 0; }
}
.success-tick {
    stroke-dasharray: 80;
    stroke-dashoffset: 80;
    animation: successTickDraw 0.4s ease-out 0.6s forwards;
}
@keyframes successTickDraw {
    to { stroke-dashoffset: 0; }
}

/* ── Step transition ── */
.rg-step-content {
    animation: rgFadeIn 0.35s ease forwards;
}
@keyframes rgFadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ── Form section stagger animation ── */
.rg-form .rg-section {
    animation: rgSlideUp 0.4s ease both;
}
.rg-form .rg-section:nth-child(2) { animation-delay: 0.05s; }
.rg-form .rg-section:nth-child(3) { animation-delay: 0.1s; }
.rg-form .rg-section:nth-child(4) { animation-delay: 0.15s; }
.rg-form .rg-section:nth-child(5) { animation-delay: 0.2s; }
@keyframes rgSlideUp {
    from { opacity: 0; transform: translateY(15px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ── Brand panel entrance animations ── */
.rg-brand-logo-wrap {
    animation: scaleIn 0.6s ease 0.2s both;
}
.rg-brand-title {
    animation: slideUp 0.5s ease 0.35s both;
}
.rg-brand-sub {
    animation: slideUp 0.5s ease 0.45s both;
}
.rg-feature-item {
    opacity: 0;
    animation: slideUp 0.4s ease both;
}
.rg-feature-item:nth-child(1) { animation-delay: 0.55s; }
.rg-feature-item:nth-child(2) { animation-delay: 0.65s; }
.rg-feature-item:nth-child(3) { animation-delay: 0.75s; }

/* ── Role card entrance animations ── */
.rg-role-card {
    opacity: 0;
    animation: rgSlideUp 0.4s ease both;
}
.rg-role-card:nth-child(1) { animation-delay: 0.15s; }
.rg-role-card:nth-child(2) { animation-delay: 0.25s; }
.rg-role-card:nth-child(3) { animation-delay: 0.35s; }

/* ═══ RESPONSIVE ═══ */
/* ═══ TABLET ═══ */
@media (max-width: 991.98px) {
    .rg-brand-panel {
        display: none;
    }
    .rg-page {
        background: #1E3A8A;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        min-height: 100dvh;
        padding: 0.75rem;
    }
    .rg-form-panel {
        max-width: 520px;
        width: 100%;
        margin: 0 auto;
        border-radius: 1.25rem;
        box-shadow: 0 20px 60px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.08);
        background: #fff;
        overflow: hidden;
        max-height: calc(100vh - 1.5rem);
        max-height: calc(100dvh - 1.5rem);
    }
    .rg-form-scroll {
        padding: 1.75rem 1.5rem;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior: contain;
    }
    .rg-form-inner {
        padding-top: 0;
        padding-bottom: 1rem;
    }

}

/* ═══ MOBILE ═══ */
@media (max-width: 575.98px) {
    .rg-page {
        align-items: center;
        padding: 0.5rem;
    }
    .rg-form-panel {
        margin: 0;
        border-radius: 1rem;
        max-width: 100%;
        max-height: calc(100vh - 1rem);
        max-height: calc(100dvh - 1rem);
    }
    .rg-form-scroll {
        padding: 1.25rem 1rem;
    }
    .rg-title {
        font-size: 1.25rem;
    }
    .rg-subtitle {
        font-size: 0.82rem;
        margin-bottom: 1.25rem;
    }
    /* Role cards - bigger touch targets */
    .rg-role-card {
        padding: 0.95rem 1rem;
        min-height: 64px;
    }
    .rg-role-icon-wrap {
        width: 42px;
        height: 42px;
        font-size: 1.15rem;
    }
    .rg-role-info h4 {
        font-size: 0.88rem;
    }
    .rg-role-info p {
        font-size: 0.74rem;
    }
    .rg-role-arrow {
        opacity: 0.5;
        transform: translateX(0);
    }
    /* Section cards */
    .rg-section {
        padding: 1rem;
        border-radius: 0.75rem;
    }
    .rg-section-label {
        font-size: 0.78rem;
    }
    /* Inputs - minimum 44px touch target */
    .rg-input, .rg-select {
        height: 42px;
        font-size: 0.88rem;
    }
    /* Steps */
    .rg-steps {
        margin-bottom: 1.25rem;
    }
    .rg-step span {
        font-size: 0.72rem;
    }
    .rg-step-num {
        width: 28px;
        height: 28px;
        font-size: 0.72rem;
    }
    .rg-step-line {
        width: 40px;
    }
    /* Submit button */
    .rg-submit-btn {
        padding: 0.85rem;
        font-size: 0.95rem;
        min-height: 48px;
    }
    /* Login link */
    .rg-login-link {
        font-size: 0.82rem;
        padding: 0.5rem 0;
    }
    /* Selected role badge */
    .rg-role-pill {
        font-size: 0.75rem;
    }
    .rg-change-role {
        min-height: 36px;
        padding: 0.35rem 0.85rem;
    }
    /* Notice */
    .rg-notice {
        font-size: 0.8rem;
        padding: 0.75rem 0.85rem;
    }
    /* Password strength */
    .rg-pwd-bar {
        height: 5px;
    }
}

/* ═══ SMALL MOBILE ═══ */
@media (max-width: 400px) {
    .rg-page {
        padding: 0.25rem;
    }
    .rg-form-panel {
        border-radius: 0.75rem;
        max-height: calc(100dvh - 0.5rem);
    }
    .rg-form-scroll {
        padding: 1rem 0.85rem;
    }
    .rg-title {
        font-size: 1.15rem;
    }
    .rg-subtitle {
        font-size: 0.78rem;
    }
    .rg-role-card {
        gap: 0.75rem;
    }
    .rg-section {
        padding: 0.85rem;
    }
    .rg-section-label {
        font-size: 0.75rem;
    }
    .rg-label {
        font-size: 0.78rem;
    }
    .rg-input, .rg-select {
        height: 40px;
        font-size: 0.85rem;
    }
}

@media (prefers-reduced-motion: reduce) {
    .rg-step-content,
    .rg-form .rg-section,
    .rg-brand-bg::before,
    .rg-brand-bg::after,
    .rg-brand-logo-wrap,
    .rg-brand-title,
    .rg-brand-sub,
    .rg-feature-item,
    .rg-role-card {
        animation: none !important;
        opacity: 1 !important;
    }
}

