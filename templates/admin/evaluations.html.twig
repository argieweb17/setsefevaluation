{# ═══════════════════════════════════════
   CREATE EVALUATION MODAL
   ═══════════════════════════════════════ #}
<div class="modal fade" id="createEvalModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content ev-modal">
            <div class="ev-modal-header">
                <div class="d-flex align-items-center gap-2">
                    <div class="ev-modal-icon"><i class="bi bi-plus-circle-fill"></i></div>
                    <div>
                        <h5 class="mb-0 fw-bold text-white">New Evaluation Period</h5>
                        <small class="text-white-50">Define evaluation parameters and schedule</small>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="{{ path(prefix ~ '_evaluation_create') }}" data-turbo="false">
                <input type="hidden" name="_token" value="{{ csrf_token('create_eval') }}">
                <div class="modal-body p-4">
                    <div class="mb-3 p-3 rounded-3" style="background:#f5f3ff;border:1px solid #ede9fe;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-info-circle-fill" style="color:#7c3aed;"></i>
                            <strong style="color:#5b21b6;font-size:.82rem;">About Evaluation Period</strong>
                        </div>
                        <p class="mb-0" style="font-size:.78rem;color:#6b7280;">
                            Create an evaluation period for <strong>Student Evaluation for Teacher (SET)</strong>.
                            Select a faculty member and their subject to schedule a specific evaluation.
                        </p>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Evaluation Type</label>
                            <select name="evaluationType" class="form-select ev-form-control" required>
                                <option value="SET">SET (Student Evaluation for Teacher)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">School Year</label>
                            <select name="schoolYear" class="form-select ev-form-control">
                                <option value="">— Select —</option>
                                {% for ay in academicYears|default([]) %}
                                    <option value="{{ ay.yearLabel }}" {{ ay.isCurrent ? 'selected' : '' }}>{{ ay.yearLabel }}{% if ay.isCurrent %} (Current){% endif %}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Year Level</label>
                            <select name="yearLevel" class="form-select ev-form-control">
                                <option value="">All Year Levels</option>
                                <option value="1st Year">1st Year</option>
                                <option value="2nd Year">2nd Year</option>
                                <option value="3rd Year">3rd Year</option>
                                <option value="4th Year">4th Year</option>
                                <option value="5th Year">5th Year</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">College</label>
                            <select name="college" class="form-select ev-form-control college-select">
                                <option value="">All Colleges</option>
                                {% for col in colleges %}
                                    <option value="{{ col }}">{{ col }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Department</label>
                            <select name="department" class="form-select ev-form-control dept-select">
                                <option value="">All Departments</option>
                                {% for dept in departments %}
                                    <option value="{{ dept.id }}" data-college="{{ dept.collegeName }}">{{ dept.departmentName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Faculty</label>
                            <select name="faculty" class="form-select ev-form-control faculty-select" data-target-subject="#createSubject">
                                <option value="" data-faculty-id="" data-department="">— Select Faculty —</option>
                                {% for f in facultyUsers %}
                                    <option value="{{ f.fullName }}" data-faculty-id="{{ f.id }}" data-department="{{ f.department ? f.department.id : '' }}">{{ f.lastName }}, {{ f.firstName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Subject</label>
                            <select name="subject" id="createSubject" class="form-select ev-form-control subject-select" data-target-time="#createTime" data-target-section="#createSection" data-current-value="">
                                <option value="" data-schedule="" data-section="">— Select Faculty first —</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Time</label>
                            <input type="text" name="time" id="createTime" class="form-control ev-form-control" placeholder="Auto-filled from subject" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Section</label>
                            <input type="text" name="section" id="createSection" class="form-control ev-form-control" placeholder="Auto-filled from subject" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">Start Date & Time</label>
                            <input type="datetime-local" name="startDate" class="form-control ev-form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label ev-form-label">End Date & Time</label>
                            <input type="datetime-local" name="endDate" class="form-control ev-form-control" required>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="status" id="evalStatus" value="1" checked>
                                <label class="form-check-label ev-form-label" for="evalStatus">Open</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="anonymousMode" id="anonMode" value="1" checked>
                                <label class="form-check-label ev-form-label" for="anonMode">Anonymous</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 py-3" style="background:#f5f3ff;">
                    <button type="button" class="btn btn-sm btn-secondary px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm px-3 fw-semibold" style="background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(5,150,105,.85));color:#fff;border:none;">
                        <i class="bi bi-plus-lg me-1"></i>Create Period
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════
   CREATE SUPERIOR EVALUATION MODAL
