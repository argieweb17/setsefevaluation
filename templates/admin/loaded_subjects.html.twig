                    {% endif %}
                </td>
                <td class="text-center">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                    {% if s.fslId %}
                    <form method="post" action="{{ path('faculty_subject_unload_fsl', {id: s.fslId}) }}" style="display:inline" onsubmit="return confirm('Unload {{ s.subject.subjectCode }} — Section {{ s.section|default('') }}?')">
