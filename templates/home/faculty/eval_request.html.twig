{% extends 'base.html.twig' %}

{% block title %}Messages | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ═══════════════════════════════════════
   CSS VARIABLES
   ═══════════════════════════════════════ */
:root {
    --msg-primary: #1f3f8f;
    --msg-primary-dark: #162d66;
    --msg-primary-light: #e8eefc;
    --msg-success: #0f766e;
    --msg-success-light: #ecfeff;
    --msg-warning: #b45309;
    --msg-warning-light: #fffbeb;
    --msg-sidebar-bg: #f5f7fb;
    --msg-border: #dde3ee;
    --msg-text-primary: #0f172a;
    --msg-text-secondary: #475569;
    --msg-text-muted: #64748b;
    --msg-shadow-sm: 0 1px 2px rgba(0,0,0,.05);
    --msg-shadow-md: 0 6px 18px rgba(15,23,42,.08);
    --msg-shadow-lg: 0 16px 36px rgba(15,23,42,.12);
    --msg-radius-sm: 8px;
    --msg-radius-md: 12px;
    --msg-radius-lg: 14px;
    --msg-radius-xl: 16px;
}

/* ═══════════════════════════════════════
   MAIN CONTAINER
   ═══════════════════════════════════════ */
.fm-app {
    display: flex;
    height: calc(100vh - 100px);
    min-height: 600px;
    background: #fff;
    border-radius: var(--msg-radius-xl);
    overflow: hidden;
    box-shadow: var(--msg-shadow-lg);
    border: 1px solid var(--msg-border);
}

/* ═══════════════════════════════════════
   SIDEBAR
   ═══════════════════════════════════════ */
.fm-sidebar {
    width: 360px;
    min-width: 320px;
    background: var(--msg-sidebar-bg);
    border-right: 1px solid var(--msg-border);
    display: flex;
    flex-direction: column;
}

/* Sidebar Header */
.fm-sidebar-header {
    padding: 24px;
    background: linear-gradient(165deg, #1b2f69 0%, #1f3f8f 100%);
    position: relative;
    overflow: hidden;
}
.fm-sidebar-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,.1) 0%, transparent 60%);
    pointer-events: none;
}
.fm-sidebar-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    position: relative;
    z-index: 1;
}
.fm-sidebar-logo {
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,.12);
    border-radius: var(--msg-radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: #fff;
    backdrop-filter: blur(8px);
}
.fm-sidebar-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 2px;
    letter-spacing: -0.3px;
}
.fm-sidebar-subtitle {
    font-size: .78rem;
    color: rgba(255,255,255,.75);
    margin: 0;
}

/* New Message Button */
.fm-new-msg-wrap {
    padding: 16px 20px;
    background: #fff;
    border-bottom: 1px solid var(--msg-border);
}
.fm-new-msg-btn {
    width: 100%;
    padding: 14px 20px;
    border: 1px solid var(--msg-border);
    border-radius: var(--msg-radius-md);
    background: var(--msg-sidebar-bg);
    color: var(--msg-text-secondary);
    font-size: .88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}
.fm-new-msg-btn:hover {
    border-color: var(--msg-primary);
    color: var(--msg-primary);
    background: var(--msg-primary-light);
    box-shadow: 0 4px 12px rgba(31,63,143,.12);
}
.fm-new-msg-btn i {
    font-size: 1.1rem;
}

/* Search */
.fm-search-section {
    padding: 12px 20px 16px;
    background: #fff;
    border-bottom: 1px solid var(--msg-border);
}
.fm-search-wrap {
    position: relative;
}
.fm-search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--msg-text-muted);
    font-size: .9rem;
    pointer-events: none;
}
.fm-search-input {
    width: 100%;
    padding: 12px 16px 12px 42px;
    border: 2px solid var(--msg-border);
    border-radius: var(--msg-radius-md);
    font-size: .84rem;
    color: var(--msg-text-primary);
    background: var(--msg-sidebar-bg);
    outline: none;
    transition: all .2s ease;
}
.fm-search-input:focus {
    border-color: var(--msg-primary);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(30,64,175,.08);
}
.fm-search-input::placeholder {
    color: var(--msg-text-muted);
}

/* Conversation List */
.fm-conv-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px 12px;
}
.fm-conv-list::-webkit-scrollbar {
    width: 6px;
}
.fm-conv-list::-webkit-scrollbar-track {
    background: transparent;
}
.fm-conv-list::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 3px;
}

.fm-conv-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px;
    border-radius: var(--msg-radius-md);
    cursor: pointer;
    transition: all .15s ease;
    margin-bottom: 4px;
    position: relative;
    border: 2px solid transparent;
}
.fm-conv-item:hover {
    background: #fff;
    border-color: var(--msg-border);
    box-shadow: var(--msg-shadow-sm);
}
.fm-conv-item.active {
    background: #fff;
    border-color: var(--msg-primary);
    box-shadow: 0 0 0 3px rgba(31,63,143,.08);
}

/* Avatar */
.fm-avatar {
    width: 46px;
    height: 46px;
    border-radius: var(--msg-radius-md);
    background: linear-gradient(135deg, var(--msg-success), #10b981);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
    box-shadow: var(--msg-shadow-sm);
}

/* Conversation Info */
.fm-conv-info {
    flex: 1;
    min-width: 0;
}
.fm-conv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 4px;
}
.fm-conv-subject {
    font-size: .88rem;
    font-weight: 700;
    color: var(--msg-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.fm-conv-time {
    font-size: .7rem;
    color: var(--msg-text-muted);
    flex-shrink: 0;
    font-weight: 500;
}
.fm-conv-preview {
    font-size: .78rem;
    color: var(--msg-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 8px;
}
.fm-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: .68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .3px;
}
.fm-status-pending {
    background: var(--msg-warning-light);
    color: var(--msg-warning);
}
.fm-status-reviewed {
    background: var(--msg-primary-light);
    color: var(--msg-primary);
}
.fm-status-resolved {
    background: var(--msg-success-light);
    color: var(--msg-success);
}

/* ═══════════════════════════════════════
   CHAT PANEL
   ═══════════════════════════════════════ */
.fm-chat {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: #fff;
}

/* Chat Header */
.fm-chat-header {
    padding: 20px 28px;
    background: #fff;
    border-bottom: 1px solid var(--msg-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.fm-chat-user {
    display: flex;
    align-items: center;
    gap: 16px;
}
.fm-chat-avatar {
    width: 48px;
    height: 48px;
    border-radius: var(--msg-radius-md);
    background: linear-gradient(160deg, #1f3f8f, #2a4fa8);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    box-shadow: var(--msg-shadow-md);
}
.fm-chat-details h5 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--msg-text-primary);
    margin: 0 0 4px;
}
.fm-chat-status {
    font-size: .8rem;
    display: flex;
    align-items: center;
    gap: 6px;
}
.fm-chat-status.pending { color: var(--msg-warning); }
.fm-chat-status.reviewed { color: var(--msg-primary); }
.fm-chat-status.resolved { color: var(--msg-success); }
.fm-chat-status i { font-size: .5rem; }
.fm-chat-actions {
    display: flex;
    align-items: center;
    gap: 10px;
}
.fm-header-badge {
    padding: 8px 16px;
    border-radius: 20px;
    font-size: .75rem;
    font-weight: 700;
}

/* Chat Body */
.fm-chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 22px;
    background: #f8fafd;
    display: flex;
    flex-direction: column;
    gap: 20px;
}
.fm-thread {
    display: flex;
    flex-direction: column;
    gap: 10px;
}
.fm-chat-body::-webkit-scrollbar {
    width: 6px;
}
.fm-chat-body::-webkit-scrollbar-track {
    background: transparent;
}
.fm-chat-body::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 3px;
}

/* Date Separator */
.fm-date-sep {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 8px 0;
}
.fm-date-sep::before,
.fm-date-sep::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--msg-border), transparent);
}
.fm-date-sep span {
    font-size: .72rem;
    font-weight: 600;
    color: var(--msg-text-muted);
    padding: 6px 16px;
    background: #fff;
    border-radius: 20px;
    border: 1px solid var(--msg-border);
    white-space: nowrap;
}

/* Message Bubbles */
.fm-message {
    display: flex;
    flex-direction: column;
    max-width: 72%;
}
.fm-message.incoming {
    align-self: flex-start;
    align-items: flex-start;
}
.fm-message.outgoing {
    align-self: flex-end;
    align-items: flex-end;
}
.fm-message-sender {
    font-size: .72rem;
    font-weight: 600;
    color: var(--msg-text-secondary);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
}
.fm-message-sender i {
    color: var(--msg-success);
}
.fm-bubble {
    padding: 9px 13px;
    border-radius: 12px;
    font-size: .82rem;
    line-height: 1.45;
    white-space: pre-wrap;
    word-break: break-word;
    width: fit-content;
    max-width: 100%;
    box-shadow: var(--msg-shadow-sm);
}
.fm-message.outgoing .fm-bubble {
    background: linear-gradient(160deg, var(--msg-primary-dark), var(--msg-primary));
    color: #fff;
    border-bottom-right-radius: 4px;
}
.fm-message.incoming .fm-bubble {
    background: #ffffff;
    color: var(--msg-text-primary);
    border: 1px solid var(--msg-border);
    border-bottom-left-radius: 4px;
}
.fm-bubble-subject {
    font-weight: 700;
    margin-bottom: 8px;
    padding: 4px 10px;
    border: none;
    border-radius: 999px;
    font-size: .74rem;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,.18);
}
.fm-message.incoming .fm-bubble-subject {
    color: var(--msg-text-secondary);
    background: var(--msg-primary-light);
}
.fm-bubble-subject i {
    font-size: .78rem;
}
.fm-message-time {
    font-size: .68rem;
    color: var(--msg-text-muted);
    margin-top: 5px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.fm-message.outgoing .fm-message-time {
    justify-content: flex-end;
}
.fm-message-time .read-icon {
    color: #60a5fa;
}

/* Waiting Message */
.fm-waiting {
    align-self: flex-start;
}
.fm-waiting .fm-bubble {
    background: #fff9eb;
    border: 1px solid #f8dba2;
    color: #9a3412;
    display: flex;
    align-items: center;
    gap: 10px;
}
.fm-waiting .fm-bubble i {
    animation: fm-spin 2s linear infinite;
}
@keyframes fm-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* Compose Area */
.fm-compose {
    padding: 12px 20px;
    background: #fff;
    border-top: 1px solid var(--msg-border);
}
.fm-compose-inner {
    background: var(--msg-sidebar-bg);
    border-radius: var(--msg-radius-md);
    border: 2px solid var(--msg-border);
    overflow: hidden;
    transition: all .2s ease;
}
.fm-compose-inner:focus-within {
    border-color: var(--msg-success);
    box-shadow: 0 0 0 4px rgba(15,118,110,.1);
}
.fm-compose-header {
    padding: 10px 14px;
    background: #fff;
    border-bottom: 1px solid var(--msg-border);
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .78rem;
    font-weight: 600;
    color: var(--msg-text-secondary);
}
.fm-compose-header i {
    color: var(--msg-success);
}
.fm-textarea {
    width: 100%;
    padding: 12px 14px;
    border: none;
    font-size: .88rem;
    color: var(--msg-text-primary);
    background: transparent;
    outline: none;
    resize: none;
    min-height: 56px;
    max-height: 120px;
    font-family: inherit;
    line-height: 1.6;
}
.fm-textarea::placeholder {
    color: var(--msg-text-muted);
}
.fm-compose-footer {
    padding: 10px 14px;
    background: #fff;
    border-top: 1px solid var(--msg-border);
    display: flex;
    justify-content: flex-end;
}
.fm-send-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    border-radius: var(--msg-radius-md);
    border: none;
    background: linear-gradient(135deg, var(--msg-success) 0%, #10b981 100%);
    color: #fff;
    font-size: .84rem;
    font-weight: 700;
    cursor: pointer;
    transition: all .2s ease;
    box-shadow: 0 4px 12px rgba(15,118,110,.22);
}
.fm-send-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(15,118,110,.3);
}

/* Empty State */
.fm-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    text-align: center;
}
.fm-empty-icon {
    width: 100px;
    height: 100px;
    border-radius: 28px;
    background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: var(--msg-text-muted);
    margin-bottom: 24px;
}
.fm-empty-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--msg-text-secondary);
    margin: 0 0 8px;
}
.fm-empty-text {
    font-size: .9rem;
    color: var(--msg-text-muted);
    max-width: 320px;
    line-height: 1.6;
    margin: 0 0 20px;
}
.fm-empty-btn {
    padding: 14px 28px;
    border-radius: var(--msg-radius-md);
    border: none;
    background: linear-gradient(160deg, var(--msg-primary-dark), var(--msg-primary));
    color: #fff;
    font-size: .9rem;
    font-weight: 700;
    cursor: pointer;
    transition: all .2s ease;
    box-shadow: 0 4px 12px rgba(30,64,175,.25);
    display: inline-flex;
    align-items: center;
    gap: 10px;
}
.fm-empty-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(31,63,143,.3);
}

/* ═══════════════════════════════════════
   NEW MESSAGE MODAL
   ═══════════════════════════════════════ */
.fm-modal-header {
    background: linear-gradient(165deg, #1b2f69 0%, #1f3f8f 100%);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
    position: relative;
    overflow: hidden;
}
.fm-modal-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -30%;
    width: 80%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,.1) 0%, transparent 60%);
    pointer-events: none;
}
.fm-modal-icon {
    width: 46px;
    height: 46px;
    background: rgba(255,255,255,.15);
    border-radius: var(--msg-radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.2rem;
    backdrop-filter: blur(4px);
    position: relative;
    z-index: 1;
}
.fm-modal-title {
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0;
    position: relative;
    z-index: 1;
}
.fm-modal-body {
    padding: 28px;
}
.fm-form-group {
    margin-bottom: 20px;
}
.fm-form-group:last-child {
    margin-bottom: 0;
}
.fm-form-label {
    display: block;
    font-size: .78rem;
    font-weight: 700;
    color: var(--msg-text-secondary);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: .5px;
}
.fm-form-label .optional {
    font-weight: 500;
    text-transform: none;
    color: var(--msg-text-muted);
}
.fm-form-input,
.fm-form-select,
.fm-form-textarea {
    width: 100%;
    padding: 14px 18px;
    border: 2px solid var(--msg-border);
    border-radius: var(--msg-radius-md);
    font-size: .88rem;
    color: var(--msg-text-primary);
    background: #fff;
    outline: none;
    transition: all .2s ease;
    font-family: inherit;
}
.fm-form-input:focus,
.fm-form-select:focus,
.fm-form-textarea:focus {
    border-color: var(--msg-primary);
    box-shadow: 0 0 0 4px rgba(30,64,175,.08);
}
.fm-form-input::placeholder,
.fm-form-textarea::placeholder {
    color: var(--msg-text-muted);
}
.fm-form-textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.6;
}
.fm-modal-footer {
    padding: 20px 28px;
    background: var(--msg-sidebar-bg);
    border-top: 1px solid var(--msg-border);
    display: flex;
    justify-content: flex-end;
    gap: 12px;
}
.fm-btn {
    padding: 12px 24px;
    border-radius: var(--msg-radius-md);
    font-size: .88rem;
    font-weight: 700;
    cursor: pointer;
    transition: all .2s ease;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}
.fm-btn-secondary {
    background: #fff;
    color: var(--msg-text-secondary);
    border: 2px solid var(--msg-border);
}
.fm-btn-secondary:hover {
    background: var(--msg-sidebar-bg);
    border-color: #cbd5e1;
}
.fm-btn-primary {
    background: linear-gradient(160deg, var(--msg-primary-dark), var(--msg-primary));
    color: #fff;
    box-shadow: 0 4px 12px rgba(30,64,175,.25);
}
.fm-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(31,63,143,.3);
}

/* ═══════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════ */
@media (max-width: 992px) {
    .fm-app {
        flex-direction: column;
        height: auto;
        min-height: calc(100vh - 80px);
    }
    .fm-sidebar {
        width: 100%;
        min-width: 100%;
        max-height: 400px;
        border-right: none;
        border-bottom: 1px solid var(--msg-border);
    }
    .fm-conv-list {
        max-height: 250px;
    }
    .fm-chat-body {
        min-height: 400px;
    }
    .fm-message {
        max-width: 85%;
    }
}
@media (max-width: 576px) {
    .fm-sidebar-header {
        padding: 18px;
    }
    .fm-chat-header {
        padding: 16px;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
    .fm-chat-actions {
        width: 100%;
        justify-content: flex-end;
    }
    .fm-compose {
        padding: 10px;
    }
    .fm-send-btn {
        width: 100%;
        justify-content: center;
    }
}

/* Animations */
.fm-conv-item {
    animation: fm-slide-in .25s ease;
}
@keyframes fm-slide-in {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
}
.fm-message {
    animation: fm-fade-up .3s ease;
}
@keyframes fm-fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>
{% endblock %}

{% block body %}
<div class="fm-app">
    {# ═══════════════════════════════════════
       SIDEBAR
       ═══════════════════════════════════════ #}
    <aside class="fm-sidebar">
        <div class="fm-sidebar-header">
            <div class="fm-sidebar-brand">
                <div class="fm-sidebar-logo">
                    <i class="bi bi-chat-dots-fill"></i>
                </div>
                <div>
                    <h4 class="fm-sidebar-title">My Messages</h4>
                    <p class="fm-sidebar-subtitle">{{ messages|length }} conversation{{ messages|length != 1 ? 's' : '' }}</p>
                </div>
            </div>
        </div>

        <div class="fm-new-msg-wrap">
            <button class="fm-new-msg-btn" data-bs-toggle="modal" data-bs-target="#newMessageModal">
                <i class="bi bi-plus-lg"></i> New Message
            </button>
        </div>

        <div class="fm-search-section">
            <div class="fm-search-wrap">
                <i class="bi bi-search fm-search-icon"></i>
                <input type="text" class="fm-search-input" id="searchInput" placeholder="Search messages..." oninput="searchMessages()">
            </div>
        </div>

        <div class="fm-conv-list" id="convList">
            {% for msg in messages %}
            <div class="fm-conv-item{% if loop.first %} active{% endif %}"
                 data-msg-id="{{ msg.id }}"
                 data-search="{{ msg.subject|lower }} {{ msg.message|lower }}"
                 onclick="selectConversation(this, {{ msg.id }})">
                <div class="fm-avatar">
                    <i class="bi bi-shield-check"></i>
                </div>
                <div class="fm-conv-info">
                    <div class="fm-conv-header">
                        <span class="fm-conv-subject">{{ msg.subject|length > 28 ? msg.subject|slice(0,28) ~ '...' : msg.subject }}</span>
                        <span class="fm-conv-time">{{ msg.createdAt|date('M d') }}</span>
                    </div>
                    <div class="fm-conv-preview">
                        {% if msg.adminReply %}
                            <i class="bi bi-reply-fill"></i> {{ msg.adminReply|slice(0,35) }}...
                        {% else %}
                            {{ msg.message|slice(0,40) }}{% if msg.message|length > 40 %}...{% endif %}
                        {% endif %}
                    </div>
                    <span class="fm-status-badge fm-status-{{ msg.status }}">
                        {% if msg.status == 'pending' %}<i class="bi bi-clock"></i> Pending
                        {% elseif msg.status == 'reviewed' %}<i class="bi bi-eye"></i> Reviewed
                        {% else %}<i class="bi bi-check-circle"></i> Resolved{% endif %}
                    </span>
                </div>
            </div>
            {% else %}
            <div class="fm-empty-state" style="padding:50px 24px;">
                <div class="fm-empty-icon" style="width:70px;height:70px;font-size:1.8rem;margin-bottom:16px;">
                    <i class="bi bi-chat-square-dots"></i>
                </div>
                <h5 class="fm-empty-title" style="font-size:1rem;">No messages yet</h5>
                <p class="fm-empty-text" style="font-size:.82rem;margin-bottom:0;">Start a new conversation</p>
            </div>
            {% endfor %}
        </div>
    </aside>

    {# ═══════════════════════════════════════
       CHAT PANEL
       ═══════════════════════════════════════ #}
    <main class="fm-chat">
        {% if messages|length > 0 %}
        {% set firstMsg = messages|first %}

        <header class="fm-chat-header" id="chatHeader">
            <div class="fm-chat-user">
                <div class="fm-chat-avatar">
                    <i class="bi bi-shield-check"></i>
                </div>
                <div class="fm-chat-details">
                    <h5 id="chatTitle">{{ firstMsg.subject }}</h5>
                    <div class="fm-chat-status {{ firstMsg.status }}" id="chatStatus">
                        <i class="bi bi-circle-fill"></i>
                        {% if firstMsg.status == 'resolved' %}Resolved
                        {% elseif firstMsg.status == 'reviewed' %}Reviewed
                        {% else %}Awaiting Response{% endif %}
                    </div>
                </div>
            </div>
            <div class="fm-chat-actions">
                {% if firstMsg.evaluationPeriod %}
                <span class="fm-header-badge fm-status-reviewed" id="chatEval">
                    <i class="bi bi-clipboard2-check me-1"></i>{{ firstMsg.evaluationPeriod.evaluationType }} - {{ firstMsg.evaluationPeriod.semester ?? '' }} {{ firstMsg.evaluationPeriod.schoolYear ?? '' }}
                </span>
                {% endif %}
            </div>
        </header>

        <div class="fm-chat-body" id="chatBody">
            {% for msg in messages %}
            <div class="fm-thread" id="thread-{{ msg.id }}"{% if not loop.first %} style="display:none"{% endif %}>
                <div class="fm-date-sep">
                    <span>{{ msg.createdAt|date('l, F d, Y') }}</span>
                </div>

                {# Faculty's message (sent) #}
                <div class="fm-message outgoing">
                    <div class="fm-bubble">
                        {{ msg.message }}
                    </div>
                    <div class="fm-message-time">
                        {{ msg.createdAt|date('h:i A') }}
                        <i class="bi bi-check2-all read-icon"></i>
                    </div>
                </div>

                {# Admin's reply (received) #}
                {% if msg.adminReply %}
                <div class="fm-message incoming">
                    <div class="fm-message-sender">
                        <i class="bi bi-shield-check"></i> Admin{% if msg.repliedBy %} ({{ msg.repliedBy.fullName }}){% endif %}
                    </div>
                    <div class="fm-bubble">{{ msg.adminReply }}</div>
                    <div class="fm-message-time">
                        {% if msg.repliedAt %}{{ msg.repliedAt|date('h:i A') }}{% endif %}
                    </div>
                </div>
                {% else %}
                <div class="fm-message fm-waiting">
                    <div class="fm-bubble">
                        <i class="bi bi-hourglass-split"></i>
                        Waiting for admin response...
                    </div>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        {% for msg in messages %}
        <div class="fm-compose" id="compose-{{ msg.id }}"{% if not loop.first %} style="display:none"{% endif %}>
            <form method="post" action="{{ path('faculty_eval_request') }}">
                <input type="hidden" name="_action" value="send_message">
                <input type="hidden" name="msg_subject" value="{{ msg.subject }}">
                <input type="hidden" name="msg_evaluation" value="{{ msg.evaluationPeriod ? msg.evaluationPeriod.id : '' }}">
                <div class="fm-compose-inner">
                    <div class="fm-compose-header">
                        <i class="bi bi-reply-fill"></i>
                        Write a reply
                    </div>
                    <textarea name="msg_body" class="fm-textarea" placeholder="Type your response here..." required></textarea>
                    <div class="fm-compose-footer">
                        <button type="submit" class="fm-send-btn">
                            <i class="bi bi-send-fill"></i> Send Reply
                        </button>
                    </div>
                </div>
            </form>
        </div>
        {% endfor %}

        {% else %}
        <div class="fm-empty-state">
            <div class="fm-empty-icon">
                <i class="bi bi-chat-square-dots"></i>
            </div>
            <h5 class="fm-empty-title">No conversations yet</h5>
            <p class="fm-empty-text">Send a message to the administration to get started with your inquiry or request.</p>
            <button class="fm-empty-btn" data-bs-toggle="modal" data-bs-target="#newMessageModal">
                <i class="bi bi-plus-lg"></i> Start Conversation
            </button>
        </div>
        {% endif %}
    </main>
</div>

{# ═══════════════════════════════════════
   NEW MESSAGE MODAL
   ═══════════════════════════════════════ #}
<div class="modal fade" id="newMessageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:var(--msg-radius-xl);overflow:hidden;">
            <form method="post" action="{{ path('faculty_eval_request') }}">
                <input type="hidden" name="_action" value="send_message">

                <div class="fm-modal-header">
                    <div class="fm-modal-icon">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <h5 class="fm-modal-title">New Message</h5>
                    <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal" style="position:relative;z-index:1;"></button>
                </div>

                <div class="fm-modal-body">
                    <div class="fm-form-group">
                        <label class="fm-form-label">Related Evaluation <span class="optional">(optional)</span></label>
                        <select name="msg_evaluation" class="fm-form-select">
                            <option value="">— General Inquiry —</option>
                            {% for eval in evaluations %}
                                <option value="{{ eval.id }}">{{ eval.evaluationType }} — {{ eval.semester ?? '' }} {{ eval.schoolYear ?? '' }}{% if eval.subject %} ({{ eval.subject }}){% endif %}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="fm-form-group">
                        <label class="fm-form-label">Subject <span class="text-danger">*</span></label>
                        <input type="text" name="msg_subject" class="fm-form-input" placeholder="e.g., Request for schedule change" required maxlength="255">
                    </div>

                    <div class="fm-form-group">
                        <label class="fm-form-label">Message <span class="text-danger">*</span></label>
                        <textarea name="msg_body" class="fm-form-textarea" placeholder="Type your message here..." required></textarea>
                    </div>
                </div>

                <div class="fm-modal-footer">
                    <button type="button" class="fm-btn fm-btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="fm-btn fm-btn-primary">
                        <i class="bi bi-send-fill"></i> Send Message
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{# Flash Messages #}
{% for label, msgs in app.flashes %}
<div class="position-fixed top-0 end-0 p-3" style="z-index:9999;">
    <div class="toast show align-items-center text-white bg-{{ label == 'error' ? 'danger' : label }}" role="alert" style="border-radius:var(--msg-radius-md);">
        <div class="d-flex">
            <div class="toast-body fw-semibold">{% for m in msgs %}{{ m }}{% endfor %}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>
{% endfor %}

<script>
const messagesData = {
    {% for msg in messages %}
    {{ msg.id }}: {
        id: {{ msg.id }},
        subject: "{{ msg.subject|e('js') }}",
        message: "{{ msg.message|e('js')|replace({"\n": "\\n", "\r": ""}) }}",
        status: "{{ msg.status }}",
        createdAt: "{{ msg.createdAt|date('M d, Y h:i A') }}",
        adminReply: {% if msg.adminReply %}"{{ msg.adminReply|e('js')|replace({"\n": "\\n", "\r": ""}) }}"{% else %}null{% endif %},
        evalId: {% if msg.evaluationPeriod %}{{ msg.evaluationPeriod.id }}{% else %}null{% endif %},
        evalLabel: {% if msg.evaluationPeriod %}"{{ msg.evaluationPeriod.evaluationType }} - {{ msg.evaluationPeriod.semester ?? '' }} {{ msg.evaluationPeriod.schoolYear ?? '' }}"{% else %}null{% endif %}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
};

function selectConversation(el, msgId) {
    document.querySelectorAll('.fm-conv-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');

    document.querySelectorAll('.fm-thread').forEach(t => t.style.display = 'none');
    document.querySelectorAll('.fm-compose').forEach(c => c.style.display = 'none');
    const thread = document.getElementById('thread-' + msgId);
    const compose = document.getElementById('compose-' + msgId);
    if (thread) thread.style.display = 'block';
    if (compose) compose.style.display = 'block';

    const msg = messagesData[msgId];
    if (msg) {
        document.getElementById('chatTitle').textContent = msg.subject;

        const statusEl = document.getElementById('chatStatus');
        statusEl.className = 'fm-chat-status ' + msg.status;
        const statusLabels = {
            pending: '<i class="bi bi-circle-fill"></i> Awaiting Response',
            reviewed: '<i class="bi bi-circle-fill"></i> Reviewed',
            resolved: '<i class="bi bi-circle-fill"></i> Resolved'
        };
        statusEl.innerHTML = statusLabels[msg.status] || statusLabels.pending;

        const evalBadge = document.getElementById('chatEval');
        if (evalBadge) {
            if (msg.evalLabel) {
                evalBadge.innerHTML = '<i class="bi bi-clipboard2-check me-1"></i>' + msg.evalLabel;
                evalBadge.style.display = '';
            } else {
                evalBadge.style.display = 'none';
            }
        }
    }

    const chatBody = document.getElementById('chatBody');
    chatBody.scrollTop = chatBody.scrollHeight;
}

function searchMessages() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.fm-conv-item').forEach(item => {
        const searchText = item.dataset.search || '';
        item.style.display = searchText.includes(query) ? '' : 'none';
    });
}

document.addEventListener('DOMContentLoaded', function() {
    const chatBody = document.getElementById('chatBody');
    if (chatBody) chatBody.scrollTop = chatBody.scrollHeight;

    document.querySelectorAll('.fm-textarea').forEach(textarea => {
        textarea.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 160) + 'px';
        });
    });

    document.querySelectorAll('.toast').forEach(toast => {
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transition = 'opacity .3s';
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    });
});
</script>
{% endblock %}
