{% extends 'base.html.twig' %}

{% block title %}Enrollments | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ─── Header ─── */
.en-header{border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);box-shadow:0 4px 24px rgba(26,86,219,.15);margin-bottom:16px;}
.en-header-inner{padding:22px 26px 18px;}
.en-header-icon{width:50px;height:50px;border-radius:14px;background:rgba(255,255,255,.12);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:#fff;flex-shrink:0;}
.en-meta-pill{display:inline-flex;align-items:center;background:rgba(255,255,255,.1);color:rgba(255,255,255,.82);padding:2px 10px;border-radius:20px;font-weight:500;backdrop-filter:blur(4px);}
.en-meta-filter{background:rgba(251,191,36,.2);color:#fbbf24;}
.en-stats-row{display:flex;gap:0;margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,255,255,.1);}
.en-stat{flex:1;text-align:center;}
.en-stat-val{display:block;font-size:1.15rem;font-weight:700;color:#fff;line-height:1.2;}
.en-stat-lbl{display:block;font-size:.6rem;color:rgba(255,255,255,.55);text-transform:uppercase;letter-spacing:.8px;margin-top:2px;}
.en-stat-divider{width:1px;background:rgba(255,255,255,.1);margin:0 2px;}
.en-val-info{color:#38bdf8!important;}
.en-val-success{color:#34d399!important;}

/* ─── Toolbar ─── */
.en-toolbar{display:flex;align-items:center;gap:12px;flex-wrap:wrap;background:#fff;border:1px solid #e8ecf1;border-radius:12px;padding:8px 12px;margin-bottom:16px;box-shadow:0 1px 3px rgba(0,0,0,.03);}
.en-search-wrap{position:relative;flex:1;min-width:200px;max-width:360px;}
.en-search-wrap>i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:.8rem;pointer-events:none;}
.en-search{width:100%;border:1px solid #e5e7eb;border-radius:8px;padding:7px 12px 7px 32px;font-size:.82rem;outline:none;transition:border-color .15s,box-shadow .15s;background:#fafbfc;}
.en-search:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.08);background:#fff;}
.en-filter-form{display:flex;align-items:center;gap:6px;}
.en-filter-group{position:relative;display:flex;align-items:center;}
.en-filter-icon{position:absolute;left:10px;color:#6b7280;font-size:.8rem;pointer-events:none;z-index:1;}
.en-filter-select{border:1px solid #e5e7eb;border-radius:8px;padding:7px 12px 7px 32px;font-size:.82rem;outline:none;background:#fafbfc;min-width:200px;cursor:pointer;transition:border-color .15s;}
.en-filter-select:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.08);}
.en-clear-btn{display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:#fef2f2;color:#ef4444;border:1px solid #fecaca;font-size:.75rem;text-decoration:none;transition:all .15s;}
.en-clear-btn:hover{background:#fee2e2;color:#dc2626;}
.en-toolbar-info{margin-left:auto;}
.en-result-count{font-size:.75rem;color:#9ca3af;font-weight:500;}

/* ─── Table ─── */
.en-table-wrap{background:#fff;border:1px solid #e8ecf1;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.03);}
.en-table{width:100%;border-collapse:collapse;font-size:.82rem;}
.en-table thead{background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-bottom:2px solid #e2e8f0;}
.en-table thead th{padding:10px 14px;font-size:.7rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.6px;white-space:nowrap;border:none;}
.en-table tbody tr{border-bottom:1px solid #f1f5f9;transition:background .12s ease;}
.en-table tbody tr:last-child{border-bottom:none;}
.en-table tbody tr:hover{background:#f8faff;}
.en-table tbody td{padding:10px 14px;vertical-align:middle;}

/* Student cell */
.en-student-cell{display:flex;align-items:center;gap:10px;}
.en-student-avatar{width:34px;height:34px;min-width:34px;border-radius:50%;background:linear-gradient(135deg,#dbeafe,#bfdbfe);color:#1d4ed8;display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;}
.en-student-name{font-weight:600;color:#1e293b;font-size:.82rem;}
.en-student-email{font-size:.7rem;color:#94a3b8;}

/* Code */
.en-code-text{font-family:'SF Mono','Cascadia Code','Consolas',monospace;font-size:.78rem;font-weight:700;color:#1e40af;background:#eff6ff;padding:2px 9px;border-radius:6px;letter-spacing:.3px;}
.en-subject-name{font-weight:500;color:#334155;font-size:.82rem;}

/* Department tag */
.en-dept-tag{display:inline-block;font-size:.7rem;font-weight:500;color:#6366f1;background:#eef2ff;padding:3px 10px;border-radius:6px;}
.en-empty{color:#cbd5e1;font-size:.78rem;}

/* Actions */
.en-action-btn{width:30px;height:30px;border:none;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;font-size:.72rem;cursor:pointer;transition:all .15s ease;background:transparent;color:#94a3b8;}
.en-action-delete{color:#ef4444;}
.en-action-delete:hover{background:#fef2f2;color:#dc2626;transform:scale(1.1);}

/* Empty state */
.en-empty-state{padding:20px 0;}
.en-empty-icon{width:64px;height:64px;border-radius:50%;background:#f1f5f9;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:1.6rem;color:#94a3b8;}

/* ─── Modals ─── */
.en-modal-content{border:none;box-shadow:0 24px 48px rgba(0,0,0,.12);}
.en-modal-header-gradient{display:flex;align-items:center;justify-content:space-between;padding:18px 22px;background:linear-gradient(135deg,#0f172a 0%,#1a56db 60%,#3b82f6 100%);color:#fff;}
.en-form-label{font-size:.78rem;font-weight:600;color:#475569;margin-bottom:4px;}

/* ─── Pagination ─── */
.en-pagination{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;padding:16px 20px;margin-top:4px;background:#fff;border:1px solid #e5e7eb;border-radius:12px;box-shadow:0 1px 3px rgba(0,0,0,.04);}
.en-page-info{font-size:.8rem;color:#6b7280;font-weight:500;}
.en-page-list{display:flex;align-items:center;gap:4px;list-style:none;margin:0;padding:0;}
.en-page-item.disabled .en-page-link{opacity:.35;pointer-events:none;}
.en-page-link{display:inline-flex;align-items:center;justify-content:center;min-width:34px;height:34px;padding:0 8px;border:1px solid #e5e7eb;border-radius:8px;background:#fff;color:#374151;font-size:.8rem;font-weight:600;text-decoration:none;transition:all .15s ease;cursor:pointer;}
.en-page-link:hover{background:#f3f4f6;border-color:#d1d5db;color:var(--norsu-blue,#1a56db);}
.en-page-item.active .en-page-link{background:var(--norsu-blue,#1a56db);border-color:var(--norsu-blue,#1a56db);color:#fff;box-shadow:0 2px 8px rgba(26,86,219,.25);}

/* ─── Responsive ─── */
@media(max-width:768px){
    .en-stats-row{flex-wrap:wrap;gap:8px;}
    .en-stat{min-width:45%;}
    .en-stat-divider{display:none;}
    .en-toolbar{flex-direction:column;align-items:stretch;}
    .en-search-wrap{max-width:100%;}
    .en-table{font-size:.75rem;}
    .en-table thead th{padding:8px 10px;font-size:.62rem;}
    .en-table tbody td{padding:8px 10px;}
}

/* Animations */
.en-header,.en-toolbar,.en-table-wrap{animation:enFadeIn .25s ease;}
@keyframes enFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.en-row{animation:enRowIn .2s ease backwards;}
@keyframes enRowIn{from{opacity:0;transform:translateX(-8px);}to{opacity:1;transform:translateX(0);}}
</style>
{% endblock %}

{% block body %}
{# ═══════════════════════════════════════
   PROFESSIONAL HEADER
   ═══════════════════════════════════════ #}
<div class="en-header">
    <div class="en-header-inner">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="en-header-icon">
                    <i class="bi bi-person-lines-fill"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">Enrollment Management</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                        <span class="en-meta-pill"><i class="bi bi-database me-1"></i>{{ totalFiltered }} Record{{ totalFiltered != 1 ? 's' : '' }}</span>
                        {% if filterDept or filterCollege or filterStudent or filterSubject or filterSearch %}
                            <span class="en-meta-pill en-meta-filter"><i class="bi bi-funnel-fill me-1"></i>Filtered</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-1">
                <button type="button" class="btn btn-sm btn-light fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#createEnrollModal">
                    <i class="bi bi-plus-lg me-1"></i>Enroll Student
                </button>
            </div>
        </div>
        <div class="en-stats-row">
            <div class="en-stat">
                <span class="en-stat-val">{{ totalEnrollments }}</span>
                <span class="en-stat-lbl">Total Enrollments</span>
            </div>
            <div class="en-stat-divider"></div>
            <div class="en-stat">
                <span class="en-stat-val en-val-info">{{ uniqueStudents }}</span>
                <span class="en-stat-lbl">Unique Students</span>
            </div>
            <div class="en-stat-divider"></div>
            <div class="en-stat">
                <span class="en-stat-val en-val-success">{{ uniqueSubjects }}</span>
                <span class="en-stat-lbl">Unique Subjects</span>
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════
   FILTER / SEARCH BAR
   ═══════════════════════════════════════ #}
<div class="en-toolbar">
    <div class="en-search-wrap">
        <i class="bi bi-search"></i>
        <input type="text" class="en-search" id="enSearchInput" placeholder="Search student or subject..." value="{{ filterSearch }}" oninput="enFilterTable()">
    </div>
    <form method="get" action="{{ path('staff_enrollments') }}" class="en-filter-form" id="enFilterForm">
        <div class="en-filter-group">
            <i class="bi bi-mortarboard-fill en-filter-icon"></i>
            <select name="college" class="en-filter-select" onchange="this.form.submit()" style="min-width:200px;">
                <option value="">All Colleges</option>
                {% for c in colleges %}
                    <option value="{{ c }}" {{ filterCollege == c ? 'selected' }}>{{ c }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="en-filter-group">
            <i class="bi bi-building en-filter-icon"></i>
            <select name="department" class="en-filter-select" onchange="this.form.submit()" style="min-width:180px;">
                <option value="">All Departments</option>
                {% for dept in departments %}
                    <option value="{{ dept.id }}" {{ filterDept is not null and filterDept == dept.id ? 'selected' }}>{{ dept.departmentName }}</option>
                {% endfor %}
            </select>
        </div>
        {% if filterDept or filterCollege or filterStudent or filterSubject or filterSearch %}
            <a href="{{ path('staff_enrollments') }}" class="en-clear-btn" title="Clear all filters">
                <i class="bi bi-x-lg"></i>
            </a>
        {% endif %}
    </form>
    <div class="en-toolbar-info">
        <span class="en-result-count" id="enResultCount">{{ totalFiltered }} result{{ totalFiltered != 1 ? 's' : '' }}</span>
    </div>
</div>

{# ═══════════════════════════════════════
   ENROLLMENTS TABLE
   ═══════════════════════════════════════ #}
<div class="en-table-wrap">
    <table class="en-table" id="enTable">
        <thead>
            <tr>
                <th>#</th>
                <th>Student</th>
                <th>Subject Code</th>
                <th>Subject Name</th>
                <th>Department</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for enrollment in enrollments %}
            <tr class="en-row">
                <td class="text-muted" style="font-size:.78rem;">{{ ((page - 1) * perPage) + loop.index }}</td>
                <td>
                    <div class="en-student-cell">
                        <span class="en-student-avatar">{{ enrollment.student.firstName|slice(0,1)|upper }}{{ enrollment.student.lastName|slice(0,1)|upper }}</span>
                        <div>
                            <div class="en-student-name">{{ enrollment.student.lastName }}, {{ enrollment.student.firstName }}</div>
                            <div class="en-student-email">{{ enrollment.student.email }}</div>
                        </div>
                    </div>
                </td>
                <td>
                    <code class="en-code-text">{{ enrollment.subject.subjectCode }}</code>
                </td>
                <td>
                    <span class="en-subject-name">{{ enrollment.subject.subjectName }}</span>
                </td>
                <td>
                    {% if enrollment.subject.department %}
                        <span class="en-dept-tag">{{ enrollment.subject.department.departmentName }}</span>
                    {% else %}
                        <span class="en-empty">—</span>
                    {% endif %}
                </td>
                <td class="text-center">
                    <form method="post" action="{{ path('staff_enrollment_delete', {id: enrollment.id}) }}" class="d-inline" onsubmit="return confirm('Remove this enrollment?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_enroll' ~ enrollment.id) }}">
                        <button type="submit" class="en-action-btn en-action-delete" title="Remove">
                            <i class="bi bi-trash3-fill"></i>
                        </button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="text-center py-5">
                    <div class="en-empty-state">
                        <div class="en-empty-icon"><i class="bi bi-person-x"></i></div>
                        <h6 class="fw-bold text-muted">No enrollments found</h6>
                        <p class="text-muted small mb-3">Get started by enrolling a student in a subject.</p>
                        <button class="btn btn-sm btn-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#createEnrollModal">
                            <i class="bi bi-plus-lg me-1"></i>Enroll Student
                        </button>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# ── Pagination ── #}
{% if totalPages > 1 %}
<nav class="en-pagination">
    <div class="en-page-info">
        {% set showStart = ((page - 1) * perPage) + 1 %}
        {% set showEnd = page * perPage %}
        {% if showEnd > totalFiltered %}{% set showEnd = totalFiltered %}{% endif %}
        Showing {{ showStart }}–{{ showEnd }} of {{ totalFiltered }} enrollments
    </div>
    <ul class="en-page-list">
        <li class="en-page-item {{ page <= 1 ? 'disabled' }}">
            <a class="en-page-link" href="{{ path('staff_enrollments', app.request.query.all|merge({page: page - 1})) }}">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>

        {% set startPage = max(1, page - 2) %}
        {% set endPage = min(totalPages, page + 2) %}

        {% if startPage > 1 %}
            <li class="en-page-item">
                <a class="en-page-link" href="{{ path('staff_enrollments', app.request.query.all|merge({page: 1})) }}">1</a>
            </li>
            {% if startPage > 2 %}
                <li class="en-page-item disabled"><span class="en-page-link">…</span></li>
            {% endif %}
        {% endif %}

        {% for p in startPage..endPage %}
            <li class="en-page-item {{ p == page ? 'active' }}">
                <a class="en-page-link" href="{{ path('staff_enrollments', app.request.query.all|merge({page: p})) }}">{{ p }}</a>
            </li>
        {% endfor %}

        {% if endPage < totalPages %}
            {% if endPage < totalPages - 1 %}
                <li class="en-page-item disabled"><span class="en-page-link">…</span></li>
            {% endif %}
            <li class="en-page-item">
                <a class="en-page-link" href="{{ path('staff_enrollments', app.request.query.all|merge({page: totalPages})) }}">{{ totalPages }}</a>
            </li>
        {% endif %}

        <li class="en-page-item {{ page >= totalPages ? 'disabled' }}">
            <a class="en-page-link" href="{{ path('staff_enrollments', app.request.query.all|merge({page: page + 1})) }}">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
</nav>
{% endif %}

{# ═══════════════════════════════════════
   CREATE ENROLLMENT MODAL
   ═══════════════════════════════════════ #}
<div class="modal fade" id="createEnrollModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content en-modal-content" style="border-radius:16px;overflow:hidden;">
            <form method="post" action="{{ path('staff_enrollment_create') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('create_enrollment') }}">
                <div class="en-modal-header-gradient">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width:42px;height:42px;border-radius:12px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:#fff;">
                            <i class="bi bi-person-plus-fill"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0 text-white" style="font-size:1.05rem;">Enroll Student</h5>
                            <span style="font-size:.72rem;color:rgba(255,255,255,.65);">Select a student and subject below</span>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" style="font-size:.7rem;" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label en-form-label">Student <span class="text-danger">*</span></label>
                            <select name="student" class="form-select form-select-sm" required id="enrollStudentSelect">
                                <option value="">— Select Student —</option>
                                {% for s in students %}
                                    <option value="{{ s.id }}">{{ s.lastName }}, {{ s.firstName }} ({{ s.email }})</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label en-form-label">Subject <span class="text-danger">*</span></label>
                            <select name="subject" class="form-select form-select-sm" required id="enrollSubjectSelect">
                                <option value="">— Select Subject —</option>
                                {% for sub in subjects %}
                                    <option value="{{ sub.id }}">{{ sub.subjectCode }} — {{ sub.subjectName }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top px-4 py-2" style="background:#f8fafc;">
                    <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg me-1"></i>Enroll</button>
                </div>
            </form>
        </div>
    </div>
</div>



<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.en-row').forEach(function(r, i) {
        r.style.animationDelay = (i * 0.03) + 's';
    });
});
</script>
{% endblock %}
